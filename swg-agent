#!/usr/bin/env python3
"""
swg-agent — node-side peer manager for swg-panel.

Reads ONE JSON request on stdin, performs a wg / AmneziaWG peer operation on a
*managed* interface, and writes ONE JSON response on stdout (exit 0 on success,
1 on error). Designed to be the forced command behind a dedicated SSH key:

  command="/opt/swg-agent/swg-agent",no-pty,no-port-forwarding,no-agent-forwarding,no-X11-forwarding ssh-ed25519 AAAA... swg-panel

so the panel can ONLY run these operations — never a shell.

Config: /etc/swg-agent/config.json   (see config.example.json)
Only interfaces listed there are touchable; S2S / exit tunnels are simply absent.

v1 targets native host interfaces (awg/wg on the host). The per-interface "cmd"
prefix is configurable for future container support.
"""

import contextlib
import fcntl
import ipaddress
import json
import os
import random
import re
import shutil
import subprocess
import sys
import tempfile
import time

CONFIG_PATH = os.environ.get("SWG_AGENT_CONFIG", "/etc/swg-agent/config.json")
AUDIT_PATH  = os.environ.get("SWG_AGENT_AUDIT",  "/var/log/swg-agent/audit.log")
LOCK_PATH   = os.environ.get("SWG_AGENT_LOCK",   "/run/swg-agent.lock")
VERSION     = "1.0"

PUBKEY_RE = re.compile(r"^[A-Za-z0-9+/]{43}=$")
AWG_KEYS  = ["Jc", "Jmin", "Jmax", "S1", "S2", "S3", "S4",
             "H1", "H2", "H3", "H4", "I1", "I2", "I3", "I4", "I5"]


class AgentError(Exception):
    def __init__(self, code, msg):
        super().__init__(msg)
        self.code = code
        self.msg = msg


# ───────────────────────── helpers ─────────────────────────

def load_config():
    try:
        with open(CONFIG_PATH) as f:
            return json.load(f)
    except Exception as e:
        raise AgentError("internal", f"cannot read {CONFIG_PATH}: {e}")


def iface_cfg(cfg, iface):
    ifaces = cfg.get("interfaces", {})
    if iface not in ifaces:
        raise AgentError("iface_not_managed", f"interface {iface!r} is not managed")
    return ifaces[iface]


def run(args, input_text=None, check=True):
    p = subprocess.run(args, input=input_text, capture_output=True, text=True)
    if check and p.returncode != 0:
        raise AgentError("internal", f"{' '.join(args)} failed: {p.stderr.strip()}")
    return p.stdout


def read_conf(path):
    with open(path) as f:
        return f.read()


def write_conf_atomic(path, text):
    d = os.path.dirname(path) or "."
    fd, tmp = tempfile.mkstemp(dir=d, suffix=".tmp")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(text)
        os.chmod(tmp, 0o600)
        os.replace(tmp, path)
    except Exception:
        if os.path.exists(tmp):
            os.unlink(tmp)
        raise


def parse_dump(out):
    """First line = interface, rest = peers (tab-separated `wg show <i> dump`)."""
    lines = out.strip().splitlines()
    iface_line = lines[0].split("\t") if lines else []
    peers = []
    for line in lines[1:]:
        f = line.split("\t")
        if len(f) < 8:
            continue
        peers.append({
            "public_key": f[0],
            "endpoint": None if f[2] in ("(none)", "") else f[2],
            "allowed_ips": f[3],
            "last_handshake": int(f[4]) if f[4].isdigit() else 0,
            "rx_bytes": int(f[5]) if f[5].isdigit() else 0,
            "tx_bytes": int(f[6]) if f[6].isdigit() else 0,
        })
    return iface_line, peers


def parse_interface_section(conf_text):
    """Key->value of the first [Interface] section."""
    info, in_iface = {}, False
    for line in conf_text.splitlines():
        s = line.strip()
        if s.startswith("["):
            in_iface = (s.lower() == "[interface]")
            continue
        if in_iface and "=" in s and not s.startswith("#"):
            k, v = s.split("=", 1)
            info[k.strip()] = v.strip()
    return info


def awg_params(info):
    out = {}
    for k in AWG_KEYS:
        if k in info:
            v = info[k]
            out[k] = int(v) if v.isdigit() else v
    return out


def iface_net(info):
    addr = info.get("Address", "").split(",")[0].strip()
    if not addr:
        raise AgentError("internal", "interface conf has no Address")
    return ipaddress.ip_interface(addr)          # .ip = server addr, .network = subnet


def used_ips(peers):
    out = set()
    for p in peers:
        for cidr in p["allowed_ips"].split(","):
            cidr = cidr.strip()
            if cidr:
                out.add(cidr.split("/")[0])
    return out


def next_free_ip(info, peers):
    net = iface_net(info)
    taken = used_ips(peers) | {str(net.ip)}
    for host in net.network.hosts():
        if str(host) not in taken:
            return str(host)
    raise AgentError("subnet_full", "no free addresses in subnet")


def wg_dump(ic, iface):
    return run(ic["cmd"] + ["show", iface, "dump"])


def gen_psk(ic):
    return run(ic["cmd"] + ["genpsk"]).strip()


def append_peer_to_conf(path, pub, psk, allowed, name):
    block = "\n"
    if name:
        block += f"# name: {name}\n"
    block += "[Peer]\n"
    block += f"PublicKey = {pub}\n"
    if psk:
        block += f"PresharedKey = {psk}\n"
    block += f"AllowedIPs = {allowed}\n"
    with open(path, "a") as f:
        f.write(block)


def remove_peer_from_conf(path, pub):
    lines = read_conf(path).splitlines()
    starts = [i for i, l in enumerate(lines) if l.strip().lower() == "[peer]"]
    target = None
    for idx, start in enumerate(starts):
        end = starts[idx + 1] if idx + 1 < len(starts) else len(lines)
        if any(re.match(rf"\s*PublicKey\s*=\s*{re.escape(pub)}\s*$", b) for b in lines[start:end]):
            target = (start, end)
            break
    if target is None:
        return
    start, end = target
    # also drop a leading "# name:" comment and blank lines directly above [Peer]
    while start - 1 >= 0 and (lines[start - 1].strip() == ""
                              or lines[start - 1].strip().lower().startswith("# name:")):
        start -= 1
    new_lines = lines[:start] + lines[end:]
    write_conf_atomic(path, ("\n".join(new_lines).rstrip("\n") + "\n") if new_lines else "")


def set_listen_port_in_conf(path, port):
    """Rewrite (or insert) ListenPort in the first [Interface] section. Atomic, 0600."""
    lines = read_conf(path).splitlines()
    out, in_iface, done = [], False, False
    for line in lines:
        s = line.strip()
        if s.startswith("["):
            in_iface = (s.lower() == "[interface]")
            out.append(line)
            continue
        if in_iface and not done and re.match(r"(?i)\s*ListenPort\s*=", line):
            out.append(f"ListenPort = {port}")
            done = True
            continue
        out.append(line)
    if not done:
        res, added = [], False
        for line in out:
            res.append(line)
            if not added and line.strip().lower() == "[interface]":
                res.append(f"ListenPort = {port}")
                added = True
        out = res
    write_conf_atomic(path, "\n".join(out).rstrip("\n") + "\n")


def set_iface_fields_in_conf(path, fields):
    """Replace (or insert) the given [Interface] fields. fields = {Name: value}. Atomic, 0600."""
    want = {k.lower(): (k, str(v)) for k, v in fields.items()}
    lines = read_conf(path).splitlines()
    out, in_iface, seen = [], False, set()
    for line in lines:
        s = line.strip()
        if s.startswith("["):
            in_iface = (s.lower() == "[interface]"); out.append(line); continue
        if in_iface and "=" in s and not s.startswith("#"):
            k = s.split("=", 1)[0].strip().lower()
            if k in want:
                name, val = want[k]; out.append(f"{name} = {val}"); seen.add(k); continue
        out.append(line)
    missing = [(name, val) for k, (name, val) in want.items() if k not in seen]
    if missing:
        res, added = [], False
        for line in out:
            res.append(line)
            if not added and line.strip().lower() == "[interface]":
                for name, val in missing:
                    res.append(f"{name} = {val}")
                added = True
        out = res
    write_conf_atomic(path, "\n".join(out).rstrip("\n") + "\n")


@contextlib.contextmanager
def locked():
    os.makedirs(os.path.dirname(LOCK_PATH) or "/run", exist_ok=True)
    f = open(LOCK_PATH, "w")
    try:
        fcntl.flock(f, fcntl.LOCK_EX)
        yield
    finally:
        fcntl.flock(f, fcntl.LOCK_UN)
        f.close()


def audit(op, req):
    try:
        os.makedirs(os.path.dirname(AUDIT_PATH), exist_ok=True)
        with open(AUDIT_PATH, "a") as f:
            f.write(json.dumps({
                "ts": int(time.time()), "op": op,
                "iface": req.get("iface"), "public_key": req.get("public_key"),
                "allowed_ips": req.get("allowed_ips"), "name": req.get("name"),
            }) + "\n")
    except Exception:
        pass   # auditing must never fail the operation


# ───────────────────────── operations ─────────────────────────

def op_describe(cfg, req):
    out = {"hostname": os.uname().nodename, "agent_version": VERSION, "interfaces": {}}
    want = req.get("iface")
    for iface, ic in cfg.get("interfaces", {}).items():
        if want and iface != want:
            continue
        iface_line, peers = parse_dump(wg_dump(ic, iface))
        info = parse_interface_section(read_conf(ic["conf"]))
        net = iface_net(info)
        port = int(iface_line[2]) if len(iface_line) > 2 and iface_line[2].isdigit() else None
        out["interfaces"][iface] = {
            "public_key": iface_line[1] if len(iface_line) > 1 else None,
            "listen_port": port,
            "endpoint": f"{cfg.get('endpoint_host', '')}:{port}" if port else None,
            "address": str(net),
            "subnet": str(net.network),
            "peer_count": len(peers),
            "used_ips": sorted(used_ips(peers)),
            "awg_params": awg_params(info),
            "dns": cfg.get("dns", []),
        }
    return out


def op_list_peers(cfg, req):
    iface = req["iface"]
    ic = iface_cfg(cfg, iface)
    _, peers = parse_dump(wg_dump(ic, iface))
    return {"iface": iface, "peers": peers}


def op_next_ip(cfg, req):
    iface = req["iface"]
    ic = iface_cfg(cfg, iface)
    _, peers = parse_dump(wg_dump(ic, iface))
    info = parse_interface_section(read_conf(ic["conf"]))
    return {"iface": iface, "next_ip": next_free_ip(info, peers) + "/32"}


def op_add_peer(cfg, req):
    iface = req["iface"]
    ic = iface_cfg(cfg, iface)
    pub = req.get("public_key", "")
    if not PUBKEY_RE.match(pub):
        raise AgentError("bad_pubkey", "public_key is not a valid WireGuard key")
    allowed = req.get("allowed_ips", "")
    name = req.get("name")
    psk_req = req.get("preshared_key", "auto")

    info = parse_interface_section(read_conf(ic["conf"]))
    iface_line, peers = parse_dump(wg_dump(ic, iface))

    if any(p["public_key"] == pub for p in peers):
        raise AgentError("peer_exists", "a peer with this public key already exists")

    # IP is always explicit; validate in-subnet, not the server, not taken.
    if "/" not in allowed:
        raise AgentError("bad_request", "allowed_ips must be CIDR, e.g. 10.0.0.5/32")
    ip = allowed.split("/")[0]
    net = iface_net(info)
    try:
        addr = ipaddress.ip_address(ip)
    except ValueError:
        raise AgentError("bad_request", f"invalid ip {ip}")
    if addr not in net.network:
        raise AgentError("bad_request", f"{ip} not in subnet {net.network}")
    if ip == str(net.ip):
        raise AgentError("ip_in_use", f"{ip} is the server address")
    if ip in used_ips(peers):
        raise AgentError("ip_in_use", f"{ip} already assigned")

    # PSK: default auto-generate; explicit value honored; "none"/false disables.
    if psk_req in (None, "none", False):
        psk = None
    elif psk_req in ("auto", "", True):
        psk = gen_psk(ic)
    else:
        psk = psk_req

    # 1) apply to the running interface (surgical — never touches other peers)
    args = ic["cmd"] + ["set", iface, "peer", pub, "allowed-ips", allowed]
    if psk:
        args += ["preshared-key", "/dev/stdin"]
    run(args, input_text=(psk + "\n") if psk else None)

    # 2) persist to the conf
    append_peer_to_conf(ic["conf"], pub, psk, allowed, name)

    port = int(iface_line[2]) if len(iface_line) > 2 and iface_line[2].isdigit() else None
    return {
        "public_key": pub,
        "allowed_ips": allowed,
        "preshared_key": psk,
        "server_public_key": iface_line[1] if len(iface_line) > 1 else None,
        "endpoint": f"{cfg.get('endpoint_host', '')}:{port}" if port else None,
        "awg_params": awg_params(info),
        "dns": cfg.get("dns", []),
    }


def op_remove_peer(cfg, req):
    iface = req["iface"]
    ic = iface_cfg(cfg, iface)
    pub = req.get("public_key", "")
    if not PUBKEY_RE.match(pub):
        raise AgentError("bad_pubkey", "public_key is not a valid WireGuard key")
    _, peers = parse_dump(wg_dump(ic, iface))
    match = next((p for p in peers if p["public_key"] == pub), None)
    if not match:
        raise AgentError("peer_not_found", "no peer with this public key")
    run(ic["cmd"] + ["set", iface, "peer", pub, "remove"])
    remove_peer_from_conf(ic["conf"], pub)
    return {"removed": pub, "freed_ip": match["allowed_ips"]}


def set_awg_in_conf(path, awg):
    """Replace the AmneziaWG param lines in the first [Interface] section with `awg` (dict)."""
    keyset = set(AWG_KEYS)
    lines = read_conf(path).splitlines()
    out, in_iface = [], False
    for line in lines:
        s = line.strip()
        if s.startswith("["):
            in_iface = (s.lower() == "[interface]")
            out.append(line)
            if in_iface:
                for k in AWG_KEYS:
                    if k in awg:
                        out.append(f"{k} = {awg[k]}")
            continue
        if in_iface and "=" in s and s.split("=", 1)[0].strip() in keyset:
            continue   # drop the old awg param line
        out.append(line)
    write_conf_atomic(path, "\n".join(out).rstrip("\n") + "\n")


def op_set_iface(cfg, req):
    """Change the interface's UDP listen port and/or AmneziaWG obfuscation params on the live
    interface + its .conf. Peers (keys / AllowedIPs) are untouched; existing client tunnels
    reconnect via the panel-rendered Endpoint / new params."""
    iface = req["iface"]
    ic = iface_cfg(cfg, iface)
    out = {"iface": iface}
    if req.get("listen_port") is not None:
        try:
            port = int(req.get("listen_port"))
        except (TypeError, ValueError):
            raise AgentError("bad_request", "listen_port must be a number")
        if not (1 <= port <= 65535):
            raise AgentError("bad_request", "listen_port out of range (1-65535)")
        with contextlib.suppress(Exception):
            run(ic["cmd"] + ["set", iface, "listen-port", str(port)])   # live, best-effort (iface may be DOWN)
        set_listen_port_in_conf(ic["conf"], port)                        # persist ALWAYS — applies on next bring-up
        out["listen_port"] = port
    awg = req.get("awg_params")
    if isinstance(awg, dict) and awg:
        awg = {k: str(awg[k]) for k in AWG_KEYS if k in awg and str(awg.get(k, "")) != ""}
        if awg:
            # apply live where the awg tool supports it (best-effort), then persist to the conf
            args = ic["cmd"] + ["set", iface]
            for k in AWG_KEYS:
                if k in awg:
                    args += [k.lower(), awg[k]]
            with contextlib.suppress(Exception):
                run(args)
            set_awg_in_conf(ic["conf"], awg)
            out["awg_params"] = awg
    if len(out) == 1:
        raise AgentError("bad_request", "nothing to set")
    return out


def _wan_iface():
    out = run(["ip", "-4", "route", "get", "1.1.1.1"], check=False)
    m = re.search(r" dev (\S+)", out or "")
    return m.group(1) if m else "eth0"


def _ensure_tool(tool):
    """Require the wg/awg tools to be present. We can't install them from here: the swg-noded service
    is sandboxed (ProtectSystem/ProtectHome make /usr and /root read-only, so apt + add-apt-repository
    fail) and the agent has a short timeout. So: a clear, copy-pasteable install command if missing —
    once it's installed the pending create completes on the next sync."""
    if shutil.which(tool) and shutil.which(tool + "-quick"):
        return
    how = ("sudo apt-get install -y wireguard" if tool == "wg" else
           "sudo add-apt-repository -y ppa:amnezia/ppa && sudo apt-get update && sudo apt-get install -y amneziawg")
    raise AgentError("no_tool", f"'{tool}' tools aren't installed on this node. Run on the node:  {how}  "
                     f"— then the interface creates automatically on the next sync.")


def _awg_obfuscation():
    """Mirror install-host.sh's awg_obfuscation: random S1–S4, four disjoint H1–H4 bands, conservative I1."""
    s1 = 15 + random.randint(0, 135); s2 = 15 + random.randint(0, 135)
    while s2 == s1 or s2 == s1 + 56:
        s2 = 15 + random.randint(0, 135)
    s3 = 15 + random.randint(0, 85); s4 = 15 + random.randint(0, 85)
    b = [base + random.randint(0, 899999999) for base in (5, 1000000000, 2000000000, 3000000000)]
    w = 15
    return ("Jc = 4\nJmin = 40\nJmax = 70\n"
            f"S1 = {s1}\nS2 = {s2}\nS3 = {s3}\nS4 = {s4}\n"
            f"H1 = {b[0]}-{b[0] + w}\nH2 = {b[1]}-{b[1] + w}\nH3 = {b[2]}-{b[2] + w}\nH4 = {b[3]}-{b[3] + w}\n"
            "I1 = <b 0xc300000001><r 1200>\n")


def op_create_iface(cfg, req):
    """Create a BRAND-NEW wg/awg interface natively (kernel on bare-metal, userspace in a node
    container): genkey, write the .conf (Address from the given subnet, ListenPort, MTU, auto-NAT
    out the WAN, AWG obfuscation for awg), bring it up via <tool>-quick. Rolls back the conf if
    bring-up fails. The caller (swg-noded) then records {cmd, conf} so the panel manages it."""
    iface = (req.get("iface") or "").strip()
    req_tool = (req.get("cmd") or ["awg"])[0]
    add_obf = (req_tool == "awg")               # genuine AmneziaWG → obfuscation; plain WireGuard → none
    # use the requested tool if it's here; otherwise fall back to awg (amneziawg-go does plain WG too,
    # e.g. a node container ships only awg/awg-quick). A plain awg conf is WireGuard-compatible.
    have = lambda t: bool(shutil.which(t) and shutil.which(t + "-quick"))
    tool = req_tool if have(req_tool) else ("awg" if have("awg") else req_tool)
    cmd = [tool]
    if not iface or "/" in iface or " " in iface:
        raise AgentError("bad_request", "invalid interface name")
    try:
        net = ipaddress.ip_network(req.get("subnet") or "", strict=False)
    except Exception:
        raise AgentError("bad_request", "subnet must be a CIDR like 10.8.0.0/24")
    try:
        port = int(req.get("listen_port") or 51820)
    except (TypeError, ValueError):
        raise AgentError("bad_request", "listen_port must be a number")
    mtu = str(req.get("mtu") or "1280")
    _ensure_tool(tool)                          # install wg/awg tools if this node doesn't have them yet
    conf_dir = "/etc/amnezia/amneziawg" if tool == "awg" else "/etc/wireguard"
    conf = os.path.join(conf_dir, iface + ".conf")
    if os.path.exists(conf):
        raise AgentError("exists", f"{conf} already exists")
    os.makedirs(conf_dir, exist_ok=True)
    priv = run(cmd + ["genkey"]).strip()
    if not priv:
        raise AgentError("internal", f"{tool} genkey produced no key")
    pub = run(cmd + ["pubkey"], input_text=priv + "\n").strip()
    addr = f"{net.network_address + 1}/{net.prefixlen}"
    wan = _wan_iface()
    # NAT is BEST-EFFORT (each step `|| true`) so the interface still comes up where iptables/nat
    # isn't available (e.g. some containers) — matching node-entrypoint.sh's non-fatal NAT. A failed
    # rule just means clients won't egress until NAT is sorted; it never blocks bring-up.
    up = (f"sysctl -q -w net.ipv4.ip_forward=1 || true; "
          f"iptables -t nat -A POSTROUTING -s {net} -o {wan} -j MASQUERADE || true; "
          f"iptables -A FORWARD -i %i -o {wan} -j ACCEPT || true; "
          f"iptables -A FORWARD -i {wan} -o %i -m state --state RELATED,ESTABLISHED -j ACCEPT || true")
    down = (f"iptables -t nat -D POSTROUTING -s {net} -o {wan} -j MASQUERADE || true; "
            f"iptables -D FORWARD -i %i -o {wan} -j ACCEPT || true; "
            f"iptables -D FORWARD -i {wan} -o %i -m state --state RELATED,ESTABLISHED -j ACCEPT || true")
    body = (f"[Interface]\nPrivateKey = {priv}\nAddress = {addr}\nListenPort = {port}\nMTU = {mtu}\n"
            f"PostUp = {up}\nPostDown = {down}\n")
    if tool == "awg" and add_obf:               # only genuine AmneziaWG gets obfuscation params
        body += _awg_obfuscation()
    write_conf_atomic(conf, body)
    try:
        run([tool + "-quick", "up", iface])
    except Exception as e:
        with contextlib.suppress(Exception):
            os.unlink(conf)
        raise AgentError("up_failed", f"{tool}-quick up {iface} failed (port/subnet may be in use): {e}")
    with contextlib.suppress(Exception):
        run(["systemctl", "enable", f"{tool}-quick@{iface}"], check=False)
    return {"iface": iface, "public_key": pub, "address": addr, "conf": conf, "cmd": cmd, "listen_port": port}


def op_delete_iface(cfg, req):
    """Tear a managed interface down and forget it: <tool>-quick down, remove its .conf, disable its
    unit. Destroys the interface, its server keypair, and all its peers on this node. Best-effort on
    each step so a partially-up interface still gets cleaned up."""
    iface = req["iface"]
    ic = iface_cfg(cfg, iface)            # raises if it isn't managed here
    tool = (ic.get("cmd") or ["awg"])[0]
    with contextlib.suppress(Exception):
        run([tool + "-quick", "down", iface])
    with contextlib.suppress(Exception):
        run(["systemctl", "disable", f"{tool}-quick@{iface}"], check=False)
    with contextlib.suppress(Exception):
        os.remove(ic["conf"])
    return {"iface": iface, "deleted": True}


def op_restart_iface(cfg, req):
    """Bounce a managed interface: <tool>-quick down (ignored if already down) then up — recovers a
    DOWN interface (e.g. one whose bring-up failed). Re-raises an up failure so the panel sees why."""
    iface = req["iface"]
    ic = iface_cfg(cfg, iface)             # raises if it isn't managed here
    tool = (ic.get("cmd") or ["awg"])[0]
    with contextlib.suppress(Exception):
        run([tool + "-quick", "down", iface])
    try:
        run([tool + "-quick", "up", iface])
    except Exception as e:
        raise AgentError("up_failed", f"{tool}-quick up {iface} failed: {e}")
    return {"iface": iface, "restarted": True}


def op_stop_iface(cfg, req):
    """Stop a managed interface and keep it down: <tool>-quick down + disable its unit (so it doesn't
    come back on reboot). The .conf is KEPT — op_start_iface brings it back. Best-effort down."""
    iface = req["iface"]
    ic = iface_cfg(cfg, iface)             # raises if it isn't managed here
    tool = (ic.get("cmd") or ["awg"])[0]
    with contextlib.suppress(Exception):
        run([tool + "-quick", "down", iface])
    with contextlib.suppress(Exception):
        run(["systemctl", "disable", f"{tool}-quick@{iface}"], check=False)
    return {"iface": iface, "stopped": True}


def op_start_iface(cfg, req):
    """Start a stopped interface: <tool>-quick up + re-enable its unit. Re-raises an up failure."""
    iface = req["iface"]
    ic = iface_cfg(cfg, iface)             # raises if it isn't managed here
    tool = (ic.get("cmd") or ["awg"])[0]
    try:
        run([tool + "-quick", "up", iface])
    except Exception as e:
        raise AgentError("up_failed", f"{tool}-quick up {iface} failed: {e}")
    with contextlib.suppress(Exception):
        run(["systemctl", "enable", f"{tool}-quick@{iface}"], check=False)
    return {"iface": iface, "started": True}


def op_restore_iface_key(cfg, req):
    """Revert an interface to its blessed identity from the node's on-disk backup: rewrite the conf's
    [Interface] PrivateKey (+ Address + ListenPort), then bounce so the original server key is live."""
    iface = req["iface"]
    ic = iface_cfg(cfg, iface)                 # raises if it isn't managed here
    priv = (req.get("private_key") or "").strip()
    if not priv:
        raise AgentError("bad_request", "private_key required")
    fields = {"PrivateKey": priv}
    if req.get("address"):
        fields["Address"] = req["address"]
    if req.get("listen_port"):
        fields["ListenPort"] = str(req["listen_port"])
    set_iface_fields_in_conf(ic["conf"], fields)
    tool = (ic.get("cmd") or ["awg"])[0]
    with contextlib.suppress(Exception):
        run([tool + "-quick", "down", iface])
    try:
        run([tool + "-quick", "up", iface])
    except Exception as e:
        raise AgentError("up_failed", f"{tool}-quick up {iface} failed after key restore: {e}")
    return {"iface": iface, "restored": True}


# ───────────────────────── dispatch ─────────────────────────

def respond(ok, op, data=None, error=None, code=None):
    out = {"ok": ok, "op": op}
    if ok:
        out["data"] = data
    else:
        out["error"] = error
        out["code"] = code
    print(json.dumps(out))
    sys.exit(0 if ok else 1)


READ_OPS = {"describe": op_describe, "list-peers": op_list_peers, "next-ip": op_next_ip}
WRITE_OPS = {"add-peer": op_add_peer, "remove-peer": op_remove_peer, "set-iface": op_set_iface,
             "create-iface": op_create_iface, "delete-iface": op_delete_iface, "restart-iface": op_restart_iface,
             "stop-iface": op_stop_iface, "start-iface": op_start_iface,
             "restore-iface-key": op_restore_iface_key}


def main():
    try:
        req = json.load(sys.stdin)
    except Exception as e:
        respond(False, None, error=f"invalid JSON request: {e}", code="bad_request")
    op = req.get("op")
    try:
        cfg = load_config()
        if op in READ_OPS:
            respond(True, op, data=READ_OPS[op](cfg, req))
        elif op in WRITE_OPS:
            with locked():
                data = WRITE_OPS[op](cfg, req)
            audit(op, req)
            respond(True, op, data=data)
        else:
            respond(False, op, error=f"unknown op {op!r}", code="unknown_op")
    except AgentError as e:
        respond(False, op, error=e.msg, code=e.code)
    except KeyError as e:
        respond(False, op, error=f"missing field {e}", code="bad_request")
    except Exception as e:
        respond(False, op, error=str(e), code="internal")


if __name__ == "__main__":
    main()
