# Images are pulled prebuilt from GHCR by default (see docker-compose.yml). To always
# re-pull the latest: PULL_POLICY=always.  To build from source, edit docker-compose.yml.
PULL_POLICY=missing

# ───────── Panel (profiles: host, host-node) ─────────
PANEL_PASSWORD=change-this-now       # required
PANEL_USER=admin                     # the installer auto-generates admin### — change it later in the panel
PANEL_DOMAIN=panel.example.net       # host/IP only (the installer parses a full URL's port + /subpath)
PANEL_BASE=                          # optional subpath mount, e.g. /swg (blank = served at root)
# TLS is issued INSIDE the container by the bundled acme.sh — same options as bare-metal:
TLS=selfsigned                       # letsencrypt | letsencrypt-ip | cloudflare | cf15 | selfsigned | none
ACME_EMAIL=                          # letsencrypt/cloudflare account email (required for those)
CF_TOKEN=                            # cloudflare DNS-01: API token (Zone:DNS:Edit + Zone:Read)
CF_ORIGIN_TOKEN=                     # cf15: API token (Zone → SSL and Certificates → Edit)
#   letsencrypt → publish port 80 (compose already maps 80:80) and point DNS at this host
#   cloudflare  → no port 80 needed; validates via DNS over the CF API (CF_TOKEN + ACME_EMAIL)
#   cf15        → 15-year Cloudflare Origin cert; ONLY valid behind Cloudflare's proxy (CF_ORIGIN_TOKEN)
PANEL_PORT=443                       # host-published port (maps to 8443 in the container)
SUB_PORT=8444                        # subscription surface (swg-sub) host port; off until enabled in the panel
# Reverse proxy (TLS=none): run your own nginx/Caddy on :443 for panel + sub subdomains. install-docker sets
# these for you when you pick TLS=none; here for a hand-edited .env. Keeps the containers on loopback.
PANEL_BIND=0.0.0.0                   # 127.0.0.1 → only your reverse proxy reaches the panel
SUB_BIND=0.0.0.0                     # 127.0.0.1 → only your reverse proxy reaches swg-sub
SUB_TRUST_XFF=0                      # 1 → trust the proxy's X-Forwarded-For (swg-sub rate-limiting)
SUB_DOMAIN=                          # subscription page hostname, for the printed reverse-proxy config

# ───────── Node (profiles: node, host-node) ─────────
# 1) bring up the panel, 2) Nodes → Add node to get the token, 3) set it here.
PANEL_URL=https://swg-panel:8443     # host-node: the panel service name on the compose net
                                     # node-only: https://your-panel-host:8443
NODE_TOKEN=                          # one-time token from the Nodes screen
NODE_ENDPOINT=203.0.113.7            # public IP/host clients dial for this node
NODE_IFACE=awg0                      # single interface (used when NODE_IFACES is blank)
NODE_LISTEN_PORT=51820
NODE_ADDRESS=10.8.0.1/24
NODE_MTU=1280                        # interface MTU; 1280 leaves headroom for turn-proxy obfuscation
NODE_PLAIN_WG=                       # yes = plain WireGuard; blank/no = AmneziaWG v2 (obfuscated)
# Several interfaces instead: "name:port:address[:proto[:endpoint]]" entries (proto wg = plain;
# endpoint = the public IP/host clients dial for THAT interface — defaults to NODE_ENDPOINT).
# Publish each port in docker-compose.yml. Or mount /etc/swg-node/*.conf to bring your own.
# NODE_IFACES=awg0:51820:10.8.0.1/24:awg:203.0.113.5,wg1:51821:10.9.0.1/24:wg:203.0.113.6
TLS_VERIFY=yes                       # verify the panel's TLS cert (default); set no only for a self-signed panel
DNS=1.1.1.1
