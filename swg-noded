# ───────────────────────── parsing (pure) ─────────────────────────

def parse_dump(out):
    lines = out.strip().splitlines()
    iface_line = lines[0].split("\t") if lines else []
    peers = []
    for line in lines[1:]:
        f = line.split("\t")
        if len(f) < 8:
            continue
        peers.append({
            "public_key": f[0],
            "preshared_key": None if f[1] in ("(none)", "") else f[1],   # keep PSK so adoption can reuse it
            "endpoint": None if f[2] in ("(none)", "") else f[2],
            "allowed_ips": f[3],
            "last_handshake": int(f[4]) if f[4].isdigit() else 0,
            "rx_bytes": int(f[5]) if f[5].isdigit() else 0,
            "tx_bytes": int(f[6]) if f[6].isdigit() else 0,
        })
    return iface_line, peers


def parse_interface_section(conf_text):
    info, in_iface = {}, False
    for line in conf_text.splitlines():
        s = line.strip()
        if s.startswith("["):
            in_iface = (s.lower() == "[interface]")
            continue
        if in_iface and "=" in s and not s.startswith("#"):
            k, v = s.split("=", 1)
            info[k.strip()] = v.strip()
    return info


def awg_params(info):
    out = {}
    for k in AWG_KEYS:
        if k in info:
            v = info[k]
            out[k] = int(v) if v.isdigit() else v
    return out


def derive_pubkey(cmd, priv):
    """Server public key from a private key (used when the interface is down / dump is empty)."""
    if not priv:
        return None
    try:
        out = run((cmd or ["awg"]) + ["pubkey"], input_text=priv + "\n").stdout.strip()
        return out or None
    except Exception:
        return None


def build_meta(iface_line, conf_text, endpoint_host, dns, cmd=None):
    info = parse_interface_section(conf_text)
    addr = info.get("Address", "").split(",")[0].strip()
    subnet = None
    if addr and "/" in addr:
        try:
            import ipaddress
            subnet = str(ipaddress.ip_network(addr, strict=False))
        except Exception:
            subnet = addr.rsplit("/", 1)[0]
    port = int(iface_line[2]) if len(iface_line) > 2 and iface_line[2].isdigit() else None
    if not port and str(info.get("ListenPort", "")).strip().isdigit():   # fall back to the .conf
        port = int(str(info["ListenPort"]).strip())
    pub = iface_line[1] if len(iface_line) > 1 and iface_line[1] else derive_pubkey(cmd, info.get("PrivateKey"))
    return {
        "public_key": pub,
        "listen_port": port,
        "endpoint": (f"{endpoint_host}:{port}" if endpoint_host and port else None),
        "address": addr or None,
        "subnet": subnet,
        "awg_params": awg_params(info),
        "dns": dns or [],
    }


# ───────── interface keypair backup (the node keeps a copy of each iface's blessed identity) ─────────
# The panel only ever stores the PUBLIC key, so it can't revert a server-key change on its own. Instead
# the NODE keeps a local backup of {private_key, public_key, listen_port, address} per interface — the
# private key is already in the .conf, so this adds no new exposure. If the live key diverges, the panel
# flags it and can ask the node to Restore (from this backup) or Adopt (re-baseline the backup).
IFACE_KEYS_DIR = "/var/lib/swg-noded/iface-keys"
def _iface_backup_path(iface): return os.path.join(IFACE_KEYS_DIR, iface + ".json")

def harvest_iface_backup(conf_text, cmd=None):
    """Blessed-identity record from a .conf, or None if it has no private key."""
    info = parse_interface_section(conf_text)
    priv = (info.get("PrivateKey") or "").strip()
    if not priv:
        return None
    port = str(info.get("ListenPort", "")).strip()
    return {"private_key": priv, "public_key": derive_pubkey(cmd, priv),
            "listen_port": int(port) if port.isdigit() else None,
            "address": (info.get("Address", "").split(",")[0].strip() or None),
            "saved_at": int(time.time())}

def write_iface_backup(iface, rec):
    with contextlib.suppress(Exception):
        os.makedirs(IFACE_KEYS_DIR, exist_ok=True)
        p = _iface_backup_path(iface); tmp = p + ".tmp"
        with open(tmp, "w") as f:
            json.dump(rec, f)
        os.chmod(tmp, 0o600); os.replace(tmp, p)

def read_iface_backup(iface):
    with contextlib.suppress(Exception):
        with open(_iface_backup_path(iface)) as f:
            return json.load(f)
    return None

def ensure_iface_backup(iface, conf_text, cmd=None):
    """Write a backup if one doesn't exist yet — covers create/onboard/install/first-sight. Re-install
    and conversion overwrite it explicitly; Adopt re-baselines it via a panel request."""
    if not conf_text or os.path.exists(_iface_backup_path(iface)):
        return
    rec = harvest_iface_backup(conf_text, cmd)
    if rec:
        write_iface_backup(iface, rec)


def peer_view(peers, last, dt, online_max, now):
    out = []
    for p in peers:
        age = (now - p["last_handshake"]) if p["last_handshake"] else None
        prev = last.get(p["public_key"])
        rs = ts = 0.0
        if prev and dt > 0:
            rs = max(0, p["rx_bytes"] - prev[0]) / dt
            ts = max(0, p["tx_bytes"] - prev[1]) / dt
        out.append({
            "public_key": p["public_key"], "endpoint": p["endpoint"],
            "preshared_key": p.get("preshared_key"),   # so adoption can reuse the on-wire PSK (panel owns PSKs)
            "allowed_ips": p["allowed_ips"], "rx_bytes": p["rx_bytes"], "tx_bytes": p["tx_bytes"],
            "rx_speed": rs, "tx_speed": ts,
            "last_handshake": p["last_handshake"] or None, "handshake_age": age,
            "online": age is not None and age <= online_max,
        })
    return out


# ───────────────────────── node health (cheap: /proc + statvfs, no subprocess) ─────────────────────────
#
# Everything here reads in-kernel pseudo-files (/proc/{loadavg,meminfo,uptime,stat}) and
# does one statvfs() syscall per mount — microseconds total, no process spawns. Far cheaper
# than the `awg show dump` we already run per interface, so sampling it every loop is free.
# proc_root / statvfs are injectable so the parsing is testable against a fixture.

def _read_proc(proc_root, name):
    with open(os.path.join(proc_root, name)) as f:
        return f.read()


def read_loadavg(proc_root="/proc"):
    p = _read_proc(proc_root, "loadavg").split()
    return [float(p[0]), float(p[1]), float(p[2])]


def read_meminfo(proc_root="/proc"):
    vals = {}
    for line in _read_proc(proc_root, "meminfo").splitlines():
        k, _, rest = line.partition(":")
        f = rest.split()
        if f and f[0].isdigit():
            vals[k] = int(f[0]) * 1024          # kB -> bytes
    total = vals.get("MemTotal", 0)
    avail = vals.get("MemAvailable", vals.get("MemFree", 0))   # MemAvailable fallback for old kernels
    mem = {"total": total, "available": avail, "used": max(0, total - avail)}
    if "SwapTotal" in vals:
        mem["swap_total"] = vals["SwapTotal"]
        mem["swap_used"] = max(0, vals["SwapTotal"] - vals.get("SwapFree", 0))
    return mem


def read_uptime(proc_root="/proc"):
    return float(_read_proc(proc_root, "uptime").split()[0])


def read_ncpu(proc_root="/proc"):
    with contextlib.suppress(Exception):
        n = sum(1 for ln in _read_proc(proc_root, "stat").splitlines()
                if ln.startswith("cpu") and len(ln) > 3 and ln[3].isdigit())
        if n:
            return n
    return os.cpu_count() or 1


def disk_usage(mount, statvfs=os.statvfs):
    st = statvfs(mount)
    total = st.f_blocks * st.f_frsize
    return {"mount": mount, "total": total,
            "used": max(0, total - st.f_bfree * st.f_frsize),
            "free": st.f_bavail * st.f_frsize}


def collect_health(proc_root="/proc", mounts=None, statvfs=os.statvfs):
    """A small per-node health block. Each field is collected independently and a failure
    in one (e.g. a missing /proc file in a stripped container) never sinks the rest."""
    mounts = mounts if mounts is not None else ["/"]
    h = {}
    with contextlib.suppress(Exception):
        h["load"] = read_loadavg(proc_root)
    with contextlib.suppress(Exception):
        h["ncpu"] = read_ncpu(proc_root)
    with contextlib.suppress(Exception):
        h["mem"] = read_meminfo(proc_root)
    with contextlib.suppress(Exception):
        h["uptime"] = read_uptime(proc_root)
    disks = []
    for m in mounts:
        with contextlib.suppress(Exception):
            disks.append(disk_usage(m, statvfs))
    if disks:
        h["disk"] = disks
    return h


# ───────────────────────── io ─────────────────────────

def run(args, input_text=None, timeout=20):
    # Fail-safe: a MISSING binary (e.g. `nft` on a node/image without nftables) must never crash a caller —
    # return a non-zero result like a normal command failure so callers handle it (smart routing then no-ops
    # instead of taking down the sync loop). Same for a timeout.
    try:
        return subprocess.run(args, input=input_text, capture_output=True, text=True, timeout=timeout)
    except (FileNotFoundError, PermissionError) as e:
        return subprocess.CompletedProcess(args, 127, "", str(e))
    except subprocess.TimeoutExpired:
        return subprocess.CompletedProcess(args, 124, "", "timeout")


def run_agent(agent, sudo, payload):
    prefix = ["sudo", "-n"] if sudo else []
    try:
        p = run(prefix + [agent], input_text=json.dumps(payload))
    except Exception as e:
        return {"ok": False, "op": payload.get("op"), "error": str(e), "code": "internal"}
    out = (p.stdout or "").strip()
    if not out:
        return {"ok": False, "op": payload.get("op"),
                "error": (p.stderr or "").strip() or "no response", "code": "internal"}
    try:
        return json.loads(out)
    except json.JSONDecodeError:
        return {"ok": False, "op": payload.get("op"), "error": "agent non-JSON", "code": "internal"}


def post_json(url, token, obj, panel, timeout=20, source_ip=""):
    """POST JSON to the panel. TLS posture comes from `panel`:
         fingerprint set -> pin sha256 (verified during the handshake, before any
                            bytes are sent, and fails closed if it can't be read);
         verify true     -> system CA verification;
         otherwise       -> unverified (self-signed; encrypted but no MITM protection).
    `source_ip` (optional) binds the local source IP for the connection (the node's "panel connection IP"
    role); callers fall back to unbound on failure so a bad IP can't cut the node off from the panel.
    Returns (status, dict). status 0 means the request never completed."""
    body = json.dumps(obj).encode()
    headers = {"Content-Type": "application/json", "Authorization": "Bearer " + token}
    u = urllib.parse.urlparse(url)
    host = u.hostname
    port = u.port or (443 if u.scheme == "https" else 80)
    path = (u.path or "/") + (("?" + u.query) if u.query else "")
    fp = (panel.get("fingerprint") or "").replace(":", "").lower().strip()
    src = (source_ip, 0) if source_ip else None
    conn = None
    try:
        if u.scheme == "http":
            conn = http.client.HTTPConnection(host, port, timeout=timeout, source_address=src)
        elif u.scheme == "https":
            if panel.get("verify", False) and not fp:
                ctx = ssl.create_default_context()
            else:
                ctx = ssl._create_unverified_context()
            conn = http.client.HTTPSConnection(host, port, timeout=timeout, context=ctx, source_address=src)
            if fp:
                conn.connect()                      # TLS handshake before sending the token
                der = conn.sock.getpeercert(True)
                if not der or hashlib.sha256(der).hexdigest() != fp:
                    return 0, {"error": "tls fingerprint mismatch"}
        else:
            return 0, {"error": f"unsupported url scheme {u.scheme!r}"}
        conn.request("POST", path, body=body, headers=headers)
        resp = conn.getresponse()
        data = (resp.read().decode() or "{}")
        if resp.status >= 400:
            return resp.status, {"error": data[:200]}
        return resp.status, json.loads(data)
    except Exception as e:
        return 0, {"error": str(e)}
    finally:
        if conn is not None:
            with contextlib.suppress(Exception):
                conn.close()


# ───────────────────────── snapshot ─────────────────────────

_TURN_READ = {"at": 0.0}
def _read_units_live(svcs):
    """Batched read of the live .service ExecStart for several units (one host call). svc -> unit text."""
    if not svcs:
        return {}
    cmd = "; ".join("printf '@@SWG@@%s\\n' " + shlex.quote(s) + "; cat " + shlex.quote(_turn_unit_path(s)) + " 2>/dev/null"
                    for s in svcs)
    out = host_sh(cmd).stdout or ""
    res = {}; cur = None; buf = []
    for ln in out.splitlines():
        if ln.startswith("@@SWG@@"):
            if cur is not None:
                res[cur] = "\n".join(buf)
            cur = ln[len("@@SWG@@"):]; buf = []
        elif cur is not None:
            buf.append(ln)
    if cur is not None:
        res[cur] = "\n".join(buf)
    return res

def _list_turn_units():
    """Bare-metal turn-proxy services present on disk (vk-turn-proxy-*.service in /etc/systemd/system).
    None on a read error (so the caller keeps the record rather than wiping it); [] means genuinely none."""
    try:
        files = os.listdir("/etc/systemd/system")
    except OSError:
        return None
    return [f[:-len(".service")] for f in files if f.startswith("vk-turn-proxy-") and f.endswith(".service")]

TURN_PENDING_DIR = "/var/lib/swg-noded/turn-pending"   # an installer/convert drops "<svc>" here (listen\nconnect\nowner) WHILE setting a turn-proxy up
def _turn_installing_markers():
    """Turn-proxies an installer/convert is actively setting up right now (fresh markers only, < 5min — a
    crashed installer's stale marker is ignored). svc -> {listen, connect, owner}. Surfaced as 'installing'."""
    out = {}
    try:
        names = os.listdir(TURN_PENDING_DIR)
    except OSError:
        return out
    for f in names:
        p = os.path.join(TURN_PENDING_DIR, f)
        try:
            if time.time() - os.path.getmtime(p) > 300:
                continue
            with open(p) as fh:
                ls = fh.read().splitlines()
        except OSError:
            continue
        out[f] = {"listen": (ls[0] if len(ls) > 0 else ""), "connect": (ls[1] if len(ls) > 1 else ""), "owner": (ls[2] if len(ls) > 2 else "")}
    return out

def load_turn_proxies():
    """Turn-proxies installed on this box — listen/connect/wrap_key/params. Refreshed from the LIVE
    .service files (throttled) so direct edits on the server show up on the panel."""
    try:
        with open(TURN_RECORD) as f:
            d = json.load(f)
        tp = d.get("turn_proxies") if isinstance(d, dict) else None
        tp = tp if isinstance(tp, list) else []
    except Exception:
        return []
    if TURN_DOCKER:                 # container model — the record IS the config; just flag running via docker ps
        # defensive dedup: collapse any same-service duplicates (last wins, like apply_turn / bare-metal) so a
        # hand-edited or round-tripped record can't surface a proxy twice or have two entries fight one container.
        seen = {}; uniq = []
        for t in tp:
            s = t.get("service")
            if not s:
                continue
            if s in seen:
                uniq[seen[s]] = t
            else:
                seen[s] = len(uniq); uniq.append(t)
        tp = uniq
        _dturn_attach_running(tp)
        _attach_turn_version(tp)
        return tp
    nowt = time.time()
    on_disk = _list_turn_units()   # bare-metal: the units on disk are the source of truth — reconcile the list
    if on_disk is not None:        # to them so convert/installer/hand-created units show (and deleted ones drop)
        rec_by = {t.get("service"): t for t in tp if t.get("service")}
        tp = [rec_by.get(svc) or {"service": svc} for svc in on_disk]
    if TURN_MANAGE_ON and (any("params" not in t for t in tp) or nowt - _TURN_READ["at"] >= 20):
        units = _read_units_live([t["service"] for t in tp if t.get("service")])
        changed = False
        for t in tp:
            u = units.get(t.get("service"))
            if not u:
                continue
            live = _tp_from_unit(t["service"], u)
            for k in ("listen", "connect", "wrap_key", "params"):
                if t.get(k) != live.get(k):
                    t[k] = live.get(k); changed = True
        _TURN_READ["at"] = nowt
        if changed:
            with contextlib.suppress(Exception):
                tmp = TURN_RECORD + ".tmp"
                with open(tmp, "w") as f:
                    json.dump({"turn_proxies": tp}, f)
                os.replace(tmp, TURN_RECORD)
    _attach_turn_running(tp)
    _attach_turn_version(tp)
    marks = _turn_installing_markers()   # an installer/convert is setting these up → show "installing" (synthetic entry if no unit yet)
    if marks:
        have = {t.get("service") for t in tp}
        for svc, m in marks.items():
            if svc in have:
                for t in tp:
                    if t.get("service") == svc and t.get("running") is not True:
                        t["installing"] = True
            else:
                tp.append({"service": svc, "listen": m["listen"], "connect": m["connect"],
                           "owner": m["owner"], "running": False, "installing": True})
    with _TURN_JOBS_LOCK:                                   # async reinstall/update in flight → surface as "updating"
        _active = {s for s, j in _TURN_JOBS.items() if not j.get("done")}
        _fin = {s for s, j in _TURN_JOBS.items() if j.get("done")}
        for s in [s for s in _fin if time.time() - _TURN_JOBS[s].get("at", 0) > 120]:
            _TURN_JOBS.pop(s, None)                         # safety: don't leak a done job apply_turn never got to consume
    for svc in _fin:
        NODE_PROGRESS.pop(svc, None)                        # finished → drop the transient note (apply_turn reports the result)
    for svc in _active:
        NODE_PROGRESS[svc] = "updating…"
        if not any(t.get("service") == svc for t in tp):
            tp.append({"service": svc, "running": False, "installing": True})
        for t in tp:
            if t.get("service") == svc:
                t["installing"] = True
    return tp

_TURN_RUN = {"at": 0.0, "map": {}}
def _attach_turn_running(tps):
    """Live `running` flag per turn-proxy (one batched `systemctl is-active`, throttled to 20s) so the
    panel can grey out a crash-looping service (e.g. a -listen IP not local → bind fails)."""
    svcs = [t["service"] for t in tps if t.get("service")]
    if not svcs or not TURN_MANAGE_ON:
        return
    nowt = time.time()
    if nowt - _TURN_RUN["at"] >= 20:
        cmd = "for s in " + " ".join(shlex.quote(s) for s in svcs) + \
              "; do printf '%s=%s\\n' \"$s\" \"$(systemctl is-active \"$s\" 2>/dev/null)\"; done"
        m = {}
        for ln in (host_sh(cmd).stdout or "").splitlines():
            s, _, state = ln.partition("=")
            if s:
                m[s] = (state.strip() == "active")
        _TURN_RUN["at"] = nowt; _TURN_RUN["map"] = m
    for t in tps:
        if t.get("service") in _TURN_RUN["map"]:
            t["running"] = _TURN_RUN["map"][t["service"]]


def _node_addrs():
    """[(dev, ip)] for the node's non-loopback, non-tunnel/bridge IPv4 addresses — the shared parse behind
    list_node_ips / _ip_ifaces / _ifaces. One `ip -o addr show` instead of three per snapshot."""
    out = []
    try:
        raw = run(["ip", "-4", "-o", "addr", "show"]).stdout
    except Exception:
        return out
    for ln in raw.splitlines():
        p = ln.split()
        if len(p) < 4 or p[2] != "inet":
            continue
        dev, ip = p[1], p[3].split("/")[0]
        if dev == "lo" or dev.startswith(("wg", "awg", "swg_", "dawg", "docker", "br-", "veth", "kube", "cni", "flannel")):
            continue
        if ip.startswith("127."):
            continue
        out.append((dev, ip))
    return out


def list_node_ips(addrs=None):
    """The node's own IPv4 addresses (candidates for a per-interface egress/source IP), excluding
    loopback + tunnel/bridge devices. On a docker host-net node this is the HOST's addresses."""
    ips = []
    for dev, ip in (addrs if addrs is not None else _node_addrs()):
        if ip not in ips:
            ips.append(ip)
    return ips


def list_node_ip_ifaces(addrs=None):
    """The node's (ipv4, nic) pairs — for the merged egress picker (a source IP always lives on a NIC)."""
    pairs = []
    for dev, ip in (addrs if addrs is not None else _node_addrs()):
        if not any(x["ip"] == ip for x in pairs):
            pairs.append({"ip": ip, "iface": dev})
    return pairs


def list_node_ifaces(addrs=None):
    """The node's WAN-candidate NIC names (devices carrying a non-loopback IPv4) — for the egress -o."""
    ifs = []
    for dev, ip in (addrs if addrs is not None else _node_addrs()):
        if dev not in ifs:
            ifs.append(dev)
    return ifs


def _detect_wan():
    out = run(["sh", "-c", "ip -4 route get 1.1.1.1 2>/dev/null"]).stdout
    m = re.search(r" dev (\S+)", out or "")
    return m.group(1) if m else "eth0"


def _iface_subnet(node_cfg, iface):
    """The interface's tunnel subnet (CIDR) read from its conf Address — for the egress SNAT match."""
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    try:
        with open(ic.get("conf", "")) as f:
            m = re.search(r"(?im)^\s*Address\s*=\s*([^\s,]+)", f.read())
    except Exception:
        return ""
    if not m:
        return ""
    import ipaddress
    try:
        return str(ipaddress.ip_network(m.group(1), strict=False))
    except Exception:
        return ""


def _comment_re(tag):
    """Match a `--comment <tag>` in `iptables -S` output. iptables QUOTES comments (--comment "tag"),
    but some builds don't — match either form. Getting this wrong makes the "does this rule already
    exist?" check always miss, so the reconcile appends a fresh duplicate every cycle → the POSTROUTING
    chain explodes into tens of thousands of rules and listing it pins the CPU."""
    return re.compile(r'--comment "?' + re.escape(tag) + r'"?(?:\s|$)')


def _snat_reconcile_rule(tag, subnet, des, rules):
    """Ensure exactly one tagged SNAT/MASQUERADE POSTROUTING rule for `subnet`, inserted at the head
    (ahead of any default MASQUERADE). des = ("SNAT", wan, ip) | ("MASQUERADE", wan, "") | None (no rule).
    `rules` = current `iptables -t nat -S POSTROUTING` lines. Returns (changed: bool, error: str|None).
    Shared by reconcile_egress (local-iface SNAT) and reconcile_cascade (exit forwarded-subnet SNAT)."""
    _re = _comment_re(tag)
    existing = [ln for ln in rules if _re.search(ln)]
    cur = None
    if existing:
        o = re.search(r"-o (\S+)", existing[0]); src = re.search(r"--to-source (\S+)", existing[0])
        cur = ("SNAT" if "SNAT" in existing[0] else "MASQUERADE", o.group(1) if o else "", src.group(1) if src else "")
    if cur == des:
        return (False, None)
    for ln in existing:                                   # drop stale rule(s)
        run(["sh", "-c", "iptables -t nat " + ln.replace("-A POSTROUTING", "-D POSTROUTING", 1)])
    if des:
        args = ["iptables", "-t", "nat", "-I", "POSTROUTING", "-s", subnet, "-o", des[1],
                "-m", "comment", "--comment", tag, "-j", des[0]]
        if des[0] == "SNAT":
            args += ["--to-source", des[2]]
        r = run(args)
        if r.returncode != 0:
            return (False, (r.stderr or "").strip()[:120])
    return (True, None)


def reconcile_egress(node_cfg, desired_ifaces, default_egress_ip=""):
    """Option-I source-NAT: per interface, ensure an SNAT rule to its chosen egress_ip (tagged with a
    'swg-egress:<iface>' comment, inserted ahead of the default MASQUERADE), replace it on change, and
    remove it when cleared (→ falls back to MASQUERADE). Runs iptables directly (root on bare-metal;
    container root + NET_ADMIN + host netns on docker)."""
    res = {"changed": 0, "errors": []}
    if not desired_ifaces:
        return res
    try:
        rules = run(["iptables", "-t", "nat", "-S", "POSTROUTING"]).stdout.splitlines()
    except Exception as e:
        res["errors"].append("iptables list: " + str(e)); return res
    default_wan = _detect_wan()
    for iface in (node_cfg.get("interfaces") or {}):
        want = (desired_ifaces or {}).get(iface) or {}
        egress = (want.get("egress_ip") or "").strip()
        wan_ov = (want.get("wan_iface") or "").strip()
        subnet = _iface_subnet(node_cfg, iface)
        if not subnet:
            continue
        if egress:                                            # SNAT to a chosen source IP, out a chosen/auto WAN
            des = ("SNAT", wan_ov or default_wan, egress)
        elif default_egress_ip:                               # node-level default direct egress IP (fallback)
            des = ("SNAT", wan_ov or default_wan, default_egress_ip)
        elif wan_ov:                                          # just pin the WAN egress interface
            des = ("MASQUERADE", wan_ov, "")
        else:
            des = None
        changed, err = _snat_reconcile_rule("swg-egress:" + iface, subnet, des, rules)
        if err:
            res["errors"].append("egress " + iface + ": " + err); continue
        if changed:
            res["changed"] += 1
    return res


# ───────────────────────── Phase 2: traffic cascade ─────────────────────────
SWG_RT_BASE = 7000          # swg-owned policy-routing table id / ip-rule priority band [BASE, MAX]
SWG_RT_MAX = 7099           # (priority == table number; one table per egress target per node)
SMART_NFT_TABLE = "swg_smart"   # Phase 3: inet nft table holding the per-category dest sets + marking chain
SNI_NFQUEUE = 0                 # SNI mode: nft queues each connection's first packets here → swg-sni reads the ClientHello
SNI_MAP_PATH = "/var/lib/swg-noded/sni-map.json"   # domain→category map swg-noded writes for swg-sni to consume
_SNI_PROC = {"p": None}         # the running swg-sni subprocess (SNI-mode classifier), or None


def _cascade_want_sig(fwd, exit_, smart=None):
    """Canonical signature of the policy rules+routes a plan wants — same token shape as the live
    reader below, so an exact-match means 'no drift' and we skip the (gap-inducing) flush+rebuild."""
    sig = set()
    for e in fwd:
        T = str(e["table"]); sig.add(f"R|from|{e['subnet']}|{T}"); sig.add(f"T|{T}|default|{e['via_iface']}")
    for e in (smart or []):                            # smart entry = fwmark T → table T (default via link)
        T = str(e["table"]); sig.add(f"R|fwmark|{int(e['table'])}|{T}"); sig.add(f"T|{T}|default|{e['via_iface']}")
    for e in exit_:
        T = str(e["table"]); sig.add(f"R|to|{e['subnet']}|{T}"); sig.add(f"T|{T}|{e['subnet']}|{e['via_iface']}")
    return sig


def _cascade_live_sig(tables):
    """Canonical signature of our LIVE policy rules (band priorities) + routes in the given tables —
    parsed from `ip rule show` / `ip route show table T` so it's robust to iproute2's output wording."""
    sig = set()
    try:
        for line in run(["ip", "rule", "show"]).stdout.splitlines():
            mp = re.match(r"^\s*(\d+):\s+(.*)$", line)
            if not mp:
                continue
            pri = int(mp.group(1))
            if not (SWG_RT_BASE <= pri <= SWG_RT_MAX):
                continue
            body = mp.group(2)
            lk = re.search(r"lookup (\S+)", body); T = lk.group(1) if lk else str(pri)
            mto = re.search(r"\bto (\S+)", body); mfrom = re.search(r"\bfrom (\S+)", body)
            mfw = re.search(r"fwmark (0x[0-9a-fA-F]+|\d+)", body)
            if mfw:
                sig.add(f"R|fwmark|{int(mfw.group(1), 0)}|{T}")
            elif mto:
                sig.add(f"R|to|{mto.group(1)}|{T}")
            elif mfrom and mfrom.group(1) != "all":
                sig.add(f"R|from|{mfrom.group(1)}|{T}")
    except Exception:
        pass
    for T in tables:
        try:
            for line in run(["ip", "route", "show", "table", str(T)]).stdout.splitlines():
                toks = line.split()
                if not toks:
                    continue
                dev = toks[toks.index("dev") + 1] if "dev" in toks else ""
                sig.add(f"T|{T}|{toks[0]}|{dev}")
        except Exception:
            pass
    return sig


def _live_band_prios():
    out = []
    with contextlib.suppress(Exception):
        for line in run(["ip", "rule", "show"]).stdout.splitlines():
            mp = re.match(r"^\s*(\d+):", line)
            if mp and SWG_RT_BASE <= int(mp.group(1)) <= SWG_RT_MAX:
                out.append(int(mp.group(1)))
    return sorted(set(out))


def _ensure_fwd_iptables(fwd, exit_, default_wan, res, default_egress_ip=""):
    """Idempotent (no-churn) exit SNAT + FORWARD-accept + MSS-clamp for the link devices, tagged
    swg-fwd-{snat,acl,mss}:* so stale entries (after a forward→direct switch) are cleaned up. Traffic
    received from other nodes (the cascade/smart exit side) SNATs to the exit record's egress_ip, falling
    back to THIS node's default direct egress IP — so routed traffic appears as the exit node's chosen IP."""
    link_devs = sorted({e["via_iface"] for e in (fwd + exit_)})
    # 1) exit SNAT per forwarded subnet (diff via the shared helper) + drop stale tags
    try:
        nat = run(["iptables", "-t", "nat", "-S", "POSTROUTING"]).stdout.splitlines()
    except Exception as e:
        res["errors"].append("cascade nat list: " + str(e)); nat = []
    want_snat = set()
    for e in exit_:
        S = e["subnet"]; tag = "swg-fwd-snat:" + S; want_snat.add(tag)
        W = (e.get("wan_iface") or "").strip() or default_wan
        X = (e.get("egress_ip") or "").strip() or default_egress_ip
        des = ("SNAT", W, X) if X else ("MASQUERADE", W, "")
        _ch, err = _snat_reconcile_rule(tag, S, des, nat)
        if err:
            res["errors"].append("cascade snat " + S + ": " + err)
        elif _ch:
            res["changed"] += 1
    for ln in nat:                                              # remove SNAT tags no longer wanted
        mt = re.search(r'--comment "?(swg-fwd-snat:[^"\s]+)"?', ln)
        if mt and mt.group(1) not in want_snat and ln.startswith("-A POSTROUTING"):
            run(["sh", "-c", "iptables -t nat " + ln.replace("-A POSTROUTING", "-D POSTROUTING", 1)]); res["changed"] += 1
    # 2) FORWARD accept (filter) + 3) MSS clamp (mangle), present-or-absent per link dev
    _ensure_dev_rules("filter", "FORWARD", "swg-fwd-acl:", link_devs, res,
                      lambda d, direction: ["iptables", "-I", "FORWARD", direction, d,
                                            "-m", "comment", "--comment", "swg-fwd-acl:" + d, "-j", "ACCEPT"])
    _ensure_dev_rules("mangle", "FORWARD", "swg-fwd-mss:", link_devs, res,
                      lambda d, direction: (["iptables", "-t", "mangle", "-I", "FORWARD", "-o", d,
                                             "-p", "tcp", "--tcp-flags", "SYN,RST", "SYN",
                                             "-m", "comment", "--comment", "swg-fwd-mss:" + d,
                                             "-j", "TCPMSS", "--clamp-mss-to-pmtu"] if direction == "-o" else None))


def _ensure_dev_rules(table, chain, prefix, link_devs, res, mk):
    """Ensure the tagged per-device rules built by mk(dev, '-i'/'-o') exist (skip if present), and drop
    any tagged rule for a device no longer in link_devs. mk may return None for a direction to skip it."""
    targs = ["-t", table] if table != "filter" else []
    try:
        lines = run(["iptables"] + targs + ["-S", chain]).stdout.splitlines()
    except Exception as e:
        res["errors"].append(f"cascade {table} list: " + str(e)); return
    want = {prefix + d for d in link_devs}
    for d in link_devs:
        tag = prefix + d
        for direction in ("-i", "-o"):
            add = mk(d, direction)
            if add is None:
                continue
            if not any((tag in ln and f"{direction} {d}" in ln) for ln in lines):
                run(add)
                res["changed"] += 1
    for ln in lines:                                            # drop stale device tags
        mt = re.search(r'--comment "?(' + re.escape(prefix) + r'[^"\s]+)"?', ln)
        if mt and mt.group(1) not in want and ln.startswith("-A " + chain):
            run(["sh", "-c", "iptables " + " ".join(targs) + " " + ln.replace("-A " + chain, "-D " + chain, 1)]); res["changed"] += 1


def _smart_setname(cat):
    return "cat_" + re.sub(r"[^a-z0-9]", "_", str(cat).lower())


_LOOP = {"n": 0}                       # reconcile-loop counter — drives per-loop caches (bumped at the top of main's loop)
_SMART_TABLE = {"n": -1, "rc": 1, "out": "", "counts": {}, "setnames": set()}


def _smart_table():
    """`nft list table inet swg_smart` rendered AND parsed at most ONCE per reconcile loop, shared by
    smart_status + _ensure_smart_nft. Both the render (serializes every CIDR of every set — thousands for a
    geoip category like cat_ru) and the element-count parse (regex + split over that text) are O(set size), so
    doing them once instead of twice halves that cost. Nothing mutates the table between those two callers
    within a loop, so the shared result is current; the next loop bumps _LOOP and re-renders. Returns the
    cache dict: ["rc"], ["out"] (raw), ["counts"] {set:element_count}, ["setnames"] {set}."""
    if _SMART_TABLE["n"] != _LOOP["n"]:
        r = run(["nft", "list", "table", "inet", SMART_NFT_TABLE])
        out = r.stdout or ""
        counts, setnames = {}, set()
        if r.returncode == 0:
            setnames = set(re.findall(r"set (\S+) {", out))
            counts = {c: 0 for c in setnames}
            # nft nests the elements in a second brace pair — `set X { type…; elements = { CIDR, … } }` — so the
            # naive `set {(.*?)}` stops at the INNER `}` and always counts 0. Anchor on the elements block
            # instead (element CIDRs contain no braces). A wrong 0 here forces a full geo set reload EVERY cycle
            # (nft -f of thousands of CIDRs ≈ 250ms), because the reload guard is "count == 0 → (re)load".
            for m in re.finditer(r"set (\S+) {(?:[^}]*?elements = {([^}]*)})?", out, re.S):
                el = m.group(2)
                counts[m.group(1)] = len([x for x in el.split(",") if x.strip()]) if el else 0
        _SMART_TABLE.update(n=_LOOP["n"], rc=r.returncode, out=out, counts=counts, setnames=setnames)
    return _SMART_TABLE


def _ensure_smart_nft(smart_e, categories, res, pin=False, v6_ifaces=()):
    """Phase 3 marking: keep an inet table `swg_smart` with one interval set per category (populated from
    shipped geo CIDR lists — see _smart_geo_refresh) and a prerouting chain that marks
    `ip saddr <S> ip daddr @cat_<c> meta mark set <T>`. Idempotent + drift-gated (flush+rebuild the chain
    only when the wanted rule set changes, so steady-state never un-marks a packet mid-flight). Packets
    stay 100% kernel-routed (the mark feeds the `ip rule fwmark` band). v1 is IPv4-only (v6 leaks direct).

    pin=True (SNI mode): swg-sni fills the sets LIVE from TLS handshakes, so a connection's dst can enter its set
    mid-flight; decide+pin the mark ONCE per connection (ct state new → ct mark) and just restore it afterwards,
    so an in-flight flow is never rerouted (which would change its egress src IP and break it). Also emit an
    NFQUEUE rule feeding each connection's first packets to swg-sni for learning (fail-open bypass)."""
    cats = sorted(set(categories) | {e["category"] for e in smart_e})
    _t = _smart_table()                                         # shared per-loop render + parse (see smart_status)
    if not smart_e and not cats:                                # nothing wanted → tear our table down
        if _t["rc"] == 0:
            run(["nft", "delete", "table", "inet", SMART_NFT_TABLE]); res["changed"] += 1
        return {}
    body = _t["out"] if _t["rc"] == 0 else ""
    # one-shot migration: sets created before auto-merge can't get the flag in place (they're chain-referenced),
    # so if any of ours lacks it, rebuild the whole table once — afterwards every set has auto-merge and the
    # additive dnsmasq/custom-IP paths can't be rejected by an overlap. Stamp-guarded so it can never loop even
    # if some nft version omits the flag from `list` output; sets refill (geoip/dnsmasq) on the next passes.
    _am = os.path.join(GEO_DIR, ".automerge-migrated")
    if _t["rc"] == 0 and not os.path.exists(_am) and re.search(r"set \S+ {(?:(?!auto-merge|}).)*}", body, re.S):
        run(["nft", "delete", "table", "inet", SMART_NFT_TABLE]); res["changed"] += 1
        body = ""
    if not body:
        run(["nft", "add", "table", "inet", SMART_NFT_TABLE])
    with contextlib.suppress(OSError):
        os.makedirs(GEO_DIR, exist_ok=True); open(_am, "w").write("1")
    have_sets = set(re.findall(r"set (\S+) {", body))
    for c in cats:                                              # one interval set per category ("all" is the catch-all → no set)
        if c == "all":
            continue
        sn = _smart_setname(c)
        if sn not in have_sets:
            run(["nft", "add", "set", "inet", SMART_NFT_TABLE, sn, "{ type ipv4_addr; flags interval; auto-merge; }"])
    if "prerouting" not in re.findall(r"chain (\S+) {", body):
        run(["nft", "add", "chain", "inet", SMART_NFT_TABLE, "prerouting",
             "{ type filter hook prerouting priority mangle; policy accept; }"])
    # drift-gate the mark rules: want vs live (parsed from the chain), flush+rebuild only on change.
    # Category rules match a dest set; the "all" catch-all matches any dest but ONLY when still unmarked
    # (`meta mark 0x0`) and is emitted LAST, so specific categories win (first-match semantics).
    subnets = sorted({e["subnet"] for e in smart_e})
    # Ordered, first-match rules carrying a per-rule ACTION: exit=mark→mesh, direct=leave in-kernel (default route),
    # block=drop. Each specific rule ends in `return` so the FIRST match wins — a direct/block exception genuinely
    # overrides a later catch-all exit, and block is a real kill-switch (not a silent fall-through to direct). "all"
    # is the catch-all → emitted after the specific rules for its subnet. Order is preserved from the panel plan.
    spec = [e for e in smart_e if e["category"] != "all"]
    allr = [e for e in smart_e if e["category"] == "all"]
    want = [(e["subnet"], e["category"], e.get("action", "exit"), e.get("table")) for e in spec + allr]
    v6f = sorted(set(v6_ifaces))                                # smart routing is IPv4-only → drop forwarded v6 on these ifaces (fail-closed, no leak)
    sig = hashlib.sha1((("pin;" if pin else "") + json.dumps(want) + "|v6:" + ",".join(v6f) + "|s2").encode()).hexdigest()[:16]   # s2: +QUIC drop (sni)
    _sigf = os.path.join(GEO_DIR, ".smart-sig")
    try:
        stored = open(_sigf).read().strip()
    except OSError:
        stored = ""
    chain_present = "prerouting" in re.findall(r"chain (\S+) {", body)
    def _cbody(name):                                          # the rules inside one chain of our table (per-chain, so a full external flush is detected)
        m = re.search(r"chain " + name + r" \{(.*?)\n\s*\}", body, re.S)
        return m.group(1) if m else ""
    expect_pre = pin or any(a != "direct" for (_, _, a, _) in want)   # exit/block rules + pin (queue/restore) all emit `ip saddr` prerouting rules
    pre_ok = (not expect_pre) or ("saddr" in _cbody("prerouting"))
    fwd_ok = (not v6f) or ("drop" in _cbody("forward"))
    if stored != sig or not chain_present or not pre_ok or not fwd_ok:   # drift-gate: signature change, or a chain was emptied externally
        stored = ""                                            # force the sig file to be rewritten below
        run(["nft", "flush", "chain", "inet", SMART_NFT_TABLE, "prerouting"])
        _ok = [True]                                            # a failed nft add must NOT persist the sig, so the rebuild retries next cycle
        def _add(*a):
            r = run(["nft", "add", "rule", "inet", SMART_NFT_TABLE, "prerouting", *a])
            if r.returncode != 0:
                res["errors"].append("smart nft: " + (r.stderr or "").strip()[:120]); _ok[0] = False
            else:
                res["changed"] += 1
        if pin:
            # restore the per-connection pinned mark ONLY on the original direction (client→dst). Reply packets
            # (dst=a local client) must stay unmarked so they route via the main table back out the user iface —
            # else the fwmark rule sends the return traffic to table 7000 (the mesh) and it never reaches the client.
            _add("ct", "direction", "original", "meta", "mark", "set", "ct", "mark")
            for S in subnets:                                  # SNI can't parse the ENCRYPTED QUIC ClientHello → drop UDP/443 so HTTP/3 falls back to TCP (which swg-sni reads). No accuracy loss (TCP still routes by SNI/IP); just no HTTP/3 on smart ifaces.
                _add("ip", "saddr", S, "udp", "dport", "443", "drop")
        _new = ["ct", "state", "new"] if pin else []           # pin: decide once per connection at ct state new
        for (S, cat, act, T) in want:
            if cat == "all":                                   # catch-all — no dest set, emitted last for its subnet
                if act == "exit":
                    _add("ip", "saddr", S, *_new, "meta", "mark", "set", str(T), *(["ct", "mark", "set", str(T)] if pin else []))
                elif act == "block":                           # kill-switch: drop everything else (pin: only the new pkt, so an allowed flow's established pkts survive)
                    _add("ip", "saddr", S, *_new, "drop")
                continue                                        # direct catch-all → no rule (falls to the main/default route)
            snm = _smart_setname(cat)
            if act == "exit":
                _add("ip", "saddr", S, *_new, "ip", "daddr", "@" + snm, "meta", "mark", "set", str(T), *(["ct", "mark", "set", str(T)] if pin else []), "return")
            elif act == "direct":
                _add("ip", "saddr", S, *_new, "ip", "daddr", "@" + snm, "return")   # explicit direct exception (wins over a later catch-all exit)
            elif act == "block":
                _add("ip", "saddr", S, "ip", "daddr", "@" + snm, "drop")
        if pin:                                                 # feed each connection's first packets to swg-sni (learning), fail-open
            for S in subnets:
                _add("ip", "saddr", S, "tcp", "dport", "443", "ct", "state", "established", "ct", "packets", "lt", "12", "queue", "num", str(SNI_NFQUEUE), "bypass")
        # IPv6 fail-closed: the marking above is IPv4-only, so a dual-stack client's v6 traffic would bypass smart
        # routing and leak out the entry node's WAN. DROP forwarded IPv6 on each smart interface (both directions).
        chains_now = re.findall(r"chain (\S+) {", body)
        if v6f:
            if "forward" not in chains_now:
                run(["nft", "add", "chain", "inet", SMART_NFT_TABLE, "forward", "{ type filter hook forward priority filter; policy accept; }"])
            run(["nft", "flush", "chain", "inet", SMART_NFT_TABLE, "forward"])
            for ifn in v6f:
                run(["nft", "add", "rule", "inet", SMART_NFT_TABLE, "forward", "meta", "nfproto", "ipv6", "iifname", ifn, "drop"])
                run(["nft", "add", "rule", "inet", SMART_NFT_TABLE, "forward", "meta", "nfproto", "ipv6", "oifname", ifn, "drop"])
        elif "forward" in chains_now:
            run(["nft", "flush", "chain", "inet", SMART_NFT_TABLE, "forward"])
            run(["nft", "delete", "chain", "inet", SMART_NFT_TABLE, "forward"])
        if _ok[0]:                                             # only stamp the sig when every rule landed → a transient nft failure retries next cycle
            with contextlib.suppress(OSError):
                os.makedirs(GEO_DIR, exist_ok=True)
                open(_sigf, "w").write(sig)
    # drop sets we no longer want (a category was un-ticked, or 'ru' was split into 'ru_net'/'ru_blocked'): after the
    # chain rebuild above they're unreferenced, so delete them — else the stale set lingers with old IPs forever.
    wanted_sn = {_smart_setname(c) for c in cats if c != "all"}
    for sn in have_sets:
        if sn.startswith("cat_") and sn not in wanted_sn:
            if run(["nft", "delete", "set", "inet", SMART_NFT_TABLE, sn]).returncode == 0:   # still-referenced → fails, retried next pass
                res["changed"] += 1
    # per-set live element counts (so _smart_geo_refresh knows which need (re)loading — e.g. empty after a reboot).
    # Reuse the shared per-loop parse; if `body` was blanked above (auto-merge migration / table absent) the sets
    # were just dropped → report {} so every set is treated as empty and gets reloaded.
    return dict(_t["counts"]) if body else {}


# ── geo CIDR distribution: per-category lists fetched from upstream (Loyalsoldier geoip / ipverse ASN),
#    cached, and loaded into the nft sets. Mirrors the turn-binary fetch (SWG_GEO_MIRROR proxy fallback).
GEO_DIR = os.path.join(STATE_DIR, "geo")
GEO_TTL = 3 * 86400          # refresh a cached category list at most this often (when fetches succeed)
GEO_RT = {"ttl": GEO_TTL}    # runtime-overridable TTL (Panel settings → advanced.geo_ttl_days)
GEO_RETRY = 3600             # …but back off failed/missing fetches to once an hour, so a source outage
#                              never re-hammers (and never blocks every sync on a hanging download)
_CIDR4_RE = re.compile(r"^\d{1,3}(?:\.\d{1,3}){3}/\d{1,2}$")
# category → upstream source specs. "LS:<file>" = Loyalsoldier/geoip release text/<file>.txt;
# "AS:<asn>" = ipverse/asn-ip as/<asn>/ipv4-aggregated.txt. Multiple specs are unioned (e.g. VK's two ASNs).
# category → geoip/ASN source(s). Every category that CAN be matched by IP has a source here, so a Kernel-only
# node (the default routing mode) matches it by destination IP — DoH-proof, no DNS dependency. The domain tier
# (panel DOMAIN_BUNDLES → dnsmasq) is layered ON TOP only for nodes in a DNS/SNI mode; in Kernel-only mode the
# panel ships no domains, so these sets fill purely from geoip. (youtube has no geoip — it shares Google's IPs;
# it's domain-only and only works on a DNS/SNI-mode node.)
GEO_SOURCES = {
    "google": ["LS:google"], "telegram": ["LS:telegram"], "cloudflare": ["LS:cloudflare"],
    "netflix": ["LS:netflix"], "meta": ["LS:facebook"], "twitter": ["LS:twitter"], "ru_net": ["LS:ru"],
    "yandex": ["AS:13238"], "vk": ["AS:47541", "AS:47542"],
}   # ru_net = the whole Russian IP space (geoip). The blocked-in-RU circumvention list is a SEPARATE, domain-only
    # category (ru_blocked in DOMAIN_SOURCES) — they mean different things, so they must never share a set.


def _geo_url(spec):
    if spec.startswith("LS:"):
        return "https://raw.githubusercontent.com/Loyalsoldier/geoip/release/text/" + spec[3:] + ".txt"
    if spec.startswith("AS:"):
        return "https://raw.githubusercontent.com/ipverse/asn-ip/master/as/" + spec[3:] + "/ipv4-aggregated.txt"
    return spec


def _geo_fetch_one(url, timeout=40):
    req = urllib.request.Request(url, headers={"User-Agent": "swg-noded"})
    with urllib.request.urlopen(req, timeout=timeout) as r:   # nosec - public CIDR list over https, CA-verified
        return r.read().decode("utf-8", "ignore")


def _geo_fetch(cat):
    """Union of CIDRs for a category from its source specs (GitHub direct, then any SWG_GEO_MIRROR proxy
    prefixes). Returns a sorted CIDR list, or None if any source couldn't be fetched (don't half-populate)."""
    mirrors = (os.environ.get("SWG_GEO_MIRROR") or "").split()
    cidrs = set()
    for spec in GEO_SOURCES.get(cat, []):
        url = _geo_url(spec)
        data = None
        for u in [url] + [m.rstrip("/") + "/" + url for m in mirrors]:
            try:
                data = _geo_fetch_one(u); break
            except Exception:
                continue
        if data is None:
            return None
        cidrs |= {ln.strip() for ln in data.splitlines() if _CIDR4_RE.match(ln.strip())}
    return sorted(cidrs) or None


def _nft_load_set(setname, cidrs):
    """Atomically replace an nft interval set's elements (flush + chunked add via `nft -f`). Overlapping or
    adjacent ranges are COLLAPSED first — an `interval` set without auto-merge rejects an overlapping add and
    the whole load fails (this is why the large, overlap-heavy Russia list never loaded), so we merge them in
    Python (collapse also fixes adjacency)."""
    import ipaddress
    try:
        cidrs = [str(n) for n in ipaddress.collapse_addresses(
            ipaddress.ip_network(c.strip(), strict=False) for c in cidrs if c.strip())]
    except Exception:
        pass   # bad entry → fall back to the raw list (best-effort; nft will reject the offending chunk only)
    lines = [f"flush set inet {SMART_NFT_TABLE} {setname}"]
    for i in range(0, len(cidrs), 2000):
        lines.append(f"add element inet {SMART_NFT_TABLE} {setname} {{ {', '.join(cidrs[i:i + 2000])} }}")
    path = os.path.join(GEO_DIR, "." + setname + ".nft")
    with open(path, "w") as f:
        f.write("\n".join(lines) + "\n")
    rc = run(["nft", "-f", path]).returncode
    with contextlib.suppress(OSError):
        os.unlink(path)
    return rc


def _smart_demote_geo(cat, res):
    """A category that's now domain-filled but was geoip-loaded before (e.g. after an upgrade that moved it to
    the domain tier): flush its set ONCE and drop the geo cache, so only dnsmasq's resolved IPs remain — else a
    provider's whole IP range would re-merge the split apart. Keyed on the .loaded marker, so it runs a single
    time per transition and never wipes dnsmasq's accumulated fill afterwards."""
    lp = os.path.join(GEO_DIR, "." + cat + ".loaded")
    if not os.path.exists(lp):
        return
    run(["nft", "flush", "set", "inet", SMART_NFT_TABLE, _smart_setname(cat)])
    for p in (lp, os.path.join(GEO_DIR, "." + cat + ".attempt"), os.path.join(GEO_DIR, cat + ".txt")):
        with contextlib.suppress(OSError):
            os.unlink(p)
    res["changed"] += 1


def _smart_geo_refresh(categories, set_counts, res, skip=()):
    """Ensure each needed category's CIDR list is cached + fresh and loaded into its nft set. Fetches only
    when the cache is missing/stale (TTL-gated, so most syncs do nothing); reloads the set when the data
    changed OR the live set is empty (e.g. after a reboot — nft sets aren't persistent). Failures leave the
    set as-is (inert / last-good) and retry next TTL. `skip` = domain-filled categories (dnsmasq owns those
    sets — geo-fetch must never touch them, else a provider's whole IP range would re-merge the split apart)."""
    if not categories:
        return
    try:
        os.makedirs(GEO_DIR, exist_ok=True)
    except OSError as e:
        res["errors"].append("smart geo dir: " + str(e)); return     # can't cache → skip (sets stay inert)
    for cat in categories:
        if cat == "all":
            continue                                           # catch-all → no set
        if cat in skip:                                        # domain-filled → dnsmasq owns it; clear any stale geoip once
            _smart_demote_geo(cat, res)
            continue
        try:                                                   # one bad category must never crash the sync loop
            sn = _smart_setname(cat)
            path = os.path.join(GEO_DIR, cat + ".txt")
            try:
                stale = (not os.path.exists(path)) or (time.time() - os.path.getmtime(path) > GEO_RT["ttl"])
            except OSError:
                stale = True
            ap = os.path.join(GEO_DIR, "." + cat + ".attempt")
            try:
                due = stale and (not os.path.exists(ap) or time.time() - os.path.getmtime(ap) > GEO_RETRY)
            except OSError:
                due = stale
            if due:
                with contextlib.suppress(OSError):                 # stamp BEFORE fetching → a hang still backs off
                    open(ap, "w").write(str(int(time.time())))
                data = _geo_fetch(cat)
                if data:
                    tmp = path + ".tmp"
                    with open(tmp, "w") as f:
                        f.write("\n".join(data) + "\n")
                    os.replace(tmp, path)
            try:
                st = os.stat(path)                             # no data yet → set stays empty (inert), retry next TTL
            except OSError:
                continue
            sig = "%d:%d" % (int(st.st_mtime), st.st_size)      # cheap change signal — avoids re-reading/hashing a big file every cycle
            lp = os.path.join(GEO_DIR, "." + cat + ".loaded")
            marker = ""
            with contextlib.suppress(OSError):
                marker = open(lp).read().strip()
            msig, mhash = marker.split("|", 1) if "|" in marker else ("", marker)   # legacy marker held the hash alone
            if msig == sig and set_counts.get(sn, 0) > 0:      # file unchanged AND set populated → nothing to do (skip read/regex/hash)
                continue
            cidrs = [ln.strip() for ln in open(path).read().splitlines() if _CIDR4_RE.match(ln.strip())]
            if not cidrs:
                continue
            h = hashlib.sha256(("\n".join(cidrs)).encode()).hexdigest()
            if mhash != h or set_counts.get(sn, 0) == 0:       # content changed, or set empty (post-reboot) → (re)load
                if _nft_load_set(sn, cidrs) == 0:
                    with contextlib.suppress(OSError):
                        open(lp, "w").write(sig + "|" + h)
                    res["changed"] += 1
                else:
                    res["errors"].append("smart geo load " + cat + " failed")
            else:                                              # mtime touched but content identical → just refresh the sig
                with contextlib.suppress(OSError):
                    open(lp, "w").write(sig + "|" + h)
        except Exception as e:
            res["errors"].append("smart geo " + cat + ": " + str(e)[:120])


def _smart_load_cidrs(cidrs_map, set_counts, res):
    """Custom-rule raw IPs/CIDRs → ADDED into their nft set directly. The set ALSO fills from dnsmasq for the
    rule's domain half, so we add elements (never flush, which would wipe the dnsmasq-resolved IPs). Add-only +
    gated on the live element count, so steady state is a no-op; a post-reboot empty set re-loads them."""
    for cat, cl in (cidrs_map or {}).items():
        cl = [c for c in (cl or []) if c]
        if not cl:
            continue
        sn = _smart_setname(cat)
        if set_counts.get(sn, 0) >= len(cl):                   # already present (count covers them) → skip the churn
            continue
        for i in range(0, len(cl), 2000):
            if run(["nft", "add", "element", "inet", SMART_NFT_TABLE, sn, "{ " + ", ".join(cl[i:i + 2000]) + " }"]).returncode == 0:
                res["changed"] += 1


# ── GeoSite host tier: per-category DOMAIN lists, fetched/cached EXACTLY like the geoip tier above but feeding
#    dnsmasq instead of nft sets. Sources: v2fly/domain-list-community for global services (one plaintext file
#    per category, may use `include:`), 1andrevich/Re-filter-lists for Russia (a pre-flattened .lst). The fetched
#    list UNIONS with the panel's curated DOMAIN_BUNDLES, then drives the dnsmasq nftset directives below. Only a
#    DNS/SNI-mode node fetches these (the panel ships a domain cat only off Kernel mode); a Kernel node matches
#    the same cats by geoip. Cached under GEO_DIR as <cat>.doms, TTL/retry-gated, mirror-able via SWG_GEO_MIRROR.
#    "V2:<name>" = v2fly data/<name>; "RF:<name>" = Re-filter <name>.lst. Keep in sync with the panel's HOST_CATEGORIES.
DOMAIN_SOURCES = {
    "google":  ["V2:google"],  "youtube": ["V2:youtube"],  "yandex":  ["V2:yandex"],
    "vk":      ["V2:vk"],       "meta":    ["V2:facebook", "V2:instagram"],
    "twitter": ["V2:twitter"],  "netflix": ["V2:netflix"],  "ru_blocked": ["RF:domains_all"],
    "spotify": ["V2:spotify"],  "twitch":  ["V2:twitch"],   "tiktok":  ["V2:tiktok"],
    "disney":  ["V2:disney"],   "reddit":  ["V2:reddit"],   "discord": ["V2:discord"],
    "github":  ["V2:github"],   "openai":  ["V2:openai"],
    # other AI providers (claude/gemini/grok/perplexity/deepseek/copilot) are curated-only on the panel — a
    # single provider's domain set is small + precise, so there's nothing to enrich and no risk of an
    # overly-broad upstream category pulling in shared/parent domains.
}
_DOM_RE = re.compile(r"^(?=.{1,253}$)(?!-)[a-z0-9-]{1,63}(?<!-)(\.(?!-)[a-z0-9-]{1,63}(?<!-))+$")
_DOM_INCLUDE_MAX = 256         # failsafe vs a pathological include tree (cycles already guarded by `seen`);
#                                set well above any real v2fly category so it never silently truncates one


def _domain_url(spec):
    if spec.startswith("V2:"):
        return "https://raw.githubusercontent.com/v2fly/domain-list-community/master/data/" + spec[3:]
    if spec.startswith("RF:"):
        return "https://raw.githubusercontent.com/1andrevich/Re-filter-lists/main/" + spec[3:] + ".lst"
    return spec


def _domain_fetch_text(url):
    """Fetch one domain-list file, trying any SWG_GEO_MIRROR prefixes (reused from the geo tier). None on failure."""
    mirrors = (os.environ.get("SWG_GEO_MIRROR") or "").split()
    for u in [url] + [m.rstrip("/") + "/" + url for m in mirrors]:
        try:
            return _geo_fetch_one(u)
        except Exception:
            continue
    return None


def _v2fly_category(name, seen):
    """A v2fly data/<name> file → its domain list. Resolves `include:` recursively (cycle-guarded by `seen`,
    bounded by _DOM_INCLUDE_MAX). Keeps bare / `domain:` / `full:` entries (all collapse to dnsmasq suffix
    matching); drops `keyword:` / `regexp:` (unmatchable) and ignores @attributes (route every domain in the
    category). FAIL-CLOSED: if this file OR any include can't be fetched, return None so the caller keeps the
    last-good cache instead of persisting a silently-truncated set (a transient blip must never shrink a list)."""
    if name in seen:
        return []                                              # already merged (cycle / shared include) → no dupes
    if len(seen) >= _DOM_INCLUDE_MAX:
        return None                                            # pathological tree → fail-closed (keep last-good)
    seen.add(name)
    text = _domain_fetch_text(_domain_url("V2:" + name))
    if text is None:
        return None
    out = []
    for raw in text.splitlines():
        ln = raw.split("#", 1)[0].strip()
        if not ln:
            continue
        val = ln.split()[0]                                    # token 0 = the value; rest are @attributes
        if val.startswith("include:"):
            inc = _v2fly_category(val[8:].strip().lower(), seen)
            if inc is None:                                    # a failed include fails the whole category (fail-closed)
                return None
            out += inc
            continue
        if ":" in val:
            kind, _, v = val.partition(":")
            if kind in ("keyword", "regexp"):
                continue                                       # dnsmasq suffix matching can't express these
            val = v                                            # domain:/full: → the bare domain
        d = val.strip().lower()
        if _DOM_RE.match(d):
            out.append(d)
    return out


def _domain_fetch(cat):
    """All domains for a category from DOMAIN_SOURCES[cat], deduped + sorted. None if the TOP-LEVEL source of
    any spec couldn't be fetched, so a source outage keeps the last-good cache instead of shrinking the set."""
    specs = DOMAIN_SOURCES.get(cat)
    if not specs:
        return None
    doms = set()
    for spec in specs:
        if spec.startswith("V2:"):
            d = _v2fly_category(spec[3:], set())
            if d is None:                                      # top-level file down → don't half-populate
                return None
            doms |= set(d)
        else:
            text = _domain_fetch_text(_domain_url(spec))
            if text is None:
                return None
            for raw in text.splitlines():
                ln = raw.split("#", 1)[0].strip().lower()
                if _DOM_RE.match(ln):
                    doms.add(ln)
    return sorted(doms) or None


_DOM_CACHE = {}   # cat -> ((mtime,size), parsed-domain-list): reuse the parsed list while the .doms file is unchanged
_DOMTIER_CACHE = {}   # {"v": (input-signature, fully-enriched {cat:[domain]})}: skip the union+sort when inputs are unchanged
_DNSMASQ_BUILD = {"n": 0}   # cycles since the domain tier went active — drives the periodic self-heal rebuild


def _smart_domain_refresh(cats, res):
    """Ensure each domain category's <cat>.doms cache is fresh (TTL-gated, retry-backed off — mirrors
    _smart_geo_refresh) and return {cat: domain-list} from cache. Cats with no DOMAIN_SOURCES entry (e.g. a
    custom_<hash> rule, whose domains come from the panel) are skipped. Failures leave the cache as last-good."""
    out = {}
    if not cats:
        return out
    try:
        os.makedirs(GEO_DIR, exist_ok=True)
    except OSError as e:
        res["errors"].append("smart domain dir: " + str(e)); return out
    for cat in cats:
        if cat not in DOMAIN_SOURCES:
            continue
        try:
            path = os.path.join(GEO_DIR, cat + ".doms")
            try:
                stale = (not os.path.exists(path)) or (time.time() - os.path.getmtime(path) > GEO_RT["ttl"])
            except OSError:
                stale = True
            ap = os.path.join(GEO_DIR, "." + cat + ".doms.attempt")
            try:
                due = stale and (not os.path.exists(ap) or time.time() - os.path.getmtime(ap) > GEO_RETRY)
            except OSError:
                due = stale
            if due:
                with contextlib.suppress(OSError):                 # stamp BEFORE fetching → a hang still backs off
                    open(ap, "w").write(str(int(time.time())))
                data = _domain_fetch(cat)
                if data:
                    tmp = path + ".tmp"
                    with open(tmp, "w") as f:
                        f.write("\n".join(data) + "\n")
                    os.replace(tmp, path)
            try:
                st = os.stat(path)
            except OSError:
                continue                                       # no cache yet → nothing to return for this cat
            sig = (int(st.st_mtime), st.st_size)
            cached = _DOM_CACHE.get(cat)
            if cached and cached[0] == sig:                    # file unchanged → reuse the parsed list (skip the big read+regex)
                doms = cached[1]
            else:
                doms = [d for d in open(path).read().splitlines() if _DOM_RE.match(d.strip())]
                _DOM_CACHE[cat] = (sig, doms)
            if doms:
                out[cat] = doms
        except Exception as e:
            res["errors"].append("smart domain " + cat + ": " + str(e)[:120])
    return out


# ── domain tier: a dedicated dnsmasq fills the domain-category nft sets. Smart-interface clients have their
#    DNS transparently DNAT-redirected here, so every lookup of a bundle domain adds its answer IPs to cat_<c>
#    — the same set the marking chain matches. Managed from the sync loop (configured/started/torn down each
#    pass, self-healing like the nft rules). The set fills as clients browse; no static IP list to go stale.
SMART_DNS_PORT = 5354                                           # dnsmasq listens here on loopback (system :53 untouched)
DNSMASQ_BIN  = "dnsmasq"
DNSMASQ_CONF = os.path.join(STATE_DIR, "smart-dnsmasq.conf")
DNSMASQ_PID  = os.path.join(STATE_DIR, "smart-dnsmasq.pid")
SMARTDNS_TAG = "swg-smartdns"                                   # iptables comment tag for the DNS-redirect rules


def _dnsmasq_running():
    """Our dnsmasq's pid if alive, else 0 (stale/absent pid-file → 0)."""
    try:
        pid = int(open(DNSMASQ_PID).read().strip())
        os.kill(pid, 0)                                        # signal 0 = liveness probe, sends nothing
        return pid
    except (OSError, ValueError):
        return 0


def _dnsmasq_stop():
    pid = _dnsmasq_running()
    if pid:
        run(["kill", str(pid)])
    run(["pkill", "-f", "--", "conf-file=" + DNSMASQ_CONF])   # reap any stray instances the pid-file missed
    for p in (DNSMASQ_PID, DNSMASQ_CONF):
        with contextlib.suppress(OSError):
            os.unlink(p)


def _smart_dns_redirect(subnets, res):
    """DNAT udp/tcp :53 from each smart subnet → our dnsmasq (127.0.0.1:SMART_DNS_PORT), tag-reconciled so it
    converges (add wanted / drop stale) without churn. Empty subnets → remove all our redirect rules. The
    route_localnet sysctl lets a forwarded packet DNAT to loopback (off by default)."""
    want = {(S, proto) for S in subnets for proto in ("udp", "tcp")}
    out = getattr(run(["iptables", "-t", "nat", "-S", "PREROUTING"]), "stdout", "") or ""
    live = set()
    for ln in out.splitlines():
        if SMARTDNS_TAG not in ln:
            continue
        ms = re.search(r"-s (\S+)", ln); mp = re.search(r"-p (\w+)", ln)
        if ms and mp:
            S = ms.group(1)
            live.add((S if "/" in S else S + "/32", mp.group(1)))
    if want and not live:
        run(["sysctl", "-q", "-w", "net.ipv4.conf.all.route_localnet=1"])

    def rule(S, proto):
        return ["-s", S, "-p", proto, "--dport", "53", "-m", "comment", "--comment", SMARTDNS_TAG,
                "-j", "DNAT", "--to-destination", "127.0.0.1:" + str(SMART_DNS_PORT)]
    for (S, proto) in sorted(want - live):
        run(["iptables", "-t", "nat", "-A", "PREROUTING"] + rule(S, proto)); res["changed"] += 1
    for (S, proto) in sorted(live - want):
        run(["iptables", "-t", "nat", "-D", "PREROUTING"] + rule(S, proto)); res["changed"] += 1


def _ensure_smart_dnsmasq(domains, smart_e, res, unchanged=False):
    """(Re)configure + run the domain-tier dnsmasq and redirect smart-subnet DNS to it. domains = {cat:[domain]}
    for the active domain categories; smart_e gives the source subnets. Nothing wanted → full teardown.
    unchanged=True (inputs identical to last cycle) → skip the expensive body rebuild, but still re-assert the DNS
    redirect (cheap, diff-gated) and, every ~12 cycles, force a full rebuild to self-heal any external drift."""
    subnets = sorted({e["subnet"] for e in smart_e})
    want = bool(domains and subnets)
    _smart_dns_redirect(subnets if want else [], res)          # cheap, diff-gated — always reconciled
    if not want:                                               # nothing to fill → tear down + reap any stray instance
        _DNSMASQ_BUILD["n"] = 0
        had = _dnsmasq_running() or os.path.exists(DNSMASQ_CONF) or run(["pgrep", "-f", "conf-file=" + DNSMASQ_CONF]).returncode == 0
        if had:
            _dnsmasq_stop(); res["changed"] += 1
        return
    _DNSMASQ_BUILD["n"] += 1
    if unchanged and _DNSMASQ_BUILD["n"] % 12 != 0 and _dnsmasq_running():
        return                                                 # inputs unchanged + dnsmasq alive → skip the O(n) config rebuild
    conf = ["# managed by swg-noded — domain-tier smart routing (do not edit)",
            "port=" + str(SMART_DNS_PORT), "listen-address=127.0.0.1", "bind-interfaces",
            "no-resolv", "no-hosts", "cache-size=2000", "pid-file=" + DNSMASQ_PID]
    conf += ["server=1.1.1.1", "server=8.8.8.8"]
    for cat in sorted(domains):                                # nftset=/d1/d2/.../4#inet#swg_smart#cat_<c>
        doms = sorted({d for d in domains[cat] if d})          # sorted → deterministic body (no needless restart)
        sn = _smart_setname(cat)
        suffix = "/4#inet#" + SMART_NFT_TABLE + "#" + sn        # chunk by BYTE length: dnsmasq's config parser caps
        cur, clen = [], 0                                       # a line at ~1024 chars (MAXDNAME), and host-tier lists
        for d in doms:                                         # (e.g. cat_ru) have long names — chunking by count
            if cur and 8 + clen + len(suffix) + 1 + len(d) > 900:   # ("nftset=/"=8, "/"=1) overflows that and dnsmasq
                conf.append("nftset=/" + "/".join(cur) + suffix)    # FAILS to start. Keep each line < ~900 bytes.
                cur, clen = [], 0
            cur.append(d); clen += len(d) + (1 if clen else 0)
        if cur:
            conf.append("nftset=/" + "/".join(cur) + suffix)
    body = "\n".join(conf) + "\n"
    try:
        cur = open(DNSMASQ_CONF).read()
    except OSError:
        cur = None
    if cur != body:
        try:
            with open(DNSMASQ_CONF, "w") as f:
                f.write(body)
        except OSError as e:
            res["errors"].append("smart dnsmasq conf: " + str(e)); return
        if _dnsmasq_running():                                 # nftset directives are read only at startup → restart
            _dnsmasq_stop()
    if not _dnsmasq_running():                                 # (re)start, also self-heals after a reboot/crash
        r = run([DNSMASQ_BIN, "--conf-file=" + DNSMASQ_CONF])
        if getattr(r, "returncode", 1) != 0:
            res["errors"].append("smart dnsmasq start: " + (getattr(r, "stderr", "") or "").strip()[:120])
        else:
            res["changed"] += 1


# ── Force-DNS guard (DoH/DoT block): in forcedns mode the node's dnsmasq IS the smart-routing oracle (it fills
#    the domain sets), so a client that resolves over ENCRYPTED DNS would bypass it. Plaintext :53 is already
#    DNAT'd to our dnsmasq (_smart_dns_redirect); this closes the encrypted holes by DROPping, from the smart
#    subnets, DoT/DoQ (:853) and DoH/DoH3 (:443 to known DoH-resolver IPs). Gated on the panel's block_doh
#    (routing_mode == forcedns) — NOT applied in kernel mode (geoip needs no DNS) or sni mode (Phase C is
#    DoH-proof without forcing DNS). Own inet table `swg_doh`, reconciled/torn-down like the smart table.
DOH_NFT_TABLE = "swg_doh"
# DoH-resolver IPs to drop on :443. DELIBERATELY a small CURATED list of the major providers' DEDICATED
# resolver anycast IPs — NOT a big crowd-sourced feed (e.g. dibdot/DoH-IP-blocklists). Those feeds resolve DoH
# *hostnames*, and many DoH services sit behind SHARED CDNs (Cloudflare 104.21/172.67/162.159…); dropping :443
# to a shared-CDN IP would blackhole unrelated websites. Blocking by IP is only safe for dedicated resolver
# anycast (1.1.1.1, 8.8.8.8, 9.9.9.9, …), which is also what every browser/OS auto-DoH defaults to — a user
# pointing at a custom CDN-hosted DoH can only be stopped by SNI inspection (Phase C), not IP. Plain /32s.
DOH_IPS = sorted(set([
    "1.1.1.1", "1.0.0.1", "1.1.1.2", "1.0.0.2", "1.1.1.3", "1.0.0.3",          # Cloudflare (+ family/security)
    "8.8.8.8", "8.8.4.4",                                                       # Google
    "9.9.9.9", "149.112.112.112", "9.9.9.10", "149.112.112.10",                # Quad9
    "9.9.9.11", "149.112.112.11",
    "94.140.14.14", "94.140.15.15", "94.140.14.140", "94.140.14.141",          # AdGuard (+ family)
    "208.67.222.222", "208.67.220.220", "208.67.222.123", "208.67.220.123",    # OpenDNS / FamilyShield
    "185.228.168.9", "185.228.169.9", "185.228.168.168",                       # CleanBrowsing
    "45.90.28.0", "45.90.30.0",                                                 # NextDNS anycast
    "194.242.2.2", "194.242.2.3", "194.242.2.4",                               # Mullvad
    "76.76.2.0", "76.76.10.0",                                                  # Control D
    "193.110.81.0", "185.253.5.0",                                             # dns0.eu
    "77.88.8.8", "77.88.8.1", "77.88.8.2", "77.88.8.3", "77.88.8.7",           # Yandex DNS
    "223.5.5.5", "223.6.6.6",                                                   # AliDNS
    "1.12.12.12", "120.53.53.53",                                              # DNSPod
]))


def _doh_ips():
    """The dedicated-resolver anycast IPs to drop on :443 (see DOH_IPS rationale)."""
    return DOH_IPS


def _ensure_doh_block(subnets, enable, res):
    """(Re)build or tear down the `swg_doh` drop table. Signature-gated (subnets + DoH-IP set), so steady state
    is a no-op and a list refresh re-applies. Built atomically via `nft -f`. Never raises into the sync loop."""
    try:
        have = run(["nft", "list", "table", "inet", DOH_NFT_TABLE])
        if not (enable and subnets):                           # disabled / no smart subnets → drop our table
            if have.returncode == 0:
                run(["nft", "delete", "table", "inet", DOH_NFT_TABLE]); res["changed"] += 1
            with contextlib.suppress(OSError):
                os.unlink(os.path.join(GEO_DIR, ".doh.sig"))
            return
        ips = _doh_ips()
        want_src = sorted(subnets)
        sig = hashlib.sha256((";".join(want_src) + "|" + ";".join(ips)).encode()).hexdigest()
        sigf = os.path.join(GEO_DIR, ".doh.sig")
        cur = ""
        with contextlib.suppress(OSError):
            cur = open(sigf).read().strip()
        if have.returncode == 0 and cur == sig:                # already converged (table present + same wants)
            return
        lines = []
        if have.returncode == 0:
            lines.append("delete table inet " + DOH_NFT_TABLE)
        lines.append("table inet " + DOH_NFT_TABLE + " {")
        lines.append("  set doh4 { type ipv4_addr; flags interval; auto-merge; elements = { " + ", ".join(ips) + " } }")
        lines.append("  chain forward { type filter hook forward priority filter; policy accept;")
        for S in want_src:
            lines.append("    ip saddr " + S + " udp dport 853 drop")    # DoQ
            lines.append("    ip saddr " + S + " tcp dport 853 drop")    # DoT
            lines.append("    ip saddr " + S + " ip daddr @doh4 udp dport 443 drop")   # DoH3 / QUIC
            lines.append("    ip saddr " + S + " ip daddr @doh4 tcp dport 443 drop")   # DoH
        lines += ["  }", "}"]
        with contextlib.suppress(OSError):
            os.makedirs(GEO_DIR, exist_ok=True)
        path = os.path.join(GEO_DIR, ".doh.nft")
        with open(path, "w") as f:
            f.write("\n".join(lines) + "\n")
        rc = run(["nft", "-f", path]).returncode
        with contextlib.suppress(OSError):
            os.unlink(path)
        if rc == 0:
            with contextlib.suppress(OSError):
                open(sigf, "w").write(sig)
            res["changed"] += 1
        else:
            res["errors"].append("doh block nft load failed")
    except Exception as e:
        res["errors"].append("doh block: " + str(e)[:120])


def reconcile_dial_src(desired_by_iface, res):
    """Pin the OUTBOUND source IP for each mesh link that set a dial_src — a /32 route to the peer endpoint
    with `src <dial_src>` in the main table (the encrypted tunnel UDP leaves the WAN, so this never touches
    the cascade 7000-band). `ip route replace` is atomic (no gap) so it's re-asserted every sync (reboot-safe);
    a cleared dial_src removes the route (diffed against a small state file). Never raises into the sync loop."""
    try:
        want = {}                                              # peer endpoint IP -> dial source IP
        for peers in (desired_by_iface or {}).values():
            for p in peers:
                ds = (p.get("dial_src") or "").strip(); ep = p.get("endpoint") or ""
                if not ds or not ep:
                    continue
                try:
                    want[socket.gethostbyname(ep.rsplit(":", 1)[0])] = ds
                except Exception:
                    continue                                   # unresolvable endpoint → skip (retry next sync)
        statef = os.path.join(STATE_DIR, "dial-src.json")
        prev = {}
        with contextlib.suppress(Exception):
            prev = json.load(open(statef))
        for ip in (set(prev) - set(want)):                     # dial_src cleared → drop our /32
            run(["ip", "route", "del", ip + "/32"]); res["changed"] += 1
        for ip, ds in want.items():                            # (re)assert the source route (atomic, idempotent)
            g = run(["ip", "route", "get", ip]).stdout
            mdev = re.search(r"\bdev (\S+)", g); mvia = re.search(r"\bvia (\S+)", g)
            cmd = ["ip", "route", "replace", ip + "/32"]
            if mvia:
                cmd += ["via", mvia.group(1)]
            if mdev:
                cmd += ["dev", mdev.group(1)]
            cmd += ["src", ds]
            if run(cmd).returncode != 0:
                res["errors"].append("dial-src " + ip + ": route failed")
            elif prev.get(ip) != ds:
                res["changed"] += 1
        if want != prev:
            with contextlib.suppress(Exception):
                with open(statef + ".tmp", "w") as f:
                    json.dump(want, f)
                os.replace(statef + ".tmp", statef)
    except Exception as e:
        res["errors"].append("dial-src: " + str(e)[:120])


def apply_panel_settings(pan):
    """Consume the sync-reply `panel` block (Panel settings): push the geo/turn mirrors via in-process env
    (existing readers pick them up untouched), set the runtime geo TTL, and force a geo re-fetch when the
    operator bumps the epoch (wipe the cache files so they read missing). Never raises."""
    try:
        if not isinstance(pan, dict):
            return
        if pan.get("geo_mirror") is not None:                  # panel is authoritative for the geo mirror
            os.environ["SWG_GEO_MIRROR"] = pan.get("geo_mirror") or ""
        if (pan.get("turn_mirror") or "").strip():             # only ADD a turn mirror (preserve any install-time one)
            os.environ["SWG_TURN_MIRROR"] = pan["turn_mirror"].strip()
        GEO_RT["ttl"] = max(86400, int(pan.get("geo_ttl_days") or 3) * 86400)
        ep = str(int(pan.get("geo_epoch") or 0))
        ef = os.path.join(GEO_DIR, ".geo-epoch")
        cur = ""
        with contextlib.suppress(Exception):
            cur = open(ef).read().strip()
        if ep != cur:                                          # Refresh-geo pressed → drop cache so it refetches
            with contextlib.suppress(OSError):
                os.makedirs(GEO_DIR, exist_ok=True)
            for fn in (os.listdir(GEO_DIR) if os.path.isdir(GEO_DIR) else []):
                if fn.endswith((".txt", ".attempt", ".loaded", ".doms")):
                    with contextlib.suppress(OSError):
                        os.unlink(os.path.join(GEO_DIR, fn))
            with contextlib.suppress(OSError):
                open(ef, "w").write(ep)
    except Exception:
        pass


def reconcile_cascade(node_cfg, plan, smart=None, default_egress_ip=""):
    """Phase 2 cascade + Phase 3 smart routing. ENTRY (P2 forward): `ip rule from S lookup T`; ENTRY
    (P3 smart): nftables marks `ip saddr S ip daddr @<category> meta mark set T` then `ip rule fwmark T
    lookup T` — both route into `default dev <link> table T`. EXIT (shared): `ip rule to S lookup T` +
    `S dev <link> table T` + SNAT S out the WAN. Idempotent: policy rules/routes are rebuilt only when
    they DRIFT from the plan (a signature compare — never churn each sync, which would leak a packet to
    direct egress mid-gap); the iptables + nft sides are diffed by tag/signature. Runtime state is lost on
    reboot, so this re-applies on the first sync after one. Returns {changed, errors}."""
    res = {"changed": 0, "errors": []}
    plan = plan or {}
    fwd = plan.get("forward") or []
    exit_ = plan.get("exit") or []
    smart_e = (smart or {}).get("entries") or []
    smart_exit = [e for e in smart_e if e.get("action", "exit") == "exit"]   # only exit rules carry a mesh table/dev; direct/block are local verdicts
    mode = (smart or {}).get("mode") or "kernel"               # kernel | forcedns | sni — picks the set-fill mechanism
    band = _live_band_prios()
    want_tables = {str(e["table"]) for e in (fwd + smart_exit + exit_)}
    want_sig = _cascade_want_sig(fwd, exit_, smart_exit)   # only exit entries create fwmark→table policy routing
    live_sig = _cascade_live_sig({str(p) for p in band} | want_tables)
    # POLICY RULES/ROUTES — only touch them when they drift (avoids per-sync rule gaps).
    if want_sig != live_sig:
        if fwd or smart_e or exit_:                            # enable forwarding + loose rp_filter (asymmetric paths)
            run(["sysctl", "-q", "-w", "net.ipv4.ip_forward=1"])
            wan = _detect_wan()
            for dev in sorted({"all", wan} | {e["via_iface"] for e in (fwd + smart_exit + exit_)}):
                run(["sysctl", "-q", "-w", f"net.ipv4.conf.{dev}.rp_filter=2"])   # effective = max(all,dev): lower BOTH
        for pri in band:                                       # teardown our whole band (rules + tables)
            for _ in range(8):                                 # del-until-absent (a priority may carry several rules)
                if run(["ip", "rule", "del", "pref", str(pri)]).returncode != 0:
                    break
            run(["ip", "route", "flush", "table", str(pri)])
        for e in fwd:                                          # P2 ENTRY: from S → table T (default via link)
            T = str(e["table"]); S = e["subnet"]; dev = e["via_iface"]
            run(["ip", "route", "replace", "default", "dev", dev, "table", T])
            run(["ip", "rule", "add", "from", S, "lookup", T, "priority", T])
            res["changed"] += 1
        for T, dev in sorted({(str(e["table"]), e["via_iface"]) for e in smart_exit}):   # P3 ENTRY: fwmark T → table T
            run(["ip", "route", "replace", "default", "dev", dev, "table", T])
            run(["ip", "rule", "add", "fwmark", T, "lookup", T, "priority", T])
            res["changed"] += 1
        for e in exit_:                                        # EXIT: to S → table T (S via link)
            T = str(e["table"]); S = e["subnet"]; dev = e["via_iface"]
            run(["ip", "route", "replace", S, "dev", dev, "table", T])
            run(["ip", "rule", "add", "to", S, "lookup", T, "priority", T])
            res["changed"] += 1
    # IPTABLES (SNAT / FORWARD accept / MSS clamp) — always reconciled by tag (cheap, no-churn).
    _ensure_fwd_iptables(fwd, exit_, _detect_wan(), res, default_egress_ip)
    # NFTABLES smart-routing marking (saddr+daddr@category → mark T) — drift-gated, packets stay in-kernel.
    smart_cats = sorted(set((smart or {}).get("categories") or []) | {e["category"] for e in smart_e})
    _smart_subs = {e["subnet"] for e in smart_e}                # smart interfaces (by subnet) → IPv6 fail-closed drop
    smart_ifs = sorted({ifn for ifn in (node_cfg.get("interfaces") or {}) if _iface_subnet(node_cfg, ifn) in _smart_subs}) if _smart_subs else []
    set_counts = _ensure_smart_nft(smart_e, smart_cats, res, pin=(mode == "sni"), v6_ifaces=smart_ifs)
    domains = dict((smart or {}).get("domains") or {})         # domain-tier bundles {cat:[domain]} → dnsmasq-filled
    # GeoSite host tier: enrich each panel-shipped domain cat with the node-fetched upstream list (union), so the
    # curated bundle stays a guaranteed fallback. The union+sort of a ~100k-entry list is expensive to redo every
    # cycle, so cache the enriched dict on a CHEAP signature of the inputs — subnets + the raw panel bundles (small)
    # + each fetched cat's geo-file (mtime,size) — never touching the big lists. Unchanged inputs reuse the enriched
    # dict AND tell _ensure_smart_dnsmasq to skip its (equally expensive) config rebuild. This keeps domains[cat]
    # populated either way, so the geoip↔domain split below (skip=...) stays correct.
    _fetched = _smart_domain_refresh([c for c in domains if c in DOMAIN_SOURCES], res)
    dom_sig = (tuple(sorted({e["subnet"] for e in smart_e})), json.dumps(domains, sort_keys=True),
               tuple(sorted((c, _DOM_CACHE.get(c, (None,))[0]) for c in _fetched)))
    _dt = _DOMTIER_CACHE.get("v")
    dom_unchanged = bool(_dt and _dt[0] == dom_sig)
    if dom_unchanged:
        domains = _dt[1]                                       # inputs unchanged → reuse enriched dict (skip union+sort)
    else:
        for cat, fl in _fetched.items():
            domains[cat] = sorted(set(domains.get(cat) or []) | set(fl))
        _DOMTIER_CACHE["v"] = (dom_sig, domains)
    # GEOIP cats fill from cached CIDR lists (TTL-gated); domain cats are owned by dnsmasq → skip them here. A
    # cat is demoted from geoip only once it actually HAS domains, so a geoip-only cat (ru_net) never demotes and a
    # domain-capable cat stays geoip until its upstream domain list lands rather than going briefly empty.
    if smart_cats:
        _smart_geo_refresh(smart_cats, set_counts or {}, res, skip={c for c, v in domains.items() if v})
    _smart_load_cidrs((smart or {}).get("cidrs") or {}, set_counts or {}, res)   # custom-rule raw IPs/CIDRs → into the set
    _subs = sorted({e["subnet"] for e in smart_e})
    if mode == "sni":                                          # SNI router owns the domain cats (swg-sni fills them from
        _ensure_sni_router(domains, _subs, res)               # the TLS handshake); the client's DNS is never touched
        if _dnsmasq_running() or os.path.exists(DNSMASQ_CONF):  # tear down any leftover Force-DNS resolver
            _ensure_smart_dnsmasq({}, [], res, unchanged=False)
        _ensure_doh_block(_subs, False, res)                  # never block the client's encrypted DNS in sni mode
    else:
        _ensure_sni_router(None, [], res)                     # not sni → stop the classifier + drop its map
        # domain tier: run/teardown the dnsmasq that fills domain sets + redirect smart-subnet DNS to it
        if smart_e or domains or _dnsmasq_running() or os.path.exists(DNSMASQ_CONF):
            _ensure_smart_dnsmasq(domains, smart_e, res, unchanged=dom_unchanged)
        # Force-DNS guard: block encrypted DNS (DoH/DoT) so the domain fill can't be bypassed (forcedns mode only)
        _ensure_doh_block(_subs, bool((smart or {}).get("block_doh")), res)
    return res


def _ensure_sni_router(domains, subnets, res):
    """SNI mode: write the domain→category map for swg-sni and keep the classifier running; any other mode stops it
    and drops the map. swg-sni reads each connection's ClientHello off the NFQUEUE that _ensure_smart_nft set up
    and adds the dst IP to the matched category set, so the kernel routes FUTURE connections to that IP — the
    client's own DNS (incl. DoH/DoT) is never touched. Supervised as a subprocess (shares swg-noded's cgroup, so it
    dies on a noded restart and is relaunched here)."""
    want = domains is not None and bool(subnets)
    p = _SNI_PROC.get("p")
    if not want:
        if p and p.poll() is None:
            with contextlib.suppress(Exception): p.terminate()
        _SNI_PROC["p"] = None
        with contextlib.suppress(OSError): os.remove(SNI_MAP_PATH)
        return
    try:                                                       # write the map only when it changes (cheap; swg-sni reloads on mtime)
        newmap = json.dumps({c: sorted(d) for c, d in (domains or {}).items() if d}, sort_keys=True)
        old = ""
        with contextlib.suppress(OSError):
            with open(SNI_MAP_PATH) as f: old = f.read()
        if newmap != old:
            os.makedirs(os.path.dirname(SNI_MAP_PATH), exist_ok=True)
            with open(SNI_MAP_PATH + ".tmp", "w") as f: f.write(newmap)
            os.replace(SNI_MAP_PATH + ".tmp", SNI_MAP_PATH)
            res["changed"] += 1
    except Exception as e:
        res["errors"].append("sni map: " + str(e)[:120]); return
    if not p or p.poll() is not None:                          # (re)launch the classifier if it isn't running
        exe = next((c for c in (os.path.join(os.path.dirname(os.path.abspath(sys.argv[0])), "swg-sni"),
                                "/opt/swg-noded/swg-sni", "/usr/local/bin/swg-sni") if os.path.exists(c)), None)
        if not exe:
            res["errors"].append("sni: swg-sni not found"); return
        try:
            log = open("/var/lib/swg-noded/swg-sni.log", "a")
            _SNI_PROC["p"] = subprocess.Popen([sys.executable, exe, "--queue", str(SNI_NFQUEUE),
                                               "--map", SNI_MAP_PATH, "--table", SMART_NFT_TABLE],
                                              stdout=log, stderr=log)
            res["changed"] += 1; print("sni: launched swg-sni (queue %d)" % SNI_NFQUEUE, flush=True)
        except Exception as e:
            res["errors"].append("sni launch: " + str(e)[:120])


def smart_status():
    """Phase 3 smart-routing health for the panel UI: whether our nft table is up, per-category element
    counts (a populated set = geo data loaded), and the number of active mark rules. nft absent → inactive."""
    t = _smart_table()                                          # shared per-loop render + parse (also used by _ensure_smart_nft)
    if t["rc"] != 0:
        return {"active": False, "sets": {}, "rules": 0}
    rules = len(re.findall(r"ip saddr \S+ ip daddr @\S+ meta mark set", t["out"]))
    return {"active": rules > 0, "sets": dict(t["counts"]), "rules": rules, "dnsmasq": bool(_dnsmasq_running())}


# ───────────────────────── internet egress volume (measured, not estimated) ─────────────────────────
# The exact bytes this node forwards to/from the INTERNET, read off the per-iface FORWARD ACCEPT counters
# the agent installs in every interface's PostUp (`-i <iface> -o <wan>` = upload · `-i <wan> -o <iface>` =
# download). Counting is free (kernel keeps these counters always-on); we only READ them, and only on a slow
# gate (~15s) — NEVER on the 5s snapshot path — caching the rate so build_snapshot just attaches the cache.
# Correct for multi-hop by construction: at an ENTRY forwarded traffic goes iface→mesh (both tunnels, no `-o
# <wan>` match), so only DIRECT client traffic counts; at an EXIT the mesh iface forwards to the WAN
# (`-i swg_… -o <wan>`), so the relayed volume is attributed to the node that actually reaches the internet.
INET_SAMPLE_EVERY_S = 15
SWG_INET_CHAIN = "SWG_INET"     # our own filter chain, jumped from FORWARD's head: counts tunnel↔wan bytes
_INET = {"t": 0.0, "cum": None, "rate": {"up": 0.0, "down": 0.0}}


def reconcile_inet_chain(node_cfg):
    """Maintain the SWG_INET counting chain: one up (iface→wan) + one down (wan→iface) rule per managed
    tunnel iface, tagged with a comment, jumped from the TOP of FORWARD. The rules carry NO target, so they
    only COUNT and fall through — the packet's verdict is unchanged (no datapath effect). Being at the head,
    they see every forwarded packet BEFORE the mesh forward-ACL (`-i swg_… -j ACCEPT`, no `-o`) would accept
    it and shadow a plain `-i swg_ -o wan` rule — which is why an EXIT's relayed egress is otherwise unseen.
    We rebuild only when the iface-set/WAN signature changes, so byte counters keep accruing between edits.
    Best-effort (a node without iptables just no-ops)."""
    managed = sorted((node_cfg.get("interfaces") or {}).keys())
    if not managed:
        return
    wan = _detect_wan()
    if not wan:
        return
    if run(["iptables", "-t", "filter", "-nL", SWG_INET_CHAIN]).returncode != 0:
        run(["iptables", "-t", "filter", "-N", SWG_INET_CHAIN])          # create the chain (idempotent)
    if ("-j " + SWG_INET_CHAIN) not in (run(["iptables", "-t", "filter", "-S", "FORWARD"]).stdout or ""):
        run(["iptables", "-t", "filter", "-I", "FORWARD", "1", "-j", SWG_INET_CHAIN])   # jump ahead of the ACL
    cur = run(["iptables", "-t", "filter", "-S", SWG_INET_CHAIN]).stdout.splitlines()
    cursig = set()
    for ln in cur:
        m = re.search(r'--comment "?(swg-inet-(?:up|dn)):([^"\s]+)', ln)   # `-S` QUOTES the comment — tolerate it, else cursig is always empty → constant flush → counters never accrue
        if not m:
            continue
        mi = re.search(r"-i (\S+)", ln); mo = re.search(r"-o (\S+)", ln)
        cursig.add((m.group(1), m.group(2), mi.group(1) if mi else "", mo.group(1) if mo else ""))
    wantsig = set()
    for ifn in managed:
        wantsig.add(("swg-inet-up", ifn, ifn, wan)); wantsig.add(("swg-inet-dn", ifn, wan, ifn))
    if cursig == wantsig:
        return                                              # unchanged → leave the counters accumulating
    run(["iptables", "-t", "filter", "-F", SWG_INET_CHAIN])   # iface set / WAN changed → rebuild
    for ifn in managed:
        run(["iptables", "-t", "filter", "-A", SWG_INET_CHAIN, "-i", ifn, "-o", wan,
             "-m", "comment", "--comment", "swg-inet-up:" + ifn])
        run(["iptables", "-t", "filter", "-A", SWG_INET_CHAIN, "-i", wan, "-o", ifn,
             "-m", "comment", "--comment", "swg-inet-dn:" + ifn])


def read_inet_bytes(managed_ifaces=None):
    """Cumulative internet-forwarded bytes {up, down} from the SWG_INET chain counters (see
    reconcile_inet_chain). One cheap `iptables-save -c -t filter` (small: geo sets live in a separate nft
    table). None → unreadable / chain not built yet."""
    r = run(["iptables-save", "-c", "-t", "filter"])
    if r.returncode != 0 or not r.stdout:
        return None
    up = down = 0
    for ln in r.stdout.splitlines():
        if "swg-inet-" not in ln:
            continue
        m = re.match(r"\[\d+:(\d+)\]\s+-A\s+" + SWG_INET_CHAIN + r"\b(.*)", ln)
        if not m:
            continue
        by = int(m.group(1))
        if "swg-inet-up:" in m.group(2):
            up += by
        elif "swg-inet-dn:" in m.group(2):
            down += by
    return {"up": up, "down": down}


def sample_inet(node_cfg, now):
    """Return the cached internet {up, down} rate (B/s), refreshing the counters at most every
    INET_SAMPLE_EVERY_S. First read only sets the baseline (rate stays 0 until the next sample)."""
    if _INET["cum"] is not None and (now - _INET["t"]) < INET_SAMPLE_EVERY_S:
        return _INET["rate"]
    managed = set((node_cfg.get("interfaces") or {}).keys())
    if not managed:
        return _INET["rate"]
    cur = read_inet_bytes(managed)
    if cur is None:                                    # no iptables (some containers) → leave last known
        return _INET["rate"]
    prev, pt = _INET["cum"], _INET["t"]
    if prev is not None and now > pt:                  # counter reset (iface flap) → clamp the negative delta to 0
        dt = now - pt
        _INET["rate"] = {"up": max(0.0, (cur["up"] - prev["up"]) / dt),
                         "down": max(0.0, (cur["down"] - prev["down"]) / dt)}
    _INET["cum"] = cur; _INET["t"] = now
    return dict(_INET["rate"])


def build_snapshot(node_cfg, online_max, last_samples, now=None):
    now = now or int(time.time())
    hcfg = node_cfg.get("health") or {}
    interfaces = {}
    stopped_set = _load_stopped_ifaces()   # interfaces the operator deliberately stopped → "stopped", not "down"
    for iface, ic in (node_cfg.get("interfaces") or {}).items():
        cmd = ic.get("cmd", ["awg"])
        try:                                        # one bad interface must never kill the whole snapshot
            _r = run(cmd + ["show", iface, "dump"])
            if _r.returncode != 0:                  # interface isn't up — flag it, but still surface its
                try:                                # intended config from the .conf (subnet/awg/port/pubkey)
                    conf_text = open(ic["conf"]).read()
                except OSError:
                    conf_text = ""
                _meta = build_meta([], conf_text, ic.get("endpoint_host") or node_cfg.get("endpoint_host"),
                                   node_cfg.get("dns", []), cmd)
                if iface in stopped_set:            # the operator stopped it — a choice, not a failure (no error)
                    interfaces[iface] = {"peers": [], "meta": _meta, "stopped": True}
                else:
                    interfaces[iface] = {"peers": [], "meta": _meta,
                        "down": ((_r.stderr or "").strip() or "interface is not up")[:140]}
                ensure_iface_backup(iface, conf_text, cmd)
                continue
            dump = _r.stdout
            iface_line, raw = parse_dump(dump)
            try:
                conf_text = open(ic["conf"]).read()
            except OSError:
                conf_text = ""
            st = last_samples.setdefault(iface, {"peers": {}, "t": now})
            dt = max(1e-6, now - st["t"])
            peers = peer_view(raw, st["peers"], dt, online_max, now)
            st["peers"] = {p["public_key"]: (p["rx_bytes"], p["tx_bytes"]) for p in raw}
            st["t"] = now
            interfaces[iface] = {
                "peers": peers,
                "meta": build_meta(iface_line, conf_text,
                                   ic.get("endpoint_host") or node_cfg.get("endpoint_host"),
                                   node_cfg.get("dns", []), cmd),
            }
            if iface in stopped_set:               # it's up again (e.g. brought up outside the panel) → clear the stopped mark
                _set_iface_stopped(iface, False)
            ensure_iface_backup(iface, conf_text, cmd)
        except Exception as e:
            print(f"snapshot: skipping {iface}: {e}", flush=True)
            continue
    _addrs = _node_addrs()                         # one `ip -o addr show`, shared by the three derived views below
    snap = {"hostname": socket.gethostname(), "generated_at": now,
            "interfaces": interfaces, "turn_proxies": load_turn_proxies(),
            "noded_version": NODED_VERSION, "kind": NODE_KIND, "net_mode": NODE_NET,
            "turn_manage": TURN_MANAGE, "cmd_errors": dict(NODE_ERRORS), "cmd_progress": dict(NODE_PROGRESS),
            "node_ips": list_node_ips(_addrs), "node_ifaces": list_node_ifaces(_addrs),
            "node_ip_ifaces": list_node_ip_ifaces(_addrs), "smartroute": smart_status()}
    if hcfg.get("enabled", True):      # additive + opt-out; mounts default to ["/"]
        snap["health"] = collect_health(mounts=hcfg.get("mounts"))
    snap["inet"] = sample_inet(node_cfg, now)   # measured internet up/down (B/s); cached, refreshed off the 5s path
    return snap


# ───────────────────────── reconcile ─────────────────────────

_UNSET = object()


def _iface_dump(node_cfg, iface):
    """One `<cmd> show <iface> dump` -> (iface_line, peers), or None if the interface can't be read (down /
    no such device). Lets a caller fetch the live interface ONCE and share it across current_pubkeys/
    current_allowed instead of shelling out per accessor every cycle."""
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    cmd = ic.get("cmd", ["awg"])
    try:
        r = run(cmd + ["show", iface, "dump"])
        if r.returncode != 0:
            return None
        return parse_dump(r.stdout)
    except Exception:
        return None


def current_pubkeys(node_cfg, iface, dump=_UNSET):
    if dump is _UNSET:                              # not pre-fetched → read it now
        dump = _iface_dump(node_cfg, iface)
    if dump is None:                               # interface down / no such device — NOT "zero peers"
        return None
    return {p["public_key"] for p in dump[1]}


def _norm_allowed(s):
    """Normalize an AllowedIPs string for comparison — sorted, deduped, whitespace-stripped CIDRs.
    (awg/wg may reorder the list, so a raw string compare would churn.)"""
    return ",".join(sorted({c.strip() for c in (s or "").split(",") if c.strip()}))


def current_allowed(node_cfg, iface, dump=_UNSET):
    """{pubkey -> normalized AllowedIPs} live on the interface, or None if it can't be read."""
    if dump is _UNSET:
        dump = _iface_dump(node_cfg, iface)
    if dump is None:
        return None
    return {p["public_key"]: _norm_allowed(p["allowed_ips"]) for p in dump[1]}


def current_listen_port(node_cfg, iface):
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    cmd = ic.get("cmd", ["awg"])
    try:
        r = run(cmd + ["show", iface, "dump"])
        if r.returncode == 0:
            iface_line, _ = parse_dump(r.stdout)
            if len(iface_line) > 2 and str(iface_line[2]).isdigit():
                return int(iface_line[2])
    except Exception:
        pass
    try:                                  # interface DOWN — fall back to the .conf so a port change still
        info = parse_interface_section(open(ic["conf"]).read())   # converges (set-iface persists it for next up)
        lp = str(info.get("ListenPort", "")).strip()
        return int(lp) if lp.isdigit() else None
    except Exception:
        return None


def current_awg(node_cfg, iface):
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    try:
        with open(ic["conf"]) as f:
            return awg_params(parse_interface_section(f.read()))
    except Exception:
        return None


def reconcile_ifaces(node_cfg, desired_ifaces, agent, sudo):
    """Apply the panel's desired interface config (listen port and/or AmneziaWG params). Only
    ever called on a valid sync reply; converges the live interface to the panel's target."""
    res = {"changed": 0, "errors": []}
    for iface, want in (desired_ifaces or {}).items():
        if iface not in (node_cfg.get("interfaces") or {}):
            continue
        payload = {"op": "set-iface", "iface": iface}
        port = want.get("listen_port")
        if port:
            cur = current_listen_port(node_cfg, iface)
            if cur is not None and int(cur) != int(port):
                payload["listen_port"] = int(port)
        awg = want.get("awg_params")
        if isinstance(awg, dict) and awg:
            cur_awg = current_awg(node_cfg, iface) or {}
            want_s = {k: str(v) for k, v in awg.items()}
            if any(str(cur_awg.get(k)) != v for k, v in want_s.items()):
                payload["awg_params"] = awg
        if len(payload) <= 2:                 # only op + iface — nothing differs
            continue
        r = run_agent(agent, sudo, payload)
        if r.get("ok"):
            res["changed"] += 1
        else:
            res["errors"].append(f"set-iface {iface}: {r.get('error')}")
    return res


def reconcile(node_cfg, desired_by_iface, agent, sudo, remove_by_iface=None):
    """Apply the panel's desired peer set. Only ever called on a valid sync reply."""
    res = {"added": 0, "removed": 0, "errors": []}
    remove_by_iface = remove_by_iface or {}
    # last DESIRED endpoint we pushed per peer — so an operator changing a node's ingress IP re-dials existing
    # links (the panel sends the new endpoint; we apply it once), without fighting WireGuard's roaming (we key
    # on the desired value, not the live/roamed one). iface|pubkey -> endpoint.
    EP_FILE = os.path.join(STATE_DIR, "mesh-eps.json")
    applied_ep = {}
    with contextlib.suppress(Exception):
        applied_ep = json.load(open(EP_FILE))
    ep_dirty = False
    for iface, ic in (node_cfg.get("interfaces") or {}).items():
        desired = {p["public_key"]: p for p in (desired_by_iface.get(iface) or [])}
        dump = _iface_dump(node_cfg, iface)         # read the live interface ONCE, shared by both accessors below
        current = current_pubkeys(node_cfg, iface, dump)
        if current is None:
            res["errors"].append(f"{iface}: cannot read interface")
            continue
        live_allowed = current_allowed(node_cfg, iface, dump) or {}   # for re-applying a CHANGED AllowedIPs (cascade /32→/0)
        # EXPLICIT retirements from the panel (a key it rotated/deleted) FIRST — removed even on an
        # add-only interface, and before the add below so the replacement key can take the freed IP.
        for pk in remove_by_iface.get(iface, []):
            if pk in current and pk not in desired:
                r = run_agent(agent, sudo, {"op": "remove-peer", "iface": iface, "public_key": pk})
                if r.get("ok"):
                    res["removed"] += 1; current.discard(pk)
                else:
                    res["errors"].append(f"retire {pk[:8]}: {r.get('error')}")
        for pk, p in desired.items():
            if pk in current:
                # already present — but its AllowedIPs may have CHANGED (cascade flips a mesh peer
                # /32 ↔ 0.0.0.0/0, or an exit gains a forwarded subnet). reconcile otherwise skips
                # present peers, so apply the diff surgically (this is risk R1).
                want_a = _norm_allowed(p.get("allowed_ips", ""))
                if want_a and live_allowed.get(pk) is not None and live_allowed[pk] != want_a:
                    r = run_agent(agent, sudo, {"op": "set-peer-allowed", "iface": iface,
                                                "public_key": pk, "allowed_ips": p.get("allowed_ips", "")})
                    if r.get("ok"):
                        res["added"] += 1                        # count as a change (drives the reconcile log)
                    else:
                        res["errors"].append(f"allowed {pk[:8]}: {r.get('error')}")
                # endpoint CHANGED (the peer's ingress IP/port was edited) → re-dial: re-assert the peer with
                # the new endpoint. Keyed on the desired value so this fires once per real change, not per roam.
                ek = iface + "|" + pk; want_ep = p.get("endpoint")
                if want_ep and applied_ep.get(ek) != want_ep:
                    r = run_agent(agent, sudo, {"op": "add-peer", "iface": iface, "public_key": pk,
                                                "allowed_ips": p.get("allowed_ips", ""),
                                                "preshared_key": p.get("preshared_key", "none"),
                                                "endpoint": want_ep,
                                                "persistent_keepalive": p.get("persistent_keepalive"),
                                                "name": p.get("name", "")})
                    if r.get("ok"):
                        applied_ep[ek] = want_ep; ep_dirty = True; res["added"] += 1
                    else:
                        res["errors"].append(f"endpoint {pk[:8]}: {r.get('error')}")
                continue
            r = run_agent(agent, sudo, {
                "op": "add-peer", "iface": iface, "public_key": pk,
                "allowed_ips": p.get("allowed_ips", ""),
                "preshared_key": p.get("preshared_key", "none"),
                "endpoint": p.get("endpoint"),                       # mesh peers dial out (user peers: None)
                "persistent_keepalive": p.get("persistent_keepalive"),
                "name": p.get("name", "")})
            if r.get("ok"):
                res["added"] += 1
                if p.get("endpoint"):
                    applied_ep[iface + "|" + pk] = p.get("endpoint"); ep_dirty = True
            else:
                res["errors"].append(f"add {pk[:8]}: {r.get('error')}")
        # An onboarded interface is ADD-ONLY: the panel never removes peers it didn't create, so an
        # interface adopted from another tool (e.g. wg-easy) keeps its existing peers. They surface
        # as adoptable orphans instead of being wiped.
        if ic.get("onboarded"):
            continue
        for pk in current - set(desired):
            r = run_agent(agent, sudo, {"op": "remove-peer", "iface": iface, "public_key": pk})
            if r.get("ok"):
                res["removed"] += 1
                applied_ep.pop(iface + "|" + pk, None); ep_dirty = True
            else:
                res["errors"].append(f"remove {pk[:8]}: {r.get('error')}")
    if ep_dirty:
        with contextlib.suppress(Exception):
            with open(EP_FILE + ".tmp", "w") as f:
                json.dump(applied_ep, f)
            os.replace(EP_FILE + ".tmp", EP_FILE)
    return res


def onboard_ifaces(node_cfg, onboard):
    """Add panel-requested interfaces to this node's managed set (config.json) when they exist
    locally — for a wg/awg interface the panel didn't auto-detect. Once added, build_snapshot
    reports it and the panel closes the request (no separate ack needed). Only ever on a 200."""
    res = {"added": [], "errors": []}
    if not onboard:
        return res
    ifaces = node_cfg.setdefault("interfaces", {})
    changed = False
    for iface, want in onboard.items():
        if iface in ifaces:                 # already managed — nothing to do (panel will clear it)
            continue
        cmd = want.get("cmd") or ["awg"]
        conf = want.get("conf") or ""
        try:
            if not conf or not os.path.exists(conf):
                res["errors"].append(f"{iface}: conf not found ({conf})"); continue
            if cmd == ["auto"]:                     # "Existing" gave no protocol — detect it from the conf
                info = parse_interface_section(open(conf).read())
                cmd = ["awg"] if any(k in info for k in AWG_KEYS) else ["wg"]
                try:
                    run(cmd + ["show", iface, "dump"])
                except Exception:
                    cmd = ["wg"] if cmd == ["awg"] else ["awg"]   # fall back to the other tool
            run(cmd + ["show", iface, "dump"])      # raises if the interface isn't actually up
        except Exception as e:
            res["errors"].append(f"{iface}: {e}"); continue
        ifaces[iface] = {"cmd": cmd, "conf": conf, "onboarded": True}   # add-only: never wipe its peers
        try:                                            # persist the marker in the conf so a docker restart
            with open(conf) as _f: _t = _f.read()       # (config.json rebuilt from confs) keeps it add-only
            if "#swg:onboarded" not in _t:
                with open(conf, "w") as _f: _f.write("#swg:onboarded\n" + _t)
        except OSError:
            pass
        changed = True
        res["added"].append(iface)
    if changed:
        try:
            _persist_config(node_cfg)
        except Exception as e:
            res["errors"].append(f"persist config.json: {e}")
    return res


def restart_ifaces(node_cfg, restart, agent, sudo):
    """Bounce panel-requested interfaces (<tool>-quick down/up) via swg-agent — recovers a DOWN one."""
    res = {"restarted": [], "errors": []}
    for iface in (restart or []):
        if iface not in (node_cfg.get("interfaces") or {}):
            continue
        r = run_agent(agent, sudo, {"op": "restart-iface", "iface": iface})
        if r.get("ok"):
            res["restarted"].append(iface); _set_iface_stopped(iface, False)   # a restart brings it back up
        else:
            res["errors"].append(f"{iface}: {r.get('error')}")
    return res


# interfaces the operator deliberately stopped from the panel → reported as "stopped" (not "down": it's a
# choice, not a failure). Persisted so it survives a daemon restart. Cleared when the interface is started.
IFACE_STOPPED_FILE = os.path.join(STATE_DIR, "iface-stopped.json")
def _load_stopped_ifaces():
    try:
        with open(IFACE_STOPPED_FILE) as f:
            v = json.load(f)
        return set(v) if isinstance(v, list) else set()
    except Exception:
        return set()
def _set_iface_stopped(iface, stopped):
    s = _load_stopped_ifaces()
    if (iface in s) == bool(stopped):
        return
    s.add(iface) if stopped else s.discard(iface)
    with contextlib.suppress(Exception):
        os.makedirs(STATE_DIR, exist_ok=True)
        tmp = IFACE_STOPPED_FILE + ".tmp"
        with open(tmp, "w") as f:
            json.dump(sorted(s), f)
        os.replace(tmp, IFACE_STOPPED_FILE)


def stop_ifaces(node_cfg, stop, agent, sudo):
    """Stop panel-requested interfaces (down + disable, conf kept) — they stay down until started again."""
    res = {"stopped": [], "errors": []}
    for iface in (stop or []):
        if iface not in (node_cfg.get("interfaces") or {}):
            continue
        r = run_agent(agent, sudo, {"op": "stop-iface", "iface": iface})
        if r.get("ok"):
            res["stopped"].append(iface); _set_iface_stopped(iface, True)   # mark as a deliberate stop, not a failure
        else:
            res["errors"].append(f"{iface}: {r.get('error')}")
    return res


def start_ifaces(node_cfg, start, agent, sudo):
    """Start panel-requested interfaces (up + enable)."""
    res = {"started": [], "errors": []}
    for iface in (start or []):
        if iface not in (node_cfg.get("interfaces") or {}):
            continue
        r = run_agent(agent, sudo, {"op": "start-iface", "iface": iface})
        if r.get("ok"):
            res["started"].append(iface); _set_iface_stopped(iface, False)   # no longer stopped
        else:
            res["errors"].append(f"{iface}: {r.get('error')}")
    return res


def apply_iface_keys(node_cfg, iface_key, agent, sudo):
    """Panel keypair requests per interface: 'rebaseline' overwrites the on-disk backup from the live
    conf (after an Adopt); 'restore' re-keys the interface from that backup + bounces it (a Restore)."""
    res = {"done": [], "errors": []}
    for iface, req in (iface_key or {}).items():
        ic = (node_cfg.get("interfaces") or {}).get(iface)
        if not ic:
            continue
        action = (req or {}).get("action")
        cmd = ic.get("cmd", ["awg"])
        try:
            if action == "rebaseline":
                conf_text = ""
                with contextlib.suppress(OSError):
                    conf_text = open(ic["conf"]).read()
                rec = harvest_iface_backup(conf_text, cmd) if conf_text else None
                if rec:
                    write_iface_backup(iface, rec); res["done"].append(iface)
            elif action == "restore":
                bak = read_iface_backup(iface)
                if not bak or not bak.get("private_key"):
                    res["errors"].append(iface + ": no keypair backup to restore from"); continue
                r = run_agent(agent, sudo, {"op": "restore-iface-key", "iface": iface, "conf": ic["conf"],
                                            "private_key": bak["private_key"], "listen_port": bak.get("listen_port"),
                                            "address": bak.get("address")})
                if r.get("ok"):
                    res["done"].append(iface)
                else:
                    res["errors"].append(iface + ": " + str(r.get("error")))
        except Exception as e:
            res["errors"].append(iface + ": " + str(e))
    return res


def _persist_config(node_cfg):
    tmp = CONFIG_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(node_cfg, f, indent=2)
    os.replace(tmp, CONFIG_PATH)


def create_ifaces(node_cfg, create, agent, sudo):
    """Create panel-requested BRAND-NEW interfaces via swg-agent (genkey + conf + auto-NAT + bring-up),
    then start managing them (config.json). Only on a valid sync. Bring-up runs live — verify on one
    node. Native datapath: kernel on a bare-metal node, container-userspace on a docker node."""
    res = {"created": [], "errors": []}
    if not create:
        return res
    ifaces = node_cfg.setdefault("interfaces", {})
    changed = False
    for iface, want in create.items():
        if iface in ifaces:                 # already created — nothing to do (panel clears it)
            continue
        cmd = want.get("cmd") or ["awg"]
        r = run_agent(agent, sudo, {"op": "create-iface", "iface": iface, "cmd": cmd,
                                    "subnet": want.get("subnet"), "listen_port": want.get("listen_port"),
                                    "address": want.get("address"),   # explicit addr (mesh /31 ends)
                                    "mtu": want.get("mtu")})
        if not r.get("ok"):
            res["errors"].append(f"{iface}: {r.get('error')}"); continue
        data = r.get("data") or {}
        conf = data.get("conf") or ""
        if not conf:
            res["errors"].append(f"{iface}: agent returned no conf path"); continue
        # the agent may have fallen back (e.g. wg→awg on a node with only amneziawg-go) — record the
        # tool it ACTUALLY used, or we'll later run the wrong CLI (`wg show`) and "can't read" it
        ifaces[iface] = {"cmd": data.get("cmd") or cmd, "conf": conf}
        changed = True
        res["created"].append(iface)
    if changed:
        try:
            _persist_config(node_cfg)
        except Exception as e:
            res["errors"].append(f"persist config.json: {e}")
    return res


def delete_ifaces(node_cfg, delete, agent, sudo):
    """Tear down panel-requested interfaces (down + remove conf via swg-agent) and stop managing them.
    Only on a valid sync. The panel clears the request once the iface stops appearing in snapshots."""
    res = {"deleted": [], "errors": []}
    if not delete:
        return res
    ifaces = node_cfg.get("interfaces") or {}
    changed = False
    for iface in list(delete):
        if iface not in ifaces:             # already gone — panel clears it when the snapshot lacks it
            continue
        r = run_agent(agent, sudo, {"op": "delete-iface", "iface": iface})
        if not r.get("ok"):
            res["errors"].append(f"{iface}: {r.get('error')}"); continue
        ifaces.pop(iface, None)
        changed = True
        res["deleted"].append(iface)
    if changed:
        try:
            _persist_config(node_cfg)
        except Exception as e:
            res["errors"].append(f"persist config.json: {e}")
    return res


# ── turn-proxy management (host systemd units) ──────────────────────────────────────────────────
# UNVERIFIED ON DOCKER: the bare-metal path edits units + systemctl directly; the docker path runs
# the same on the HOST via a privileged --pid=host helper through the mounted docker.sock (nsenter
# into PID 1). Test on a real node before relying on it. The socket = root-on-host (opt-in install).
HELPER_IMAGE = os.environ.get("HELPER_IMAGE") or "ghcr.io/sanityprotocol/swg-node:latest"
TURN_UNIT_DIR = "/etc/systemd/system"
TURN_MANAGE_ON = (NODE_KIND != "docker") or ((os.environ.get("TURN_MANAGE") or "manual").strip().lower() == "panel")
NODE_PROGRESS = {} # request key (iface name / turn service) -> transient "what's happening right now" line
                   # (e.g. a slow GitHub download retrying) → cmd_progress on the snapshot → yellow card note.
NODE_ERRORS = {}   # request key (iface name / turn service / .service path) -> last apply error, reported
                   # in the snapshot ("cmd_errors") so the panel can show WHY a host->node command failed

def host_sh(cmd, timeout=90):
    """Run a shell command on the HOST. Bare-metal: directly. Docker: via a one-shot privileged
    --pid=host helper through the mounted docker socket — nsenter into PID 1 so the command runs in
    the host's namespaces (its filesystem + systemd)."""
    if NODE_KIND != "docker":
        args = ["sh", "-c", cmd] if os.geteuid() == 0 else ["sudo", "-n", "sh", "-c", cmd]
    else:
        # --entrypoint nsenter is REQUIRED: the swg-node image's entrypoint is node-entrypoint.sh
        # (it demands PANEL_URL + sets up wg) — passing nsenter as the command alone still runs it.
        args = ["docker", "run", "--rm", "--privileged", "--pid=host", "--entrypoint", "nsenter",
                HELPER_IMAGE, "-t", "1", "-m", "-u", "-i", "-n", "-p", "--", "sh", "-c", cmd]
    try:
        r = run(args, timeout=timeout)
    except Exception as e:                              # e.g. 'docker' not found, or a timeout
        print("host_sh EXC: " + str(e) + " :: " + cmd[:160], flush=True)
        class _R:                                       # synthesize a failed result so callers see it
            returncode = 127; stdout = ""; stderr = str(e)
        return _R()
    if r.returncode != 0:
        print("host_sh rc=" + str(r.returncode) + " :: " + cmd[:160] + " :: " + (r.stderr or r.stdout or "")[:300], flush=True)
    return r

def _turn_unit_path(svc):
    return TURN_UNIT_DIR + "/" + svc + ".service"

def _exec_of(unit_text):
    for ln in unit_text.splitlines():
        if ln.startswith("ExecStart="):
            return ln[len("ExecStart="):]
    return ""

def _set_arg(execl, flag, value):
    """Replace '-flag <val>' (space- or =-separated) in the ExecStart, or append it."""
    pat = re.compile(r"(-" + re.escape(flag) + r")[ =]+\S+")
    if pat.search(execl):
        return pat.sub(lambda m: m.group(1) + " " + value, execl, count=1)
    return execl.rstrip() + " -" + flag + " " + value

def _strip_wrap(execl):
    """Remove the wrap key + the fork's wrap flag (-wrap / -wrap-srtp / -wrap-mode on)."""
    execl = re.sub(r"\s*-wrap-key[ =]+\S+", "", execl)
    execl = re.sub(r"\s*-wrap-mode[ =]+\S+", "", execl)
    execl = re.sub(r"\s*-wrap-srtp\b", "", execl)
    execl = re.sub(r"\s*-wrap\b", "", execl)
    return execl

def _exec_params(execl):
    """Everything after '-connect <ip:port>' in the ExecStart — the free-text extra flags (wrap etc.)."""
    m = re.search(r"-connect[ =]+\S+\s*(.*)$", execl)
    return (m.group(1).strip() if m else "")

def _parse_tp(svc, execl):
    def g(flag):
        m = re.search(r"-" + re.escape(flag) + r"[ =]+(\S+)", execl)
        return m.group(1) if m else ""
    return {"service": svc, "listen": g("listen"), "connect": g("connect"),
            "wrap_key": g("wrap-key"), "params": _exec_params(execl)}

def _installed_tp(svc):
    """Re-read a turn unit (after install/edit) so the record carries the real ExecStart, incl. the
    generated wrap key."""
    unit = host_sh("cat " + shlex.quote(_turn_unit_path(svc)) + " 2>/dev/null").stdout
    return _tp_from_unit(svc, unit)


# ───────── docker turn-proxies: sibling CONTAINERS (no host systemd, no --pid=host helper) ─────────
# A docker node runs each turn-proxy as its OWN container (swg-turn-<inst>, host networking) instead of
# editing host systemd through a privileged --pid=host nsenter helper. swg-noded fetches the fork binary
# into its host-mounted data dir and runs it in the swg-node image; a change = recreate the container
# (fast, no daemon-reload). TURN_RECORD is the source of truth for the config on a docker node.
SWG_HOST_NODE_DIR = (os.environ.get("SWG_HOST_NODE_DIR") or "").rstrip("/")   # host path mapped to /var/lib/swg-noded
SWG_TURN_IMAGE = os.environ.get("SWG_TURN_IMAGE") or ""                       # image used to run the turn binary
TURN_DOCKER = (NODE_KIND == "docker")

def _turn_inst(svc):  return svc[len("vk-turn-proxy-"):] if svc.startswith("vk-turn-proxy-") else svc
def _turn_fork(svc):  inst = _turn_inst(svc); return inst.rsplit("-", 1)[0] or inst   # <fork>-<port> → <fork> (handles hyphenated forks, e.g. WINGS-N)
def _turn_cname(svc): return "swg-turn-" + _turn_inst(svc)
# ONE binary per fork, not per instance: every WINGS-N-<port> instance shares …/turn/.bin/WINGS-N/server.
def _turn_bin_local(svc): return "/var/lib/swg-noded/turn/.bin/" + _turn_fork(svc) + "/server"   # inside swg-noded
def _turn_bin_host(svc):  return SWG_HOST_NODE_DIR + "/turn/.bin/" + _turn_fork(svc) + "/server"  # same file on the host (mounted into each instance's container)
def _turn_bin_local_legacy(svc): return "/var/lib/swg-noded/turn/" + _turn_inst(svc) + "/server"  # pre-dedup per-instance path (migrated on next download)
def _turn_fork_in_use(svc, rec):   # is any OTHER instance of this fork still in the record? (don't drop a shared binary others use)
    fork = _turn_fork(svc); items = rec.values() if isinstance(rec, dict) else (rec or [])
    return any(isinstance(tp, dict) and tp.get("service") and tp["service"] != svc and _turn_fork(tp["service"]) == fork for tp in items)

def _params_wrapkey(params):
    m = re.search(r"-wrap-key[ =]+(\S+)", params or ""); return m.group(1) if m else ""
def _params_set_wrapkey(params, key):
    params = params or ""
    if re.search(r"-wrap-key[ =]+\S+", params):
        return re.sub(r"-wrap-key[ =]+\S+", "-wrap-key " + key, params)
    return (params + " -wrap-key " + key).strip()

def _dturn_args(tp):
    args = ["-listen", tp.get("listen", ""), "-connect", tp.get("connect", "")]
    p = (tp.get("params") or "").strip()
    if p:
        try: args += shlex.split(p)
        except Exception: args += p.split()
    return args

def _turn_dl_urls(owner, arch):
    """GitHub release assets are single-origin (objects.githubusercontent.com). Try GitHub direct first, then
    any operator-configured proxy mirrors (SWG_TURN_MIRROR, space-separated prefixes — OPT-IN: proxying a binary
    you execute is a supply-chain trust decision, so it's off by default)."""
    base = "https://github.com/" + owner + "/releases/latest/download/server-linux-" + arch
    urls = [base]
    for m in (os.environ.get("SWG_TURN_MIRROR") or "").split():
        urls.append(m.rstrip("/") + "/" + base)   # e.g. https://ghproxy.example/https://github.com/<owner>/releases/...
    return urls

def _dturn_download(svc, owner):
    arch = "arm64" if os.uname().machine in ("aarch64", "arm64") else "amd64"
    binp = _turn_bin_local(svc)   # shared per-fork slot
    if os.path.exists(binp):       # already have this fork's binary (another instance, or a prior install) → REUSE,
        return ""                  # no GitHub hit. (A panel Reinstall removes binp first, so it still forces a fresh fetch.)
    try: os.makedirs(os.path.dirname(binp), exist_ok=True)
    except OSError as e: return "mkdir: " + str(e)
    leg = _turn_bin_local_legacy(svc)                    # upgrade: reuse a pre-dedup per-instance binary instead of re-downloading
    if os.path.exists(leg):
        with contextlib.suppress(OSError):
            os.replace(leg, binp); os.chmod(binp, 0o755)
        if os.path.exists(binp):
            _turn_write_version(svc, _turn_resolve_tag(owner)); return ""
    err = "binary download failed"
    for url in _turn_dl_urls(owner, arch):
        r = run(["curl", "-fsSL", "--connect-timeout", "20", "--max-time", "240", "--retry", "3",
                 "--retry-delay", "3", "--retry-all-errors", url, "-o", binp], timeout=320)
        if r.returncode == 0:
            with contextlib.suppress(OSError): os.chmod(binp, 0o755)
            _turn_write_version(svc, _turn_resolve_tag(owner))   # record which release tag we just fetched
            return ""
        err = (r.stderr or "binary download failed").strip()[:160]
    return err

def _dturn_force_download(svc, owner):
    """Reinstall/update: fetch the fork binary FRESH and atomically swap it in — WITHOUT ever unlinking the live
    shared file. A container bind-mounts this path (…:/turn-server); if it's momentarily missing when docker
    (re)creates a container, docker creates a *directory* there and everything breaks. So: temp + os.replace only."""
    arch = "arm64" if os.uname().machine in ("aarch64", "arm64") else "amd64"
    binp = _turn_bin_local(svc)
    try: os.makedirs(os.path.dirname(binp), exist_ok=True)
    except OSError as e: return "mkdir: " + str(e)
    tag = _turn_resolve_tag(owner)
    if tag and os.path.isfile(binp):                     # a sibling instance of this fork already refreshed the
        with contextlib.suppress(Exception):             # shared binary this round → reuse, don't re-download 22MB
            with open(_turn_ver_path(svc)) as f:
                if f.read().strip() == tag: return ""
    tmp = binp + ".new." + _turn_inst(svc)
    err = "binary download failed"
    for url in _turn_dl_urls(owner, arch):
        r = run(["curl", "-fsSL", "--connect-timeout", "20", "--max-time", "240", "--retry", "3",
                 "--retry-delay", "3", "--retry-all-errors", url, "-o", tmp], timeout=320)
        if r.returncode == 0:
            with contextlib.suppress(OSError): os.chmod(tmp, 0o755)
            try: os.replace(tmp, binp)                   # atomic: the path is a valid file at every instant
            except OSError as e:
                with contextlib.suppress(OSError): os.remove(tmp)
                return ("swap failed (is " + binp + " a directory? — docker bind-mount footgun): " + str(e))[:160]
            _turn_write_version(svc, tag)                # record which release tag we just fetched
            return ""
        err = (r.stderr or "binary download failed").strip()[:160]
    with contextlib.suppress(OSError): os.remove(tmp)
    return err

def _dturn_run(tp):   # (re)create the container to match tp; returns the docker-run CompletedProcess
    svc = tp["service"]; cn = _turn_cname(svc)
    run(["docker", "rm", "-f", cn], timeout=30)   # ignore errors (may not exist yet)
    return run(["docker", "run", "-d", "--name", cn, "--network", "host", "--restart", "unless-stopped",
                "-v", _turn_bin_host(svc) + ":/turn-server:ro", "--entrypoint", "/turn-server",
                SWG_TURN_IMAGE] + _dturn_args(tp), timeout=60)

def _dturn_verify(svc):
    time.sleep(1.5)
    r = run(["docker", "inspect", "-f", "{{.State.Running}}", _turn_cname(svc)])
    if (r.stdout or "").strip() == "true": return ""
    lg = run(["docker", "logs", "--tail", "5", _turn_cname(svc)])
    return ("turn container isn't running: " + ((lg.stderr or lg.stdout or "").strip() or "see docker logs"))[:160]

def _dturn_delete(svc, rec=None):
    run(["docker", "rm", "-f", _turn_cname(svc)], timeout=30)
    shutil.rmtree(os.path.dirname(_turn_bin_local_legacy(svc)), ignore_errors=True)   # old per-instance dir, if any
    if not _turn_fork_in_use(svc, rec):                  # last instance of this fork → drop the shared binary
        shutil.rmtree(os.path.dirname(_turn_bin_local(svc)), ignore_errors=True)

# ── turn-proxy VERSION/owner — sidecars next to the SHARED per-fork binary (one tag/owner per fork) ──
# docker: …/turn/.bin/<fork>/version.txt · bare: /opt/vk-turn-proxy/.bin/<fork>/version.txt + repo.txt.
# Reads fall back to the pre-dedup per-instance path so an un-migrated install still shows its version.
def _turn_ver_path(svc):
    if TURN_DOCKER:
        return os.path.join(os.path.dirname(_turn_bin_local(svc)), "version.txt")
    return "/opt/vk-turn-proxy/.bin/" + _turn_fork(svc) + "/version.txt"
def _turn_repo_path(svc):    # owner repo (fallback if a reinstall req lacks owner)
    if TURN_DOCKER:
        return os.path.join(os.path.dirname(_turn_bin_local(svc)), "repo.txt")
    return "/opt/vk-turn-proxy/.bin/" + _turn_fork(svc) + "/repo.txt"
def _turn_ver_path_legacy(svc):
    if TURN_DOCKER:
        return "/var/lib/swg-noded/turn/" + _turn_inst(svc) + "/version.txt"
    return "/opt/vk-turn-proxy/" + _turn_inst(svc) + "/version.txt"
def _turn_repo_path_legacy(svc):
    return "/opt/vk-turn-proxy/" + _turn_inst(svc) + "/repo.txt"
def _turn_version(svc):
    for p in (_turn_ver_path(svc), _turn_ver_path_legacy(svc)):
        try:
            with open(p) as f:
                return f.read().strip()[:40]
        except Exception:
            pass
    return ""
def _turn_write_version(svc, tag):
    if not tag:
        return
    p = _turn_ver_path(svc)
    try:
        os.makedirs(os.path.dirname(p), exist_ok=True)
        with open(p, "w") as f:
            f.write(tag.strip()[:40])
        with contextlib.suppress(OSError): os.chmod(p, 0o644)
    except OSError:
        pass
def _turn_resolve_tag(owner):
    """Latest release tag, read from the 302 of releases/latest/download (no API → no rate limit)."""
    if not owner:
        return ""
    arch = "arm64" if os.uname().machine in ("aarch64", "arm64") else "amd64"
    url = "https://github.com/" + owner + "/releases/latest/download/server-linux-" + arch
    r = run(["curl", "-fsS", "-o", "/dev/null", "-w", "%{redirect_url}",
             "--connect-timeout", "15", "--max-time", "30", url], timeout=40)
    m = re.search(r"/releases/download/([^/]+)/", r.stdout or "")
    return m.group(1) if m else ""
def _attach_turn_version(tps):
    for t in tps:
        if t.get("service"):
            t["version"] = _turn_version(t["service"])

def _dturn_install(svc, req):   # returns (err, tp_record_or_None)
    owner = (req.get("owner") or "").strip(); listen = (req.get("listen") or "").strip()
    connect = (req.get("connect") or "").strip(); wrap_flags = (req.get("wrap_flags") or "").strip()
    if "/" not in owner or ":" not in listen or ":" not in connect: return "bad install request", None
    if not SWG_TURN_IMAGE or not SWG_HOST_NODE_DIR:
        return "turn-on-docker not configured (re-install the node with turn management on)", None
    if "params" in req:   # explicit ExecStart tail from the create form (verbatim, including its wrap key)
        params = (req.get("params") or "").strip()
    else:                 # legacy: build from the fork's wrap flags + a generated key
        params = (wrap_flags + " -wrap-key " + secrets.token_hex(32)) if wrap_flags else ""
    err = _dturn_download(svc, owner)
    if err: return err, None
    tp = {"service": svc, "listen": listen, "connect": connect,
          "wrap_key": _params_wrapkey(params), "params": params, "owner": owner}
    _ti = (req.get("title") or "").strip()
    if _ti: tp["title"] = _ti          # optional display label, kept on the record
    r = _dturn_run(tp)
    if r.returncode != 0: return (r.stderr or "container start failed").strip()[:160], None
    verr = _dturn_verify(svc)
    return (verr, tp)   # keep the record even if down, so the panel shows it (greyed)

_DTURN_RUN = {"at": 0.0, "set": set()}
_TURN_INSTALLING = set()   # services whose container is being downloaded/(re)created RIGHT NOW → "installing"
_TURN_FAILED = set()       # services whose last install/run attempt errored → "install failed" on the panel
_TURN_ATTEMPTS = {}        # svc -> consecutive failed-download count; the bg reconcile STOPS retrying after
TURN_MAX_ATTEMPTS = 4      # this many (so a stuck 502/timeout becomes "install failed", not an endless "installing"). A manual Reinstall resets it.
# Async reinstall/update: the binary download + restart runs in a daemon thread so the sync loop STAYS RESPONSIVE
# and keeps posting snapshots — the panel sees the proxy as "updating" for the whole download (a synchronous
# reinstall blocks the loop, so the card can only jump pending→updated). apply_turn keeps the request in-flight
# (no "done" reported → turn_pending stays) while the job runs, then reports the result once it finishes.
_TURN_JOBS = {}            # svc -> {"done": bool, "err": str, "tp": dict, "at": ts}
_TURN_JOBS_LOCK = threading.Lock()
def _turn_job_launch(svc, tp, work):
    """Run work() (returns an error string, "" == success) in a daemon thread; mark the job done when it returns."""
    def _run():
        err = ""
        try:
            err = work() or ""
        except Exception as e:
            err = str(e)[:140]
        with _TURN_JOBS_LOCK:
            if svc in _TURN_JOBS:
                _TURN_JOBS[svc].update(done=True, err=err)
    with _TURN_JOBS_LOCK:
        _TURN_JOBS[svc] = {"done": False, "err": "", "tp": tp, "at": time.time()}
    threading.Thread(target=_run, daemon=True).start()

# Instances of the SAME fork share one binary (…/.bin/<fork>/server). Two reinstalls of that fork would race on the
# shared download temp / removal → "server.new: No such file" and half-updated units. Serialise per fork so the
# shared binary is refreshed by one job at a time; same-fork jobs simply queue (their cards stay "updating" while waiting).
_TURN_FORK_LOCKS = {}
_TURN_FORK_LOCKS_GUARD = threading.Lock()
def _turn_fork_lock(fork):
    with _TURN_FORK_LOCKS_GUARD:
        return _TURN_FORK_LOCKS.setdefault(fork or "", threading.Lock())
def _dturn_attach_running(tps):
    nowt = time.time()
    if nowt - _DTURN_RUN["at"] >= 15:
        r = run(["docker", "ps", "--filter", "name=swg-turn-", "--format", "{{.Names}}"])
        _DTURN_RUN["set"] = set((r.stdout or "").split()); _DTURN_RUN["at"] = nowt
    for t in tps:
        if t.get("service"):
            svc = t["service"]
            t["running"] = _turn_cname(svc) in _DTURN_RUN["set"]
            stopped = bool(t.get("stopped"))
            active = svc in _TURN_INSTALLING   # being downloaded / (re)created RIGHT NOW (only one at a time)
            failed = (svc in _TURN_FAILED) and not t["running"] and not stopped
            t["failed"] = failed
            # docker: only the proxy the bg reconcile is working on right now is "installing"; the others not
            # yet up (and not failed/stopped) are "pending" — queued for the sequential reconcile, not stuck.
            t["installing"] = active and not stopped
            t["pending"] = (not t["running"]) and (not failed) and (not stopped) and (not active)

def _dturn_ensure(tp):   # make the container match the record entry (download binary if missing, run if not up)
    svc = tp.get("service")
    if not svc:
        return
    if tp.get("stopped"):   # intentionally stopped from the panel → don't auto-(re)start it
        _TURN_INSTALLING.discard(svc)
        return
    r = run(["docker", "inspect", "-f", "{{.State.Running}}", _turn_cname(svc)])
    if (r.stdout or "").strip() == "true":
        _TURN_INSTALLING.discard(svc); _TURN_FAILED.discard(svc); _TURN_ATTEMPTS.pop(svc, None); NODE_PROGRESS.pop(svc, None)
        return
    if _TURN_ATTEMPTS.get(svc, 0) >= TURN_MAX_ATTEMPTS and not os.path.exists(_turn_bin_local(svc)):
        _TURN_FAILED.add(svc); _TURN_INSTALLING.discard(svc); NODE_PROGRESS.pop(svc, None)   # given up — "install failed" (a manual Reinstall resets the counter)
        return
    _TURN_INSTALLING.add(svc)   # downloading / (re)creating now → the panel shows it as "installing"
    try:
        if not os.path.exists(_turn_bin_local(svc)) and tp.get("owner"):
            NODE_PROGRESS[svc] = "Downloading the turn-proxy binary from GitHub — this can take a minute…"
            derr = _dturn_download(svc, tp["owner"])
            if derr:
                _TURN_ATTEMPTS[svc] = _TURN_ATTEMPTS.get(svc, 0) + 1
                # NON-terminating: keep retrying every pass, but tell the operator WHY it's slow so it doesn't look hung.
                NODE_PROGRESS[svc] = ("GitHub download failed (attempt %d/%d): %s. Still retrying — please wait for the install to finish."
                                       % (_TURN_ATTEMPTS[svc], TURN_MAX_ATTEMPTS, derr))
                print("swg-noded: turn %s binary download failed (attempt %d/%d): %s" % (svc, _TURN_ATTEMPTS[svc], TURN_MAX_ATTEMPTS, derr), flush=True)
        if not os.path.exists(_turn_bin_local(svc)):   # no binary yet
            if _TURN_ATTEMPTS.get(svc, 0) >= TURN_MAX_ATTEMPTS:   # stop the endless "installing" → mark failed + report it
                _TURN_FAILED.add(svc); NODE_PROGRESS.pop(svc, None)
                NODE_ERRORS[svc] = "binary download failed after %d attempts — Reinstall to retry" % TURN_MAX_ATTEMPTS
                print("swg-noded: turn %s — gave up after %d download attempts; Reinstall from the panel to retry" % (svc, TURN_MAX_ATTEMPTS), flush=True)
            else:
                print("swg-noded: turn %s has no binary yet — will retry on the next pass" % svc, flush=True)
            return
        _TURN_ATTEMPTS.pop(svc, None); NODE_ERRORS.pop(svc, None)   # got the binary → clear any prior failure
        NODE_PROGRESS[svc] = "Binary downloaded — starting the container…"
        rr = _dturn_run(tp)
        if rr.returncode != 0:
            _TURN_FAILED.add(svc); NODE_PROGRESS.pop(svc, None)
            print("swg-noded: turn %s 'docker run' failed: %s" % (svc, (rr.stderr or rr.stdout or "").strip()[:200]), flush=True)
            return
        verr = _dturn_verify(svc)
        if verr:
            _TURN_FAILED.add(svc); NODE_PROGRESS.pop(svc, None)
            print("swg-noded: turn %s started but didn't stay up: %s" % (svc, verr), flush=True)
        else:
            _TURN_FAILED.discard(svc); NODE_PROGRESS.pop(svc, None)
            print("swg-noded: turn %s container (re)started (%s)" % (svc, _turn_cname(svc)), flush=True)
    finally:
        _TURN_INSTALLING.discard(svc)

def _dturn_reconcile():   # startup/periodic: ensure every recorded turn-proxy has a running container
    if not TURN_DOCKER:
        return
    tps = load_turn_proxies()
    if not tps:
        return
    if not (SWG_TURN_IMAGE and SWG_HOST_NODE_DIR):   # the #1 silent failure — say so loudly
        print("swg-noded: %d turn-proxy record(s) present but turn-on-docker isn't configured "
              "(SWG_TURN_IMAGE=%r SWG_HOST_NODE_DIR=%r) — re-install the node with turn management ON"
              % (len(tps), SWG_TURN_IMAGE, SWG_HOST_NODE_DIR), flush=True)
        return
    for tp in tps:
        try:
            _dturn_ensure(tp)
        except Exception as e:
            print("swg-noded: turn reconcile %s failed: %s" % (tp.get("service"), e), flush=True)

def _dturn_bg_loop():   # background thread: keep turn-proxy containers up WITHOUT blocking the sync loop, so the
    while True:         # node appears on the panel right away and the cards fill in (installing → up) as each starts
        try:
            _dturn_reconcile()
        except Exception as e:
            print("swg-noded: turn reconcile error: %s" % e, flush=True)
        time.sleep(30)


# ───────── bare-metal turn-proxies: systemd unit + EnvironmentFile (edit = rewrite env, NO daemon-reload) ─────────
# The connect/listen/params live in a turn.env next to the binary; ExecStart references them as ${SWG_…}.
# Editing a turn-proxy then only rewrites turn.env + `systemctl restart` — systemd re-parsing EVERY unit
# (daemon-reload) was the CPU spike. Old units (values baked into ExecStart) are migrated on first edit.
def _turn_env_path(svc): return "/opt/vk-turn-proxy/" + _turn_inst(svc) + "/turn.env"
def _turn_env_text(listen, connect, params):
    return "SWG_LISTEN=%s\nSWG_CONNECT=%s\nSWG_PARAMS=%s\n" % (listen, connect, (params or "").strip())
def _exec_bin(execl):
    try: return shlex.split(execl)[0]
    except Exception: return (execl.split() or [""])[0]
def _unit_is_envform(unit_text): return "${SWG_" in _exec_of(unit_text)

def _tp_from_unit(svc, unit_text):
    """Resolve a turn-proxy's config from its unit. EnvironmentFile form → read turn.env; old form → ExecStart."""
    if not _unit_is_envform(unit_text):
        return _parse_tp(svc, _exec_of(unit_text))
    env = host_sh("cat " + shlex.quote(_turn_env_path(svc)) + " 2>/dev/null").stdout or ""
    vals = {}
    for ln in env.splitlines():
        k, _, v = ln.partition("="); vals[k.strip()] = v.strip()
    params = vals.get("SWG_PARAMS", "")
    return {"service": svc, "listen": vals.get("SWG_LISTEN", ""), "connect": vals.get("SWG_CONNECT", ""),
            "wrap_key": _params_wrapkey(params), "params": params}

def _unit_to_envform(unit_text, svc, binp):
    """Rewrite a baked-ExecStart unit to the EnvironmentFile form (one-time migration)."""
    envp = _turn_env_path(svc); out = []; have_ef = any(l.startswith("EnvironmentFile=") for l in unit_text.splitlines())
    for l in unit_text.splitlines():
        if l.startswith("ExecStart="):
            if not have_ef: out.append("EnvironmentFile=-" + envp)
            out.append("ExecStart=" + binp + " -listen ${SWG_LISTEN} -connect ${SWG_CONNECT} $SWG_PARAMS")
        elif l.startswith("EnvironmentFile="):
            out.append("EnvironmentFile=-" + envp)
        else:
            out.append(l)
    return "\n".join(out) + "\n"

def _turn_install(svc, req):
    """Install a new turn-proxy: download the fork's prebuilt binary, write the systemd unit, enable
    it. Mirrors the installer's install_turn_binary (server-linux-<arch>). '' on success, else error."""
    owner = (req.get("owner") or "").strip()
    listen = (req.get("listen") or "").strip()
    connect = (req.get("connect") or "").strip()
    wrap_flags = (req.get("wrap_flags") or "").strip()
    if "/" not in owner or ":" not in listen or ":" not in connect:
        return "bad install request"
    inst = svc[len("vk-turn-proxy-"):] if svc.startswith("vk-turn-proxy-") else svc
    fork = _turn_fork(svc)
    fdir = "/opt/vk-turn-proxy/.bin/" + fork   # shared per-fork: one binary + version.txt + repo.txt for every instance
    sbin = fdir + "/server"
    d = "/opt/vk-turn-proxy/" + inst           # per-instance: turn.env + a 'server' symlink → the shared binary
    binp = d + "/server"
    arch = "arm64" if os.uname().machine in ("aarch64", "arm64") else "amd64"
    extra = ""
    if "params" in req:   # explicit ExecStart tail from the create form (verbatim, including its wrap key)
        extra = (req.get("params") or "").strip()
    elif wrap_flags:
        key = secrets.token_hex(32)   # 64 hex chars, no openssl dependency (the slim image lacks it)
        if not key:
            return "keygen failed"
        extra = wrap_flags + " -wrap-key " + key
    envp = _turn_env_path(svc)
    unit = ("[Unit]\nDescription=vk-turn-proxy (" + owner + ") - " + listen + " -> " + connect + "\n"
            "After=network-online.target\nWants=network-online.target\n\n"
            "[Service]\nEnvironmentFile=-" + envp + "\n"
            "ExecStart=" + binp + " -listen ${SWG_LISTEN} -connect ${SWG_CONNECT} $SWG_PARAMS\n"
            "Restart=on-failure\nRestartSec=3\n\n"
            "[Install]\nWantedBy=multi-user.target\n")
    tag = _turn_resolve_tag(owner)
    dl = " || ".join("curl -fsSL --connect-timeout 20 --max-time 240 --retry 3 --retry-delay 3 --retry-all-errors "
                     + shlex.quote(u) + " -o " + shlex.quote(sbin) for u in _turn_dl_urls(owner, arch))
    cmd = ("mkdir -p " + shlex.quote(fdir) + " " + shlex.quote(d)
           + " && { [ -x " + shlex.quote(sbin) + " ] || { " + dl + "; }; } && chmod 755 " + shlex.quote(sbin)   # reuse this fork's binary if already downloaded
           + " && ln -sfn " + shlex.quote("../.bin/" + fork + "/server") + " " + shlex.quote(binp)
           + " && printf %s " + shlex.quote(owner) + " > " + shlex.quote(fdir + "/repo.txt")
           + ((" && printf %s " + shlex.quote(tag) + " > " + shlex.quote(fdir + "/version.txt")) if tag else "")
           + " && cat > " + shlex.quote(envp) + " <<'SWGENV'\n" + _turn_env_text(listen, connect, extra) + "SWGENV\n"
           + "cat > " + shlex.quote(_turn_unit_path(svc)) + " <<'SWGEOF'\n" + unit + "SWGEOF\n"
           + "systemctl daemon-reload && systemctl enable --now " + shlex.quote(svc) + " >/dev/null 2>&1")
    w = host_sh(cmd, timeout=210)
    if w.returncode != 0:
        return (w.stderr or w.stdout or "install failed").strip()[:160]
    return _turn_verify(svc)   # enable --now returns 0 even if the binary crash-loops — confirm it stays up

def _turn_verify(svc):
    """Confirm a turn-proxy service is actually running after install/edit. enable/restart returns 0 as
    soon as the binary is exec'd, so a crash-loop (e.g. a -listen IP not local to the host → bind fails)
    looks like success — this catches it + returns the journal reason so the panel can show it."""
    v = host_sh("sleep 1.5; systemctl is-active " + shlex.quote(svc) + " 2>/dev/null; "
                "journalctl -u " + shlex.quote(svc) + " -n 5 --no-pager -o cat 2>/dev/null | grep -iE 'error|invalid|fail|bind|address|panic' | tail -1")
    lines = (v.stdout or "").strip().splitlines()
    if lines and lines[0] == "active":
        return ""
    reason = lines[-1] if len(lines) > 1 else "not running (check the -listen IP is an address on this host)"
    return "service didn't stay up: " + reason[:150]

def apply_turn(turn, turn_onboard):
    """Apply panel turn-proxy requests (manage/rotate/delete) + onboard host .service units, then
    update the turn record so the snapshot reflects it (which clears the panel request)."""
    res = {"done": [], "errors": []}
    if not turn and not turn_onboard:
        return res
    keys = set(turn or {}) | set(turn_onboard or [])
    print("turn: applying " + str(sorted(keys)) + " manage_on=" + str(TURN_MANAGE_ON)
          + " kind=" + NODE_KIND, flush=True)
    def fail(k, m):
        res["errors"].append(k + ": " + m); NODE_ERRORS[k] = m
        print("turn: FAIL " + k + " -> " + m, flush=True)
    def good(k, tag):
        res["done"].append(tag); NODE_ERRORS.pop(k, None)
        print("turn: ok " + tag, flush=True)
    if not TURN_MANAGE_ON:
        for k in keys:
            fail(k, "turn management off — re-install the docker node with the 'panel' option")
        return res
    rec = {tp.get("service"): tp for tp in load_turn_proxies() if tp.get("service")}
    changed = False
    for svc, req in (turn or {}).items():
        try:
            act = req.get("action")
            if TURN_DOCKER:                                   # ── container model ──
                if act == "install":
                    err, tp = _dturn_install(svc, req)
                    if tp is not None: rec[svc] = tp; changed = True
                    fail(svc, err) if err else good(svc, "ins:" + svc)
                    continue
                if act == "delete":
                    _dturn_delete(svc, rec); rec.pop(svc, None); changed = True; good(svc, "del:" + svc); continue
                if act == "reinstall":      # force a fresh binary (fix a failed download / update to latest) + (re)create — ASYNC (see _TURN_JOBS)
                    with _TURN_JOBS_LOCK: _job = dict(_TURN_JOBS.get(svc) or {})
                    if _job and not _job.get("done"):
                        continue                            # still downloading/recreating → keep it in-flight (card stays "updating")
                    if _job and _job.get("done"):           # thread finished → report the result + clear the job
                        with _TURN_JOBS_LOCK: _TURN_JOBS.pop(svc, None)
                        NODE_PROGRESS.pop(svc, None); _TURN_INSTALLING.discard(svc)
                        if _job.get("err"):
                            _TURN_FAILED.add(svc); fail(svc, _job["err"])
                        else:
                            rec[svc] = _job.get("tp") or rec.get(svc); changed = True; _TURN_FAILED.discard(svc); good(svc, "rei:" + svc)
                        continue
                    tp = rec.get(svc) or {"service": svc, "listen": req.get("listen", ""), "connect": req.get("connect", ""), "params": req.get("params", "")}
                    if req.get("owner"): tp["owner"] = req["owner"].strip()
                    if not tp.get("owner"):
                        fail(svc, "no owner repo for reinstall"); continue
                    _TURN_ATTEMPTS.pop(svc, None)   # manual retry → clear the give-up counter so the bg reconcile resumes if this one also fails
                    _TURN_INSTALLING.add(svc)       # mark "installing/updating" for the docker card (attach_running keys off this set,
                                                    # overriding load_turn_proxies' job flag) — cleared in the done handler below
                    def _work(svc=svc, tp=tp):      # runs in a thread — download fresh + (re)create the container
                        with _turn_fork_lock(_turn_fork(svc)):   # serialise same-fork refreshes; atomic-swap the shared binary
                            with contextlib.suppress(OSError): os.remove(_turn_bin_local_legacy(svc))   # drop a stale pre-dedup copy
                            derr = _dturn_force_download(svc, tp["owner"])
                        if derr: return derr
                        r = _dturn_run(tp)
                        if r.returncode != 0: return (r.stderr or "container start failed").strip()[:120]
                        return _dturn_verify(svc)
                    _turn_job_launch(svc, tp, _work)
                    continue                                 # in flight now — don't report done yet (card shows "updating")
                if act == "title":            # cosmetic label only → update the record, DON'T touch the container
                    tp = rec.get(svc)
                    if not tp:
                        fail(svc, "turn-proxy not in the node record"); continue
                    tp["title"] = (req.get("title") or "").strip(); rec[svc] = tp; changed = True
                    good(svc, "title:" + svc); continue
                if act == "stop":             # stop + remove the container; the 'stopped' flag keeps the bg reconcile from restarting it
                    tp = rec.get(svc)
                    if not tp:
                        fail(svc, "turn-proxy not in the node record"); continue
                    run(["docker", "rm", "-f", _turn_cname(svc)])
                    tp["stopped"] = True; rec[svc] = tp; changed = True
                    _TURN_INSTALLING.discard(svc); _TURN_FAILED.discard(svc); _TURN_ATTEMPTS.pop(svc, None); NODE_PROGRESS.pop(svc, None)
                    good(svc, "stop:" + svc); continue
                if act == "start":            # clear 'stopped' + (re)create the container
                    tp = rec.get(svc)
                    if not tp:
                        fail(svc, "turn-proxy not in the node record"); continue
                    tp.pop("stopped", None); rec[svc] = tp; changed = True
                    r = _dturn_run(tp)
                    if r.returncode != 0:
                        _TURN_FAILED.add(svc); fail(svc, (r.stderr or "container start failed").strip()[:120]); continue
                    verr = _dturn_verify(svc)
                    fail(svc, verr) if verr else good(svc, "start:" + svc)
                    continue
                tp = rec.get(svc)
                if not tp:
                    fail(svc, "turn-proxy not in the node record"); continue
                if act == "manage":
                    if req.get("listen"):  tp["listen"] = req["listen"].strip()
                    if req.get("connect"): tp["connect"] = req["connect"].strip()
                    if "params" in req:    tp["params"] = (req.get("params") or "").strip(); tp["wrap_key"] = _params_wrapkey(tp["params"])
                    if "title" in req:     tp["title"] = (req.get("title") or "").strip()
                elif act == "rotate":
                    nk = secrets.token_hex(32); tp["params"] = _params_set_wrapkey(tp.get("params", ""), nk); tp["wrap_key"] = nk
                # restart: no config change — just recreate the container
                r = _dturn_run(tp)
                if r.returncode != 0:
                    fail(svc, (r.stderr or "container start failed").strip()[:120]); continue
                rec[svc] = tp; changed = True
                verr = _dturn_verify(svc)
                fail(svc, verr) if verr else good(svc, act + ":" + svc)
                continue
            up = _turn_unit_path(svc)                          # ── bare-metal systemd model ──
            if act == "install":
                err = _turn_install(svc, req)
                if err:
                    fail(svc, err)
                else:
                    rec[svc] = _installed_tp(svc)
                    _ti = (req.get("title") or "").strip()
                    if _ti: rec[svc]["title"] = _ti
                    changed = True; good(svc, "ins:" + svc)
                continue
            if act == "delete":
                w = host_sh("systemctl disable --now " + shlex.quote(svc) + " >/dev/null 2>&1; "
                            "rm -f " + shlex.quote(up) + "; systemctl daemon-reload")
                if w.returncode != 0:
                    fail(svc, (w.stderr or "remove failed").strip()[:120]); continue
                rec.pop(svc, None); changed = True; good(svc, "del:" + svc); continue
            if act == "reinstall":          # re-download the binary (fix/update) + restart the unit — ASYNC (see _TURN_JOBS)
                with _TURN_JOBS_LOCK: _job = dict(_TURN_JOBS.get(svc) or {})
                if _job and not _job.get("done"):
                    continue                                 # download/restart running → keep in-flight (card "updating")
                if _job and _job.get("done"):
                    with _TURN_JOBS_LOCK: _TURN_JOBS.pop(svc, None)
                    NODE_PROGRESS.pop(svc, None)
                    fail(svc, _job["err"]) if _job.get("err") else good(svc, "rei:" + svc)
                    continue
                owner = (req.get("owner") or "").strip()
                if not owner:               # fall back to the recorded repo.txt (shared fork dir, then pre-dedup per-instance)
                    for rp in (_turn_repo_path(svc), _turn_repo_path_legacy(svc)):
                        try:
                            with open(rp) as f: owner = f.read().strip()
                        except Exception: owner = ""
                        if owner: break
                if not owner:
                    fail(svc, "no owner repo for reinstall"); continue
                arch = "arm64" if os.uname().machine in ("aarch64", "arm64") else "amd64"
                fork = _turn_fork(svc)
                sbin = "/opt/vk-turn-proxy/.bin/" + fork + "/server"          # shared per-fork binary (a reinstall refreshes it for every instance of the fork)
                binp = "/opt/vk-turn-proxy/" + _turn_inst(svc) + "/server"    # this instance's symlink → the shared binary
                tag = _turn_resolve_tag(owner); vp = _turn_ver_path(svc)
                tmp = sbin + ".new." + _turn_inst(svc)   # per-instance temp then atomically mv over the LIVE binary — curl -o onto a
                dl = " || ".join("curl -fsSL --connect-timeout 20 --max-time 240 --retry 3 --retry-delay 3 --retry-all-errors "   # running executable fails ETXTBSY ("Failure
                                 + shlex.quote(u) + " -o " + shlex.quote(tmp) for u in _turn_dl_urls(owner, arch))          # writing output"); rename keeps the old
                cmd = ("mkdir -p " + shlex.quote(os.path.dirname(sbin)) + " " + shlex.quote(os.path.dirname(binp))          # inode for the running proc until restart.
                       + " && ( " + dl + " ) && chmod 755 " + shlex.quote(tmp) + " && mv -f " + shlex.quote(tmp) + " " + shlex.quote(sbin)
                       + " && ln -sfn " + shlex.quote("../.bin/" + fork + "/server") + " " + shlex.quote(binp)
                       + " && printf %s " + shlex.quote(owner) + " > " + shlex.quote(_turn_repo_path(svc)))
                if tag:
                    cmd += " && printf %s " + shlex.quote(tag) + " > " + shlex.quote(vp) + " && chmod 644 " + shlex.quote(vp)
                cmd += " && systemctl restart " + shlex.quote(svc)
                def _work(cmd=cmd, svc=svc, fork=fork):    # runs in a thread; serialise same-fork refreshes on the shared binary
                    with _turn_fork_lock(fork):
                        w = host_sh(cmd, timeout=340)
                    if w.returncode != 0: return (w.stderr or "reinstall failed").strip()[:140]
                    return _turn_verify(svc)
                _turn_job_launch(svc, rec.get(svc), _work)
                continue
            if act == "title":                # cosmetic label only → update the record, DON'T restart the unit
                tp = rec.get(svc)
                if not tp:
                    fail(svc, "turn-proxy not in the node record"); continue
                tp["title"] = (req.get("title") or "").strip(); rec[svc] = tp; changed = True
                good(svc, "title:" + svc); continue
            if act == "stop":                 # stop + disable the unit; 'stopped' flag distinguishes it from a crash
                tp = rec.get(svc)
                if not tp:
                    fail(svc, "turn-proxy not in the node record"); continue
                host_sh("systemctl disable --now " + shlex.quote(svc) + " >/dev/null 2>&1; systemctl stop " + shlex.quote(svc) + " >/dev/null 2>&1; true")
                tp["stopped"] = True; rec[svc] = tp; changed = True; good(svc, "stop:" + svc); continue
            if act == "start":                # re-enable + start the unit
                tp = rec.get(svc)
                if not tp:
                    fail(svc, "turn-proxy not in the node record"); continue
                w = host_sh("systemctl enable --now " + shlex.quote(svc))
                if w.returncode != 0:
                    fail(svc, (w.stderr or "start failed").strip()[:120]); continue
                tp.pop("stopped", None); rec[svc] = tp; changed = True
                verr = _turn_verify(svc)
                fail(svc, verr) if verr else good(svc, "start:" + svc)
                continue
            unit = host_sh("cat " + shlex.quote(up) + " 2>/dev/null").stdout
            if not unit:
                fail(svc, "unit not found on the node"); continue
            cur = _tp_from_unit(svc, unit)   # resolves env-file or old baked-ExecStart units
            listen, connect, params = cur.get("listen", ""), cur.get("connect", ""), cur.get("params", "")
            if act == "manage":
                if req.get("listen"):  listen = req["listen"].strip()
                if req.get("connect"): connect = req["connect"].strip()
                if "params" in req:    params = (req.get("params") or "").strip()
            elif act == "rotate":
                params = _params_set_wrapkey(params, secrets.token_hex(32))
            # restart: no config change — just rewrite turn.env (unchanged) + restart below
            envp = _turn_env_path(svc)
            env_here = "cat > " + shlex.quote(envp) + " <<'SWGENV'\n" + _turn_env_text(listen, connect, params) + "SWGENV\n"
            if _unit_is_envform(unit):       # fast path: rewrite turn.env + restart, NO daemon-reload (the spike)
                w = host_sh(env_here + "systemctl restart " + shlex.quote(svc))
            else:                            # one-time migrate: move the baked ExecStart onto the EnvironmentFile
                new_unit = _unit_to_envform(unit, svc, _exec_bin(_exec_of(unit)))
                w = host_sh("mkdir -p " + shlex.quote(os.path.dirname(envp)) + "\n" + env_here
                            + "cat > " + shlex.quote(up) + " <<'SWGEOF'\n" + new_unit + "SWGEOF\n"
                            + "systemctl daemon-reload && systemctl restart " + shlex.quote(svc))
            if w.returncode != 0:
                fail(svc, (w.stderr or "restart failed").strip()[:120]); continue
            _ti = req.get("title")   # set if the request carried one, else preserve the existing record's title
            _ti = _ti.strip() if isinstance(_ti, str) else (rec.get(svc) or {}).get("title", "")
            rec[svc] = {"service": svc, "listen": listen, "connect": connect,
                        "wrap_key": _params_wrapkey(params), "params": params}   # reflect even if it won't start
            if _ti: rec[svc]["title"] = _ti
            changed = True
            verr = _turn_verify(svc)
            if verr:
                fail(svc, verr); continue   # report not-running; the record already shows the new (broken) params
            good(svc, act + ":" + svc)
        except Exception as e:
            fail(svc, str(e))
    for sp in (turn_onboard or []):
        try:
            unit = host_sh("cat " + shlex.quote(sp) + " 2>/dev/null").stdout
            if not unit:
                fail(sp, "unit not found at that path"); continue
            base = os.path.basename(sp)
            svc = base[:-8] if base.endswith(".service") else base
            rec[svc] = _parse_tp(svc, _exec_of(unit)); changed = True; good(sp, "onb:" + svc)
        except Exception as e:
            fail(sp, str(e))
    if changed:
        try:
            tmp = TURN_RECORD + ".tmp"
            with open(tmp, "w") as f:
                json.dump({"turn_proxies": list(rec.values())}, f)
            os.replace(tmp, TURN_RECORD)
        except Exception as e:
            res["errors"].append("record: " + str(e))
    return res


# node self-update is NODE-ONLY: on a master box (panel + node together) it must NOT restart the
# co-located panel, or the panel restart breaks the very sync that would clear the update request.
DEFAULT_UPDATE_CMD = ("curl -fsSL https://raw.githubusercontent.com/SanityProtocol/swg-panel/main/"
                      "bootstrap.sh | bash -s update -y --no-components --node-only")


def run_self_update(node_cfg, want):
    """Run the swg-only in-place updater, detached so it survives swg-noded's own restart. Only ever
    called on a valid sync reply that carries an 'update'. Updates swg-noded/swg-agent (and a co-located
    panel) — NOT wg/awg/turn-proxies. The panel clears the request once we report the new version."""
    cmd = (node_cfg.get("node") or {}).get("update_cmd") or DEFAULT_UPDATE_CMD
    base = cmd if isinstance(cmd, list) else ["bash", "-lc", (cmd if os.geteuid() == 0 else "sudo -n " + cmd)]
    try:
        # run OUTSIDE swg-noded's own cgroup, so the updater's 'systemctl restart swg-noded' doesn't
        # kill the updater itself. systemd-run --scope gives it a fresh transient scope.
        if os.path.exists("/run/systemd/system") and shutil.which("systemd-run"):
            argv = ["systemd-run", "--scope", "--collect", "--quiet", "--unit", "swg-self-update"] + base
        else:
            argv = base
        subprocess.Popen(argv, stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
                         stderr=subprocess.DEVNULL, start_new_session=True)
        print(f"self-update started → {want.get('to')}", flush=True)
        return True
    except Exception as e:
        print("self-update failed to start:", e, flush=True)
        return False


def report_proc(panel, state, err=None):
    """Best-effort POST of a lifecycle proc-status (e.g. 'update-failed' + reason) to the panel, so a failure
    that never reaches the normal script-side lifecycle reporting still surfaces as a red tag on the node."""
    try:
        u = panel["url"].rstrip("/") + "/api/node/proc-status"
        post_json(u, panel["token"], {"state": state, "err": (err or "")[:2000]}, panel)
        print(f"proc-status → {state}", flush=True)
    except Exception as e:
        print("proc-status report failed:", e, flush=True)


# ───────────────────────── main loop ─────────────────────────

# Routing convergence (egress SNAT + P2/P3 cascade) checks for drift by shelling out to `ip rule`,
# `iptables -S` and `nft list` (a big smart-routing table) — cheap individually but done EVERY sync it
# dominates a co-located master's CPU. Desired routing changes rarely, so we only run it on a change or
# every this-many seconds as a drift/reboot safety re-converge. Snapshot+POST (the 5s "alive" push) is
# never gated — the panel keeps seeing the node live every interval.
ROUTING_RECONCILE_EVERY_S = 60

def main():
    node_cfg = json.load(open(CONFIG_PATH))
    panel = node_cfg.get("panel") or {}
    nd = node_cfg.get("node") or {}
    if not panel.get("url") or not panel.get("token"):
        sys.exit("config needs a 'panel' block with url + token")
    url = panel["url"].rstrip("/") + "/api/node/sync"
    token = panel["token"]
    interval = nd.get("interval", 5)
    online_max = nd.get("online_max", 180)
    agent = nd.get("agent", "/opt/swg-agent/swg-agent")
    sudo = bool(nd.get("sudo"))
    os.makedirs(STATE_DIR, exist_ok=True)
    last_samples = {}
    last_route_sig = None; last_route_t = 0.0    # gate the heavy routing reconcile (see ROUTING_RECONCILE_EVERY_S)
    PANEL_IP_FILE = os.path.join(STATE_DIR, "panel-ip")   # node IP role: source IP to dial the panel (persisted)
    panel_ip = ""; bad_pip = ""                     # bad_pip = a panel_ip that failed to connect → don't keep re-binding it
    with contextlib.suppress(OSError):
        panel_ip = open(PANEL_IP_FILE).read().strip()
    update_started = False                          # spawn the self-updater at most once per process
    print(f"swg-noded: panel={panel['url']} interval={interval}s "
          f"ifaces={list((node_cfg.get('interfaces') or {}).keys())}", flush=True)
    if TURN_DOCKER:   # download + start turn-proxy containers in the BACKGROUND so the node appears on the
        threading.Thread(target=_dturn_bg_loop, daemon=True).start()   # panel immediately (cards show installing → up)
    while True:
        t0 = time.time()
        _LOOP["n"] += 1                             # new loop → per-loop caches (nft table render) refresh
        try:
            snap = build_snapshot(node_cfg, online_max, last_samples)
            use_ip = panel_ip if (panel_ip and panel_ip != bad_pip) else ""
            status, reply = post_json(url, token, {"snapshot": snap}, panel, source_ip=use_ip)
            if status == 0 and use_ip:              # fail-safe: a bound source couldn't reach the panel → retry unbound + stop binding that IP
                bad_pip = use_ip
                status, reply = post_json(url, token, {"snapshot": snap}, panel)
            if status == 200:                       # adopt the panel-chosen connection IP (persist; reset bad-flag if it changed)
                want_pip = ((reply.get("node_egress") or {}).get("panel_ip") or "").strip()
                if want_pip != panel_ip:
                    panel_ip = want_pip
                    if want_pip != bad_pip:
                        bad_pip = ""
                    with contextlib.suppress(OSError):
                        if want_pip:
                            with open(PANEL_IP_FILE + ".tmp", "w") as _f:
                                _f.write(want_pip)
                            os.replace(PANEL_IP_FILE + ".tmp", PANEL_IP_FILE)
                        else:
                            os.unlink(PANEL_IP_FILE)
            if status == 200 and isinstance(reply.get("desired"), dict):
                _upd0 = reply.get("update")
                if _upd0 and not update_started:   # already fired THIS exact request (a recreate restarted us)? then DON'T re-fire — else the update loops forever (recreate → restart → re-trigger → recreate …)
                    _at = str((_upd0 or {}).get("at") or "")
                    _marker = os.path.join(STATE_DIR, ".update-done")   # persists across the container recreate (bind-mounted to data/node)
                    try: _prev = open(_marker).read().strip()
                    except Exception: _prev = ""
                    if _at and _at == _prev: update_started = True
                if reply.get("update") and not update_started:        # panel asked us to self-update (and we haven't fired this one yet)
                    _trig = os.environ.get("SWG_UPDATE_TRIGGER")
                    if _trig:   # docker node: a container can't recreate its own image — touch the HOST trigger
                        try:    # instead; its swg-update.path runs `compose pull && up` on the host (swg images only)
                            with open(_trig, "w") as _f: _f.write(str(int(time.time())) + "\n")
                            try: open(_marker, "w").write(_at)   # remember the request we fired so a recreate-restart won't re-fire it
                            except Exception: pass
                            update_started = True; print(f"update trigger written → {_trig}", flush=True)
                        except Exception as _e:
                            print("update trigger failed:", _e, flush=True)
                            report_proc(panel, "update-failed", f"swg-noded could not write the update trigger {_trig}: {_e}")
                            update_started = True   # reported the failure — don't retry the bad write every sync
                    elif NODE_KIND == "docker":
                        # docker node with NO host updater wired: a container can't recreate its own image, so
                        # run_self_update can do nothing. Report a clear failure instead of silently no-op'ing.
                        print("update requested but no host updater is wired (docker)", flush=True)
                        report_proc(panel, "update-failed",
                                    "This docker node has no one-click host updater wired. Re-install it "
                                    "(bootstrap docker node) to enable the panel's Update button, or update on the box: "
                                    "cd /opt/swg-panel-docker && docker compose --profile node pull && docker compose --profile node up -d")
                        update_started = True
                    else:
                        update_started = run_self_update(node_cfg, reply["update"])
                cr = create_ifaces(node_cfg, reply.get("create"), agent, sudo)   # create new interfaces
                dl = delete_ifaces(node_cfg, reply.get("delete"), agent, sudo)   # tear down deleted ones
                apply_panel_settings(reply.get("panel"))      # Panel settings → mirrors / geo TTL / geo refetch
                ob = onboard_ifaces(node_cfg, reply.get("onboard"))   # add panel-requested interfaces first
                tp = apply_turn(reply.get("turn"), reply.get("turn_onboard"))   # turn-proxy manage/onboard
                r = reconcile(node_cfg, reply["desired"], agent, sudo, reply.get("remove"))
                reconcile_dial_src(reply["desired"], r)        # Part 3: pin per-link outbound source IPs (folds into r)
                ri = reconcile_ifaces(node_cfg, reply.get("desired_ifaces") or {}, agent, sudo)   # set-iface: write the new listen-port to the conf FIRST
                rs = restart_ifaces(node_cfg, reply.get("restart"), agent, sudo)   # THEN bounce — a restart picks up the just-written conf (e.g. a changed port)
                sp = stop_ifaces(node_cfg, reply.get("iface_stop"), agent, sudo)    # stop (down + disable) / start (up + enable) on request
                sa = start_ifaces(node_cfg, reply.get("iface_start"), agent, sudo)
                ik = apply_iface_keys(node_cfg, reply.get("iface_key"), agent, sudo)   # keypair restore/rebaseline from the on-disk backup
                _def_egress = ((reply.get("node_egress") or {}).get("default_egress_ip") or "").strip()   # node IP role: fallback SNAT source
                # Only run the drift-checking routing reconcile when the DESIRED routing changed, an interface's
                # lifecycle changed this cycle, or the safety window elapsed — not every 5s. (See ROUTING_RECONCILE_EVERY_S.)
                _route_sig = json.dumps([reply.get("desired_ifaces"), reply.get("cascade"),
                                         reply.get("smart"), _def_egress], sort_keys=True, default=str)
                _iface_churn = bool(cr["created"] or dl["deleted"] or ob["added"] or rs["restarted"]
                                    or sp["stopped"] or sa["started"] or ri["changed"])
                if (_route_sig != last_route_sig or _iface_churn
                        or (time.time() - last_route_t) >= ROUTING_RECONCILE_EVERY_S):
                    eg = reconcile_egress(node_cfg, reply.get("desired_ifaces") or {}, _def_egress)   # per-interface egress SNAT (+ node default)
                    cas = reconcile_cascade(node_cfg, reply.get("cascade"), reply.get("smart"), _def_egress)   # P2 forward + P3 smart + exit SNAT
                    with contextlib.suppress(Exception):
                        reconcile_inet_chain(node_cfg)   # keep the SWG_INET byte-counting chain in step with the iface set (measured internet lane)
                    last_route_sig = _route_sig; last_route_t = time.time()
                else:
                    eg = {"changed": 0, "errors": []}; cas = {"changed": 0, "errors": []}   # unchanged routing → skip the ip/iptables/nft drift-check shell-outs
                # surface iface command failures to the panel too (cmd_errors), keyed by iface name
                for blk in (cr, dl, ob, rs, sp, sa):
                    for e in blk["errors"]:
                        k, _, m = e.partition(": ")
                        NODE_ERRORS[k] = m or e
                for k in (cr.get("created", []) + dl.get("deleted", []) + ob.get("added", [])
                          + rs.get("restarted", []) + sp.get("stopped", []) + sa.get("started", [])):
                    NODE_ERRORS.pop(k, None)
                # prune errors for requests the panel has since cleared (iface + turn)
                active = (set(reply.get("create") or {}) | set(reply.get("onboard") or {})
                          | set(reply.get("delete") or []) | set(reply.get("restart") or []) | set(reply.get("turn") or {})
                          | set(reply.get("iface_stop") or []) | set(reply.get("iface_start") or [])
                          | set(reply.get("turn_onboard") or []))
                for k in list(NODE_ERRORS):
                    if k not in active:
                        NODE_ERRORS.pop(k, None)
                for e in eg["errors"] + cas["errors"]:
                    print("egress: " + e, flush=True)
                if (r["added"] or r["removed"] or r["errors"] or ri["changed"] or ri["errors"]
                        or eg["changed"] or eg["errors"] or cas["changed"] or cas["errors"]
                        or ob["added"] or ob["errors"] or cr["created"] or cr["errors"]
                        or dl["deleted"] or dl["errors"] or tp["done"] or tp["errors"]):
                    print(f"reconcile: +{r['added']} -{r['removed']} ifaces~{ri['changed']} cascade~{cas['changed']} "
                          f"onboard+{ob['added']} create+{cr['created']} delete-{dl['deleted']} turn={tp['done']} "
                          f"errors={(r['errors'] + ri['errors'] + ob['errors'] + cr['errors'] + dl['errors'] + tp['errors'] + eg['errors'] + cas['errors'])[:3]}", flush=True)
                interval = reply.get("interval", interval)
            elif status == 0:
                print("sync error:", reply.get("error"), flush=True)
            else:
                print(f"sync HTTP {status}: {reply.get('error')}", flush=True)
        except Exception as e:
            print("loop error:", e, flush=True)
        with _TURN_JOBS_LOCK:                       # while an async reinstall/update is in flight, sync fast so the
            _busy = bool(_TURN_JOBS)                 # panel actually SEES the "updating" phase (else a sub-interval
        _iv = 1.0 if _busy else interval            # download finishes entirely between two 5s posts → pending→updated)
        time.sleep(max(0.5, _iv - (time.time() - t0)))


if __name__ == "__main__":
    main()
