_SELF_CONTAINER = (os.environ.get("SWG_NODE_CONTAINER") or "").strip() or socket.gethostname()

# A plain-wg interface persists cmd=["wg"], but the docker image ships ONLY `awg` (a superset that also reads/writes
# plain-wg interfaces — they're even set up via `awg setconf`). With no `wg` binary every `wg show`/op would fail,
# so the interface's peers report no handshake/transfer (dashboard throughput, online status, top-talkers all blank).
# Resolve to the tool actually present: fall back to awg when wg is missing. Bare-metal with real wg is unchanged.
_HAVE_WG = shutil.which("wg") is not None
def _wgcmd(cmd):
    return ["awg"] if (cmd == ["wg"] and not _HAVE_WG) else cmd
