#!/usr/bin/env python3
"""
swg-noded — node daemon. One outbound-only HTTPS loop, no inbound, no rsync.

Every `interval` seconds:
  1. sample each managed interface  -> snapshot {peers + per-interface meta}
  2. POST it to the panel's /api/node/sync with the node's bearer token
  3. the panel replies with this node's DESIRED peer set (from the roster)
  4. reconcile: add desired-but-missing peers, remove present-but-undesired ones,
     each applied through swg-agent locally.

The panel is the source of truth; the node converges to it and self-heals. Only
outbound HTTPS to the panel is required, so edge/Russian nodes need no inbound.

Config (/etc/swg-agent/config.json), see config.example.json:
  interfaces, endpoint_host, dns  — as before
  panel: { url, token, verify, fingerprint }
  node:  { interval, agent, sudo }
"""

import contextlib
import hashlib
import http.client
import json
import os
import re
import secrets
import shlex
import shutil
import socket
import ssl
import subprocess
import sys
import time
import urllib.parse

CONFIG_PATH = os.environ.get("SWG_AGENT_CONFIG", "/etc/swg-agent/config.json")
STATE_DIR   = os.environ.get("SWG_NODED_STATE", "/var/lib/swg-noded")
TURN_RECORD = os.environ.get("SWG_TURN_RECORD", "/etc/swg-agent/turn-proxy.json")
AWG_KEYS = ["Jc", "Jmin", "Jmax", "S1", "S2", "S3", "S4",
            "H1", "H2", "H3", "H4", "I1", "I2", "I3", "I4", "I5"]


def _noded_version():
    for p in (os.path.join(os.path.dirname(os.path.abspath(__file__)), "VERSION"),
              "/opt/swg-noded/VERSION"):
        try:
            with open(p) as f:
                v = f.read().strip()
                if v:
                    return v
        except OSError:
            pass
    return None


NODED_VERSION = _noded_version()
# bare-metal vs docker — reported so the panel can tag the node (containers carry /.dockerenv)
NODE_KIND = "docker" if (os.path.exists("/.dockerenv") or os.path.exists("/run/.containerenv")) else "baremetal"
# docker network mode (set by the installer via the compose env): "host" = every interface port is on
# the host (no publishing); "bridge" = panel-created interface ports must be published. Bare-metal is
# always "host"-like. The panel uses this to show port-publishing guidance only where it's needed.
NODE_NET = (os.environ.get("NODE_NET") or "host").strip().lower()
if NODE_NET not in ("host", "bridge"):
    NODE_NET = "host"
# can the panel manage this node's host turn-proxy services? bare-metal: always (swg-noded is on the
# host). docker: only when the installer mounted docker.sock (TURN_MANAGE=panel) so we can drive host
# units via a privileged --pid=host helper. Reported so the panel only shows manage/onboard controls
# when they'd actually work.
TURN_MANAGE = (NODE_KIND != "docker") or ((os.environ.get("TURN_MANAGE") or "manual").strip().lower() == "panel")


# ───────────────────────── parsing (pure) ─────────────────────────

def parse_dump(out):
    lines = out.strip().splitlines()
    iface_line = lines[0].split("\t") if lines else []
    peers = []
    for line in lines[1:]:
        f = line.split("\t")
        if len(f) < 8:
            continue
        peers.append({
            "public_key": f[0],
            "preshared_key": None if f[1] in ("(none)", "") else f[1],   # keep PSK so adoption can reuse it
            "endpoint": None if f[2] in ("(none)", "") else f[2],
            "allowed_ips": f[3],
            "last_handshake": int(f[4]) if f[4].isdigit() else 0,
            "rx_bytes": int(f[5]) if f[5].isdigit() else 0,
            "tx_bytes": int(f[6]) if f[6].isdigit() else 0,
        })
    return iface_line, peers


def parse_interface_section(conf_text):
    info, in_iface = {}, False
    for line in conf_text.splitlines():
        s = line.strip()
        if s.startswith("["):
            in_iface = (s.lower() == "[interface]")
            continue
        if in_iface and "=" in s and not s.startswith("#"):
            k, v = s.split("=", 1)
            info[k.strip()] = v.strip()
    return info


def awg_params(info):
    out = {}
    for k in AWG_KEYS:
        if k in info:
            v = info[k]
            out[k] = int(v) if v.isdigit() else v
    return out


def derive_pubkey(cmd, priv):
    """Server public key from a private key (used when the interface is down / dump is empty)."""
    if not priv:
        return None
    try:
        out = run((cmd or ["awg"]) + ["pubkey"], input_text=priv + "\n").stdout.strip()
        return out or None
    except Exception:
        return None


def build_meta(iface_line, conf_text, endpoint_host, dns, cmd=None):
    info = parse_interface_section(conf_text)
    addr = info.get("Address", "").split(",")[0].strip()
    subnet = None
    if addr and "/" in addr:
        try:
            import ipaddress
            subnet = str(ipaddress.ip_network(addr, strict=False))
        except Exception:
            subnet = addr.rsplit("/", 1)[0]
    port = int(iface_line[2]) if len(iface_line) > 2 and iface_line[2].isdigit() else None
    if not port and str(info.get("ListenPort", "")).strip().isdigit():   # fall back to the .conf
        port = int(str(info["ListenPort"]).strip())
    pub = iface_line[1] if len(iface_line) > 1 and iface_line[1] else derive_pubkey(cmd, info.get("PrivateKey"))
    return {
        "public_key": pub,
        "listen_port": port,
        "endpoint": (f"{endpoint_host}:{port}" if endpoint_host and port else None),
        "address": addr or None,
        "subnet": subnet,
        "awg_params": awg_params(info),
        "dns": dns or [],
    }


def peer_view(peers, last, dt, online_max, now):
    out = []
    for p in peers:
        age = (now - p["last_handshake"]) if p["last_handshake"] else None
        prev = last.get(p["public_key"])
        rs = ts = 0.0
        if prev and dt > 0:
            rs = max(0, p["rx_bytes"] - prev[0]) / dt
            ts = max(0, p["tx_bytes"] - prev[1]) / dt
        out.append({
            "public_key": p["public_key"], "endpoint": p["endpoint"],
            "allowed_ips": p["allowed_ips"], "rx_bytes": p["rx_bytes"], "tx_bytes": p["tx_bytes"],
            "rx_speed": rs, "tx_speed": ts,
            "last_handshake": p["last_handshake"] or None, "handshake_age": age,
            "online": age is not None and age <= online_max,
        })
    return out


# ───────────────────────── node health (cheap: /proc + statvfs, no subprocess) ─────────────────────────
#
# Everything here reads in-kernel pseudo-files (/proc/{loadavg,meminfo,uptime,stat}) and
# does one statvfs() syscall per mount — microseconds total, no process spawns. Far cheaper
# than the `awg show dump` we already run per interface, so sampling it every loop is free.
# proc_root / statvfs are injectable so the parsing is testable against a fixture.

def _read_proc(proc_root, name):
    with open(os.path.join(proc_root, name)) as f:
        return f.read()


def read_loadavg(proc_root="/proc"):
    p = _read_proc(proc_root, "loadavg").split()
    return [float(p[0]), float(p[1]), float(p[2])]


def read_meminfo(proc_root="/proc"):
    vals = {}
    for line in _read_proc(proc_root, "meminfo").splitlines():
        k, _, rest = line.partition(":")
        f = rest.split()
        if f and f[0].isdigit():
            vals[k] = int(f[0]) * 1024          # kB -> bytes
    total = vals.get("MemTotal", 0)
    avail = vals.get("MemAvailable", vals.get("MemFree", 0))   # MemAvailable fallback for old kernels
    mem = {"total": total, "available": avail, "used": max(0, total - avail)}
    if "SwapTotal" in vals:
        mem["swap_total"] = vals["SwapTotal"]
        mem["swap_used"] = max(0, vals["SwapTotal"] - vals.get("SwapFree", 0))
    return mem


def read_uptime(proc_root="/proc"):
    return float(_read_proc(proc_root, "uptime").split()[0])


def read_ncpu(proc_root="/proc"):
    with contextlib.suppress(Exception):
        n = sum(1 for ln in _read_proc(proc_root, "stat").splitlines()
                if ln.startswith("cpu") and len(ln) > 3 and ln[3].isdigit())
        if n:
            return n
    return os.cpu_count() or 1


def disk_usage(mount, statvfs=os.statvfs):
    st = statvfs(mount)
    total = st.f_blocks * st.f_frsize
    return {"mount": mount, "total": total,
            "used": max(0, total - st.f_bfree * st.f_frsize),
            "free": st.f_bavail * st.f_frsize}


def collect_health(proc_root="/proc", mounts=None, statvfs=os.statvfs):
    """A small per-node health block. Each field is collected independently and a failure
    in one (e.g. a missing /proc file in a stripped container) never sinks the rest."""
    mounts = mounts if mounts is not None else ["/"]
    h = {}
    with contextlib.suppress(Exception):
        h["load"] = read_loadavg(proc_root)
    with contextlib.suppress(Exception):
        h["ncpu"] = read_ncpu(proc_root)
    with contextlib.suppress(Exception):
        h["mem"] = read_meminfo(proc_root)
    with contextlib.suppress(Exception):
        h["uptime"] = read_uptime(proc_root)
    disks = []
    for m in mounts:
        with contextlib.suppress(Exception):
            disks.append(disk_usage(m, statvfs))
    if disks:
        h["disk"] = disks
    return h


# ───────────────────────── io ─────────────────────────

def run(args, input_text=None, timeout=20):
    return subprocess.run(args, input=input_text, capture_output=True, text=True, timeout=timeout)


def run_agent(agent, sudo, payload):
    prefix = ["sudo", "-n"] if sudo else []
    try:
        p = run(prefix + [agent], input_text=json.dumps(payload))
    except Exception as e:
        return {"ok": False, "op": payload.get("op"), "error": str(e), "code": "internal"}
    out = (p.stdout or "").strip()
    if not out:
        return {"ok": False, "op": payload.get("op"),
                "error": (p.stderr or "").strip() or "no response", "code": "internal"}
    try:
        return json.loads(out)
    except json.JSONDecodeError:
        return {"ok": False, "op": payload.get("op"), "error": "agent non-JSON", "code": "internal"}


def post_json(url, token, obj, panel, timeout=20):
    """POST JSON to the panel. TLS posture comes from `panel`:
         fingerprint set -> pin sha256 (verified during the handshake, before any
                            bytes are sent, and fails closed if it can't be read);
         verify true     -> system CA verification;
         otherwise       -> unverified (self-signed; encrypted but no MITM protection).
    Returns (status, dict). status 0 means the request never completed."""
    body = json.dumps(obj).encode()
    headers = {"Content-Type": "application/json", "Authorization": "Bearer " + token}
    u = urllib.parse.urlparse(url)
    host = u.hostname
    port = u.port or (443 if u.scheme == "https" else 80)
    path = (u.path or "/") + (("?" + u.query) if u.query else "")
    fp = (panel.get("fingerprint") or "").replace(":", "").lower().strip()
    conn = None
    try:
        if u.scheme == "http":
            conn = http.client.HTTPConnection(host, port, timeout=timeout)
        elif u.scheme == "https":
            if panel.get("verify", False) and not fp:
                ctx = ssl.create_default_context()
            else:
                ctx = ssl._create_unverified_context()
            conn = http.client.HTTPSConnection(host, port, timeout=timeout, context=ctx)
            if fp:
                conn.connect()                      # TLS handshake before sending the token
                der = conn.sock.getpeercert(True)
                if not der or hashlib.sha256(der).hexdigest() != fp:
                    return 0, {"error": "tls fingerprint mismatch"}
        else:
            return 0, {"error": f"unsupported url scheme {u.scheme!r}"}
        conn.request("POST", path, body=body, headers=headers)
        resp = conn.getresponse()
        data = (resp.read().decode() or "{}")
        if resp.status >= 400:
            return resp.status, {"error": data[:200]}
        return resp.status, json.loads(data)
    except Exception as e:
        return 0, {"error": str(e)}
    finally:
        if conn is not None:
            with contextlib.suppress(Exception):
                conn.close()


# ───────────────────────── snapshot ─────────────────────────

def load_turn_proxies():
    """Turn-proxies installed on this box (written by the installer) — listen/connect/wrap_key.
    Forwarded to the panel so it can flag turn-proxied clients and build their configs."""
    try:
        with open(TURN_RECORD) as f:
            d = json.load(f)
        tp = d.get("turn_proxies") if isinstance(d, dict) else None
        return tp if isinstance(tp, list) else []
    except Exception:
        return []


def build_snapshot(node_cfg, online_max, last_samples, now=None):
    now = now or int(time.time())
    hcfg = node_cfg.get("health") or {}
    interfaces = {}
    for iface, ic in (node_cfg.get("interfaces") or {}).items():
        cmd = ic.get("cmd", ["awg"])
        try:                                        # one bad interface must never kill the whole snapshot
            dump = run(cmd + ["show", iface, "dump"]).stdout
            iface_line, raw = parse_dump(dump)
            try:
                conf_text = open(ic["conf"]).read()
            except OSError:
                conf_text = ""
            st = last_samples.setdefault(iface, {"peers": {}, "t": now})
            dt = max(1e-6, now - st["t"])
            peers = peer_view(raw, st["peers"], dt, online_max, now)
            st["peers"] = {p["public_key"]: (p["rx_bytes"], p["tx_bytes"]) for p in raw}
            st["t"] = now
            interfaces[iface] = {
                "peers": peers,
                "meta": build_meta(iface_line, conf_text,
                                   ic.get("endpoint_host") or node_cfg.get("endpoint_host"),
                                   node_cfg.get("dns", []), cmd),
            }
        except Exception as e:
            print(f"snapshot: skipping {iface}: {e}", flush=True)
            continue
    snap = {"hostname": socket.gethostname(), "generated_at": now,
            "interfaces": interfaces, "turn_proxies": load_turn_proxies(),
            "noded_version": NODED_VERSION, "kind": NODE_KIND, "net_mode": NODE_NET,
            "turn_manage": TURN_MANAGE, "cmd_errors": dict(NODE_ERRORS)}
    if hcfg.get("enabled", True):      # additive + opt-out; mounts default to ["/"]
        snap["health"] = collect_health(mounts=hcfg.get("mounts"))
    return snap


# ───────────────────────── reconcile ─────────────────────────

def current_pubkeys(node_cfg, iface):
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    cmd = ic.get("cmd", ["awg"])
    try:
        _, peers = parse_dump(run(cmd + ["show", iface, "dump"]).stdout)
        return {p["public_key"] for p in peers}
    except Exception:
        return None


def current_listen_port(node_cfg, iface):
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    cmd = ic.get("cmd", ["awg"])
    try:
        iface_line, _ = parse_dump(run(cmd + ["show", iface, "dump"]).stdout)
        return int(iface_line[2]) if len(iface_line) > 2 and str(iface_line[2]).isdigit() else None
    except Exception:
        return None


def current_awg(node_cfg, iface):
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    try:
        with open(ic["conf"]) as f:
            return awg_params(parse_interface_section(f.read()))
    except Exception:
        return None


def reconcile_ifaces(node_cfg, desired_ifaces, agent, sudo):
    """Apply the panel's desired interface config (listen port and/or AmneziaWG params). Only
    ever called on a valid sync reply; converges the live interface to the panel's target."""
    res = {"changed": 0, "errors": []}
    for iface, want in (desired_ifaces or {}).items():
        if iface not in (node_cfg.get("interfaces") or {}):
            continue
        payload = {"op": "set-iface", "iface": iface}
        port = want.get("listen_port")
        if port:
            cur = current_listen_port(node_cfg, iface)
            if cur is not None and int(cur) != int(port):
                payload["listen_port"] = int(port)
        awg = want.get("awg_params")
        if isinstance(awg, dict) and awg:
            cur_awg = current_awg(node_cfg, iface) or {}
            want_s = {k: str(v) for k, v in awg.items()}
            if any(str(cur_awg.get(k)) != v for k, v in want_s.items()):
                payload["awg_params"] = awg
        if len(payload) <= 2:                 # only op + iface — nothing differs
            continue
        r = run_agent(agent, sudo, payload)
        if r.get("ok"):
            res["changed"] += 1
        else:
            res["errors"].append(f"set-iface {iface}: {r.get('error')}")
    return res


def reconcile(node_cfg, desired_by_iface, agent, sudo):
    """Apply the panel's desired peer set. Only ever called on a valid sync reply."""
    res = {"added": 0, "removed": 0, "errors": []}
    for iface, ic in (node_cfg.get("interfaces") or {}).items():
        desired = {p["public_key"]: p for p in (desired_by_iface.get(iface) or [])}
        current = current_pubkeys(node_cfg, iface)
        if current is None:
            res["errors"].append(f"{iface}: cannot read interface")
            continue
        for pk, p in desired.items():
            if pk in current:
                continue
            r = run_agent(agent, sudo, {
                "op": "add-peer", "iface": iface, "public_key": pk,
                "allowed_ips": p.get("allowed_ips", ""),
                "preshared_key": p.get("preshared_key", "none"),
                "name": p.get("name", "")})
            if r.get("ok"):
                res["added"] += 1
            else:
                res["errors"].append(f"add {pk[:8]}: {r.get('error')}")
        # An onboarded interface is ADD-ONLY: the panel never removes peers it didn't create, so an
        # interface adopted from another tool (e.g. wg-easy) keeps its existing peers. They surface
        # as adoptable orphans instead of being wiped.
        if ic.get("onboarded"):
            continue
        for pk in current - set(desired):
            r = run_agent(agent, sudo, {"op": "remove-peer", "iface": iface, "public_key": pk})
            if r.get("ok"):
                res["removed"] += 1
            else:
                res["errors"].append(f"remove {pk[:8]}: {r.get('error')}")
    return res


def onboard_ifaces(node_cfg, onboard):
    """Add panel-requested interfaces to this node's managed set (config.json) when they exist
    locally — for a wg/awg interface the panel didn't auto-detect. Once added, build_snapshot
    reports it and the panel closes the request (no separate ack needed). Only ever on a 200."""
    res = {"added": [], "errors": []}
    if not onboard:
        return res
    ifaces = node_cfg.setdefault("interfaces", {})
    changed = False
    for iface, want in onboard.items():
        if iface in ifaces:                 # already managed — nothing to do (panel will clear it)
            continue
        cmd = want.get("cmd") or ["awg"]
        conf = want.get("conf") or ""
        try:
            if not conf or not os.path.exists(conf):
                res["errors"].append(f"{iface}: conf not found ({conf})"); continue
            if cmd == ["auto"]:                     # "Existing" gave no protocol — detect it from the conf
                info = parse_interface_section(open(conf).read())
                cmd = ["awg"] if any(k in info for k in AWG_KEYS) else ["wg"]
                try:
                    run(cmd + ["show", iface, "dump"])
                except Exception:
                    cmd = ["wg"] if cmd == ["awg"] else ["awg"]   # fall back to the other tool
            run(cmd + ["show", iface, "dump"])      # raises if the interface isn't actually up
        except Exception as e:
            res["errors"].append(f"{iface}: {e}"); continue
        ifaces[iface] = {"cmd": cmd, "conf": conf, "onboarded": True}   # add-only: never wipe its peers
        changed = True
        res["added"].append(iface)
    if changed:
        try:
            _persist_config(node_cfg)
        except Exception as e:
            res["errors"].append(f"persist config.json: {e}")
    return res


def _persist_config(node_cfg):
    tmp = CONFIG_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(node_cfg, f, indent=2)
    os.replace(tmp, CONFIG_PATH)


def create_ifaces(node_cfg, create, agent, sudo):
    """Create panel-requested BRAND-NEW interfaces via swg-agent (genkey + conf + auto-NAT + bring-up),
    then start managing them (config.json). Only on a valid sync. Bring-up runs live — verify on one
    node. Native datapath: kernel on a bare-metal node, container-userspace on a docker node."""
    res = {"created": [], "errors": []}
    if not create:
        return res
    ifaces = node_cfg.setdefault("interfaces", {})
    changed = False
    for iface, want in create.items():
        if iface in ifaces:                 # already created — nothing to do (panel clears it)
            continue
        cmd = want.get("cmd") or ["awg"]
        r = run_agent(agent, sudo, {"op": "create-iface", "iface": iface, "cmd": cmd,
                                    "subnet": want.get("subnet"), "listen_port": want.get("listen_port"),
                                    "mtu": want.get("mtu")})
        if not r.get("ok"):
            res["errors"].append(f"{iface}: {r.get('error')}"); continue
        data = r.get("data") or {}
        conf = data.get("conf") or ""
        if not conf:
            res["errors"].append(f"{iface}: agent returned no conf path"); continue
        # the agent may have fallen back (e.g. wg→awg on a node with only amneziawg-go) — record the
        # tool it ACTUALLY used, or we'll later run the wrong CLI (`wg show`) and "can't read" it
        ifaces[iface] = {"cmd": data.get("cmd") or cmd, "conf": conf}
        changed = True
        res["created"].append(iface)
    if changed:
        try:
            _persist_config(node_cfg)
        except Exception as e:
            res["errors"].append(f"persist config.json: {e}")
    return res


def delete_ifaces(node_cfg, delete, agent, sudo):
    """Tear down panel-requested interfaces (down + remove conf via swg-agent) and stop managing them.
    Only on a valid sync. The panel clears the request once the iface stops appearing in snapshots."""
    res = {"deleted": [], "errors": []}
    if not delete:
        return res
    ifaces = node_cfg.get("interfaces") or {}
    changed = False
    for iface in list(delete):
        if iface not in ifaces:             # already gone — panel clears it when the snapshot lacks it
            continue
        r = run_agent(agent, sudo, {"op": "delete-iface", "iface": iface})
        if not r.get("ok"):
            res["errors"].append(f"{iface}: {r.get('error')}"); continue
        ifaces.pop(iface, None)
        changed = True
        res["deleted"].append(iface)
    if changed:
        try:
            _persist_config(node_cfg)
        except Exception as e:
            res["errors"].append(f"persist config.json: {e}")
    return res


# ── turn-proxy management (host systemd units) ──────────────────────────────────────────────────
# UNVERIFIED ON DOCKER: the bare-metal path edits units + systemctl directly; the docker path runs
# the same on the HOST via a privileged --pid=host helper through the mounted docker.sock (nsenter
# into PID 1). Test on a real node before relying on it. The socket = root-on-host (opt-in install).
HELPER_IMAGE = os.environ.get("HELPER_IMAGE") or "ghcr.io/sanityprotocol/swg-node:latest"
TURN_UNIT_DIR = "/etc/systemd/system"
TURN_MANAGE_ON = (NODE_KIND != "docker") or ((os.environ.get("TURN_MANAGE") or "manual").strip().lower() == "panel")
NODE_ERRORS = {}   # request key (iface name / turn service / .service path) -> last apply error, reported
                   # in the snapshot ("cmd_errors") so the panel can show WHY a host->node command failed

def host_sh(cmd, timeout=90):
    """Run a shell command on the HOST. Bare-metal: directly. Docker: via a one-shot privileged
    --pid=host helper through the mounted docker socket — nsenter into PID 1 so the command runs in
    the host's namespaces (its filesystem + systemd)."""
    if NODE_KIND != "docker":
        args = ["sh", "-c", cmd] if os.geteuid() == 0 else ["sudo", "-n", "sh", "-c", cmd]
    else:
        args = ["docker", "run", "--rm", "--privileged", "--pid=host", "--network=host", HELPER_IMAGE,
                "nsenter", "-t", "1", "-m", "-u", "-i", "-n", "-p", "--", "sh", "-c", cmd]
    try:
        r = run(args, timeout=timeout)
    except Exception as e:                              # e.g. 'docker' not found, or a timeout
        print("host_sh EXC: " + str(e) + " :: " + cmd[:160], flush=True)
        class _R:                                       # synthesize a failed result so callers see it
            returncode = 127; stdout = ""; stderr = str(e)
        return _R()
    if r.returncode != 0:
        print("host_sh rc=" + str(r.returncode) + " :: " + cmd[:160] + " :: " + (r.stderr or r.stdout or "")[:300], flush=True)
    return r

def _turn_unit_path(svc):
    return TURN_UNIT_DIR + "/" + svc + ".service"

def _exec_of(unit_text):
    for ln in unit_text.splitlines():
        if ln.startswith("ExecStart="):
            return ln[len("ExecStart="):]
    return ""

def _set_arg(execl, flag, value):
    """Replace '-flag <val>' (space- or =-separated) in the ExecStart, or append it."""
    pat = re.compile(r"(-" + re.escape(flag) + r")[ =]+\S+")
    if pat.search(execl):
        return pat.sub(lambda m: m.group(1) + " " + value, execl, count=1)
    return execl.rstrip() + " -" + flag + " " + value

def _strip_wrap(execl):
    """Remove the wrap key + the fork's wrap flag (-wrap / -wrap-srtp / -wrap-mode on)."""
    execl = re.sub(r"\s*-wrap-key[ =]+\S+", "", execl)
    execl = re.sub(r"\s*-wrap-mode[ =]+\S+", "", execl)
    execl = re.sub(r"\s*-wrap-srtp\b", "", execl)
    execl = re.sub(r"\s*-wrap\b", "", execl)
    return execl

def _parse_tp(svc, execl):
    def g(flag):
        m = re.search(r"-" + re.escape(flag) + r"[ =]+(\S+)", execl)
        return m.group(1) if m else ""
    return {"service": svc, "listen": g("listen"), "connect": g("connect"), "wrap_key": g("wrap-key")}

def _installed_tp(svc):
    """Re-read a turn unit (after install/edit) so the record carries the real ExecStart, incl. the
    generated wrap key."""
    unit = host_sh("cat " + shlex.quote(_turn_unit_path(svc)) + " 2>/dev/null").stdout
    return _parse_tp(svc, _exec_of(unit))

def _turn_install(svc, req):
    """Install a new turn-proxy: download the fork's prebuilt binary, write the systemd unit, enable
    it. Mirrors the installer's install_turn_binary (server-linux-<arch>). '' on success, else error."""
    owner = (req.get("owner") or "").strip()
    listen = (req.get("listen") or "").strip()
    connect = (req.get("connect") or "").strip()
    wrap_flags = (req.get("wrap_flags") or "").strip()
    if "/" not in owner or ":" not in listen or ":" not in connect:
        return "bad install request"
    inst = svc[len("vk-turn-proxy-"):] if svc.startswith("vk-turn-proxy-") else svc
    d = "/opt/vk-turn-proxy/" + inst
    binp = d + "/server"
    arch = "arm64" if os.uname().machine in ("aarch64", "arm64") else "amd64"
    url = "https://github.com/" + owner + "/releases/latest/download/server-linux-" + arch
    extra = ""
    if wrap_flags:
        key = secrets.token_hex(32)   # 64 hex chars, no openssl dependency (the slim image lacks it)
        if not key:
            return "keygen failed"
        extra = wrap_flags + " -wrap-key " + key
    exec_line = binp + " -listen " + listen + " -connect " + connect + ((" " + extra) if extra else "")
    unit = ("[Unit]\nDescription=vk-turn-proxy (" + owner + ") - " + listen + " -> " + connect + "\n"
            "After=network-online.target\nWants=network-online.target\n\n"
            "[Service]\nExecStart=" + exec_line + "\nRestart=on-failure\nRestartSec=3\n\n"
            "[Install]\nWantedBy=multi-user.target\n")
    cmd = ("mkdir -p " + shlex.quote(d)
           + " && curl -fsSL --connect-timeout 10 --max-time 180 --retry 2 --retry-all-errors "
           + shlex.quote(url) + " -o " + shlex.quote(binp) + " && chmod +x " + shlex.quote(binp)
           + " && cat > " + shlex.quote(_turn_unit_path(svc)) + " <<'SWGEOF'\n" + unit + "SWGEOF\n"
           + "systemctl daemon-reload && systemctl enable --now " + shlex.quote(svc))
    w = host_sh(cmd, timeout=210)
    if w.returncode != 0:
        return (w.stderr or w.stdout or "install failed").strip()[:160]
    return ""

def apply_turn(turn, turn_onboard):
    """Apply panel turn-proxy requests (manage/rotate/delete) + onboard host .service units, then
    update the turn record so the snapshot reflects it (which clears the panel request)."""
    res = {"done": [], "errors": []}
    if not turn and not turn_onboard:
        return res
    keys = set(turn or {}) | set(turn_onboard or [])
    print("turn: applying " + str(sorted(keys)) + " manage_on=" + str(TURN_MANAGE_ON)
          + " kind=" + NODE_KIND, flush=True)
    def fail(k, m):
        res["errors"].append(k + ": " + m); NODE_ERRORS[k] = m
        print("turn: FAIL " + k + " -> " + m, flush=True)
    def good(k, tag):
        res["done"].append(tag); NODE_ERRORS.pop(k, None)
        print("turn: ok " + tag, flush=True)
    if not TURN_MANAGE_ON:
        for k in keys:
            fail(k, "turn management off — re-install the docker node with the 'panel' option")
        return res
    rec = {tp.get("service"): tp for tp in load_turn_proxies() if tp.get("service")}
    changed = False
    for svc, req in (turn or {}).items():
        try:
            act = req.get("action"); up = _turn_unit_path(svc)
            if act == "install":
                err = _turn_install(svc, req)
                if err:
                    fail(svc, err)
                else:
                    rec[svc] = _installed_tp(svc); changed = True; good(svc, "ins:" + svc)
                continue
            if act == "delete":
                w = host_sh("systemctl disable --now " + shlex.quote(svc) + " >/dev/null 2>&1; "
                            "rm -f " + shlex.quote(up) + "; systemctl daemon-reload")
                if w.returncode != 0:
                    fail(svc, (w.stderr or "remove failed").strip()[:120]); continue
                rec.pop(svc, None); changed = True; good(svc, "del:" + svc); continue
            unit = host_sh("cat " + shlex.quote(up) + " 2>/dev/null").stdout
            if not unit:
                fail(svc, "unit not found on the node"); continue
            execl = _exec_of(unit)
            if act == "manage":
                if req.get("listen"):  execl = _set_arg(execl, "listen", req["listen"])
                if req.get("connect"): execl = _set_arg(execl, "connect", req["connect"])
                if "wrap_key" in req:
                    execl = _set_arg(execl, "wrap-key", req["wrap_key"]) if req["wrap_key"] else _strip_wrap(execl)
            elif act == "rotate":
                execl = _set_arg(execl, "wrap-key", secrets.token_hex(32))
            new_unit = "\n".join(("ExecStart=" + execl) if ln.startswith("ExecStart=") else ln
                                 for ln in unit.splitlines())
            w = host_sh("cat > " + shlex.quote(up) + " <<'SWGEOF'\n" + new_unit + "\nSWGEOF\n"
                        "systemctl daemon-reload && systemctl restart " + shlex.quote(svc))
            if w.returncode != 0:
                fail(svc, (w.stderr or "restart failed").strip()[:120]); continue
            rec[svc] = _parse_tp(svc, execl); changed = True; good(svc, act + ":" + svc)
        except Exception as e:
            fail(svc, str(e))
    for sp in (turn_onboard or []):
        try:
            unit = host_sh("cat " + shlex.quote(sp) + " 2>/dev/null").stdout
            if not unit:
                fail(sp, "unit not found at that path"); continue
            base = os.path.basename(sp)
            svc = base[:-8] if base.endswith(".service") else base
            rec[svc] = _parse_tp(svc, _exec_of(unit)); changed = True; good(sp, "onb:" + svc)
        except Exception as e:
            fail(sp, str(e))
    if changed:
        try:
            tmp = TURN_RECORD + ".tmp"
            with open(tmp, "w") as f:
                json.dump({"turn_proxies": list(rec.values())}, f)
            os.replace(tmp, TURN_RECORD)
        except Exception as e:
            res["errors"].append("record: " + str(e))
    return res


# node self-update is NODE-ONLY: on a master box (panel + node together) it must NOT restart the
# co-located panel, or the panel restart breaks the very sync that would clear the update request.
DEFAULT_UPDATE_CMD = ("curl -fsSL https://raw.githubusercontent.com/SanityProtocol/swg-panel/main/"
                      "bootstrap.sh | bash -s update -y --no-components --node-only")


def run_self_update(node_cfg, want):
    """Run the swg-only in-place updater, detached so it survives swg-noded's own restart. Only ever
    called on a valid sync reply that carries an 'update'. Updates swg-noded/swg-agent (and a co-located
    panel) — NOT wg/awg/turn-proxies. The panel clears the request once we report the new version."""
    cmd = (node_cfg.get("node") or {}).get("update_cmd") or DEFAULT_UPDATE_CMD
    base = cmd if isinstance(cmd, list) else ["bash", "-lc", (cmd if os.geteuid() == 0 else "sudo -n " + cmd)]
    try:
        # run OUTSIDE swg-noded's own cgroup, so the updater's 'systemctl restart swg-noded' doesn't
        # kill the updater itself. systemd-run --scope gives it a fresh transient scope.
        if os.path.exists("/run/systemd/system") and shutil.which("systemd-run"):
            argv = ["systemd-run", "--scope", "--collect", "--quiet", "--unit", "swg-self-update"] + base
        else:
            argv = base
        subprocess.Popen(argv, stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
                         stderr=subprocess.DEVNULL, start_new_session=True)
        print(f"self-update started → {want.get('to')}", flush=True)
        return True
    except Exception as e:
        print("self-update failed to start:", e, flush=True)
        return False


# ───────────────────────── main loop ─────────────────────────

def main():
    node_cfg = json.load(open(CONFIG_PATH))
    panel = node_cfg.get("panel") or {}
    nd = node_cfg.get("node") or {}
    if not panel.get("url") or not panel.get("token"):
        sys.exit("config needs a 'panel' block with url + token")
    url = panel["url"].rstrip("/") + "/api/node/sync"
    token = panel["token"]
    interval = nd.get("interval", 5)
    online_max = nd.get("online_max", 180)
    agent = nd.get("agent", "/opt/swg-agent/swg-agent")
    sudo = bool(nd.get("sudo"))
    os.makedirs(STATE_DIR, exist_ok=True)
    last_samples = {}
    update_started = False                          # spawn the self-updater at most once per process
    print(f"swg-noded: panel={panel['url']} interval={interval}s "
          f"ifaces={list((node_cfg.get('interfaces') or {}).keys())}", flush=True)
    while True:
        t0 = time.time()
        try:
            snap = build_snapshot(node_cfg, online_max, last_samples)
            status, reply = post_json(url, token, {"snapshot": snap}, panel)
            if status == 200 and isinstance(reply.get("desired"), dict):
                if reply.get("update") and not update_started:        # panel asked us to self-update
                    update_started = run_self_update(node_cfg, reply["update"])
                cr = create_ifaces(node_cfg, reply.get("create"), agent, sudo)   # create new interfaces
                dl = delete_ifaces(node_cfg, reply.get("delete"), agent, sudo)   # tear down deleted ones
                ob = onboard_ifaces(node_cfg, reply.get("onboard"))   # add panel-requested interfaces first
                tp = apply_turn(reply.get("turn"), reply.get("turn_onboard"))   # turn-proxy manage/onboard
                # surface iface command failures to the panel too (cmd_errors), keyed by iface name
                for blk in (cr, dl, ob):
                    for e in blk["errors"]:
                        k, _, m = e.partition(": ")
                        NODE_ERRORS[k] = m or e
                for k in (cr.get("created", []) + dl.get("deleted", []) + ob.get("added", [])):
                    NODE_ERRORS.pop(k, None)
                # prune errors for requests the panel has since cleared (iface + turn)
                active = (set(reply.get("create") or {}) | set(reply.get("onboard") or {})
                          | set(reply.get("delete") or []) | set(reply.get("turn") or {})
                          | set(reply.get("turn_onboard") or []))
                for k in list(NODE_ERRORS):
                    if k not in active:
                        NODE_ERRORS.pop(k, None)
                r = reconcile(node_cfg, reply["desired"], agent, sudo)
                ri = reconcile_ifaces(node_cfg, reply.get("desired_ifaces") or {}, agent, sudo)
                if (r["added"] or r["removed"] or r["errors"] or ri["changed"] or ri["errors"]
                        or ob["added"] or ob["errors"] or cr["created"] or cr["errors"]
                        or dl["deleted"] or dl["errors"] or tp["done"] or tp["errors"]):
                    print(f"reconcile: +{r['added']} -{r['removed']} ifaces~{ri['changed']} "
                          f"onboard+{ob['added']} create+{cr['created']} delete-{dl['deleted']} turn={tp['done']} "
                          f"errors={(r['errors'] + ri['errors'] + ob['errors'] + cr['errors'] + dl['errors'] + tp['errors'])[:3]}", flush=True)
                interval = reply.get("interval", interval)
            elif status == 0:
                print("sync error:", reply.get("error"), flush=True)
            else:
                print(f"sync HTTP {status}: {reply.get('error')}", flush=True)
        except Exception as e:
            print("loop error:", e, flush=True)
        time.sleep(max(0.5, interval - (time.time() - t0)))


if __name__ == "__main__":
    main()
