# ───────────────────────── parsing (pure) ─────────────────────────

def parse_dump(out):
    lines = out.strip().splitlines()
    iface_line = lines[0].split("\t") if lines else []
    peers = []
    for line in lines[1:]:
        f = line.split("\t")
        if len(f) < 8:
            continue
        peers.append({
            "public_key": f[0],
            "preshared_key": None if f[1] in ("(none)", "") else f[1],   # keep PSK so adoption can reuse it
            "endpoint": None if f[2] in ("(none)", "") else f[2],
            "allowed_ips": f[3],
            "last_handshake": int(f[4]) if f[4].isdigit() else 0,
            "rx_bytes": int(f[5]) if f[5].isdigit() else 0,
            "tx_bytes": int(f[6]) if f[6].isdigit() else 0,
        })
    return iface_line, peers


def parse_interface_section(conf_text):
    info, in_iface = {}, False
    for line in conf_text.splitlines():
        s = line.strip()
        if s.startswith("["):
            in_iface = (s.lower() == "[interface]")
            continue
        if in_iface and "=" in s and not s.startswith("#"):
            k, v = s.split("=", 1)
            info[k.strip()] = v.strip()
    return info


def awg_params(info):
    out = {}
    for k in AWG_KEYS:
        if k in info:
            v = info[k]
            out[k] = int(v) if v.isdigit() else v
    return out


def derive_pubkey(cmd, priv):
    """Server public key from a private key (used when the interface is down / dump is empty)."""
    if not priv:
        return None
    try:
        out = run((cmd or ["awg"]) + ["pubkey"], input_text=priv + "\n").stdout.strip()
        return out or None
    except Exception:
        return None


def build_meta(iface_line, conf_text, endpoint_host, dns, cmd=None):
    info = parse_interface_section(conf_text)
    addr = info.get("Address", "").split(",")[0].strip()
    subnet = None
    if addr and "/" in addr:
        try:
            import ipaddress
            subnet = str(ipaddress.ip_network(addr, strict=False))
        except Exception:
            subnet = addr.rsplit("/", 1)[0]
    port = int(iface_line[2]) if len(iface_line) > 2 and iface_line[2].isdigit() else None
    if not port and str(info.get("ListenPort", "")).strip().isdigit():   # fall back to the .conf
        port = int(str(info["ListenPort"]).strip())
    pub = iface_line[1] if len(iface_line) > 1 and iface_line[1] else derive_pubkey(cmd, info.get("PrivateKey"))
    return {
        "public_key": pub,
        "listen_port": port,
        "endpoint": (f"{endpoint_host}:{port}" if endpoint_host and port else None),
        "address": addr or None,
        "subnet": subnet,
        "awg_params": awg_params(info),
        "dns": dns or [],
    }


# ───────── interface keypair backup (the node keeps a copy of each iface's blessed identity) ─────────
# The panel only ever stores the PUBLIC key, so it can't revert a server-key change on its own. Instead
# the NODE keeps a local backup of {private_key, public_key, listen_port, address} per interface — the
# private key is already in the .conf, so this adds no new exposure. If the live key diverges, the panel
# flags it and can ask the node to Restore (from this backup) or Adopt (re-baseline the backup).
IFACE_KEYS_DIR = "/var/lib/swg-noded/iface-keys"
def _iface_backup_path(iface): return os.path.join(IFACE_KEYS_DIR, iface + ".json")

def harvest_iface_backup(conf_text, cmd=None):
    """Blessed-identity record from a .conf, or None if it has no private key."""
    info = parse_interface_section(conf_text)
    priv = (info.get("PrivateKey") or "").strip()
    if not priv:
        return None
    port = str(info.get("ListenPort", "")).strip()
    return {"private_key": priv, "public_key": derive_pubkey(cmd, priv),
            "listen_port": int(port) if port.isdigit() else None,
            "address": (info.get("Address", "").split(",")[0].strip() or None),
            "saved_at": int(time.time())}

def write_iface_backup(iface, rec):
    with contextlib.suppress(Exception):
        os.makedirs(IFACE_KEYS_DIR, exist_ok=True)
        p = _iface_backup_path(iface); tmp = p + ".tmp"
        with open(tmp, "w") as f:
            json.dump(rec, f)
        os.chmod(tmp, 0o600); os.replace(tmp, p)

def read_iface_backup(iface):
    with contextlib.suppress(Exception):
        with open(_iface_backup_path(iface)) as f:
            return json.load(f)
    return None

def ensure_iface_backup(iface, conf_text, cmd=None):
    """Write a backup if one doesn't exist yet — covers create/onboard/install/first-sight. Re-install
    and conversion overwrite it explicitly; Adopt re-baselines it via a panel request."""
    if not conf_text or os.path.exists(_iface_backup_path(iface)):
        return
    rec = harvest_iface_backup(conf_text, cmd)
    if rec:
        write_iface_backup(iface, rec)


def peer_view(peers, last, dt, online_max, now):
    out = []
    for p in peers:
        age = (now - p["last_handshake"]) if p["last_handshake"] else None
        prev = last.get(p["public_key"])
        rs = ts = 0.0
        if prev and dt > 0:
            rs = max(0, p["rx_bytes"] - prev[0]) / dt
            ts = max(0, p["tx_bytes"] - prev[1]) / dt
        out.append({
            "public_key": p["public_key"], "endpoint": p["endpoint"],
            "preshared_key": p.get("preshared_key"),   # so adoption can reuse the on-wire PSK (panel owns PSKs)
            "allowed_ips": p["allowed_ips"], "rx_bytes": p["rx_bytes"], "tx_bytes": p["tx_bytes"],
            "rx_speed": rs, "tx_speed": ts,
            "last_handshake": p["last_handshake"] or None, "handshake_age": age,
            "online": age is not None and age <= online_max,
        })
    return out


# ───────────────────────── node health (cheap: /proc + statvfs, no subprocess) ─────────────────────────
#
# Everything here reads in-kernel pseudo-files (/proc/{loadavg,meminfo,uptime,stat}) and
# does one statvfs() syscall per mount — microseconds total, no process spawns. Far cheaper
# than the `awg show dump` we already run per interface, so sampling it every loop is free.
# proc_root / statvfs are injectable so the parsing is testable against a fixture.

def _read_proc(proc_root, name):
    with open(os.path.join(proc_root, name)) as f:
        return f.read()


def read_loadavg(proc_root="/proc"):
    p = _read_proc(proc_root, "loadavg").split()
    return [float(p[0]), float(p[1]), float(p[2])]


def read_meminfo(proc_root="/proc"):
    vals = {}
    for line in _read_proc(proc_root, "meminfo").splitlines():
        k, _, rest = line.partition(":")
        f = rest.split()
        if f and f[0].isdigit():
            vals[k] = int(f[0]) * 1024          # kB -> bytes
    total = vals.get("MemTotal", 0)
    avail = vals.get("MemAvailable", vals.get("MemFree", 0))   # MemAvailable fallback for old kernels
    mem = {"total": total, "available": avail, "used": max(0, total - avail)}
    if "SwapTotal" in vals:
        mem["swap_total"] = vals["SwapTotal"]
        mem["swap_used"] = max(0, vals["SwapTotal"] - vals.get("SwapFree", 0))
    return mem


def read_uptime(proc_root="/proc"):
    return float(_read_proc(proc_root, "uptime").split()[0])


def read_ncpu(proc_root="/proc"):
    with contextlib.suppress(Exception):
        n = sum(1 for ln in _read_proc(proc_root, "stat").splitlines()
                if ln.startswith("cpu") and len(ln) > 3 and ln[3].isdigit())
        if n:
            return n
    return os.cpu_count() or 1


def disk_usage(mount, statvfs=os.statvfs):
    st = statvfs(mount)
    total = st.f_blocks * st.f_frsize
    return {"mount": mount, "total": total,
            "used": max(0, total - st.f_bfree * st.f_frsize),
            "free": st.f_bavail * st.f_frsize}


def collect_health(proc_root="/proc", mounts=None, statvfs=os.statvfs):
    """A small per-node health block. Each field is collected independently and a failure
    in one (e.g. a missing /proc file in a stripped container) never sinks the rest."""
    mounts = mounts if mounts is not None else ["/"]
    h = {}
    with contextlib.suppress(Exception):
        h["load"] = read_loadavg(proc_root)
    with contextlib.suppress(Exception):
        h["ncpu"] = read_ncpu(proc_root)
    with contextlib.suppress(Exception):
        h["mem"] = read_meminfo(proc_root)
    with contextlib.suppress(Exception):
        h["uptime"] = read_uptime(proc_root)
    disks = []
    for m in mounts:
        with contextlib.suppress(Exception):
            disks.append(disk_usage(m, statvfs))
    if disks:
        h["disk"] = disks
    return h


# ───────────────────────── io ─────────────────────────

def run(args, input_text=None, timeout=20):
    return subprocess.run(args, input=input_text, capture_output=True, text=True, timeout=timeout)


def run_agent(agent, sudo, payload):
    prefix = ["sudo", "-n"] if sudo else []
    try:
        p = run(prefix + [agent], input_text=json.dumps(payload))
    except Exception as e:
        return {"ok": False, "op": payload.get("op"), "error": str(e), "code": "internal"}
    out = (p.stdout or "").strip()
    if not out:
        return {"ok": False, "op": payload.get("op"),
                "error": (p.stderr or "").strip() or "no response", "code": "internal"}
    try:
        return json.loads(out)
    except json.JSONDecodeError:
        return {"ok": False, "op": payload.get("op"), "error": "agent non-JSON", "code": "internal"}


def post_json(url, token, obj, panel, timeout=20):
    """POST JSON to the panel. TLS posture comes from `panel`:
         fingerprint set -> pin sha256 (verified during the handshake, before any
                            bytes are sent, and fails closed if it can't be read);
         verify true     -> system CA verification;
         otherwise       -> unverified (self-signed; encrypted but no MITM protection).
    Returns (status, dict). status 0 means the request never completed."""
    body = json.dumps(obj).encode()
    headers = {"Content-Type": "application/json", "Authorization": "Bearer " + token}
    u = urllib.parse.urlparse(url)
    host = u.hostname
    port = u.port or (443 if u.scheme == "https" else 80)
    path = (u.path or "/") + (("?" + u.query) if u.query else "")
    fp = (panel.get("fingerprint") or "").replace(":", "").lower().strip()
    conn = None
    try:
        if u.scheme == "http":
            conn = http.client.HTTPConnection(host, port, timeout=timeout)
        elif u.scheme == "https":
            if panel.get("verify", False) and not fp:
                ctx = ssl.create_default_context()
            else:
                ctx = ssl._create_unverified_context()
            conn = http.client.HTTPSConnection(host, port, timeout=timeout, context=ctx)
            if fp:
                conn.connect()                      # TLS handshake before sending the token
                der = conn.sock.getpeercert(True)
                if not der or hashlib.sha256(der).hexdigest() != fp:
                    return 0, {"error": "tls fingerprint mismatch"}
        else:
            return 0, {"error": f"unsupported url scheme {u.scheme!r}"}
        conn.request("POST", path, body=body, headers=headers)
        resp = conn.getresponse()
        data = (resp.read().decode() or "{}")
        if resp.status >= 400:
            return resp.status, {"error": data[:200]}
        return resp.status, json.loads(data)
    except Exception as e:
        return 0, {"error": str(e)}
    finally:
        if conn is not None:
            with contextlib.suppress(Exception):
                conn.close()


# ───────────────────────── snapshot ─────────────────────────

_TURN_READ = {"at": 0.0}
def _read_units_live(svcs):
    """Batched read of the live .service ExecStart for several units (one host call). svc -> unit text."""
    if not svcs:
        return {}
    cmd = "; ".join("printf '@@SWG@@%s\\n' " + shlex.quote(s) + "; cat " + shlex.quote(_turn_unit_path(s)) + " 2>/dev/null"
                    for s in svcs)
    out = host_sh(cmd).stdout or ""
    res = {}; cur = None; buf = []
    for ln in out.splitlines():
        if ln.startswith("@@SWG@@"):
            if cur is not None:
                res[cur] = "\n".join(buf)
            cur = ln[len("@@SWG@@"):]; buf = []
        elif cur is not None:
            buf.append(ln)
    if cur is not None:
        res[cur] = "\n".join(buf)
    return res

def _list_turn_units():
    """Bare-metal turn-proxy services present on disk (vk-turn-proxy-*.service in /etc/systemd/system).
    None on a read error (so the caller keeps the record rather than wiping it); [] means genuinely none."""
    try:
        files = os.listdir("/etc/systemd/system")
    except OSError:
        return None
    return [f[:-len(".service")] for f in files if f.startswith("vk-turn-proxy-") and f.endswith(".service")]

TURN_PENDING_DIR = "/var/lib/swg-noded/turn-pending"   # an installer/convert drops "<svc>" here (listen\nconnect\nowner) WHILE setting a turn-proxy up
def _turn_installing_markers():
    """Turn-proxies an installer/convert is actively setting up right now (fresh markers only, < 5min — a
    crashed installer's stale marker is ignored). svc -> {listen, connect, owner}. Surfaced as 'installing'."""
    out = {}
    try:
        names = os.listdir(TURN_PENDING_DIR)
    except OSError:
        return out
    for f in names:
        p = os.path.join(TURN_PENDING_DIR, f)
        try:
            if time.time() - os.path.getmtime(p) > 300:
                continue
            with open(p) as fh:
                ls = fh.read().splitlines()
        except OSError:
            continue
        out[f] = {"listen": (ls[0] if len(ls) > 0 else ""), "connect": (ls[1] if len(ls) > 1 else ""), "owner": (ls[2] if len(ls) > 2 else "")}
    return out

def load_turn_proxies():
    """Turn-proxies installed on this box — listen/connect/wrap_key/params. Refreshed from the LIVE
    .service files (throttled) so direct edits on the server show up on the panel."""
    try:
        with open(TURN_RECORD) as f:
            d = json.load(f)
        tp = d.get("turn_proxies") if isinstance(d, dict) else None
        tp = tp if isinstance(tp, list) else []
    except Exception:
        return []
    if TURN_DOCKER:                 # container model — the record IS the config; just flag running via docker ps
        # defensive dedup: collapse any same-service duplicates (last wins, like apply_turn / bare-metal) so a
        # hand-edited or round-tripped record can't surface a proxy twice or have two entries fight one container.
        seen = {}; uniq = []
        for t in tp:
            s = t.get("service")
            if not s:
                continue
            if s in seen:
                uniq[seen[s]] = t
            else:
                seen[s] = len(uniq); uniq.append(t)
        tp = uniq
        _dturn_attach_running(tp)
        _attach_turn_version(tp)
        return tp
    nowt = time.time()
    on_disk = _list_turn_units()   # bare-metal: the units on disk are the source of truth — reconcile the list
    if on_disk is not None:        # to them so convert/installer/hand-created units show (and deleted ones drop)
        rec_by = {t.get("service"): t for t in tp if t.get("service")}
        tp = [rec_by.get(svc) or {"service": svc} for svc in on_disk]
    if TURN_MANAGE_ON and (any("params" not in t for t in tp) or nowt - _TURN_READ["at"] >= 20):
        units = _read_units_live([t["service"] for t in tp if t.get("service")])
        changed = False
        for t in tp:
            u = units.get(t.get("service"))
            if not u:
                continue
            live = _tp_from_unit(t["service"], u)
            for k in ("listen", "connect", "wrap_key", "params"):
                if t.get(k) != live.get(k):
                    t[k] = live.get(k); changed = True
        _TURN_READ["at"] = nowt
        if changed:
            with contextlib.suppress(Exception):
                tmp = TURN_RECORD + ".tmp"
                with open(tmp, "w") as f:
                    json.dump({"turn_proxies": tp}, f)
                os.replace(tmp, TURN_RECORD)
    _attach_turn_running(tp)
    _attach_turn_version(tp)
    marks = _turn_installing_markers()   # an installer/convert is setting these up → show "installing" (synthetic entry if no unit yet)
    if marks:
        have = {t.get("service") for t in tp}
        for svc, m in marks.items():
            if svc in have:
                for t in tp:
                    if t.get("service") == svc and t.get("running") is not True:
                        t["installing"] = True
            else:
                tp.append({"service": svc, "listen": m["listen"], "connect": m["connect"],
                           "owner": m["owner"], "running": False, "installing": True})
    return tp

_TURN_RUN = {"at": 0.0, "map": {}}
def _attach_turn_running(tps):
    """Live `running` flag per turn-proxy (one batched `systemctl is-active`, throttled to 20s) so the
    panel can grey out a crash-looping service (e.g. a -listen IP not local → bind fails)."""
    svcs = [t["service"] for t in tps if t.get("service")]
    if not svcs or not TURN_MANAGE_ON:
        return
    nowt = time.time()
    if nowt - _TURN_RUN["at"] >= 20:
        cmd = "for s in " + " ".join(shlex.quote(s) for s in svcs) + \
              "; do printf '%s=%s\\n' \"$s\" \"$(systemctl is-active \"$s\" 2>/dev/null)\"; done"
        m = {}
        for ln in (host_sh(cmd).stdout or "").splitlines():
            s, _, state = ln.partition("=")
            if s:
                m[s] = (state.strip() == "active")
        _TURN_RUN["at"] = nowt; _TURN_RUN["map"] = m
    for t in tps:
        if t.get("service") in _TURN_RUN["map"]:
            t["running"] = _TURN_RUN["map"][t["service"]]


def list_node_ips():
    """The node's own IPv4 addresses (candidates for a per-interface egress/source IP), excluding
    loopback + tunnel/bridge devices. On a docker host-net node this is the HOST's addresses."""
    ips = []
    try:
        out = run(["ip", "-4", "-o", "addr", "show"]).stdout
    except Exception:
        return ips
    for ln in out.splitlines():
        p = ln.split()
        if len(p) < 4 or p[2] != "inet":
            continue
        dev, ip = p[1], p[3].split("/")[0]
        if dev == "lo" or dev.startswith(("wg", "awg", "dawg", "docker", "br-", "veth", "kube", "cni", "flannel")):
            continue
        if ip.startswith("127.") or ip in ips:
            continue
        ips.append(ip)
    return ips


def list_node_ip_ifaces():
    """The node's (ipv4, nic) pairs — for the merged egress picker (a source IP always lives on a NIC)."""
    pairs = []
    try:
        out = run(["ip", "-4", "-o", "addr", "show"]).stdout
    except Exception:
        return pairs
    for ln in out.splitlines():
        p = ln.split()
        if len(p) < 4 or p[2] != "inet":
            continue
        dev, ip = p[1], p[3].split("/")[0]
        if dev == "lo" or dev.startswith(("wg", "awg", "dawg", "docker", "br-", "veth", "kube", "cni", "flannel")):
            continue
        if ip.startswith("127.") or any(x["ip"] == ip for x in pairs):
            continue
        pairs.append({"ip": ip, "iface": dev})
    return pairs


def list_node_ifaces():
    """The node's WAN-candidate NIC names (devices carrying a non-loopback IPv4) — for the egress -o."""
    ifs = []
    try:
        out = run(["ip", "-4", "-o", "addr", "show"]).stdout
    except Exception:
        return ifs
    for ln in out.splitlines():
        p = ln.split()
        if len(p) < 4 or p[2] != "inet":
            continue
        dev, ip = p[1], p[3].split("/")[0]
        if dev == "lo" or dev.startswith(("wg", "awg", "dawg", "docker", "br-", "veth", "kube", "cni", "flannel")):
            continue
        if ip.startswith("127.") or dev in ifs:
            continue
        ifs.append(dev)
    return ifs


def _detect_wan():
    out = run(["sh", "-c", "ip -4 route get 1.1.1.1 2>/dev/null"]).stdout
    m = re.search(r" dev (\S+)", out or "")
    return m.group(1) if m else "eth0"


def _iface_subnet(node_cfg, iface):
    """The interface's tunnel subnet (CIDR) read from its conf Address — for the egress SNAT match."""
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    try:
        with open(ic.get("conf", "")) as f:
            m = re.search(r"(?im)^\s*Address\s*=\s*([^\s,]+)", f.read())
    except Exception:
        return ""
    if not m:
        return ""
    import ipaddress
    try:
        return str(ipaddress.ip_network(m.group(1), strict=False))
    except Exception:
        return ""


def reconcile_egress(node_cfg, desired_ifaces):
    """Option-I source-NAT: per interface, ensure an SNAT rule to its chosen egress_ip (tagged with a
    'swg-egress:<iface>' comment, inserted ahead of the default MASQUERADE), replace it on change, and
    remove it when cleared (→ falls back to MASQUERADE). Runs iptables directly (root on bare-metal;
    container root + NET_ADMIN + host netns on docker)."""
    res = {"changed": 0, "errors": []}
    if not desired_ifaces:
        return res
    try:
        rules = run(["iptables", "-t", "nat", "-S", "POSTROUTING"]).stdout.splitlines()
    except Exception as e:
        res["errors"].append("iptables list: " + str(e)); return res
    default_wan = _detect_wan()
    for iface in (node_cfg.get("interfaces") or {}):
        want = (desired_ifaces or {}).get(iface) or {}
        egress = (want.get("egress_ip") or "").strip()
        wan_ov = (want.get("wan_iface") or "").strip()
        subnet = _iface_subnet(node_cfg, iface)
        if not subnet:
            continue
        tag = "swg-egress:" + iface
        if egress:                                            # SNAT to a chosen source IP, out a chosen/auto WAN
            des = ("SNAT", wan_ov or default_wan, egress)
        elif wan_ov:                                          # just pin the WAN egress interface
            des = ("MASQUERADE", wan_ov, "")
        else:
            des = None
        existing = [ln for ln in rules if ("--comment " + tag) in ln]
        cur = None
        if existing:
            o = re.search(r"-o (\S+)", existing[0]); src = re.search(r"--to-source (\S+)", existing[0])
            cur = ("SNAT" if "SNAT" in existing[0] else "MASQUERADE", o.group(1) if o else "", src.group(1) if src else "")
        if cur == des:
            continue
        for ln in existing:                                   # drop stale rule(s)
            run(["sh", "-c", "iptables -t nat " + ln.replace("-A POSTROUTING", "-D POSTROUTING", 1)])
        if des:
            args = ["iptables", "-t", "nat", "-I", "POSTROUTING", "-s", subnet, "-o", des[1],
                    "-m", "comment", "--comment", tag, "-j", des[0]]
            if des[0] == "SNAT":
                args += ["--to-source", des[2]]
            r = run(args)
            if r.returncode != 0:
                res["errors"].append("egress " + iface + ": " + (r.stderr or "").strip()[:120]); continue
        res["changed"] += 1
    return res


def build_snapshot(node_cfg, online_max, last_samples, now=None):
    now = now or int(time.time())
    hcfg = node_cfg.get("health") or {}
    interfaces = {}
    stopped_set = _load_stopped_ifaces()   # interfaces the operator deliberately stopped → "stopped", not "down"
    for iface, ic in (node_cfg.get("interfaces") or {}).items():
        cmd = ic.get("cmd", ["awg"])
        try:                                        # one bad interface must never kill the whole snapshot
            _r = run(cmd + ["show", iface, "dump"])
            if _r.returncode != 0:                  # interface isn't up — flag it, but still surface its
                try:                                # intended config from the .conf (subnet/awg/port/pubkey)
                    conf_text = open(ic["conf"]).read()
                except OSError:
                    conf_text = ""
                _meta = build_meta([], conf_text, ic.get("endpoint_host") or node_cfg.get("endpoint_host"),
                                   node_cfg.get("dns", []), cmd)
                if iface in stopped_set:            # the operator stopped it — a choice, not a failure (no error)
                    interfaces[iface] = {"peers": [], "meta": _meta, "stopped": True}
                else:
                    interfaces[iface] = {"peers": [], "meta": _meta,
                        "down": ((_r.stderr or "").strip() or "interface is not up")[:140]}
                ensure_iface_backup(iface, conf_text, cmd)
                continue
            dump = _r.stdout
            iface_line, raw = parse_dump(dump)
            try:
                conf_text = open(ic["conf"]).read()
            except OSError:
                conf_text = ""
            st = last_samples.setdefault(iface, {"peers": {}, "t": now})
            dt = max(1e-6, now - st["t"])
            peers = peer_view(raw, st["peers"], dt, online_max, now)
            st["peers"] = {p["public_key"]: (p["rx_bytes"], p["tx_bytes"]) for p in raw}
            st["t"] = now
            interfaces[iface] = {
                "peers": peers,
                "meta": build_meta(iface_line, conf_text,
                                   ic.get("endpoint_host") or node_cfg.get("endpoint_host"),
                                   node_cfg.get("dns", []), cmd),
            }
            if iface in stopped_set:               # it's up again (e.g. brought up outside the panel) → clear the stopped mark
                _set_iface_stopped(iface, False)
            ensure_iface_backup(iface, conf_text, cmd)
        except Exception as e:
            print(f"snapshot: skipping {iface}: {e}", flush=True)
            continue
    snap = {"hostname": socket.gethostname(), "generated_at": now,
            "interfaces": interfaces, "turn_proxies": load_turn_proxies(),
            "noded_version": NODED_VERSION, "kind": NODE_KIND, "net_mode": NODE_NET,
            "turn_manage": TURN_MANAGE, "cmd_errors": dict(NODE_ERRORS), "cmd_progress": dict(NODE_PROGRESS),
            "node_ips": list_node_ips(), "node_ifaces": list_node_ifaces(),
            "node_ip_ifaces": list_node_ip_ifaces()}
    if hcfg.get("enabled", True):      # additive + opt-out; mounts default to ["/"]
        snap["health"] = collect_health(mounts=hcfg.get("mounts"))
    return snap


# ───────────────────────── reconcile ─────────────────────────

def current_pubkeys(node_cfg, iface):
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    cmd = ic.get("cmd", ["awg"])
    try:
        r = run(cmd + ["show", iface, "dump"])
        if r.returncode != 0:                       # interface down / no such device — NOT "zero peers"
            return None
        _, peers = parse_dump(r.stdout)
        return {p["public_key"] for p in peers}
    except Exception:
        return None


def current_listen_port(node_cfg, iface):
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    cmd = ic.get("cmd", ["awg"])
    try:
        r = run(cmd + ["show", iface, "dump"])
        if r.returncode == 0:
            iface_line, _ = parse_dump(r.stdout)
            if len(iface_line) > 2 and str(iface_line[2]).isdigit():
                return int(iface_line[2])
    except Exception:
        pass
    try:                                  # interface DOWN — fall back to the .conf so a port change still
        info = parse_interface_section(open(ic["conf"]).read())   # converges (set-iface persists it for next up)
        lp = str(info.get("ListenPort", "")).strip()
        return int(lp) if lp.isdigit() else None
    except Exception:
        return None


def current_awg(node_cfg, iface):
    ic = (node_cfg.get("interfaces") or {}).get(iface) or {}
    try:
        with open(ic["conf"]) as f:
            return awg_params(parse_interface_section(f.read()))
    except Exception:
        return None


def reconcile_ifaces(node_cfg, desired_ifaces, agent, sudo):
    """Apply the panel's desired interface config (listen port and/or AmneziaWG params). Only
    ever called on a valid sync reply; converges the live interface to the panel's target."""
    res = {"changed": 0, "errors": []}
    for iface, want in (desired_ifaces or {}).items():
        if iface not in (node_cfg.get("interfaces") or {}):
            continue
        payload = {"op": "set-iface", "iface": iface}
        port = want.get("listen_port")
        if port:
            cur = current_listen_port(node_cfg, iface)
            if cur is not None and int(cur) != int(port):
                payload["listen_port"] = int(port)
        awg = want.get("awg_params")
        if isinstance(awg, dict) and awg:
            cur_awg = current_awg(node_cfg, iface) or {}
            want_s = {k: str(v) for k, v in awg.items()}
            if any(str(cur_awg.get(k)) != v for k, v in want_s.items()):
                payload["awg_params"] = awg
        if len(payload) <= 2:                 # only op + iface — nothing differs
            continue
        r = run_agent(agent, sudo, payload)
        if r.get("ok"):
            res["changed"] += 1
        else:
            res["errors"].append(f"set-iface {iface}: {r.get('error')}")
    return res


def reconcile(node_cfg, desired_by_iface, agent, sudo, remove_by_iface=None):
    """Apply the panel's desired peer set. Only ever called on a valid sync reply."""
    res = {"added": 0, "removed": 0, "errors": []}
    remove_by_iface = remove_by_iface or {}
    for iface, ic in (node_cfg.get("interfaces") or {}).items():
        desired = {p["public_key"]: p for p in (desired_by_iface.get(iface) or [])}
        current = current_pubkeys(node_cfg, iface)
        if current is None:
            res["errors"].append(f"{iface}: cannot read interface")
            continue
        # EXPLICIT retirements from the panel (a key it rotated/deleted) FIRST — removed even on an
        # add-only interface, and before the add below so the replacement key can take the freed IP.
        for pk in remove_by_iface.get(iface, []):
            if pk in current and pk not in desired:
                r = run_agent(agent, sudo, {"op": "remove-peer", "iface": iface, "public_key": pk})
                if r.get("ok"):
                    res["removed"] += 1; current.discard(pk)
                else:
                    res["errors"].append(f"retire {pk[:8]}: {r.get('error')}")
        for pk, p in desired.items():
            if pk in current:
                continue
            r = run_agent(agent, sudo, {
                "op": "add-peer", "iface": iface, "public_key": pk,
                "allowed_ips": p.get("allowed_ips", ""),
                "preshared_key": p.get("preshared_key", "none"),
                "name": p.get("name", "")})
            if r.get("ok"):
                res["added"] += 1
            else:
                res["errors"].append(f"add {pk[:8]}: {r.get('error')}")
        # An onboarded interface is ADD-ONLY: the panel never removes peers it didn't create, so an
        # interface adopted from another tool (e.g. wg-easy) keeps its existing peers. They surface
        # as adoptable orphans instead of being wiped.
        if ic.get("onboarded"):
            continue
        for pk in current - set(desired):
            r = run_agent(agent, sudo, {"op": "remove-peer", "iface": iface, "public_key": pk})
            if r.get("ok"):
                res["removed"] += 1
            else:
                res["errors"].append(f"remove {pk[:8]}: {r.get('error')}")
    return res


def onboard_ifaces(node_cfg, onboard):
    """Add panel-requested interfaces to this node's managed set (config.json) when they exist
    locally — for a wg/awg interface the panel didn't auto-detect. Once added, build_snapshot
    reports it and the panel closes the request (no separate ack needed). Only ever on a 200."""
    res = {"added": [], "errors": []}
    if not onboard:
        return res
    ifaces = node_cfg.setdefault("interfaces", {})
    changed = False
    for iface, want in onboard.items():
        if iface in ifaces:                 # already managed — nothing to do (panel will clear it)
            continue
        cmd = want.get("cmd") or ["awg"]
        conf = want.get("conf") or ""
        try:
            if not conf or not os.path.exists(conf):
                res["errors"].append(f"{iface}: conf not found ({conf})"); continue
            if cmd == ["auto"]:                     # "Existing" gave no protocol — detect it from the conf
                info = parse_interface_section(open(conf).read())
                cmd = ["awg"] if any(k in info for k in AWG_KEYS) else ["wg"]
                try:
                    run(cmd + ["show", iface, "dump"])
                except Exception:
                    cmd = ["wg"] if cmd == ["awg"] else ["awg"]   # fall back to the other tool
            run(cmd + ["show", iface, "dump"])      # raises if the interface isn't actually up
        except Exception as e:
            res["errors"].append(f"{iface}: {e}"); continue
        ifaces[iface] = {"cmd": cmd, "conf": conf, "onboarded": True}   # add-only: never wipe its peers
        try:                                            # persist the marker in the conf so a docker restart
            with open(conf) as _f: _t = _f.read()       # (config.json rebuilt from confs) keeps it add-only
            if "#swg:onboarded" not in _t:
                with open(conf, "w") as _f: _f.write("#swg:onboarded\n" + _t)
        except OSError:
            pass
        changed = True
        res["added"].append(iface)
    if changed:
        try:
            _persist_config(node_cfg)
        except Exception as e:
            res["errors"].append(f"persist config.json: {e}")
    return res


def restart_ifaces(node_cfg, restart, agent, sudo):
    """Bounce panel-requested interfaces (<tool>-quick down/up) via swg-agent — recovers a DOWN one."""
    res = {"restarted": [], "errors": []}
    for iface in (restart or []):
        if iface not in (node_cfg.get("interfaces") or {}):
            continue
        r = run_agent(agent, sudo, {"op": "restart-iface", "iface": iface})
        if r.get("ok"):
            res["restarted"].append(iface); _set_iface_stopped(iface, False)   # a restart brings it back up
        else:
            res["errors"].append(f"{iface}: {r.get('error')}")
    return res


# interfaces the operator deliberately stopped from the panel → reported as "stopped" (not "down": it's a
# choice, not a failure). Persisted so it survives a daemon restart. Cleared when the interface is started.
IFACE_STOPPED_FILE = os.path.join(STATE_DIR, "iface-stopped.json")
def _load_stopped_ifaces():
    try:
        with open(IFACE_STOPPED_FILE) as f:
            v = json.load(f)
        return set(v) if isinstance(v, list) else set()
    except Exception:
        return set()
def _set_iface_stopped(iface, stopped):
    s = _load_stopped_ifaces()
    if (iface in s) == bool(stopped):
        return
    s.add(iface) if stopped else s.discard(iface)
    with contextlib.suppress(Exception):
        os.makedirs(STATE_DIR, exist_ok=True)
        tmp = IFACE_STOPPED_FILE + ".tmp"
        with open(tmp, "w") as f:
            json.dump(sorted(s), f)
        os.replace(tmp, IFACE_STOPPED_FILE)


def stop_ifaces(node_cfg, stop, agent, sudo):
    """Stop panel-requested interfaces (down + disable, conf kept) — they stay down until started again."""
    res = {"stopped": [], "errors": []}
    for iface in (stop or []):
        if iface not in (node_cfg.get("interfaces") or {}):
            continue
        r = run_agent(agent, sudo, {"op": "stop-iface", "iface": iface})
        if r.get("ok"):
            res["stopped"].append(iface); _set_iface_stopped(iface, True)   # mark as a deliberate stop, not a failure
        else:
            res["errors"].append(f"{iface}: {r.get('error')}")
    return res


def start_ifaces(node_cfg, start, agent, sudo):
    """Start panel-requested interfaces (up + enable)."""
    res = {"started": [], "errors": []}
    for iface in (start or []):
        if iface not in (node_cfg.get("interfaces") or {}):
            continue
        r = run_agent(agent, sudo, {"op": "start-iface", "iface": iface})
        if r.get("ok"):
            res["started"].append(iface); _set_iface_stopped(iface, False)   # no longer stopped
        else:
            res["errors"].append(f"{iface}: {r.get('error')}")
    return res


def apply_iface_keys(node_cfg, iface_key, agent, sudo):
    """Panel keypair requests per interface: 'rebaseline' overwrites the on-disk backup from the live
    conf (after an Adopt); 'restore' re-keys the interface from that backup + bounces it (a Restore)."""
    res = {"done": [], "errors": []}
    for iface, req in (iface_key or {}).items():
        ic = (node_cfg.get("interfaces") or {}).get(iface)
        if not ic:
            continue
        action = (req or {}).get("action")
        cmd = ic.get("cmd", ["awg"])
        try:
            if action == "rebaseline":
                conf_text = ""
                with contextlib.suppress(OSError):
                    conf_text = open(ic["conf"]).read()
                rec = harvest_iface_backup(conf_text, cmd) if conf_text else None
                if rec:
                    write_iface_backup(iface, rec); res["done"].append(iface)
            elif action == "restore":
                bak = read_iface_backup(iface)
                if not bak or not bak.get("private_key"):
                    res["errors"].append(iface + ": no keypair backup to restore from"); continue
                r = run_agent(agent, sudo, {"op": "restore-iface-key", "iface": iface, "conf": ic["conf"],
                                            "private_key": bak["private_key"], "listen_port": bak.get("listen_port"),
                                            "address": bak.get("address")})
                if r.get("ok"):
                    res["done"].append(iface)
                else:
                    res["errors"].append(iface + ": " + str(r.get("error")))
        except Exception as e:
            res["errors"].append(iface + ": " + str(e))
    return res


def _persist_config(node_cfg):
    tmp = CONFIG_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(node_cfg, f, indent=2)
    os.replace(tmp, CONFIG_PATH)


def create_ifaces(node_cfg, create, agent, sudo):
    """Create panel-requested BRAND-NEW interfaces via swg-agent (genkey + conf + auto-NAT + bring-up),
    then start managing them (config.json). Only on a valid sync. Bring-up runs live — verify on one
    node. Native datapath: kernel on a bare-metal node, container-userspace on a docker node."""
    res = {"created": [], "errors": []}
    if not create:
        return res
    ifaces = node_cfg.setdefault("interfaces", {})
    changed = False
    for iface, want in create.items():
        if iface in ifaces:                 # already created — nothing to do (panel clears it)
            continue
        cmd = want.get("cmd") or ["awg"]
        r = run_agent(agent, sudo, {"op": "create-iface", "iface": iface, "cmd": cmd,
                                    "subnet": want.get("subnet"), "listen_port": want.get("listen_port"),
                                    "mtu": want.get("mtu")})
        if not r.get("ok"):
            res["errors"].append(f"{iface}: {r.get('error')}"); continue
        data = r.get("data") or {}
        conf = data.get("conf") or ""
        if not conf:
            res["errors"].append(f"{iface}: agent returned no conf path"); continue
        # the agent may have fallen back (e.g. wg→awg on a node with only amneziawg-go) — record the
        # tool it ACTUALLY used, or we'll later run the wrong CLI (`wg show`) and "can't read" it
        ifaces[iface] = {"cmd": data.get("cmd") or cmd, "conf": conf}
        changed = True
        res["created"].append(iface)
    if changed:
        try:
            _persist_config(node_cfg)
        except Exception as e:
            res["errors"].append(f"persist config.json: {e}")
    return res


def delete_ifaces(node_cfg, delete, agent, sudo):
    """Tear down panel-requested interfaces (down + remove conf via swg-agent) and stop managing them.
    Only on a valid sync. The panel clears the request once the iface stops appearing in snapshots."""
    res = {"deleted": [], "errors": []}
    if not delete:
        return res
    ifaces = node_cfg.get("interfaces") or {}
    changed = False
    for iface in list(delete):
        if iface not in ifaces:             # already gone — panel clears it when the snapshot lacks it
            continue
        r = run_agent(agent, sudo, {"op": "delete-iface", "iface": iface})
        if not r.get("ok"):
            res["errors"].append(f"{iface}: {r.get('error')}"); continue
        ifaces.pop(iface, None)
        changed = True
        res["deleted"].append(iface)
    if changed:
        try:
            _persist_config(node_cfg)
        except Exception as e:
            res["errors"].append(f"persist config.json: {e}")
    return res


# ── turn-proxy management (host systemd units) ──────────────────────────────────────────────────
# UNVERIFIED ON DOCKER: the bare-metal path edits units + systemctl directly; the docker path runs
# the same on the HOST via a privileged --pid=host helper through the mounted docker.sock (nsenter
# into PID 1). Test on a real node before relying on it. The socket = root-on-host (opt-in install).
HELPER_IMAGE = os.environ.get("HELPER_IMAGE") or "ghcr.io/sanityprotocol/swg-node:latest"
TURN_UNIT_DIR = "/etc/systemd/system"
TURN_MANAGE_ON = (NODE_KIND != "docker") or ((os.environ.get("TURN_MANAGE") or "manual").strip().lower() == "panel")
NODE_PROGRESS = {} # request key (iface name / turn service) -> transient "what's happening right now" line
                   # (e.g. a slow GitHub download retrying) → cmd_progress on the snapshot → yellow card note.
NODE_ERRORS = {}   # request key (iface name / turn service / .service path) -> last apply error, reported
                   # in the snapshot ("cmd_errors") so the panel can show WHY a host->node command failed

def host_sh(cmd, timeout=90):
    """Run a shell command on the HOST. Bare-metal: directly. Docker: via a one-shot privileged
    --pid=host helper through the mounted docker socket — nsenter into PID 1 so the command runs in
    the host's namespaces (its filesystem + systemd)."""
    if NODE_KIND != "docker":
        args = ["sh", "-c", cmd] if os.geteuid() == 0 else ["sudo", "-n", "sh", "-c", cmd]
    else:
        # --entrypoint nsenter is REQUIRED: the swg-node image's entrypoint is node-entrypoint.sh
        # (it demands PANEL_URL + sets up wg) — passing nsenter as the command alone still runs it.
        args = ["docker", "run", "--rm", "--privileged", "--pid=host", "--entrypoint", "nsenter",
                HELPER_IMAGE, "-t", "1", "-m", "-u", "-i", "-n", "-p", "--", "sh", "-c", cmd]
    try:
        r = run(args, timeout=timeout)
    except Exception as e:                              # e.g. 'docker' not found, or a timeout
        print("host_sh EXC: " + str(e) + " :: " + cmd[:160], flush=True)
        class _R:                                       # synthesize a failed result so callers see it
            returncode = 127; stdout = ""; stderr = str(e)
        return _R()
    if r.returncode != 0:
        print("host_sh rc=" + str(r.returncode) + " :: " + cmd[:160] + " :: " + (r.stderr or r.stdout or "")[:300], flush=True)
    return r

def _turn_unit_path(svc):
    return TURN_UNIT_DIR + "/" + svc + ".service"

def _exec_of(unit_text):
    for ln in unit_text.splitlines():
        if ln.startswith("ExecStart="):
            return ln[len("ExecStart="):]
    return ""

def _set_arg(execl, flag, value):
    """Replace '-flag <val>' (space- or =-separated) in the ExecStart, or append it."""
    pat = re.compile(r"(-" + re.escape(flag) + r")[ =]+\S+")
    if pat.search(execl):
        return pat.sub(lambda m: m.group(1) + " " + value, execl, count=1)
    return execl.rstrip() + " -" + flag + " " + value

def _strip_wrap(execl):
    """Remove the wrap key + the fork's wrap flag (-wrap / -wrap-srtp / -wrap-mode on)."""
    execl = re.sub(r"\s*-wrap-key[ =]+\S+", "", execl)
    execl = re.sub(r"\s*-wrap-mode[ =]+\S+", "", execl)
    execl = re.sub(r"\s*-wrap-srtp\b", "", execl)
    execl = re.sub(r"\s*-wrap\b", "", execl)
    return execl

def _exec_params(execl):
    """Everything after '-connect <ip:port>' in the ExecStart — the free-text extra flags (wrap etc.)."""
    m = re.search(r"-connect[ =]+\S+\s*(.*)$", execl)
    return (m.group(1).strip() if m else "")

def _parse_tp(svc, execl):
    def g(flag):
        m = re.search(r"-" + re.escape(flag) + r"[ =]+(\S+)", execl)
        return m.group(1) if m else ""
    return {"service": svc, "listen": g("listen"), "connect": g("connect"),
            "wrap_key": g("wrap-key"), "params": _exec_params(execl)}

def _installed_tp(svc):
    """Re-read a turn unit (after install/edit) so the record carries the real ExecStart, incl. the
    generated wrap key."""
    unit = host_sh("cat " + shlex.quote(_turn_unit_path(svc)) + " 2>/dev/null").stdout
    return _tp_from_unit(svc, unit)


# ───────── docker turn-proxies: sibling CONTAINERS (no host systemd, no --pid=host helper) ─────────
# A docker node runs each turn-proxy as its OWN container (swg-turn-<inst>, host networking) instead of
# editing host systemd through a privileged --pid=host nsenter helper. swg-noded fetches the fork binary
# into its host-mounted data dir and runs it in the swg-node image; a change = recreate the container
# (fast, no daemon-reload). TURN_RECORD is the source of truth for the config on a docker node.
SWG_HOST_NODE_DIR = (os.environ.get("SWG_HOST_NODE_DIR") or "").rstrip("/")   # host path mapped to /var/lib/swg-noded
SWG_TURN_IMAGE = os.environ.get("SWG_TURN_IMAGE") or ""                       # image used to run the turn binary
TURN_DOCKER = (NODE_KIND == "docker")

def _turn_inst(svc):  return svc[len("vk-turn-proxy-"):] if svc.startswith("vk-turn-proxy-") else svc
def _turn_fork(svc):  inst = _turn_inst(svc); return inst.rsplit("-", 1)[0] or inst   # <fork>-<port> → <fork> (handles hyphenated forks, e.g. WINGS-N)
def _turn_cname(svc): return "swg-turn-" + _turn_inst(svc)
# ONE binary per fork, not per instance: every WINGS-N-<port> instance shares …/turn/.bin/WINGS-N/server.
def _turn_bin_local(svc): return "/var/lib/swg-noded/turn/.bin/" + _turn_fork(svc) + "/server"   # inside swg-noded
def _turn_bin_host(svc):  return SWG_HOST_NODE_DIR + "/turn/.bin/" + _turn_fork(svc) + "/server"  # same file on the host (mounted into each instance's container)
def _turn_bin_local_legacy(svc): return "/var/lib/swg-noded/turn/" + _turn_inst(svc) + "/server"  # pre-dedup per-instance path (migrated on next download)
def _turn_fork_in_use(svc, rec):   # is any OTHER instance of this fork still in the record? (don't drop a shared binary others use)
    fork = _turn_fork(svc); items = rec.values() if isinstance(rec, dict) else (rec or [])
    return any(isinstance(tp, dict) and tp.get("service") and tp["service"] != svc and _turn_fork(tp["service"]) == fork for tp in items)

def _params_wrapkey(params):
    m = re.search(r"-wrap-key[ =]+(\S+)", params or ""); return m.group(1) if m else ""
def _params_set_wrapkey(params, key):
    params = params or ""
    if re.search(r"-wrap-key[ =]+\S+", params):
        return re.sub(r"-wrap-key[ =]+\S+", "-wrap-key " + key, params)
    return (params + " -wrap-key " + key).strip()

def _dturn_args(tp):
    args = ["-listen", tp.get("listen", ""), "-connect", tp.get("connect", "")]
    p = (tp.get("params") or "").strip()
    if p:
        try: args += shlex.split(p)
        except Exception: args += p.split()
    return args

def _turn_dl_urls(owner, arch):
    """GitHub release assets are single-origin (objects.githubusercontent.com). Try GitHub direct first, then
    any operator-configured proxy mirrors (SWG_TURN_MIRROR, space-separated prefixes — OPT-IN: proxying a binary
    you execute is a supply-chain trust decision, so it's off by default)."""
    base = "https://github.com/" + owner + "/releases/latest/download/server-linux-" + arch
    urls = [base]
    for m in (os.environ.get("SWG_TURN_MIRROR") or "").split():
        urls.append(m.rstrip("/") + "/" + base)   # e.g. https://ghproxy.example/https://github.com/<owner>/releases/...
    return urls

def _dturn_download(svc, owner):
    arch = "arm64" if os.uname().machine in ("aarch64", "arm64") else "amd64"
    binp = _turn_bin_local(svc)   # shared per-fork slot
    if os.path.exists(binp):       # already have this fork's binary (another instance, or a prior install) → REUSE,
        return ""                  # no GitHub hit. (A panel Reinstall removes binp first, so it still forces a fresh fetch.)
    try: os.makedirs(os.path.dirname(binp), exist_ok=True)
    except OSError as e: return "mkdir: " + str(e)
    leg = _turn_bin_local_legacy(svc)                    # upgrade: reuse a pre-dedup per-instance binary instead of re-downloading
    if os.path.exists(leg):
        with contextlib.suppress(OSError):
            os.replace(leg, binp); os.chmod(binp, 0o755)
        if os.path.exists(binp):
            _turn_write_version(svc, _turn_resolve_tag(owner)); return ""
    err = "binary download failed"
    for url in _turn_dl_urls(owner, arch):
        r = run(["curl", "-fsSL", "--connect-timeout", "20", "--max-time", "240", "--retry", "3",
                 "--retry-delay", "3", "--retry-all-errors", url, "-o", binp], timeout=320)
        if r.returncode == 0:
            with contextlib.suppress(OSError): os.chmod(binp, 0o755)
            _turn_write_version(svc, _turn_resolve_tag(owner))   # record which release tag we just fetched
            return ""
        err = (r.stderr or "binary download failed").strip()[:160]
    return err

def _dturn_run(tp):   # (re)create the container to match tp; returns the docker-run CompletedProcess
    svc = tp["service"]; cn = _turn_cname(svc)
    run(["docker", "rm", "-f", cn], timeout=30)   # ignore errors (may not exist yet)
    return run(["docker", "run", "-d", "--name", cn, "--network", "host", "--restart", "unless-stopped",
                "-v", _turn_bin_host(svc) + ":/turn-server:ro", "--entrypoint", "/turn-server",
                SWG_TURN_IMAGE] + _dturn_args(tp), timeout=60)

def _dturn_verify(svc):
    time.sleep(1.5)
    r = run(["docker", "inspect", "-f", "{{.State.Running}}", _turn_cname(svc)])
    if (r.stdout or "").strip() == "true": return ""
    lg = run(["docker", "logs", "--tail", "5", _turn_cname(svc)])
    return ("turn container isn't running: " + ((lg.stderr or lg.stdout or "").strip() or "see docker logs"))[:160]

def _dturn_delete(svc, rec=None):
    run(["docker", "rm", "-f", _turn_cname(svc)], timeout=30)
    shutil.rmtree(os.path.dirname(_turn_bin_local_legacy(svc)), ignore_errors=True)   # old per-instance dir, if any
    if not _turn_fork_in_use(svc, rec):                  # last instance of this fork → drop the shared binary
        shutil.rmtree(os.path.dirname(_turn_bin_local(svc)), ignore_errors=True)

# ── turn-proxy VERSION/owner — sidecars next to the SHARED per-fork binary (one tag/owner per fork) ──
# docker: …/turn/.bin/<fork>/version.txt · bare: /opt/vk-turn-proxy/.bin/<fork>/version.txt + repo.txt.
# Reads fall back to the pre-dedup per-instance path so an un-migrated install still shows its version.
def _turn_ver_path(svc):
    if TURN_DOCKER:
        return os.path.join(os.path.dirname(_turn_bin_local(svc)), "version.txt")
    return "/opt/vk-turn-proxy/.bin/" + _turn_fork(svc) + "/version.txt"
def _turn_repo_path(svc):    # owner repo (fallback if a reinstall req lacks owner)
    if TURN_DOCKER:
        return os.path.join(os.path.dirname(_turn_bin_local(svc)), "repo.txt")
    return "/opt/vk-turn-proxy/.bin/" + _turn_fork(svc) + "/repo.txt"
def _turn_ver_path_legacy(svc):
    if TURN_DOCKER:
        return "/var/lib/swg-noded/turn/" + _turn_inst(svc) + "/version.txt"
    return "/opt/vk-turn-proxy/" + _turn_inst(svc) + "/version.txt"
def _turn_repo_path_legacy(svc):
    return "/opt/vk-turn-proxy/" + _turn_inst(svc) + "/repo.txt"
def _turn_version(svc):
    for p in (_turn_ver_path(svc), _turn_ver_path_legacy(svc)):
        try:
            with open(p) as f:
                return f.read().strip()[:40]
        except Exception:
            pass
    return ""
def _turn_write_version(svc, tag):
    if not tag:
        return
    p = _turn_ver_path(svc)
    try:
        os.makedirs(os.path.dirname(p), exist_ok=True)
        with open(p, "w") as f:
            f.write(tag.strip()[:40])
        with contextlib.suppress(OSError): os.chmod(p, 0o644)
    except OSError:
        pass
def _turn_resolve_tag(owner):
    """Latest release tag, read from the 302 of releases/latest/download (no API → no rate limit)."""
    if not owner:
        return ""
    arch = "arm64" if os.uname().machine in ("aarch64", "arm64") else "amd64"
    url = "https://github.com/" + owner + "/releases/latest/download/server-linux-" + arch
    r = run(["curl", "-fsS", "-o", "/dev/null", "-w", "%{redirect_url}",
             "--connect-timeout", "15", "--max-time", "30", url], timeout=40)
    m = re.search(r"/releases/download/([^/]+)/", r.stdout or "")
    return m.group(1) if m else ""
def _attach_turn_version(tps):
    for t in tps:
        if t.get("service"):
            t["version"] = _turn_version(t["service"])

def _dturn_install(svc, req):   # returns (err, tp_record_or_None)
    owner = (req.get("owner") or "").strip(); listen = (req.get("listen") or "").strip()
    connect = (req.get("connect") or "").strip(); wrap_flags = (req.get("wrap_flags") or "").strip()
    if "/" not in owner or ":" not in listen or ":" not in connect: return "bad install request", None
    if not SWG_TURN_IMAGE or not SWG_HOST_NODE_DIR:
        return "turn-on-docker not configured (re-install the node with turn management on)", None
    if "params" in req:   # explicit ExecStart tail from the create form (verbatim, including its wrap key)
        params = (req.get("params") or "").strip()
    else:                 # legacy: build from the fork's wrap flags + a generated key
        params = (wrap_flags + " -wrap-key " + secrets.token_hex(32)) if wrap_flags else ""
    err = _dturn_download(svc, owner)
    if err: return err, None
    tp = {"service": svc, "listen": listen, "connect": connect,
          "wrap_key": _params_wrapkey(params), "params": params, "owner": owner}
    _ti = (req.get("title") or "").strip()
    if _ti: tp["title"] = _ti          # optional display label, kept on the record
    r = _dturn_run(tp)
    if r.returncode != 0: return (r.stderr or "container start failed").strip()[:160], None
    verr = _dturn_verify(svc)
    return (verr, tp)   # keep the record even if down, so the panel shows it (greyed)

_DTURN_RUN = {"at": 0.0, "set": set()}
_TURN_INSTALLING = set()   # services whose container is being downloaded/(re)created RIGHT NOW → "installing"
_TURN_FAILED = set()       # services whose last install/run attempt errored → "install failed" on the panel
_TURN_ATTEMPTS = {}        # svc -> consecutive failed-download count; the bg reconcile STOPS retrying after
TURN_MAX_ATTEMPTS = 4      # this many (so a stuck 502/timeout becomes "install failed", not an endless "installing"). A manual Reinstall resets it.
def _dturn_attach_running(tps):
    nowt = time.time()
    if nowt - _DTURN_RUN["at"] >= 15:
        r = run(["docker", "ps", "--filter", "name=swg-turn-", "--format", "{{.Names}}"])
        _DTURN_RUN["set"] = set((r.stdout or "").split()); _DTURN_RUN["at"] = nowt
    for t in tps:
        if t.get("service"):
            svc = t["service"]
            t["running"] = _turn_cname(svc) in _DTURN_RUN["set"]
            stopped = bool(t.get("stopped"))
            active = svc in _TURN_INSTALLING   # being downloaded / (re)created RIGHT NOW (only one at a time)
            failed = (svc in _TURN_FAILED) and not t["running"] and not stopped
            t["failed"] = failed
            # docker: only the proxy the bg reconcile is working on right now is "installing"; the others not
            # yet up (and not failed/stopped) are "pending" — queued for the sequential reconcile, not stuck.
            t["installing"] = active and not stopped
            t["pending"] = (not t["running"]) and (not failed) and (not stopped) and (not active)

def _dturn_ensure(tp):   # make the container match the record entry (download binary if missing, run if not up)
    svc = tp.get("service")
    if not svc:
        return
    if tp.get("stopped"):   # intentionally stopped from the panel → don't auto-(re)start it
        _TURN_INSTALLING.discard(svc)
        return
    r = run(["docker", "inspect", "-f", "{{.State.Running}}", _turn_cname(svc)])
    if (r.stdout or "").strip() == "true":
        _TURN_INSTALLING.discard(svc); _TURN_FAILED.discard(svc); _TURN_ATTEMPTS.pop(svc, None); NODE_PROGRESS.pop(svc, None)
        return
    if _TURN_ATTEMPTS.get(svc, 0) >= TURN_MAX_ATTEMPTS and not os.path.exists(_turn_bin_local(svc)):
        _TURN_FAILED.add(svc); _TURN_INSTALLING.discard(svc); NODE_PROGRESS.pop(svc, None)   # given up — "install failed" (a manual Reinstall resets the counter)
        return
    _TURN_INSTALLING.add(svc)   # downloading / (re)creating now → the panel shows it as "installing"
    try:
        if not os.path.exists(_turn_bin_local(svc)) and tp.get("owner"):
            NODE_PROGRESS[svc] = "Downloading the turn-proxy binary from GitHub — this can take a minute…"
            derr = _dturn_download(svc, tp["owner"])
            if derr:
                _TURN_ATTEMPTS[svc] = _TURN_ATTEMPTS.get(svc, 0) + 1
                # NON-terminating: keep retrying every pass, but tell the operator WHY it's slow so it doesn't look hung.
                NODE_PROGRESS[svc] = ("GitHub download failed (attempt %d/%d): %s. Still retrying — please wait for the install to finish."
                                       % (_TURN_ATTEMPTS[svc], TURN_MAX_ATTEMPTS, derr))
                print("swg-noded: turn %s binary download failed (attempt %d/%d): %s" % (svc, _TURN_ATTEMPTS[svc], TURN_MAX_ATTEMPTS, derr), flush=True)
        if not os.path.exists(_turn_bin_local(svc)):   # no binary yet
            if _TURN_ATTEMPTS.get(svc, 0) >= TURN_MAX_ATTEMPTS:   # stop the endless "installing" → mark failed + report it
                _TURN_FAILED.add(svc); NODE_PROGRESS.pop(svc, None)
                NODE_ERRORS[svc] = "binary download failed after %d attempts — Reinstall to retry" % TURN_MAX_ATTEMPTS
                print("swg-noded: turn %s — gave up after %d download attempts; Reinstall from the panel to retry" % (svc, TURN_MAX_ATTEMPTS), flush=True)
            else:
                print("swg-noded: turn %s has no binary yet — will retry on the next pass" % svc, flush=True)
            return
        _TURN_ATTEMPTS.pop(svc, None); NODE_ERRORS.pop(svc, None)   # got the binary → clear any prior failure
        NODE_PROGRESS[svc] = "Binary downloaded — starting the container…"
        rr = _dturn_run(tp)
        if rr.returncode != 0:
            _TURN_FAILED.add(svc); NODE_PROGRESS.pop(svc, None)
            print("swg-noded: turn %s 'docker run' failed: %s" % (svc, (rr.stderr or rr.stdout or "").strip()[:200]), flush=True)
            return
        verr = _dturn_verify(svc)
        if verr:
            _TURN_FAILED.add(svc); NODE_PROGRESS.pop(svc, None)
            print("swg-noded: turn %s started but didn't stay up: %s" % (svc, verr), flush=True)
        else:
            _TURN_FAILED.discard(svc); NODE_PROGRESS.pop(svc, None)
            print("swg-noded: turn %s container (re)started (%s)" % (svc, _turn_cname(svc)), flush=True)
    finally:
        _TURN_INSTALLING.discard(svc)

def _dturn_reconcile():   # startup/periodic: ensure every recorded turn-proxy has a running container
    if not TURN_DOCKER:
        return
    tps = load_turn_proxies()
    if not tps:
        return
    if not (SWG_TURN_IMAGE and SWG_HOST_NODE_DIR):   # the #1 silent failure — say so loudly
        print("swg-noded: %d turn-proxy record(s) present but turn-on-docker isn't configured "
              "(SWG_TURN_IMAGE=%r SWG_HOST_NODE_DIR=%r) — re-install the node with turn management ON"
              % (len(tps), SWG_TURN_IMAGE, SWG_HOST_NODE_DIR), flush=True)
        return
    for tp in tps:
        try:
            _dturn_ensure(tp)
        except Exception as e:
            print("swg-noded: turn reconcile %s failed: %s" % (tp.get("service"), e), flush=True)

def _dturn_bg_loop():   # background thread: keep turn-proxy containers up WITHOUT blocking the sync loop, so the
    while True:         # node appears on the panel right away and the cards fill in (installing → up) as each starts
        try:
            _dturn_reconcile()
        except Exception as e:
            print("swg-noded: turn reconcile error: %s" % e, flush=True)
        time.sleep(30)


# ───────── bare-metal turn-proxies: systemd unit + EnvironmentFile (edit = rewrite env, NO daemon-reload) ─────────
# The connect/listen/params live in a turn.env next to the binary; ExecStart references them as ${SWG_…}.
# Editing a turn-proxy then only rewrites turn.env + `systemctl restart` — systemd re-parsing EVERY unit
# (daemon-reload) was the CPU spike. Old units (values baked into ExecStart) are migrated on first edit.
def _turn_env_path(svc): return "/opt/vk-turn-proxy/" + _turn_inst(svc) + "/turn.env"
def _turn_env_text(listen, connect, params):
    return "SWG_LISTEN=%s\nSWG_CONNECT=%s\nSWG_PARAMS=%s\n" % (listen, connect, (params or "").strip())
def _exec_bin(execl):
    try: return shlex.split(execl)[0]
    except Exception: return (execl.split() or [""])[0]
def _unit_is_envform(unit_text): return "${SWG_" in _exec_of(unit_text)

def _tp_from_unit(svc, unit_text):
    """Resolve a turn-proxy's config from its unit. EnvironmentFile form → read turn.env; old form → ExecStart."""
    if not _unit_is_envform(unit_text):
        return _parse_tp(svc, _exec_of(unit_text))
    env = host_sh("cat " + shlex.quote(_turn_env_path(svc)) + " 2>/dev/null").stdout or ""
    vals = {}
    for ln in env.splitlines():
        k, _, v = ln.partition("="); vals[k.strip()] = v.strip()
    params = vals.get("SWG_PARAMS", "")
    return {"service": svc, "listen": vals.get("SWG_LISTEN", ""), "connect": vals.get("SWG_CONNECT", ""),
            "wrap_key": _params_wrapkey(params), "params": params}

def _unit_to_envform(unit_text, svc, binp):
    """Rewrite a baked-ExecStart unit to the EnvironmentFile form (one-time migration)."""
    envp = _turn_env_path(svc); out = []; have_ef = any(l.startswith("EnvironmentFile=") for l in unit_text.splitlines())
    for l in unit_text.splitlines():
        if l.startswith("ExecStart="):
            if not have_ef: out.append("EnvironmentFile=-" + envp)
            out.append("ExecStart=" + binp + " -listen ${SWG_LISTEN} -connect ${SWG_CONNECT} $SWG_PARAMS")
        elif l.startswith("EnvironmentFile="):
            out.append("EnvironmentFile=-" + envp)
        else:
            out.append(l)
    return "\n".join(out) + "\n"

def _turn_install(svc, req):
    """Install a new turn-proxy: download the fork's prebuilt binary, write the systemd unit, enable
    it. Mirrors the installer's install_turn_binary (server-linux-<arch>). '' on success, else error."""
    owner = (req.get("owner") or "").strip()
    listen = (req.get("listen") or "").strip()
    connect = (req.get("connect") or "").strip()
    wrap_flags = (req.get("wrap_flags") or "").strip()
    if "/" not in owner or ":" not in listen or ":" not in connect:
        return "bad install request"
    inst = svc[len("vk-turn-proxy-"):] if svc.startswith("vk-turn-proxy-") else svc
    fork = _turn_fork(svc)
    fdir = "/opt/vk-turn-proxy/.bin/" + fork   # shared per-fork: one binary + version.txt + repo.txt for every instance
    sbin = fdir + "/server"
    d = "/opt/vk-turn-proxy/" + inst           # per-instance: turn.env + a 'server' symlink → the shared binary
    binp = d + "/server"
    arch = "arm64" if os.uname().machine in ("aarch64", "arm64") else "amd64"
    extra = ""
    if "params" in req:   # explicit ExecStart tail from the create form (verbatim, including its wrap key)
        extra = (req.get("params") or "").strip()
    elif wrap_flags:
        key = secrets.token_hex(32)   # 64 hex chars, no openssl dependency (the slim image lacks it)
        if not key:
            return "keygen failed"
        extra = wrap_flags + " -wrap-key " + key
    envp = _turn_env_path(svc)
    unit = ("[Unit]\nDescription=vk-turn-proxy (" + owner + ") - " + listen + " -> " + connect + "\n"
            "After=network-online.target\nWants=network-online.target\n\n"
            "[Service]\nEnvironmentFile=-" + envp + "\n"
            "ExecStart=" + binp + " -listen ${SWG_LISTEN} -connect ${SWG_CONNECT} $SWG_PARAMS\n"
            "Restart=on-failure\nRestartSec=3\n\n"
            "[Install]\nWantedBy=multi-user.target\n")
    tag = _turn_resolve_tag(owner)
    dl = " || ".join("curl -fsSL --connect-timeout 20 --max-time 240 --retry 3 --retry-delay 3 --retry-all-errors "
                     + shlex.quote(u) + " -o " + shlex.quote(sbin) for u in _turn_dl_urls(owner, arch))
    cmd = ("mkdir -p " + shlex.quote(fdir) + " " + shlex.quote(d)
           + " && { [ -x " + shlex.quote(sbin) + " ] || { " + dl + "; }; } && chmod 755 " + shlex.quote(sbin)   # reuse this fork's binary if already downloaded
           + " && ln -sfn " + shlex.quote("../.bin/" + fork + "/server") + " " + shlex.quote(binp)
           + " && printf %s " + shlex.quote(owner) + " > " + shlex.quote(fdir + "/repo.txt")
           + ((" && printf %s " + shlex.quote(tag) + " > " + shlex.quote(fdir + "/version.txt")) if tag else "")
           + " && cat > " + shlex.quote(envp) + " <<'SWGENV'\n" + _turn_env_text(listen, connect, extra) + "SWGENV\n"
           + "cat > " + shlex.quote(_turn_unit_path(svc)) + " <<'SWGEOF'\n" + unit + "SWGEOF\n"
           + "systemctl daemon-reload && systemctl enable --now " + shlex.quote(svc) + " >/dev/null 2>&1")
    w = host_sh(cmd, timeout=210)
    if w.returncode != 0:
        return (w.stderr or w.stdout or "install failed").strip()[:160]
    return _turn_verify(svc)   # enable --now returns 0 even if the binary crash-loops — confirm it stays up

def _turn_verify(svc):
    """Confirm a turn-proxy service is actually running after install/edit. enable/restart returns 0 as
    soon as the binary is exec'd, so a crash-loop (e.g. a -listen IP not local to the host → bind fails)
    looks like success — this catches it + returns the journal reason so the panel can show it."""
    v = host_sh("sleep 1.5; systemctl is-active " + shlex.quote(svc) + " 2>/dev/null; "
                "journalctl -u " + shlex.quote(svc) + " -n 5 --no-pager -o cat 2>/dev/null | grep -iE 'error|invalid|fail|bind|address|panic' | tail -1")
    lines = (v.stdout or "").strip().splitlines()
    if lines and lines[0] == "active":
        return ""
    reason = lines[-1] if len(lines) > 1 else "not running (check the -listen IP is an address on this host)"
    return "service didn't stay up: " + reason[:150]

def apply_turn(turn, turn_onboard):
    """Apply panel turn-proxy requests (manage/rotate/delete) + onboard host .service units, then
    update the turn record so the snapshot reflects it (which clears the panel request)."""
    res = {"done": [], "errors": []}
    if not turn and not turn_onboard:
        return res
    keys = set(turn or {}) | set(turn_onboard or [])
    print("turn: applying " + str(sorted(keys)) + " manage_on=" + str(TURN_MANAGE_ON)
          + " kind=" + NODE_KIND, flush=True)
    def fail(k, m):
        res["errors"].append(k + ": " + m); NODE_ERRORS[k] = m
        print("turn: FAIL " + k + " -> " + m, flush=True)
    def good(k, tag):
        res["done"].append(tag); NODE_ERRORS.pop(k, None)
        print("turn: ok " + tag, flush=True)
    if not TURN_MANAGE_ON:
        for k in keys:
            fail(k, "turn management off — re-install the docker node with the 'panel' option")
        return res
    rec = {tp.get("service"): tp for tp in load_turn_proxies() if tp.get("service")}
    changed = False
    for svc, req in (turn or {}).items():
        try:
            act = req.get("action")
            if TURN_DOCKER:                                   # ── container model ──
                if act == "install":
                    err, tp = _dturn_install(svc, req)
                    if tp is not None: rec[svc] = tp; changed = True
                    fail(svc, err) if err else good(svc, "ins:" + svc)
                    continue
                if act == "delete":
                    _dturn_delete(svc, rec); rec.pop(svc, None); changed = True; good(svc, "del:" + svc); continue
                if act == "reinstall":      # force a fresh binary (fix a failed download / update to latest) + (re)create
                    tp = rec.get(svc) or {"service": svc, "listen": req.get("listen", ""), "connect": req.get("connect", ""), "params": req.get("params", "")}
                    if req.get("owner"): tp["owner"] = req["owner"].strip()
                    if not tp.get("owner"):
                        fail(svc, "no owner repo for reinstall"); continue
                    _TURN_ATTEMPTS.pop(svc, None)   # manual retry → clear the give-up counter so the bg reconcile resumes if this one also fails
                    with contextlib.suppress(OSError): os.remove(_turn_bin_local(svc))
                    with contextlib.suppress(OSError): os.remove(_turn_bin_local_legacy(svc))   # so _dturn_download fetches fresh, doesn't re-migrate the stale one
                    with contextlib.suppress(OSError): os.remove(_turn_ver_path(svc))
                    derr = _dturn_download(svc, tp["owner"])
                    if derr:
                        _TURN_FAILED.add(svc); fail(svc, derr); continue
                    r = _dturn_run(tp)
                    if r.returncode != 0:
                        _TURN_FAILED.add(svc); fail(svc, (r.stderr or "container start failed").strip()[:120]); continue
                    rec[svc] = tp; changed = True
                    verr = _dturn_verify(svc)
                    if verr:
                        _TURN_FAILED.add(svc); fail(svc, verr)
                    else:
                        _TURN_FAILED.discard(svc); good(svc, "rei:" + svc)
                    continue
                if act == "title":            # cosmetic label only → update the record, DON'T touch the container
                    tp = rec.get(svc)
                    if not tp:
                        fail(svc, "turn-proxy not in the node record"); continue
                    tp["title"] = (req.get("title") or "").strip(); rec[svc] = tp; changed = True
                    good(svc, "title:" + svc); continue
                if act == "stop":             # stop + remove the container; the 'stopped' flag keeps the bg reconcile from restarting it
                    tp = rec.get(svc)
                    if not tp:
                        fail(svc, "turn-proxy not in the node record"); continue
                    run(["docker", "rm", "-f", _turn_cname(svc)])
                    tp["stopped"] = True; rec[svc] = tp; changed = True
                    _TURN_INSTALLING.discard(svc); _TURN_FAILED.discard(svc); _TURN_ATTEMPTS.pop(svc, None); NODE_PROGRESS.pop(svc, None)
                    good(svc, "stop:" + svc); continue
                if act == "start":            # clear 'stopped' + (re)create the container
                    tp = rec.get(svc)
                    if not tp:
                        fail(svc, "turn-proxy not in the node record"); continue
                    tp.pop("stopped", None); rec[svc] = tp; changed = True
                    r = _dturn_run(tp)
                    if r.returncode != 0:
                        _TURN_FAILED.add(svc); fail(svc, (r.stderr or "container start failed").strip()[:120]); continue
                    verr = _dturn_verify(svc)
                    fail(svc, verr) if verr else good(svc, "start:" + svc)
                    continue
                tp = rec.get(svc)
                if not tp:
                    fail(svc, "turn-proxy not in the node record"); continue
                if act == "manage":
                    if req.get("listen"):  tp["listen"] = req["listen"].strip()
                    if req.get("connect"): tp["connect"] = req["connect"].strip()
                    if "params" in req:    tp["params"] = (req.get("params") or "").strip(); tp["wrap_key"] = _params_wrapkey(tp["params"])
                    if "title" in req:     tp["title"] = (req.get("title") or "").strip()
                elif act == "rotate":
                    nk = secrets.token_hex(32); tp["params"] = _params_set_wrapkey(tp.get("params", ""), nk); tp["wrap_key"] = nk
                # restart: no config change — just recreate the container
                r = _dturn_run(tp)
                if r.returncode != 0:
                    fail(svc, (r.stderr or "container start failed").strip()[:120]); continue
                rec[svc] = tp; changed = True
                verr = _dturn_verify(svc)
                fail(svc, verr) if verr else good(svc, act + ":" + svc)
                continue
            up = _turn_unit_path(svc)                          # ── bare-metal systemd model ──
            if act == "install":
                err = _turn_install(svc, req)
                if err:
                    fail(svc, err)
                else:
                    rec[svc] = _installed_tp(svc)
                    _ti = (req.get("title") or "").strip()
                    if _ti: rec[svc]["title"] = _ti
                    changed = True; good(svc, "ins:" + svc)
                continue
            if act == "delete":
                w = host_sh("systemctl disable --now " + shlex.quote(svc) + " >/dev/null 2>&1; "
                            "rm -f " + shlex.quote(up) + "; systemctl daemon-reload")
                if w.returncode != 0:
                    fail(svc, (w.stderr or "remove failed").strip()[:120]); continue
                rec.pop(svc, None); changed = True; good(svc, "del:" + svc); continue
            if act == "reinstall":          # re-download the binary (fix/update) + restart the unit
                owner = (req.get("owner") or "").strip()
                if not owner:               # fall back to the recorded repo.txt (shared fork dir, then pre-dedup per-instance)
                    for rp in (_turn_repo_path(svc), _turn_repo_path_legacy(svc)):
                        try:
                            with open(rp) as f: owner = f.read().strip()
                        except Exception: owner = ""
                        if owner: break
                if not owner:
                    fail(svc, "no owner repo for reinstall"); continue
                arch = "arm64" if os.uname().machine in ("aarch64", "arm64") else "amd64"
                fork = _turn_fork(svc)
                sbin = "/opt/vk-turn-proxy/.bin/" + fork + "/server"          # shared per-fork binary (a reinstall refreshes it for every instance of the fork)
                binp = "/opt/vk-turn-proxy/" + _turn_inst(svc) + "/server"    # this instance's symlink → the shared binary
                tag = _turn_resolve_tag(owner); vp = _turn_ver_path(svc)
                dl = " || ".join("curl -fsSL --connect-timeout 20 --max-time 240 --retry 3 --retry-delay 3 --retry-all-errors "   # GitHub direct, then any SWG_TURN_MIRROR proxies
                                 + shlex.quote(u) + " -o " + shlex.quote(sbin) for u in _turn_dl_urls(owner, arch))
                cmd = ("mkdir -p " + shlex.quote(os.path.dirname(sbin)) + " " + shlex.quote(os.path.dirname(binp))
                       + " && ( " + dl + " ) && chmod 755 " + shlex.quote(sbin)
                       + " && ln -sfn " + shlex.quote("../.bin/" + fork + "/server") + " " + shlex.quote(binp)
                       + " && printf %s " + shlex.quote(owner) + " > " + shlex.quote(_turn_repo_path(svc)))
                if tag:
                    cmd += " && printf %s " + shlex.quote(tag) + " > " + shlex.quote(vp) + " && chmod 644 " + shlex.quote(vp)
                cmd += " && systemctl restart " + shlex.quote(svc)
                w = host_sh(cmd, timeout=340)
                if w.returncode != 0:
                    fail(svc, (w.stderr or "reinstall failed").strip()[:140]); continue
                verr = _turn_verify(svc)
                fail(svc, verr) if verr else good(svc, "rei:" + svc)
                continue
            if act == "title":                # cosmetic label only → update the record, DON'T restart the unit
                tp = rec.get(svc)
                if not tp:
                    fail(svc, "turn-proxy not in the node record"); continue
                tp["title"] = (req.get("title") or "").strip(); rec[svc] = tp; changed = True
                good(svc, "title:" + svc); continue
            if act == "stop":                 # stop + disable the unit; 'stopped' flag distinguishes it from a crash
                tp = rec.get(svc)
                if not tp:
                    fail(svc, "turn-proxy not in the node record"); continue
                host_sh("systemctl disable --now " + shlex.quote(svc) + " >/dev/null 2>&1; systemctl stop " + shlex.quote(svc) + " >/dev/null 2>&1; true")
                tp["stopped"] = True; rec[svc] = tp; changed = True; good(svc, "stop:" + svc); continue
            if act == "start":                # re-enable + start the unit
                tp = rec.get(svc)
                if not tp:
                    fail(svc, "turn-proxy not in the node record"); continue
                w = host_sh("systemctl enable --now " + shlex.quote(svc))
                if w.returncode != 0:
                    fail(svc, (w.stderr or "start failed").strip()[:120]); continue
                tp.pop("stopped", None); rec[svc] = tp; changed = True
                verr = _turn_verify(svc)
                fail(svc, verr) if verr else good(svc, "start:" + svc)
                continue
            unit = host_sh("cat " + shlex.quote(up) + " 2>/dev/null").stdout
            if not unit:
                fail(svc, "unit not found on the node"); continue
            cur = _tp_from_unit(svc, unit)   # resolves env-file or old baked-ExecStart units
            listen, connect, params = cur.get("listen", ""), cur.get("connect", ""), cur.get("params", "")
            if act == "manage":
                if req.get("listen"):  listen = req["listen"].strip()
                if req.get("connect"): connect = req["connect"].strip()
                if "params" in req:    params = (req.get("params") or "").strip()
            elif act == "rotate":
                params = _params_set_wrapkey(params, secrets.token_hex(32))
            # restart: no config change — just rewrite turn.env (unchanged) + restart below
            envp = _turn_env_path(svc)
            env_here = "cat > " + shlex.quote(envp) + " <<'SWGENV'\n" + _turn_env_text(listen, connect, params) + "SWGENV\n"
            if _unit_is_envform(unit):       # fast path: rewrite turn.env + restart, NO daemon-reload (the spike)
                w = host_sh(env_here + "systemctl restart " + shlex.quote(svc))
            else:                            # one-time migrate: move the baked ExecStart onto the EnvironmentFile
                new_unit = _unit_to_envform(unit, svc, _exec_bin(_exec_of(unit)))
                w = host_sh("mkdir -p " + shlex.quote(os.path.dirname(envp)) + "\n" + env_here
                            + "cat > " + shlex.quote(up) + " <<'SWGEOF'\n" + new_unit + "SWGEOF\n"
                            + "systemctl daemon-reload && systemctl restart " + shlex.quote(svc))
            if w.returncode != 0:
                fail(svc, (w.stderr or "restart failed").strip()[:120]); continue
            _ti = req.get("title")   # set if the request carried one, else preserve the existing record's title
            _ti = _ti.strip() if isinstance(_ti, str) else (rec.get(svc) or {}).get("title", "")
            rec[svc] = {"service": svc, "listen": listen, "connect": connect,
                        "wrap_key": _params_wrapkey(params), "params": params}   # reflect even if it won't start
            if _ti: rec[svc]["title"] = _ti
            changed = True
            verr = _turn_verify(svc)
            if verr:
                fail(svc, verr); continue   # report not-running; the record already shows the new (broken) params
            good(svc, act + ":" + svc)
        except Exception as e:
            fail(svc, str(e))
    for sp in (turn_onboard or []):
        try:
            unit = host_sh("cat " + shlex.quote(sp) + " 2>/dev/null").stdout
            if not unit:
                fail(sp, "unit not found at that path"); continue
            base = os.path.basename(sp)
            svc = base[:-8] if base.endswith(".service") else base
            rec[svc] = _parse_tp(svc, _exec_of(unit)); changed = True; good(sp, "onb:" + svc)
        except Exception as e:
            fail(sp, str(e))
    if changed:
        try:
            tmp = TURN_RECORD + ".tmp"
            with open(tmp, "w") as f:
                json.dump({"turn_proxies": list(rec.values())}, f)
            os.replace(tmp, TURN_RECORD)
        except Exception as e:
            res["errors"].append("record: " + str(e))
    return res


# node self-update is NODE-ONLY: on a master box (panel + node together) it must NOT restart the
# co-located panel, or the panel restart breaks the very sync that would clear the update request.
DEFAULT_UPDATE_CMD = ("curl -fsSL https://raw.githubusercontent.com/SanityProtocol/swg-panel/main/"
                      "bootstrap.sh | bash -s update -y --no-components --node-only")


def run_self_update(node_cfg, want):
    """Run the swg-only in-place updater, detached so it survives swg-noded's own restart. Only ever
    called on a valid sync reply that carries an 'update'. Updates swg-noded/swg-agent (and a co-located
    panel) — NOT wg/awg/turn-proxies. The panel clears the request once we report the new version."""
    cmd = (node_cfg.get("node") or {}).get("update_cmd") or DEFAULT_UPDATE_CMD
    base = cmd if isinstance(cmd, list) else ["bash", "-lc", (cmd if os.geteuid() == 0 else "sudo -n " + cmd)]
    try:
        # run OUTSIDE swg-noded's own cgroup, so the updater's 'systemctl restart swg-noded' doesn't
        # kill the updater itself. systemd-run --scope gives it a fresh transient scope.
        if os.path.exists("/run/systemd/system") and shutil.which("systemd-run"):
            argv = ["systemd-run", "--scope", "--collect", "--quiet", "--unit", "swg-self-update"] + base
        else:
            argv = base
        subprocess.Popen(argv, stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
                         stderr=subprocess.DEVNULL, start_new_session=True)
        print(f"self-update started → {want.get('to')}", flush=True)
        return True
    except Exception as e:
        print("self-update failed to start:", e, flush=True)
        return False


def report_proc(panel, state, err=None):
    """Best-effort POST of a lifecycle proc-status (e.g. 'update-failed' + reason) to the panel, so a failure
    that never reaches the normal script-side lifecycle reporting still surfaces as a red tag on the node."""
    try:
        u = panel["url"].rstrip("/") + "/api/node/proc-status"
        post_json(u, panel["token"], {"state": state, "err": (err or "")[:2000]}, panel)
        print(f"proc-status → {state}", flush=True)
    except Exception as e:
        print("proc-status report failed:", e, flush=True)


# ───────────────────────── main loop ─────────────────────────

def main():
    node_cfg = json.load(open(CONFIG_PATH))
    panel = node_cfg.get("panel") or {}
    nd = node_cfg.get("node") or {}
    if not panel.get("url") or not panel.get("token"):
        sys.exit("config needs a 'panel' block with url + token")
    url = panel["url"].rstrip("/") + "/api/node/sync"
    token = panel["token"]
    interval = nd.get("interval", 5)
    online_max = nd.get("online_max", 180)
    agent = nd.get("agent", "/opt/swg-agent/swg-agent")
    sudo = bool(nd.get("sudo"))
    os.makedirs(STATE_DIR, exist_ok=True)
    last_samples = {}
    update_started = False                          # spawn the self-updater at most once per process
    print(f"swg-noded: panel={panel['url']} interval={interval}s "
          f"ifaces={list((node_cfg.get('interfaces') or {}).keys())}", flush=True)
    if TURN_DOCKER:   # download + start turn-proxy containers in the BACKGROUND so the node appears on the
        threading.Thread(target=_dturn_bg_loop, daemon=True).start()   # panel immediately (cards show installing → up)
    while True:
        t0 = time.time()
        try:
            snap = build_snapshot(node_cfg, online_max, last_samples)
            status, reply = post_json(url, token, {"snapshot": snap}, panel)
            if status == 200 and isinstance(reply.get("desired"), dict):
                _upd0 = reply.get("update")
                if _upd0 and not update_started:   # already fired THIS exact request (a recreate restarted us)? then DON'T re-fire — else the update loops forever (recreate → restart → re-trigger → recreate …)
                    _at = str((_upd0 or {}).get("at") or "")
                    _marker = os.path.join(STATE_DIR, ".update-done")   # persists across the container recreate (bind-mounted to data/node)
                    try: _prev = open(_marker).read().strip()
                    except Exception: _prev = ""
                    if _at and _at == _prev: update_started = True
                if reply.get("update") and not update_started:        # panel asked us to self-update (and we haven't fired this one yet)
                    _trig = os.environ.get("SWG_UPDATE_TRIGGER")
                    if _trig:   # docker node: a container can't recreate its own image — touch the HOST trigger
                        try:    # instead; its swg-update.path runs `compose pull && up` on the host (swg images only)
                            with open(_trig, "w") as _f: _f.write(str(int(time.time())) + "\n")
                            try: open(_marker, "w").write(_at)   # remember the request we fired so a recreate-restart won't re-fire it
                            except Exception: pass
                            update_started = True; print(f"update trigger written → {_trig}", flush=True)
                        except Exception as _e:
                            print("update trigger failed:", _e, flush=True)
                            report_proc(panel, "update-failed", f"swg-noded could not write the update trigger {_trig}: {_e}")
                            update_started = True   # reported the failure — don't retry the bad write every sync
                    elif NODE_KIND == "docker":
                        # docker node with NO host updater wired: a container can't recreate its own image, so
                        # run_self_update can do nothing. Report a clear failure instead of silently no-op'ing.
                        print("update requested but no host updater is wired (docker)", flush=True)
                        report_proc(panel, "update-failed",
                                    "This docker node has no one-click host updater wired. Re-install it "
                                    "(bootstrap docker node) to enable the panel's Update button, or update on the box: "
                                    "cd /opt/swg-panel-docker && docker compose --profile node pull && docker compose --profile node up -d")
                        update_started = True
                    else:
                        update_started = run_self_update(node_cfg, reply["update"])
                cr = create_ifaces(node_cfg, reply.get("create"), agent, sudo)   # create new interfaces
                dl = delete_ifaces(node_cfg, reply.get("delete"), agent, sudo)   # tear down deleted ones
                ob = onboard_ifaces(node_cfg, reply.get("onboard"))   # add panel-requested interfaces first
                tp = apply_turn(reply.get("turn"), reply.get("turn_onboard"))   # turn-proxy manage/onboard
                r = reconcile(node_cfg, reply["desired"], agent, sudo, reply.get("remove"))
                ri = reconcile_ifaces(node_cfg, reply.get("desired_ifaces") or {}, agent, sudo)   # set-iface: write the new listen-port to the conf FIRST
                rs = restart_ifaces(node_cfg, reply.get("restart"), agent, sudo)   # THEN bounce — a restart picks up the just-written conf (e.g. a changed port)
                sp = stop_ifaces(node_cfg, reply.get("iface_stop"), agent, sudo)    # stop (down + disable) / start (up + enable) on request
                sa = start_ifaces(node_cfg, reply.get("iface_start"), agent, sudo)
                ik = apply_iface_keys(node_cfg, reply.get("iface_key"), agent, sudo)   # keypair restore/rebaseline from the on-disk backup
                eg = reconcile_egress(node_cfg, reply.get("desired_ifaces") or {})   # per-interface egress SNAT
                # surface iface command failures to the panel too (cmd_errors), keyed by iface name
                for blk in (cr, dl, ob, rs, sp, sa):
                    for e in blk["errors"]:
                        k, _, m = e.partition(": ")
                        NODE_ERRORS[k] = m or e
                for k in (cr.get("created", []) + dl.get("deleted", []) + ob.get("added", [])
                          + rs.get("restarted", []) + sp.get("stopped", []) + sa.get("started", [])):
                    NODE_ERRORS.pop(k, None)
                # prune errors for requests the panel has since cleared (iface + turn)
                active = (set(reply.get("create") or {}) | set(reply.get("onboard") or {})
                          | set(reply.get("delete") or []) | set(reply.get("restart") or []) | set(reply.get("turn") or {})
                          | set(reply.get("iface_stop") or []) | set(reply.get("iface_start") or [])
                          | set(reply.get("turn_onboard") or []))
                for k in list(NODE_ERRORS):
                    if k not in active:
                        NODE_ERRORS.pop(k, None)
                for e in eg["errors"]:
                    print("egress: " + e, flush=True)
                if (r["added"] or r["removed"] or r["errors"] or ri["changed"] or ri["errors"]
                        or eg["changed"] or eg["errors"]
                        or ob["added"] or ob["errors"] or cr["created"] or cr["errors"]
                        or dl["deleted"] or dl["errors"] or tp["done"] or tp["errors"]):
                    print(f"reconcile: +{r['added']} -{r['removed']} ifaces~{ri['changed']} "
                          f"onboard+{ob['added']} create+{cr['created']} delete-{dl['deleted']} turn={tp['done']} "
                          f"errors={(r['errors'] + ri['errors'] + ob['errors'] + cr['errors'] + dl['errors'] + tp['errors'])[:3]}", flush=True)
                interval = reply.get("interval", interval)
            elif status == 0:
                print("sync error:", reply.get("error"), flush=True)
            else:
                print(f"sync HTTP {status}: {reply.get('error')}", flush=True)
        except Exception as e:
            print("loop error:", e, flush=True)
        time.sleep(max(0.5, interval - (time.time() - t0)))


if __name__ == "__main__":
    main()
