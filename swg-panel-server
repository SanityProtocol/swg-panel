def make_token_hash(token, iters=200000):
    salt = os.urandom(16)
    h = hashlib.pbkdf2_hmac("sha256", token.encode(), salt, iters)
    return f"pbkdf2_sha256${iters}${base64.b64encode(salt).decode()}${base64.b64encode(h).decode()}"


# password hashing reuses the same pbkdf2_sha256 format verify_password() understands
make_pw_hash = make_token_hash


def nodes_load(path):
    d = load_json(path, {})
    return d if isinstance(d, dict) else {}


def nodes_save(path, nodes):
    atomic_write(path, json.dumps(nodes, indent=2) + "\n", mode=0o600)


def migrate_node_ids(nodes_path, roster_path, store_configs, config_dir):
    """One-time: nodes keyed by their (mutable) name -> keyed by a stable opaque id, with the
    name kept as a free-to-change display title. Rewrites roster peer targets (node name -> id)
    and renames any stored config files. Idempotent: a no-op once every node is id-keyed."""
    nodes = load_json(nodes_path, {})
    if not isinstance(nodes, dict) or not nodes:
        return
    if all(isinstance(v, dict) and v.get("id") == k for k, v in nodes.items()):
        return                                      # already migrated
    name_to_id, new_nodes = {}, {}
    for key, v in nodes.items():
        if not isinstance(v, dict):
            continue
        nid = v.get("id") or gen_id()
        while nid in new_nodes:
            nid = gen_id()
        v["id"] = nid
        v["name"] = v.get("name", key)              # the old dict key was the (display) name
        new_nodes[nid] = v
        for nm in {key, v["name"]}:
            if nm and nm != nid:
                name_to_id[nm] = nid
    nodes_save(nodes_path, new_nodes)
    roster = roster_load(roster_path)
    changed = False
    for p in (roster.get("peers") or {}).values():
        if not isinstance(p, dict):
            continue
        for t in p.get("targets", []):
            old, new = t.get("node"), name_to_id.get(t.get("node"))
            if new and new != old:
                if store_configs and config_dir and p.get("pubkey") and t.get("iface"):
                    with contextlib.suppress(OSError):
                        os.replace(os.path.join(config_dir, cfg_hash(p["pubkey"], old, t["iface"])),
                                   os.path.join(config_dir, cfg_hash(p["pubkey"], new, t["iface"])))
                t["node"] = new
                changed = True
    if changed:
        roster_save(roster_path, roster)
    print(f"migrated {len(new_nodes)} node(s) to stable ids", flush=True)


def find_node_by_token(nodes, token):
    if not token:
        return None, None
    for nid, n in nodes.items():
        if verify_password(n.get("token_hash", ""), token):
            return nid, n
    return None, None


def node_remove(deps, nid):
    """Drop a node from the store and cascade: purge its peer targets (deleting peers whose only
    deployment was here), forget its live snapshot, and delete its stats + health files. Returns
    the removed node's display name, or None if it wasn't there. Shared by force-remove + goodbye."""
    nodes = nodes_load(deps["nodes_path"])
    if nid not in nodes:
        return None
    nm = nodes[nid].get("name", nid)
    sf = nodes[nid].get("stats_file", f"stats-{nid}.json")
    del nodes[nid]
    nodes_save(deps["nodes_path"], nodes)
    roster = roster_load(deps["roster_path"]); changed = False
    for pid in list(roster["peers"].keys()):
        p = roster["peers"][pid]
        kept = [t for t in p.get("targets", []) if t.get("node") != nid]
        if len(kept) != len(p.get("targets", [])):
            changed = True
            if kept:
                p["targets"] = kept; p["modified_at"] = int(time.time())
            else:
                del roster["peers"][pid]
    if changed:
        roster_save(deps["roster_path"], roster)
    (deps.get("node_snaps") or {}).pop(nid, None)
    (deps.get("node_seen") or {}).pop(nid, None)
    sd = deps.get("stats_dir")
    if sd:
        with contextlib.suppress(OSError):
            os.unlink(os.path.join(sd, sf))
        with contextlib.suppress(OSError):
            os.unlink(os.path.join(sd, f"health-{nid}.rrd"))
    ev_append(deps["roster_path"], "node", nid, "Removed node", nm)
    return nm


def desired_for_node(roster, node_id):
    """The peer set the roster assigns to one node, grouped by interface.

    Derived entirely from peers→targets: a node may serve several interfaces
    (e.g. awg100 + wg99); each target names the (node, iface, ip) it lands on, so
    we never push a peer onto the wrong one. The wire shape is unchanged from the
    flat-roster era — a node still receives
        { "<iface>": [ {public_key, allowed_ips, preshared_key, name}, ... ] }
    — so swg-noded / swg-agent are untouched by the schema change.
    """
    users = roster.get("users") or {}
    out = {}
    for p in (roster.get("peers") or {}).values():
        if not isinstance(p, dict):
            continue
        uname = (users.get(p.get("user_id")) or {}).get("name", "")
        # node-side label (a .conf comment): "user · title" so the operator can tell devices apart
        name = " · ".join(x for x in (uname, p.get("title", "")) if x)
        for t in p.get("targets", []):
            if t.get("node") != node_id:
                continue
            iface = t.get("iface") or ""
            if not iface:
                continue
            ip = (t.get("ip") or "").split("/")[0]
            out.setdefault(iface, []).append({
                "public_key": p.get("pubkey"),
                "allowed_ips": (ip + "/32") if ip else "",
                "preshared_key": p.get("psk") or "none",
                "name": name,
            })
    return out


# ───────────────────────── node snapshots → reads ─────────────────────────

def _node_issues(c, snap):
    """Health-check roll-up for one node: settings edited on the server (drift), an egress IP / WAN
    NIC the node no longer has, and turn-proxies that aren't running. Empty list = healthy."""
    issues = []
    nips = snap.get("node_ips") or []; nifs = snap.get("node_ifaces") or []
    for ifn, ov in (c.get("ifaces") or {}).items():
        if ov.get("_drift"):
            issues.append(ifn + ": edited directly on the server")
        eg = ov.get("egress_ip")
        if eg and nips and eg not in nips:
            issues.append(ifn + ": egress IP " + eg + " is no longer on the node")
        wn = ov.get("wan_iface")
        if wn and nifs and wn not in nifs:
            issues.append(ifn + ": WAN interface " + wn + " is no longer on the node")
    for tp in (snap.get("turn_proxies") or []):
        if tp.get("running") is False:
            issues.append((tp.get("service") or "turn-proxy") + ": not running")
    return issues

def node_describe(snapshot):
    """Server/interface info from a node's pushed snapshot (config-building + UI)."""
    interfaces = {}
    for iface, blk in (snapshot.get("interfaces") or {}).items():
        meta = blk.get("meta") or {}
        peers = blk.get("peers") or []
        used = sorted({(p.get("allowed_ips") or "").split("/")[0]
                       for p in peers if p.get("allowed_ips")})
        interfaces[iface] = {
            "public_key": meta.get("public_key"), "listen_port": meta.get("listen_port"),
            "endpoint": meta.get("endpoint"), "address": meta.get("address"),
            "subnet": meta.get("subnet"), "awg_params": meta.get("awg_params", {}),
            "dns": meta.get("dns", []), "used_ips": used, "peer_count": len(peers),
        }
    return {"ok": True, "op": "describe",
            "data": {"hostname": snapshot.get("hostname"), "interfaces": interfaces}}


AWG_PARAM_KEYS = ["Jc", "Jmin", "Jmax", "S1", "S2", "S3", "S4",
                  "H1", "H2", "H3", "H4", "I1", "I2", "I3", "I4", "I5"]


def apply_iface_meta(node_cfg, interfaces):
    """Overlay panel-side per-interface overrides onto node-reported metadata, in place:
    a public endpoint host/port (what clients dial — may differ from the node's listen port
    behind NAT), and a default DNS / MTU used when rendering configs & creating new peers.
    Does not change the node — only what the panel emits in client configs. Returns interfaces."""
    node_ep = (node_cfg or {}).get("endpoint_host")
    ifov = (node_cfg or {}).get("ifaces") or {}
    for ifn, ifc in interfaces.items():
        ov = ifov.get(ifn) or {}
        rep = ifc.get("endpoint") or ""
        rep_host = rep.rsplit(":", 1)[0] if ":" in rep else rep
        host = ov.get("endpoint_host") or node_ep or rep_host
        # listen_port is the desired UDP port — the node converges its ListenPort to it, and the
        # client Endpoint uses it (listen IP == connection IP for our purposes).
        want_port = ov.get("listen_port")
        port = want_port or ifc.get("listen_port")
        if host and port:
            ifc["endpoint"] = f"{host}:{port}"
        if want_port:
            ifc["desired_port"] = want_port   # != reported listen_port => "updating" in the UI
        if ov.get("dns") is not None:                # always serve dns as a list (the UI expects one)
            d = ov["dns"]
            ifc["dns"] = d if isinstance(d, list) else [s.strip() for s in str(d).split(",") if s.strip()]
        ifc["mtu"] = ov.get("mtu") or 1280
        ifc["egress_ip"] = ov.get("egress_ip") or ""   # per-interface source/egress IP (blank = auto/MASQUERADE)
        ifc["wan_iface"] = ov.get("wan_iface") or ""   # per-interface egress WAN NIC (blank = auto-detect)
        ifc["drift"] = dict(ov.get("_drift") or {})    # settings edited directly on the server (key → the node's value)
        # AmneziaWG obfuscation params: the override wins for what the panel renders into configs;
        # the node converges its interface to it. awg_pending flags desired != reported in the UI.
        ovawg = ov.get("awg_params")
        if isinstance(ovawg, dict) and ovawg:
            rep_awg = dict(ifc.get("awg_params") or {})
            ifc["awg_reported"] = rep_awg
            ifc["awg_params"] = {**rep_awg, **{k: ovawg[k] for k in ovawg if ovawg[k] not in (None, "")}}
            ifc["awg_pending"] = ifc["awg_params"] != rep_awg
    return interfaces


def panel_next_ip(snaps, roster, nodes, iface):
    """Lowest address free on every selected node's iface AND unclaimed in the roster."""
    used, subnet = set(), None
    for node in nodes:
        snap = snaps.get(node)
        if not snap:
            return err("next-ip", f"{node}: no snapshot yet (is the node online?)", "offline")
        blk = (snap.get("interfaces") or {}).get(iface)
        if not blk:
            return err("next-ip", f"{node} has no interface {iface!r}", "bad_request")
        meta = blk.get("meta") or {}
        for p in (blk.get("peers") or []):
            ip = (p.get("allowed_ips") or "").split("/")[0]
            if ip:
                used.add(ip)
        used.add((meta.get("address") or "").split("/")[0])
        if subnet is None:
            subnet = meta.get("subnet")
    for p in (roster.get("peers") or {}).values():
        if not isinstance(p, dict):
            continue
        for t in p.get("targets", []):
            if t.get("iface") == iface and t.get("ip"):   # IPs only collide within one iface's subnet
                used.add(t["ip"].split("/")[0])
    if not subnet:
        return err("next-ip", "no subnet info in snapshot")
    net = ipaddress.ip_network(subnet, strict=False)
    for host in net.hosts():
        if str(host) not in used:
            return {"ok": True, "op": "next-ip",
                    "data": {"iface": iface, "next_ip": str(host) + "/32", "subnet": subnet}}
    return err("next-ip", "no free addresses across selected nodes", "subnet_full")


# ───────────────── node health history (RRD-style binary ring) ─────────────────
#
# A tiny round-robin file per node under stats_dir (health-<node>.rrd): fixed size,
# one slot per HRRD_STEP-second bucket, HRRD_SLOTS slots = a 24h window that wraps and
# overwrites the oldest. Each slot keeps the LAST cpu/mem/disk percent seen in its
# bucket (consolidation), so 5s syncs naturally downsample to 1-minute points.
# Stdlib `struct`, O(1) seek+write per sync, survives restart, ~11 KB/node. Reads
# return the most recent points for the sparklines. Lock guards concurrent node syncs.

HRRD_MAGIC = b"SWGH"
HRRD_VER = 3            # v3: a coarse hourly ring added after the minute ring (week/month views)
HRRD_STEP = 60          # minute ring: seconds per bucket (1-minute resolution)
HRRD_SLOTS = 1440       # minute ring: 24h of buckets  → live + day views
HRRD_HSTEP = 3600       # hour ring: seconds per bucket (1-hour resolution)
HRRD_HSLOTS = 744       # hour ring: 31 days of buckets → week + month views
HRRD_VIEW = 60          # points returned for the default (live) sparkline
LIVE_MAX = 120          # in-memory raw samples kept per node for the LIVE view (one per sync; ~10min@5s)
HRRD_HEAD = struct.Struct("<4sBII")           # magic, version, min_step, min_slots
HRRD_SLOT = struct.Struct("<IBBBxII")         # bucket, cpu, mem, disk, pad, rx, tx  (16 bytes)
HRRD_NA = 255
HRRD_U32 = 0xFFFFFFFF
HRRD_HBASE = HRRD_HEAD.size + HRRD_SLOTS * HRRD_SLOT.size   # byte offset of the hour ring
_hrrd_lock = threading.Lock()


def snap_traffic(snap):
    """Aggregate (rx, tx) bytes/sec across all interfaces' peers in a node snapshot."""
    rx = tx = 0
    for blk in ((snap or {}).get("interfaces") or {}).values():
        for p in (blk.get("peers") or []):
            rx += p.get("rx_speed", 0) or 0
            tx += p.get("tx_speed", 0) or 0
    return int(rx), int(tx)


def health_pcts(health):
    """(cpu, mem, disk) integer percentages from a snapshot health block, NA where absent.
    CPU is load-per-core; disk is the busiest mount."""
    if not isinstance(health, dict):
        return None
    def pc(used, total):
        return HRRD_NA if not total else max(0, min(100, round(used / total * 100)))
    cpu = HRRD_NA
    load = health.get("load")
    if isinstance(load, list) and load:
        cpu = max(0, min(100, round((load[0] or 0) / (health.get("ncpu") or 1) * 100)))
    m = health.get("mem") or {}
    mem = pc(m.get("used", 0), m.get("total", 0))
    disk = HRRD_NA
    for d in (health.get("disk") or []):
        if d.get("total"):
            disk = max(0 if disk == HRRD_NA else disk, pc(d["used"], d["total"]))
    return (cpu, mem, disk)


def _hrrd_ok(path):
    try:
        with open(path, "rb") as f:
            magic, ver, step, slots = HRRD_HEAD.unpack(f.read(HRRD_HEAD.size))
        return magic == HRRD_MAGIC and ver == HRRD_VER and step == HRRD_STEP and slots == HRRD_SLOTS
    except (OSError, struct.error):
        return False


def _hrrd_mx(new, old):           # peak of two pct bytes, ignoring the NA sentinel
    if new == HRRD_NA: return old
    if old == HRRD_NA: return new
    return max(new, old)


def _hrrd_put(f, base, slots, bucket, cpu, mem, disk, rx, tx, merge=False):
    off = base + (bucket % slots) * HRRD_SLOT.size
    if merge:
        # same bucket still in this slot → keep the peak so sub-bucket spikes survive the
        # coarser downsample (the hour ring is 1 sample/hour; last-write-wins would hide them).
        f.seek(off)
        cur = f.read(HRRD_SLOT.size)
        if len(cur) == HRRD_SLOT.size:
            b0, c0, m0, d0, rx0, tx0 = HRRD_SLOT.unpack(cur)
            if b0 == (bucket & 0xFFFFFFFF):
                cpu, mem, disk = _hrrd_mx(cpu, c0), _hrrd_mx(mem, m0), _hrrd_mx(disk, d0)
                rx, tx = max(int(rx), rx0), max(int(tx), tx0)
    f.seek(off)
    f.write(HRRD_SLOT.pack(bucket & 0xFFFFFFFF, cpu & 0xFF, mem & 0xFF, disk & 0xFF,
                           min(max(int(rx), 0), HRRD_U32), min(max(int(tx), 0), HRRD_U32)))


def hrrd_update(path, ts, cpu, mem, disk, rx=0, tx=0):
    ts = int(ts)
    with _hrrd_lock:
        if not _hrrd_ok(path):                    # (re)create: header + both zeroed rings (also upgrades v1/v2)
            with contextlib.suppress(OSError):
                with open(path, "wb") as f:
                    f.write(HRRD_HEAD.pack(HRRD_MAGIC, HRRD_VER, HRRD_STEP, HRRD_SLOTS))
                    f.write(b"\x00" * (HRRD_SLOT.size * (HRRD_SLOTS + HRRD_HSLOTS)))
        with contextlib.suppress(OSError):
            with open(path, "r+b") as f:
                _hrrd_put(f, HRRD_HEAD.size, HRRD_SLOTS, ts // HRRD_STEP, cpu, mem, disk, rx, tx)   # minute ring
                _hrrd_put(f, HRRD_HBASE, HRRD_HSLOTS, ts // HRRD_HSTEP, cpu, mem, disk, rx, tx, merge=True)  # hour ring (peak-consolidated)


def hrrd_read(path, want=HRRD_VIEW, hourly=False):
    """Most recent `want` buckets from the minute (or hourly) ring as
    {t, cpu, mem, disk, rx, tx} (NA -> None)."""
    with _hrrd_lock:
        try:
            with open(path, "rb") as f:
                data = f.read()
        except OSError:
            return None
    if len(data) < HRRD_HEAD.size or data[:4] != HRRD_MAGIC:
        return None
    _, ver, step, slots = HRRD_HEAD.unpack_from(data, 0)
    if ver != HRRD_VER or step != HRRD_STEP or slots != HRRD_SLOTS:   # old layout — show nothing till it refills
        return None
    base = HRRD_HBASE if hourly else HRRD_HEAD.size
    nslots = HRRD_HSLOTS if hourly else HRRD_SLOTS
    rstep = HRRD_HSTEP if hourly else HRRD_STEP
    rows = []
    for i in range(nslots):
        off = base + i * HRRD_SLOT.size
        if off + HRRD_SLOT.size > len(data):
            break
        b, c, m, d, rx, tx = HRRD_SLOT.unpack_from(data, off)
        if b:
            rows.append((b, c, m, d, rx, tx))
    if not rows:
        return None
    rows.sort()
    rows = rows[-want:]
    na = lambda v: None if v == HRRD_NA else v
    return {"t": [r[0] * rstep for r in rows],
            "cpu": [na(r[1]) for r in rows], "mem": [na(r[2]) for r in rows], "disk": [na(r[3]) for r in rows],
            "rx": [r[4] for r in rows], "tx": [r[5] for r in rows]}


# ───────────────────────── API ─────────────────────────

def api(method, path, qs, body, deps):
    fleet = deps["fleet"]; roster_path = deps["roster_path"]
    nodes = nodes_load(deps["nodes_path"])
    snaps = deps.get("node_snaps") or {}; seen = deps.get("node_seen") or {}
    now = deps.get("now", lambda: int(time.time()))
    # store_configs defaults ON: client configs (with the private key) are kept on the panel host
    # so QR codes / config downloads stay available any time, not just at creation. Set it to
    # false in fleet.json to keep no client secrets at rest. config_dir defaults next to the roster.
    store_configs = fleet.get("store_configs", True) is not False
    config_dir = fleet.get("config_dir") or os.path.join(os.path.dirname(roster_path) or ".", "configs")

    def known(node):
        return node in nodes

    if method == "GET" and path == "/api/fleet":
        out = [{"id": nid, "name": c.get("name", nid), "color": c.get("color"), "transport": "https",
                "stats_file": c.get("stats_file", f"stats-{nid}.json")}
               for nid, c in nodes.items()]
        return 200, {"ok": True, "data": {"nodes": out, "store_configs": store_configs, "versions": VERSIONS}}

    stats_dir = deps.get("stats_dir")

    def nodes_view():
        out = []
        for nid, c in nodes.items():
            snap = snaps.get(nid) or {}
            ls = seen.get(nid)
            online = ls is not None and (now() - ls) <= NODE_OFFLINE
            pc = rx = tx = 0
            for blk in (snap.get("interfaces") or {}).values():
                ps = blk.get("peers") or []
                pc += len(ps)
                rx += sum(p.get("rx_speed", 0) or 0 for p in ps)
                tx += sum(p.get("tx_speed", 0) or 0 for p in ps)
            hh = hrrd_read(os.path.join(stats_dir, f"health-{nid}.rrd")) if stats_dir else None
            lb = (deps.get("live_samples") or {}).get(nid) or []   # raw 5s-granular buffer (one point/sync)
            na = lambda v: None if v == HRRD_NA else v
            hl = ({"t": [s[0] for s in lb], "cpu": [na(s[1]) for s in lb], "mem": [na(s[2]) for s in lb],
                   "disk": [na(s[3]) for s in lb], "rx": [s[4] for s in lb], "tx": [s[5] for s in lb]}
                  if len(lb) > 1 else None)
            out.append({"id": nid, "name": c.get("name", nid), "color": c.get("color"),
                        "transport": "https",
                        "endpoint_host": c.get("endpoint_host"), "created": c.get("created"),
                        "removing": bool(c.get("removing")), "removing_at": c.get("removing_at"),
                        "last_seen": ls,
                        "status": "online" if online else ("dangling" if ls is None else "offline"),
                        "peer_count": pc, "rx_speed": rx, "tx_speed": tx,
                        "hostname": snap.get("hostname"),
                        "health": snap.get("health"),     # per-node load/mem/disk/uptime (additive)
                        "health_history": hh,             # recent cpu/mem/disk % series (RRD-style ring)
                        "health_live": hl,                # raw per-sync samples for the LIVE view (5s)
                        "kind": snap.get("kind"),               # "docker" | "baremetal"
                        "net_mode": snap.get("net_mode") or "host",   # docker net mode: host | bridge (bridge → created-iface ports need publishing)
                        "turn_manage": bool(snap.get("turn_manage")),  # can the panel edit/restart this node's turn-proxies?
                        "ips": snap.get("node_ips") or [],             # the node's own IPs — candidates for a per-interface egress IP
                        "wan_ifaces": snap.get("node_ifaces") or [],   # the node's NICs — candidates for the egress WAN interface
                        "version": snap.get("noded_version"),   # swg-noded version this node reports
                        "latest": VERSIONS.get("panel"),        # the fleet reference (panel's own version)
                        "outdated": _ver_behind(snap.get("noded_version"), VERSIONS.get("panel")),   # strictly older only — never offer a downgrade
                        "ahead": _ver_ahead(snap.get("noded_version"), VERSIONS.get("panel")),        # node is NEWER than the panel
                        "updating": bool(c.get("update")),                       # self-update in flight
                        "onboarding": sorted((c.get("onboard") or {}).keys()),   # ifaces pending onboard
                        "creating": {k: ((v.get("cmd") or ["awg"])[0])               # iface → wg/awg (we know it)
                                     for k, v in (c.get("create") or {}).items()},
                        "deleting": sorted((c.get("delete") or {}).keys()),         # ifaces being torn down
                        "restarting": sorted((c.get("restart") or {}).keys()),      # ifaces being bounced
                        "turn_pending": {k: (v.get("action") or "manage")           # turn service → pending action
                                         for k, v in (c.get("turn") or {}).items()},
                        "turn_onboarding": list(c.get("turn_onboard") or []),       # .service paths pending onboard
                        "cmd_errors": (snap.get("cmd_errors") or {}),               # request key -> last host->node command error
                        "issues": _node_issues(c, snap),                            # health-check roll-up: drift / missing egress / turn down
                        "interfaces": list((snap.get("interfaces") or {}).keys())})
        return out

    def describe_view():
        """Per-node interface metadata (server key / endpoint / subnet / awg / dns) the
        create + copy flows need, with the panel's endpoint_host override applied — so the
        UI builds client configs without a describe round-trip per node. Keyed by node id."""
        out = {}
        for nid in nodes:
            snap = snaps.get(nid)
            if not snap:
                continue
            d = node_describe(snap)["data"]["interfaces"]
            apply_iface_meta(nodes.get(nid), d)
            out[nid] = d
        return out

    if method == "GET" and path == "/api/nodes":
        return 200, {"ok": True, "data": {"nodes": nodes_view()}}

    if method == "GET" and path == "/api/state":
        # One consolidated read: everything the UI polls for, in a single round trip.
        # Status is NOT computed here — the browser derives it from roster + snapshots via
        # reconcile.js (the single source of truth), so this stays a raw-data bundle.
        return 200, {"ok": True, "data": {
            "roster": roster_load(roster_path),          # {version, users, peers}
            "nodes": nodes_view(),                       # fleet metadata + live counters
            "describe": describe_view(),                 # per-node interface meta for config building
            "snapshots": snaps,                          # raw observed state, keyed by node (reconcile input)
            "store_configs": store_configs, "versions": VERSIONS,
            "latest_remote": LATEST_REMOTE.get("version"),           # newest published version (repo VERSION)
            "panel_outdated": bool(LATEST_REMOTE.get("version") and VERSIONS.get("panel")
                                   and LATEST_REMOTE["version"] != VERSIONS.get("panel")),
            "env": {"docker": IN_DOCKER, "fleet_path": FLEET_PATH},   # for UI hints (e.g. enable store_configs)
        }}

    if method == "GET" and path == "/api/roster":
        return 200, {"ok": True, "data": roster_load(roster_path)}

    if method == "GET" and path == "/api/account":
        creds = deps.get("auth")
        return 200, {"ok": True, "data": {"username": creds[0] if creds else None,
                                          "auth_enabled": bool(creds)}}

    if method == "POST" and path == "/api/account":
        creds = deps.get("auth")
        if not creds:
            return 403, {"ok": False, "error": "login is not enabled on this panel", "code": "no_auth"}
        if not AUTH_FILE:
            return 400, {"ok": False, "error": "no auth file configured (SWG_PANEL_AUTH unset)", "code": "no_auth_file"}
        cur = body.get("current_password", "")
        if not verify_password(creds[1], cur):
            return 403, {"ok": False, "error": "current password is incorrect", "code": "bad_password"}
        new_user = (body.get("username") or creds[0]).strip()
        new_pw = body.get("new_password") or ""
        if not new_user:
            return 400, {"ok": False, "error": "username cannot be empty", "code": "bad_request"}
        if ":" in new_user:
            return 400, {"ok": False, "error": "username cannot contain ':'", "code": "bad_request"}
        if new_pw and len(new_pw) < 8:
            return 400, {"ok": False, "error": "new password must be at least 8 characters", "code": "weak_password"}
        new_hash = make_pw_hash(new_pw) if new_pw else creds[1]
        try:
            atomic_write(AUTH_FILE, f"{new_user}:{new_hash}\n", mode=0o600)
        except OSError as e:
            return 500, {"ok": False, "error": f"could not write auth file: {e}", "code": "internal"}
        deps["auth"] = (new_user, new_hash)          # hot-reload in-process; no restart
        return 200, {"ok": True, "data": {"username": new_user, "password_changed": bool(new_pw)}}

    if method == "GET" and path == "/api/config":
        pk = (qs.get("pubkey") or [""])[0]; node = (qs.get("node") or [""])[0]
        iface = (qs.get("iface") or [""])[0]
        if not (store_configs and config_dir and pk and node):
            return 404, {"ok": False, "error": "config not stored", "code": "not_found"}
        text = None
        with contextlib.suppress(OSError):
            with open(os.path.join(config_dir, cfg_hash(pk, node, iface))) as f:
                text = f.read()
        if text is None:
            return 404, {"ok": False, "error": "config not stored", "code": "not_found"}
        return 200, {"ok": True, "data": {"config": text}}

    if method == "GET" and path == "/api/describe":
        node = (qs.get("node") or [""])[0]
        if not known(node):
            return 400, {"ok": False, "error": f"unknown node {node!r}", "code": "bad_request"}
        snap = snaps.get(node)
        if not snap:
            return 400, {"ok": False, "error": "node has not reported yet (is swg-noded running?)",
                         "code": "offline"}
        d = node_describe(snap)
        apply_iface_meta(nodes.get(node), d["data"]["interfaces"])
        return 200, d

    if method == "GET" and path == "/api/events":
        try:
            limit = max(1, min(50, int((qs.get("limit") or ["12"])[0])))
        except ValueError:
            limit = 12
        return 200, {"ok": True, "data": ev_read(roster_path, limit)}

    if method == "GET" and path == "/api/node-history":
        node = (qs.get("node") or [""])[0]
        rng = (qs.get("range") or ["live"])[0]
        if not known(node):
            return 400, {"ok": False, "error": f"unknown node {node!r}", "code": "bad_request"}
        rrd = os.path.join(stats_dir, f"health-{node}.rrd") if stats_dir else None
        # (points, hourly): live=10m, hour=60m, day=24h from the minute ring; week/month from the hour ring
        spec = {"live": (10, False), "hour": (60, False), "day": (HRRD_SLOTS, False),
                "week": (168, True), "month": (HRRD_HSLOTS, True)}.get(rng)
        if not spec:
            return 400, {"ok": False, "error": "range must be live|hour|day|week|month", "code": "bad_request"}
        data = hrrd_read(rrd, spec[0], hourly=spec[1]) if rrd else None
        return 200, {"ok": True, "data": data or {"t": [], "cpu": [], "mem": [], "disk": [], "rx": [], "tx": []}}

    if method == "GET" and path == "/api/next-ip":
        sel = [n for n in (qs.get("nodes") or [""])[0].split(",") if n]
        iface = (qs.get("iface") or [""])[0]
        if not sel or not iface:
            return 400, {"ok": False, "error": "need nodes and iface", "code": "bad_request"}
        bad = [n for n in sel if not known(n)]
        if bad:
            return 400, {"ok": False, "error": f"unknown node(s): {', '.join(bad)}", "code": "bad_request"}
        r = panel_next_ip(snaps, roster_load(roster_path), sel, iface)
        return (200 if r.get("ok") else 400), r

    # ─────────────── users (identity) ───────────────

    if method == "POST" and path == "/api/users/create":
        name = (body.get("name") or "").strip()
        if not name:
            return 400, {"ok": False, "error": "name is required", "code": "bad_request"}
        roster = roster_load(roster_path)
        uid = gen_id()
        while uid in roster["users"]:
            uid = gen_id()
        u = user_set(roster, uid, {"name": name, "tag": (body.get("tag") or "").strip(),
                                   "note": body.get("note", "")}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "user", uid, "Created user", name)
        return 200, {"ok": True, "data": u}

    if method == "POST" and path == "/api/users/update":
        uid = body.get("id") or ""
        roster = roster_load(roster_path)
        if uid not in roster["users"]:
            return 404, {"ok": False, "error": "unknown user", "code": "not_found"}
        fields = {}
        for k in ("name", "tag", "note"):
            if k in body:
                v = body[k]
                fields[k] = v.strip() if (isinstance(v, str) and k != "note") else v
        if "name" in fields and not fields["name"]:
            return 400, {"ok": False, "error": "name cannot be empty", "code": "bad_request"}
        renamed = "name" in fields
        u = user_set(roster, uid, fields, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "user", uid, "Renamed user" if renamed else "Updated user",
                  u.get("name", ""), "" if renamed else ", ".join(sorted(fields)) or "")
        return 200, {"ok": True, "data": u}

    if method == "POST" and path == "/api/users/delete":
        uid = body.get("id") or ""
        roster = roster_load(roster_path)
        if uid not in roster["users"]:
            return 404, {"ok": False, "error": "unknown user", "code": "not_found"}
        # Deleting a user never silently wipes their peers — they go unassigned. But each
        # is PSK-rotated so the (now ex-)user's saved configs stop working immediately.
        uname = (roster["users"][uid] or {}).get("name", "")
        freed = 0
        for p in roster["peers"].values():
            if p.get("user_id") == uid:
                unassign_peer(p, store_configs, config_dir, now()); freed += 1
        del roster["users"][uid]
        roster_save(roster_path, roster)
        ev_append(roster_path, "user", uid, "Deleted user", uname,
                  f"{freed} peer{'' if freed == 1 else 's'} unassigned" if freed else "")
        return 200, {"ok": True, "data": {"id": uid, "unassigned_peers": freed}}

    # ─────────────── peers (credential + targets) ───────────────

    if method == "POST" and path == "/api/peers/create":
        # Mint a NEW credential (own key + PSK) and deploy it to one or more targets in a
        # single atomic write. Accepts targets:[{node,iface,ip}, ...]; a lone `target` is
        # still honoured. Per-target client configs come in body.configs keyed "node|iface".
        pubkey = (body.get("pubkey") or "").strip()
        targets = body.get("targets")
        if not isinstance(targets, list) or not targets:
            t = body.get("target")
            targets = [t] if t else []
        if not pubkey:
            return 400, {"ok": False, "error": "pubkey is required", "code": "bad_request"}
        if not targets:
            return 400, {"ok": False, "error": "at least one target is required", "code": "bad_request"}
        for t in targets:
            for f in ("node", "iface", "ip"):
                if not (t or {}).get(f):
                    return 400, {"ok": False, "error": f"target.{f} is required", "code": "bad_request"}
            if not known(t["node"]):
                return 400, {"ok": False, "error": f"unknown node {t['node']!r}", "code": "bad_request"}
        seen = set()
        for t in targets:
            k = (t["node"], t["iface"])
            if k in seen:
                return 400, {"ok": False, "error": f"duplicate target {t['node']}/{t['iface']}", "code": "bad_request"}
            seen.add(k)
        be = bad_targets(targets)
        if be:
            return 400, {"ok": False, "error": be, "code": "bad_request"}
        roster = roster_load(roster_path)
        if find_peer_by_pubkey(roster, pubkey):
            return 409, {"ok": False, "error": "a peer with this key already exists "
                         "(use add-target to deploy it elsewhere)", "code": "exists"}
        uid = body.get("user_id")
        if uid and uid not in roster["users"]:
            return 400, {"ok": False, "error": "unknown user", "code": "bad_request"}
        for t in targets:
            if not t.get("type"):
                t["type"] = iface_type(snaps, t["node"], t["iface"])
        psk = body.get("psk") or gen_psk()      # PSK is panel-owned; auto-mint when the client omits one
        pid = gen_id()
        while pid in roster["peers"]:
            pid = gen_id()
        p = peer_set(roster, pid, {"user_id": uid or None, "title": body.get("title", ""),
                                   "pubkey": pubkey, "psk": psk, "targets": targets}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Created peer", peer_label(roster, p),
                  f"{len(targets)} target{'' if len(targets) == 1 else 's'} · {targets[0]['node']}/{targets[0]['iface']}")
        configs = body.get("configs") or {}
        for t in targets:
            conf = configs.get(t["node"] + "|" + t["iface"])
            if conf is None and len(targets) == 1:
                conf = body.get("config")   # single-target back-compat
            save_config(store_configs, config_dir, pubkey, t["node"], t["iface"], conf)
        return 200, {"ok": True, "data": p}

    if method == "POST" and path == "/api/peers/add-target":
        # "Copy peer interface→interface" — SAME key + SAME PSK on a new (node, iface, ip).
        pid = body.get("peer_id") or ""
        target = body.get("target") or {}
        for f in ("node", "iface", "ip"):
            if not target.get(f):
                return 400, {"ok": False, "error": f"target.{f} is required", "code": "bad_request"}
        if not known(target["node"]):
            return 400, {"ok": False, "error": f"unknown node {target['node']!r}", "code": "bad_request"}
        if not valid_addr(target["ip"]):
            return 400, {"ok": False, "error": f"invalid address {target['ip']!r}", "code": "bad_request"}
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        if any(t["node"] == target["node"] and t["iface"] == target["iface"] for t in p["targets"]):
            return 409, {"ok": False, "error": "peer already has a target on that node/interface",
                         "code": "exists"}
        if not target.get("type"):
            target["type"] = iface_type(snaps, target["node"], target["iface"])
        p2 = peer_set(roster, pid, {"targets": p["targets"] + [target]}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Added deployment", peer_label(roster, p2),
                  f"{target['node']}/{target['iface']}")
        save_config(store_configs, config_dir, p["pubkey"], target["node"], target["iface"], body.get("config"))
        return 200, {"ok": True, "data": p2}

    if method == "POST" and path == "/api/peers/remove-target":
        pid = body.get("peer_id") or ""
        node = body.get("node") or ""; iface = body.get("iface") or ""
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        kept = [t for t in p["targets"] if not (t["node"] == node and t["iface"] == iface)]
        if not kept:
            # Never silently delete via the last target — deletion is an explicit, gated act
            # (and only for unassigned peers). Caller must use peers/delete instead.
            return 409, {"ok": False, "error": "this is the peer's only deployment — "
                         "delete the peer instead (unassign it first)", "code": "last_target"}
        del_config(store_configs, config_dir, p["pubkey"], node, iface)
        retire_pubkey(nodes, deps["nodes_path"], [{"node": node, "iface": iface}], p["pubkey"])   # drop it even on add-only ifaces
        p2 = peer_set(roster, pid, {"targets": kept}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Removed deployment", peer_label(roster, p2),
                  f"{node}/{iface}")
        return 200, {"ok": True, "data": p2}

    if method == "POST" and path == "/api/peers/update":
        # Edit a peer's operator-facing label (title) and/or owner (user_id). Metadata only —
        # the key/PSK/config are untouched, so assigning an unassigned peer keeps the credential
        # it already has (a config that's been handed out keeps working). Reassigning a peer
        # between users (which must rotate keys) goes through /api/peers/rekey instead.
        pid = body.get("peer_id") or ""
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        changed = {}
        if "title" in body:
            changed["title"] = body.get("title", "")
        if "user_id" in body:
            uid = body.get("user_id")
            if uid and uid not in roster["users"]:
                return 400, {"ok": False, "error": "unknown user", "code": "bad_request"}
            changed["user_id"] = uid or None
        if not changed:
            return 400, {"ok": False, "error": "nothing to update", "code": "bad_request"}
        p2 = peer_set(roster, pid, changed, now())
        roster_save(roster_path, roster)
        if "title" in changed:
            ev_append(roster_path, "peer", pid, "Renamed peer", peer_label(roster, p2))
        if "user_id" in changed:
            ev_append(roster_path, "peer", pid,
                      "Assigned peer" if changed["user_id"] else "Unassigned peer", peer_label(roster, p2))
        return 200, {"ok": True, "data": p2}

    if method == "POST" and path == "/api/peers/update-target":
        # Change a target's assigned address — a real connectivity change (its allowed_ips moves),
        # reconciled to the node on the next sync. Validates the IP and guards against a collision
        # with another peer on the same interface.
        pid = body.get("peer_id") or ""
        node = body.get("node") or ""; iface = body.get("iface") or ""
        ip = (body.get("ip") or "").split("/")[0].strip()
        if not valid_addr(ip):
            return 400, {"ok": False, "error": f"invalid address {body.get('ip')!r}", "code": "bad_request"}
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        if not any(t["node"] == node and t["iface"] == iface for t in p["targets"]):
            return 404, {"ok": False, "error": "peer has no target on that node/interface", "code": "not_found"}
        for op in roster["peers"].values():     # uniqueness within the (node, iface) subnet
            if op.get("id") == pid:
                continue
            for t in op.get("targets", []):
                if t.get("node") == node and t.get("iface") == iface and (t.get("ip") or "").split("/")[0] == ip:
                    return 409, {"ok": False, "error": f"{ip} is already used on {node}/{iface}", "code": "exists"}
        targets = [dict(t, ip=ip) if (t["node"] == node and t["iface"] == iface) else t for t in p["targets"]]
        p2 = peer_set(roster, pid, {"targets": targets}, now())
        roster_save(roster_path, roster)
        if isinstance(body.get("config"), str) and body["config"]:
            save_config(store_configs, config_dir, p["pubkey"], node, iface, body["config"])
        ev_append(roster_path, "peer", pid, "Changed address", peer_label(roster, p2), f"{node}/{iface} → {ip}")
        return 200, {"ok": True, "data": p2}

    if method == "POST" and path == "/api/peers/delete":
        pid = body.get("peer_id") or ""
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        if p.get("user_id"):
            # Deletion is for unassigned peers only — unassign first (which also revokes the
            # holder by rotating the PSK). Keeps an assigned peer from vanishing in one click.
            return 409, {"ok": False, "error": "peer is assigned to a user — unassign it first",
                         "code": "assigned"}
        label = peer_label(roster, p)
        for t in p["targets"]:
            del_config(store_configs, config_dir, p["pubkey"], t["node"], t["iface"])
        retire_pubkey(nodes, deps["nodes_path"], p.get("targets", []), p["pubkey"])   # drop it even on add-only ifaces
        del roster["peers"][pid]
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Deleted peer", label)
        return 200, {"ok": True, "data": {"id": pid, "deleted": True}}

    if method == "POST" and path == "/api/peers/unassign":
        # Detach from the user and REVOKE the old holder (rotate PSK). Server-side, no
        # browser needed — used directly, and as the first half of a reassignment.
        pid = body.get("peer_id") or ""
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        label = peer_label(roster, p)
        unassign_peer(p, store_configs, config_dir, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Unassigned peer", p.get("title") or label)
        return 200, {"ok": True, "data": p}

    if method == "POST" and path == "/api/peers/rekey":
        # Assign a peer to a user with a FRESH credential. The browser mints a new keypair
        # + PSK and rebuilds the config for every target, so the new owner gets a working
        # config and never inherits a key a previous owner could still hold. Used for both
        # first assignment (unassigned -> user) and reassignment (after unassign).
        pid = body.get("peer_id") or ""
        uid = body.get("user_id") or ""
        pubkey = (body.get("pubkey") or "").strip()
        if not pubkey:
            return 400, {"ok": False, "error": "pubkey is required (reassignment mints a fresh key)",
                         "code": "bad_request"}
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        if uid and uid not in roster["users"]:   # empty uid is allowed — rotate keeps it unassigned
            return 400, {"ok": False, "error": "unknown user", "code": "bad_request"}
        clash = find_peer_by_pubkey(roster, pubkey)
        if clash and clash["id"] != pid:
            return 409, {"ok": False, "error": "another peer already uses this key", "code": "exists"}
        old_pubkey = p.get("pubkey", "")
        if old_pubkey and old_pubkey != pubkey:
            for t in p.get("targets", []):
                del_config(store_configs, config_dir, old_pubkey, t["node"], t["iface"])
            retire_pubkey(nodes, deps["nodes_path"], p.get("targets", []), old_pubkey)   # drop the old key even on add-only ifaces
        psk = body.get("psk") or gen_psk()
        p2 = peer_set(roster, pid, {"user_id": uid or None, "pubkey": pubkey, "psk": psk}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Assigned peer", peer_label(roster, p2),
                  "fresh key issued")
        configs = body.get("configs") or {}
        for t in p2["targets"]:
            save_config(store_configs, config_dir, pubkey, t["node"], t["iface"],
                        configs.get(t["node"] + "|" + t["iface"]))
        return 200, {"ok": True, "data": p2}

    if method == "POST" and path == "/api/peers/adopt":
        # Pull a peer observed on a node (an orphan) into the roster. Known key → add the
        # target to the existing credential; new key → mint a peer (unassigned by default).
        pubkey = (body.get("pubkey") or "").strip()
        target = body.get("target") or {}
        for f in ("node", "iface", "ip"):
            if not target.get(f):
                return 400, {"ok": False, "error": f"target.{f} is required", "code": "bad_request"}
        if not pubkey:
            return 400, {"ok": False, "error": "pubkey is required", "code": "bad_request"}
        if not known(target["node"]):
            return 400, {"ok": False, "error": f"unknown node {target['node']!r}", "code": "bad_request"}
        if not valid_addr(target["ip"]):
            return 400, {"ok": False, "error": f"invalid address {target['ip']!r}", "code": "bad_request"}
        roster = roster_load(roster_path)
        uid = body.get("user_id")
        if uid and uid not in roster["users"]:
            return 400, {"ok": False, "error": "unknown user", "code": "bad_request"}
        if not target.get("type"):
            target["type"] = iface_type(snaps, target["node"], target["iface"])
        existing = find_peer_by_pubkey(roster, pubkey)
        if existing:
            pid = existing["id"]
            if not any(t["node"] == target["node"] and t["iface"] == target["iface"]
                       for t in existing["targets"]):
                peer_set(roster, pid, {"targets": existing["targets"] + [target]}, now())
        else:
            pid = gen_id()
            while pid in roster["peers"]:
                pid = gen_id()
            peer_set(roster, pid, {"user_id": uid or None, "pubkey": pubkey,
                                   "psk": body.get("psk") or "", "targets": [target]}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Adopted peer", peer_label(roster, roster["peers"][pid]),
                  f"{target['node']}/{target['iface']}")
        return 200, {"ok": True, "data": roster["peers"][pid]}

    if method == "POST" and path == "/api/peers/save-config":
        # Persist a re-issued client config (e.g. after an edit). Only meaningful with
        # store_configs on; the config carries the private key, so it must match a real target.
        pubkey = (body.get("pubkey") or "").strip()
        node = body.get("node") or ""; iface = body.get("iface") or ""
        conf = body.get("config")
        if not (pubkey and node and iface and isinstance(conf, str) and conf):
            return 400, {"ok": False, "error": "need pubkey, node, iface, config", "code": "bad_request"}
        if not store_configs:
            return 400, {"ok": False, "error": "store_configs is off — nothing is persisted", "code": "disabled"}
        roster = roster_load(roster_path)
        p = find_peer_by_pubkey(roster, pubkey)
        if not p or not any(t["node"] == node and t["iface"] == iface for t in p["targets"]):
            return 404, {"ok": False, "error": "no such target for this key", "code": "not_found"}
        save_config(store_configs, config_dir, pubkey, node, iface, conf)
        return 200, {"ok": True, "data": {"pubkey": pubkey, "node": node, "iface": iface}}

    if method == "POST" and path == "/api/nodes/create":
        name = (body.get("name") or "").strip()
        if not name or len(name) > 40 or not all(c.isalnum() or c in "-_" for c in name):
            return 400, {"ok": False, "error": "name must be 1–40 chars: letters, digits, - or _",
                         "code": "bad_request"}
        nid = gen_id()
        while nid in nodes:
            nid = gen_id()
        token = base64.urlsafe_b64encode(os.urandom(18)).decode().rstrip("=")
        nodes[nid] = {"id": nid, "name": name, "color": body.get("color") or "#34d399",
                      "endpoint_host": (body.get("endpoint_host") or "").strip(),
                      "stats_file": f"stats-{nid}.json",
                      "token_hash": make_token_hash(token), "created": now()}
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Enrolled node", name)
        return 200, {"ok": True, "data": {"id": nid, "name": name, "token": token}}

    if method == "POST" and path == "/api/nodes/update":
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if "name" in body:                      # name is a free-to-change display title (no refs to migrate)
            nm = (body.get("name") or "").strip()
            if not nm or len(nm) > 40 or not all(c.isalnum() or c in "-_" for c in nm):
                return 400, {"ok": False, "error": "name must be 1–40 chars: letters, digits, - or _", "code": "bad_request"}
            nodes[nid]["name"] = nm
        if "color" in body:
            nodes[nid]["color"] = body.get("color") or nodes[nid].get("color")
        if "endpoint_host" in body:
            nodes[nid]["endpoint_host"] = (body.get("endpoint_host") or "").strip()
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Updated node", nodes[nid].get("name", nid))
        return 200, {"ok": True, "data": {"id": nid, "name": nodes[nid].get("name")}}

    if method == "POST" and path == "/api/iface/update":
        # Panel-side per-interface overrides: public endpoint host/port (what clients dial) and the
        # default DNS / MTU. Affects only the configs the panel emits (existing peers keep their
        # stored configs; new peers pick up the defaults). The node itself is untouched.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface:
            return 400, {"ok": False, "error": "iface is required", "code": "bad_request"}
        ov = dict((nodes[nid].get("ifaces") or {}).get(iface) or {})
        if "endpoint_host" in body:
            h = (body.get("endpoint_host") or "").strip()
            if h and (" " in h or "/" in h):
                return 400, {"ok": False, "error": "endpoint host must be a bare hostname or IP", "code": "bad_request"}
            ov["endpoint_host"] = h if h else None
            if not h:
                ov.pop("endpoint_host", None)
        if "listen_port" in body:
            raw = body.get("listen_port")
            if raw in (None, "", 0, "0"):
                ov.pop("listen_port", None)
            else:
                try:
                    p = int(raw)
                except (TypeError, ValueError):
                    return 400, {"ok": False, "error": "port must be a number", "code": "bad_request"}
                if not (1 <= p <= 65535):
                    return 400, {"ok": False, "error": "port must be 1–65535", "code": "bad_request"}
                ov["listen_port"] = p
        if "dns" in body:
            dns = body.get("dns")
            if isinstance(dns, str):
                dns = [s.strip() for s in dns.split(",") if s.strip()]
            ov["dns"] = dns or []
        if "mtu" in body:
            raw = body.get("mtu")
            if raw in (None, "", 0, "0"):
                ov.pop("mtu", None)
            else:
                try:
                    m = int(raw)
                except (TypeError, ValueError):
                    return 400, {"ok": False, "error": "mtu must be a number", "code": "bad_request"}
                if not (576 <= m <= 9200):
                    return 400, {"ok": False, "error": "mtu must be 576–9200", "code": "bad_request"}
                ov["mtu"] = m
        if "awg_params" in body:
            awg = body.get("awg_params")
            if not awg:
                ov.pop("awg_params", None)
            elif isinstance(awg, dict):
                clean = {k: str(awg[k]).strip() for k in AWG_PARAM_KEYS
                         if k in awg and str(awg.get(k, "")).strip() != ""}
                if clean:
                    ov["awg_params"] = clean
                else:
                    ov.pop("awg_params", None)
            else:
                return 400, {"ok": False, "error": "awg_params must be an object", "code": "bad_request"}
        if "egress_ip" in body:                          # per-interface source/egress IP ("" = clear → MASQUERADE)
            e = (body.get("egress_ip") or "").strip()
            if e:
                try:
                    if ipaddress.ip_address(e).version != 4:
                        raise ValueError
                except ValueError:
                    return 400, {"ok": False, "error": "egress IP must be an IPv4 address", "code": "bad_request"}
                ov["egress_ip"] = e
            else:
                ov.pop("egress_ip", None)
        if "wan_iface" in body:                          # egress WAN NIC ("" = clear → auto-detect)
            w = (body.get("wan_iface") or "").strip()
            if w and (" " in w or "/" in w):
                return 400, {"ok": False, "error": "WAN interface must be a bare device name", "code": "bad_request"}
            if w:
                ov["wan_iface"] = w
            else:
                ov.pop("wan_iface", None)
        for k in ("listen_port", "awg_params"):     # a user-set value re-asserts: drop its drift + synced so it re-pushes
            if k in body:
                (ov.get("_synced") or {}).pop(k, None); (ov.get("_drift") or {}).pop(k, None)
        ifaces = nodes[nid].setdefault("ifaces", {})
        if ov:
            ifaces[iface] = ov
        else:
            ifaces.pop(iface, None)
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Updated interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface, "override": ov}}

    if method == "POST" and path == "/api/iface/onboard":
        # Ask a node to start managing an existing wg/awg interface the panel didn't auto-detect.
        # The node pulls this on its next sync, adds it to its config if the interface really exists,
        # and then reports it in its snapshot (which closes the request). Endpoint host is a panel-
        # side config-render override (the node only needs the tool + .conf path).
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        conf = (body.get("conf") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface or " " in iface or "/" in iface:
            return 400, {"ok": False, "error": "interface name is required (no spaces or /)", "code": "bad_request"}
        if not conf or " " in conf or not conf.startswith("/"):
            return 400, {"ok": False, "error": "an absolute config path is required", "code": "bad_request"}
        proto = (body.get("protocol") or "awg").lower()
        cmd = ["wg"] if proto == "wg" else (["auto"] if proto == "auto" else ["awg"])
        nodes[nid].setdefault("onboard", {})[iface] = {"cmd": cmd, "conf": conf}
        eh = (body.get("endpoint_host") or "").strip()
        if eh:
            nodes[nid].setdefault("ifaces", {}).setdefault(iface, {})["endpoint_host"] = eh
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Onboarding interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface}}

    if method == "POST" and path == "/api/iface/create":
        # Ask a node to create a BRAND-NEW wg/awg interface (the node genkeys + writes the conf +
        # auto-NATs + brings it up on its next sync, then manages it). Native datapath per node type.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        subnet = (body.get("subnet") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface or " " in iface or "/" in iface:
            return 400, {"ok": False, "error": "interface name is required (no spaces or /)", "code": "bad_request"}
        try:
            ipaddress.ip_network(subnet, strict=False)
        except Exception:
            return 400, {"ok": False, "error": "subnet must be a CIDR like 10.8.0.0/24", "code": "bad_request"}
        cmd = ["wg"] if (body.get("protocol") or "awg").lower() == "wg" else ["awg"]
        req = {"cmd": cmd, "subnet": subnet}
        if str(body.get("listen_port") or "").isdigit():
            req["listen_port"] = int(body["listen_port"])
        if str(body.get("mtu") or "").strip():
            req["mtu"] = str(body["mtu"]).strip()
        nodes[nid].setdefault("create", {})[iface] = req
        ov = nodes[nid].setdefault("ifaces", {}).setdefault(iface, {})   # config-render overrides
        if (body.get("endpoint_host") or "").strip():
            ov["endpoint_host"] = body["endpoint_host"].strip()
        if (body.get("dns") or "").strip():
            ov["dns"] = [s.strip() for s in body["dns"].split(",") if s.strip()]   # list, like /iface/update
        if str(body.get("keepalive") or "").strip().isdigit():
            ov["keepalive"] = int(body["keepalive"])
        if (body.get("egress_ip") or "").strip():       # per-interface source/egress IP
            e = body["egress_ip"].strip()
            try:
                if ipaddress.ip_address(e).version == 4:
                    ov["egress_ip"] = e
            except ValueError:
                pass
        if (body.get("wan_iface") or "").strip():        # per-interface egress WAN NIC
            w = body["wan_iface"].strip()
            if " " not in w and "/" not in w:
                ov["wan_iface"] = w
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Creating interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface}}

    if method == "POST" and path == "/api/iface/cancel":
        # Drop a pending create/onboard request (clears a stuck "creating"/"onboarding" card). Does
        # NOT touch anything the node already brought up — it only removes the panel-side request.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        removed = False
        for key in ("create", "onboard"):
            d = nodes[nid].get(key)
            if isinstance(d, dict) and iface in d:
                d.pop(iface, None)
                if not d:
                    nodes[nid].pop(key, None)
                removed = True
        if removed:
            nodes_save(deps["nodes_path"], nodes)
            ev_append(roster_path, "node", nid, "Cancelled interface request", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface, "removed": removed}}

    if method == "POST" and path in ("/api/iface/adopt", "/api/iface/restore"):
        # Resolve a drift (a setting edited directly on the server): ADOPT pulls the node's value into
        # the panel override (the panel stops fighting it); RESTORE re-asserts the panel's value.
        nid = body.get("node") or ""; iface = (body.get("iface") or "").strip(); key = (body.get("key") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        ov = (nodes[nid].get("ifaces") or {}).get(iface)
        if not ov or key not in (ov.get("_drift") or {}):
            return 400, {"ok": False, "error": "no pending drift for that setting", "code": "bad_request"}
        if path.endswith("/adopt"):
            ov[key] = ov["_drift"][key]                 # panel override ← the node's actual value
            ov.setdefault("_synced", {})[key] = ov[key]
            verb = "Adopted server-edited"
        else:                                           # restore → re-push the panel value
            (ov.get("_synced") or {}).pop(key, None)
            verb = "Restored panel"
        ov.get("_drift", {}).pop(key, None)
        if not ov.get("_drift"):
            ov.pop("_drift", None)
        if not ov.get("_synced"):
            ov.pop("_synced", None)
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, verb + " " + key, iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface, "key": key}}

    # ── turn-proxy management (only on nodes that report turn_manage=true) ──
    if method == "POST" and path == "/api/turn/install":
        # Install a NEW turn-proxy: the node downloads the fork's prebuilt binary, writes the systemd
        # unit (listen → connect, + the fork's wrap flags & a fresh key), and enables it. Keyed by the
        # service name the node will create (vk-turn-proxy-<fork>-<port>) so it self-clears on appear.
        nid = body.get("node") or ""
        fork = (body.get("fork") or "").strip()
        owner = (body.get("owner") or "").strip()
        listen = (body.get("listen") or "").strip()
        connect = (body.get("connect") or "").strip()
        wrap_flags = (body.get("wrap_flags") or "").strip()
        def _ipport(s):
            return ":" in s and s.rsplit(":", 1)[1].isdigit() and bool(s.rsplit(":", 1)[0])
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not fork or "/" in fork or " " in fork or "/" not in owner:
            return 400, {"ok": False, "error": "a fork + owner repo are required", "code": "bad_request"}
        if not _ipport(listen) or not _ipport(connect):
            return 400, {"ok": False, "error": "listen and connect must be ip:port", "code": "bad_request"}
        svc = "vk-turn-proxy-" + fork + "-" + listen.rsplit(":", 1)[1]
        if svc in (nodes[nid].get("turn") or {}):
            return 409, {"ok": False, "error": "an install for this fork+port is already pending", "code": "conflict"}
        nodes[nid].setdefault("turn", {})[svc] = {"action": "install", "owner": owner, "listen": listen,
                                                  "connect": connect, "wrap_flags": wrap_flags, "at": now()}
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Installing turn-proxy", svc)
        return 200, {"ok": True, "data": {"node": nid, "service": svc}}

    if method == "POST" and path in ("/api/turn/manage", "/api/turn/rotate", "/api/turn/delete", "/api/turn/restart"):
        # The node pulls these on its next sync, rewrites the unit's ExecStart / regenerates the wrap
        # key / removes it, restarts, and reports the new state (which clears the request).
        nid = body.get("node") or ""; svc = (body.get("service") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not svc:
            return 400, {"ok": False, "error": "service is required", "code": "bad_request"}
        if path.endswith("/manage"):
            req = {"action": "manage", "at": now()}
            for k in ("listen", "connect"):
                if (body.get(k) or "").strip():
                    req[k] = body[k].strip()
            if "params" in body:                        # free-text ExecStart tail after -connect
                req["params"] = body.get("params") or ""
            verb = "Editing turn-proxy"
        elif path.endswith("/rotate"):
            req = {"action": "rotate", "at": now()}; verb = "Rotating turn-proxy key"
        elif path.endswith("/restart"):
            req = {"action": "restart", "at": now()}; verb = "Restarting turn-proxy"
        else:
            req = {"action": "delete", "at": now()}; verb = "Deleting turn-proxy"
        nodes[nid].setdefault("turn", {})[svc] = req
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, verb, svc)
        return 200, {"ok": True, "data": {"node": nid, "service": svc}}

    if method == "POST" and path == "/api/turn/onboard":
        # Adopt an existing turn-proxy systemd unit by its .service path; the node reads it + reports it.
        nid = body.get("node") or ""; sp = (body.get("path") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not sp or " " in sp or not sp.startswith("/"):
            return 400, {"ok": False, "error": "an absolute .service path is required", "code": "bad_request"}
        lst = nodes[nid].setdefault("turn_onboard", [])
        if sp not in lst:
            lst.append(sp)
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Onboarding turn-proxy", sp)
        return 200, {"ok": True, "data": {"node": nid, "path": sp}}

    if method == "POST" and path == "/api/turn/cancel":
        nid = body.get("node") or ""; svc = (body.get("service") or "").strip(); sp = (body.get("path") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        removed = False
        d = nodes[nid].get("turn")
        if isinstance(d, dict) and svc and svc in d:
            d.pop(svc, None); removed = True
            if not d: nodes[nid].pop("turn", None)
        lst = nodes[nid].get("turn_onboard")
        if isinstance(lst, list) and sp and sp in lst:
            lst.remove(sp); removed = True
            if not lst: nodes[nid].pop("turn_onboard", None)
        if removed:
            nodes_save(deps["nodes_path"], nodes)
            ev_append(roster_path, "node", nid, "Cancelled turn-proxy request", svc or sp)
        return 200, {"ok": True, "data": {"node": nid, "removed": removed}}

    if method == "POST" and path == "/api/iface/restart":
        # Bounce the interface's service on the node (<tool>-quick down/up) — recovers a DOWN iface.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface:
            return 400, {"ok": False, "error": "interface name is required", "code": "bad_request"}
        nodes[nid].setdefault("restart", {})[iface] = int(time.time())   # node bounces it on its next sync
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Restarting interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface}}

    if method == "POST" and path == "/api/iface/delete":
        # Tear an interface down on the node (down + remove conf) and purge it from the panel: its
        # peers' targets here go away (peers with no other deployment are deleted), and its overrides
        # + any pending create/onboard are dropped. Destructive — the UI gates it behind typed confirm.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface:
            return 400, {"ok": False, "error": "interface name is required", "code": "bad_request"}
        nodes[nid].setdefault("delete", {})[iface] = int(time.time())   # queue the node teardown
        for key in ("create", "onboard", "ifaces"):
            d = nodes[nid].get(key)
            if isinstance(d, dict):
                d.pop(iface, None)
                if not d:
                    nodes[nid].pop(key, None)
        nodes_save(deps["nodes_path"], nodes)
        roster = roster_load(roster_path); changed = False         # purge peer targets on this iface
        for pid in list(roster["peers"].keys()):
            p = roster["peers"][pid]
            kept = [t for t in p.get("targets", []) if not (t.get("node") == nid and t.get("iface") == iface)]
            if len(kept) != len(p.get("targets", [])):
                changed = True
                if kept:
                    p["targets"] = kept; p["modified_at"] = int(time.time())
                else:
                    del roster["peers"][pid]
        if changed:
            roster_save(roster_path, roster)
        ev_append(roster_path, "node", nid, "Deleting interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface}}

    if method == "POST" and path == "/api/node/update":
        # Flag a (remote) node to self-update on its next sync. The node pulls this, runs the swg-only
        # updater (detached, restarts swg-noded), and the flag clears once it reports the new version.
        nid = body.get("node") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        # capture the node's current version — we clear the request once it reports ANYTHING different
        # (it updates to latest, which can move past a docker panel's lagging-CI image version)
        frm = ((deps.get("node_snaps") or {}).get(nid) or {}).get("noded_version")
        nodes[nid]["update"] = {"to": VERSIONS.get("panel") or "", "from": frm}
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Update requested", "")
        return 200, {"ok": True, "data": {"node": nid}}

    if method == "POST" and path == "/api/update/check":
        reached = _check_latest_remote()             # synchronous one-off poll (for the header "check" icon)
        return 200, {"ok": True, "data": {
            "checked": reached,                      # did we actually reach the repo this time?
            "latest_remote": LATEST_REMOTE.get("version"),
            "panel_outdated": bool(LATEST_REMOTE.get("version") and VERSIONS.get("panel")
                                   and LATEST_REMOTE["version"] != VERSIONS.get("panel"))}}

    if method == "POST" and path == "/api/host/update":
        # Update THIS host (panel + a co-located node) in place. The panel runs unprivileged, so it
        # can't (and shouldn't) run the privileged updater itself. The installer wires a root systemd
        # updater that watches a trigger file; we just touch it. If that's not present (older install
        # or Docker), hand back the exact command to run on the host instead of failing silently.
        manual_cmd = ("curl -fsSL https://raw.githubusercontent.com/SanityProtocol/swg-panel/main/"
                      "bootstrap.sh | sudo bash -s update -y --no-components")
        if not IN_DOCKER and UPDATE_TRIGGER:
            try:
                os.makedirs(os.path.dirname(UPDATE_TRIGGER) or ".", exist_ok=True)
                with open(UPDATE_TRIGGER, "w") as f:
                    f.write(str(int(time.time())) + "\n")    # swg-update.path fires swg-update.service
                ev_append(roster_path, "node", "host", "Host update started", "")
                return 200, {"ok": True, "data": {"started": True}}
            except Exception as e:
                return 500, {"ok": False, "error": f"couldn't signal the updater: {e}", "code": "exec_failed"}
        reason = ("this panel runs in Docker — a container can't recreate itself" if IN_DOCKER
                  else "automatic host update isn't set up on this install (update once on the host to enable it)")
        return 200, {"ok": True, "data": {"manual": True, "cmd": manual_cmd, "reason": reason}}

    if method == "POST" and path == "/api/nodes/rotate":
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        token = base64.urlsafe_b64encode(os.urandom(18)).decode().rstrip("=")
        nodes[nid]["token_hash"] = make_token_hash(token)
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Rotated node token", nodes[nid].get("name", nid))
        return 200, {"ok": True, "data": {"id": nid, "name": nodes[nid].get("name"), "token": token}}

    if method == "POST" and path == "/api/nodes/flag-remove":
        # Soft removal: mark the node "removing" but keep it (and its peers) working until it
        # signs off (uninstall -> /api/node/goodbye). Force-remove cuts it off without waiting.
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        nodes[nid]["removing"] = True
        nodes[nid]["removing_at"] = now()
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Flagged node for removal", nodes[nid].get("name", nid))
        return 200, {"ok": True, "data": {"id": nid}}

    if method == "POST" and path == "/api/nodes/unflag-remove":   # cancel a pending soft removal
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        nodes[nid].pop("removing", None); nodes[nid].pop("removing_at", None)
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Cancelled node removal", nodes[nid].get("name", nid))
        return 200, {"ok": True, "data": {"id": nid}}

    if method == "POST" and path == "/api/nodes/delete":     # force-remove (no waiting for goodbye)
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        nm = node_remove(deps, nid)
        return 200, {"ok": True, "data": {"id": nid, "name": nm}}

    return 404, {"ok": False, "error": "not found", "code": "bad_request"}


# ───────────────────────── HTTP shell ─────────────────────────

class Handler(BaseHTTPRequestHandler):
    deps = None

    def _send(self, code, obj):
        payload = json.dumps(obj).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(payload)))
        self.send_header("Cache-Control", "no-store")   # API replies may carry secrets — never cache
        self.end_headers()
        with contextlib.suppress(BrokenPipeError, ConnectionError):
            self.wfile.write(payload); self.wfile.flush()   # flush so the body reaches the client before the socket closes

    def _static(self, key):
        full = os.path.normpath(os.path.join(WEB_DIR, STATIC[key]))
        if not full.startswith(os.path.realpath(WEB_DIR)) and not full.startswith(WEB_DIR):
            return self.send_error(403)
        try:
            with open(full, "rb") as f:
                data = f.read()
        except OSError:
            return self.send_error(404)
        if PANEL_BASE and STATIC[key] == "index.html":   # point the SPA's <base> at the mount point
            data = data.replace(b'<base href="/">', ('<base href="%s/">' % PANEL_BASE).encode())
        _, ext = os.path.splitext(full)
        # The SPA is buildless (no content-hashed filenames), so a stale app.js/app.css served
        # against a freshly-updated backend silently breaks the UI (e.g. a schema change). Force
        # revalidation: clients must check with the server (304 if unchanged) rather than trust a
        # cached copy. ETag makes that cheap; fonts can cache long since they never change.
        if ext == ".woff2":
            self.send_response(200)
            self.send_header("Content-Type", CTYPES.get(ext, "application/octet-stream"))
            self.send_header("Content-Length", str(len(data)))
            self.send_header("Cache-Control", "public, max-age=31536000, immutable")
            self.end_headers()
            with contextlib.suppress(BrokenPipeError):
                self.wfile.write(data)
            return
        etag = '"%s"' % hashlib.sha256(data).hexdigest()[:16]
        if self.headers.get("If-None-Match") == etag:
            self.send_response(304)
            self.send_header("ETag", etag)
            self.send_header("Cache-Control", "no-cache")
            self.end_headers()
            return
        self.send_response(200)
        self.send_header("Content-Type", CTYPES.get(ext, "application/octet-stream"))
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Cache-Control", "no-cache")
        self.send_header("ETag", etag)
        self.end_headers()
        with contextlib.suppress(BrokenPipeError):
            self.wfile.write(data)

    def _cookie(self, name):
        for part in self.headers.get("Cookie", "").split(";"):
            k, _, v = part.strip().partition("=")
            if k == name:
                return v
        return ""

    def _authed_user(self):
        """Authenticated username, True if auth is disabled, or None if unauthenticated.
        Accepts a session cookie (browser) or HTTP Basic (API clients / curl)."""
        creds = Handler.deps.get("auth")
        if not creds:
            return True
        secret = Handler.deps.get("session_secret")
        tok = self._cookie("swgsess")
        if tok and secret and verify_session(tok, secret) == creds[0]:
            return creds[0]
        hdr = self.headers.get("Authorization", "")
        if hdr.startswith("Basic "):
            try:
                user, _, pw = base64.b64decode(hdr[6:]).decode("utf-8", "replace").partition(":")
            except Exception:
                user, pw = "", ""
            if hmac.compare_digest(user, creds[0]) and verify_password(creds[1], pw):
                return creds[0]
        return None

    def _require_auth(self):
        if self._authed_user() is not None:
            return True
        # 401 JSON, deliberately WITHOUT WWW-Authenticate so the browser shows our login
        # page instead of its native Basic-auth popup.
        self._send(401, {"ok": False, "error": "authentication required", "code": "unauthorized"})
        return False

    def _session_cookie(self, value, max_age):
        base = (PANEL_BASE or "") + "/"
        secure = "; Secure" if (TLS_CERT and TLS_KEY) else ""
        return f"swgsess={value}; Path={base}; HttpOnly; SameSite=Strict; Max-Age={max_age}{secure}"

    def _send_with_cookie(self, code, obj, cookie):
        payload = json.dumps(obj).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(payload)))
        if cookie:
            self.send_header("Set-Cookie", cookie)
        self.end_headers()
        with contextlib.suppress(BrokenPipeError):
            self.wfile.write(payload)

    def _login(self):
        creds = Handler.deps.get("auth")
        try:
            length = int(self.headers.get("Content-Length", 0) or 0)
            body = json.loads(self.rfile.read(length) or b"{}")
        except Exception:
            body = {}
        if not creds:
            return self._send(200, {"ok": True, "data": {"auth": False}})
        user = (body.get("username") or "").strip()
        pw = body.get("password") or ""
        if not (hmac.compare_digest(user, creds[0]) and verify_password(creds[1], pw)):
            return self._send(401, {"ok": False, "error": "invalid username or password", "code": "bad_login"})
        tok = make_session(creds[0], Handler.deps.get("session_secret"))
        return self._send_with_cookie(200, {"ok": True, "data": {"username": creds[0]}},
                                      self._session_cookie(tok, SESSION_TTL))

    def _logout(self):
        return self._send_with_cookie(200, {"ok": True}, self._session_cookie("", 0))

    def _wgstats(self, path):
        name = os.path.basename(path)          # basename strips any traversal
        if not name.endswith(".json") or "/" in name or name.startswith("."):
            return self.send_error(404)
        full = os.path.join(Handler.deps.get("stats_dir", "/var/www/wgstats"), name)
        try:
            with open(full, "rb") as f:
                data = f.read()
        except OSError:
            data = b"{}"                        # before the first snapshot lands
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        with contextlib.suppress(BrokenPipeError):
            self.wfile.write(data)

    def _node_sync(self):
        nodes = nodes_load(Handler.deps["nodes_path"])
        hdr = self.headers.get("Authorization", "")
        token = hdr[7:].strip() if hdr.startswith("Bearer ") else ""
        nid, node = find_node_by_token(nodes, token)
        if not nid:
            return self._send(401, {"error": "invalid node token"})
        try:
            length = int(self.headers.get("Content-Length", "0"))
            body = json.loads(self.rfile.read(length) or "{}")
        except Exception:
            return self._send(400, {"error": "bad body"})
        snap = body.get("snapshot") or {}
        Handler.deps.setdefault("node_snaps", {})[nid] = snap
        Handler.deps.setdefault("node_seen", {})[nid] = int(time.time())
        stats_dir = Handler.deps.get("stats_dir")
        if stats_dir and snap:
            sf = node.get("stats_file", f"stats-{nid}.json")
            with contextlib.suppress(Exception):
                atomic_write(os.path.join(stats_dir, sf), json.dumps(snap), mode=0o644)
            cpu, mem, disk = health_pcts(snap.get("health")) or (HRRD_NA, HRRD_NA, HRRD_NA)
            rx, tx = snap_traffic(snap)              # append one point to the per-node RRD ring
            with contextlib.suppress(Exception):
                hrrd_update(os.path.join(stats_dir, f"health-{nid}.rrd"), int(time.time()), cpu, mem, disk, rx, tx)
            # also keep a short in-memory raw buffer (one sample per sync) for a 5s-granular LIVE view
            buf = Handler.deps.setdefault("live_samples", {}).setdefault(nid, [])
            buf.append((int(time.time()), cpu, mem, disk, rx, tx))
            if len(buf) > LIVE_MAX:
                del buf[:len(buf) - LIVE_MAX]
        roster = roster_load(Handler.deps["roster_path"])
        desired = desired_for_node(roster, nid)
        # panel-managed interface config the node converges to — drift-aware: push an override until the
        # node confirms it (_synced); once confirmed, if the node diverges (a direct edit on the server)
        # PAUSE pushing + record the node's value in _drift so the panel can flag it (Adopt / Restore).
        snap_ifs = snap.get("interfaces") or {}
        ifaces_dirty = False
        desired_ifaces = {}
        for ifn, ov in (node.get("ifaces") or {}).items():
            rep = (snap_ifs.get(ifn) or {}).get("meta") or {}
            synced = ov.setdefault("_synced", {})
            drift = ov.setdefault("_drift", {})
            d = {}
            def _clear_drift(k):
                if k in drift:
                    drift.pop(k, None); return True
                return False
            # listen port
            if ov.get("listen_port"):
                want = int(ov["listen_port"]); r = rep.get("listen_port")
                rp = int(r) if str(r).isdigit() else None
                if rp is None:
                    d["listen_port"] = want
                elif rp == want:
                    if synced.get("listen_port") != want:
                        synced["listen_port"] = want; ifaces_dirty = True
                    ifaces_dirty = _clear_drift("listen_port") or ifaces_dirty
                elif synced.get("listen_port") == want:                 # confirmed, then diverged → drift
                    if drift.get("listen_port") != rp:
                        drift["listen_port"] = rp; ifaces_dirty = True
                else:                                                   # not yet confirmed → push to converge
                    ifaces_dirty = _clear_drift("listen_port") or ifaces_dirty
                    d["listen_port"] = want
            # AmneziaWG params
            if isinstance(ov.get("awg_params"), dict) and ov["awg_params"]:
                want = ov["awg_params"]; ra = rep.get("awg_params") or {}
                if not ra:
                    d["awg_params"] = want
                elif all(str(ra.get(k)) == str(want[k]) for k in want):
                    if synced.get("awg_params") != want:
                        synced["awg_params"] = dict(want); ifaces_dirty = True
                    ifaces_dirty = _clear_drift("awg_params") or ifaces_dirty
                elif synced.get("awg_params") == want:                  # confirmed, then diverged → drift
                    nd = {k: ra.get(k) for k in want}
                    if drift.get("awg_params") != nd:
                        drift["awg_params"] = nd; ifaces_dirty = True
                else:
                    ifaces_dirty = _clear_drift("awg_params") or ifaces_dirty
                    d["awg_params"] = want
            # egress IP + WAN NIC: the node doesn't report them back, so always push (no drift tracking)
            if "egress_ip" in ov:
                d["egress_ip"] = ov.get("egress_ip") or ""
            if "wan_iface" in ov:
                d["wan_iface"] = ov.get("wan_iface") or ""
            if not synced:
                ov.pop("_synced", None)
            if not drift:
                ov.pop("_drift", None)
            if d:
                desired_ifaces[ifn] = d
        if ifaces_dirty:
            with contextlib.suppress(Exception):
                nodes_save(Handler.deps["nodes_path"], nodes)
        # clear a pending self-update once the node reports a version different from when it was
        # requested — robust to the node landing past a lagging docker-panel image version. Docker
        # nodes can't self-update (a container can't recreate its image), so never let one hang.
        upd = node.get("update")
        rv = snap.get("noded_version")
        if upd and ((rv and rv != upd.get("from")) or snap.get("kind") == "docker"):
            node.pop("update", None)
            with contextlib.suppress(Exception):
                nodes_save(Handler.deps["nodes_path"], nodes)
            upd = None
        # close onboard/create requests for interfaces the node now reports (it added them on its side)
        for key in ("onboard", "create"):
            reqs = node.get(key) or {}
            if not reqs:
                continue
            present = set((snap.get("interfaces") or {}).keys())
            remaining = {k: v for k, v in reqs.items() if k not in present}
            if remaining != reqs:
                node[key] = remaining
                if not remaining:
                    node.pop(key, None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        # close DELETE requests once the iface is GONE from the snapshot (the node tore it down)
        dele = node.get("delete") or {}
        if dele:
            present = set((snap.get("interfaces") or {}).keys())
            remaining = {k: v for k, v in dele.items() if k in present}
            if remaining != dele:
                node["delete"] = remaining
                if not remaining:
                    node.pop("delete", None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        # clear RETIRE entries once the node stops reporting the pubkey (it removed it)
        retire = node.get("retire") or {}
        if retire:
            snap_ifs2 = snap.get("interfaces") or {}
            r_changed = False
            for ifn in list(retire.keys()):
                cur_pks = {pp.get("public_key") for pp in ((snap_ifs2.get(ifn) or {}).get("peers") or [])}
                kept = [pk for pk in retire[ifn] if pk in cur_pks]   # still on the iface → keep asking the node to drop it
                if kept != retire[ifn]:
                    r_changed = True
                    if kept:
                        retire[ifn] = kept
                    else:
                        retire.pop(ifn, None)
            if r_changed:
                if retire:
                    node["retire"] = retire
                else:
                    node.pop("retire", None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        # close RESTART requests after a grace — the node bounces the iface within a sync cycle
        rst = node.get("restart") or {}
        if rst:
            now_t = int(time.time())
            kept = {k: v for k, v in rst.items() if (now_t - (v or 0)) < 12}
            if kept != rst:
                if kept:
                    node["restart"] = kept
                else:
                    node.pop("restart", None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        # close turn-proxy requests once the node reflects them (delete: service gone; onboard: it
        # appears; manage/rotate: the node applied + restarted — verified by listen match, else a grace)
        turn = node.get("turn") or {}; turn_onb = node.get("turn_onboard") or []
        if turn or turn_onb:
            now_ts = int(time.time())   # NB: the module 'now' lambda is local to the api handler — not in scope here
            tps = {tp.get("service"): tp for tp in (snap.get("turn_proxies") or []) if tp.get("service")}
            t_changed = False
            for svc, req in list(turn.items()):
                act, age = req.get("action"), now_ts - (req.get("at") or 0)
                tp = tps.get(svc)
                if act == "delete":
                    done = svc not in tps
                elif act == "install":              # clears once the new service shows up
                    done = svc in tps or age > 240   # generous: download can take a couple minutes
                elif act in ("manage", "restart"):
                    done = (tp and ("listen" not in req or tp.get("listen") == req["listen"])
                            and ("connect" not in req or tp.get("connect") == req["connect"]) and age > 5) or age > 60
                else:   # rotate — panel can't see the new key; give the node time to regen + restart
                    done = age > 12
                if done:
                    turn.pop(svc, None); t_changed = True
            def _svc(sp): b = sp.rsplit("/", 1)[-1]; return b[:-8] if b.endswith(".service") else b
            new_onb = [sp for sp in turn_onb if _svc(sp) not in tps]
            if new_onb != turn_onb:
                t_changed = True
            if t_changed:
                if turn: node["turn"] = turn
                else: node.pop("turn", None)
                if new_onb: node["turn_onboard"] = new_onb
                else: node.pop("turn_onboard", None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        interval = (Handler.deps.get("fleet") or {}).get("node_interval", 5)
        return self._send(200, {"desired": desired, "desired_ifaces": desired_ifaces,
                                "remove": node.get("retire") or {},   # pubkeys to drop even on add-only ifaces (rotated/deleted)
                                "delete": list((node.get("delete") or {}).keys()),
                                "restart": list((node.get("restart") or {}).keys()),   # interfaces to bounce
                                "onboard": node.get("onboard") or {}, "create": node.get("create") or None,
                                "turn": node.get("turn") or {}, "turn_onboard": node.get("turn_onboard") or [],
                                "update": upd or None, "interval": interval})

    def _node_goodbye(self):
        # The node's uninstaller signs off here (its bearer token) so the panel can cleanly drop
        # it — the "astalavista" signal that completes a soft removal without operator action.
        nodes = nodes_load(Handler.deps["nodes_path"])
        hdr = self.headers.get("Authorization", "")
        token = hdr[7:].strip() if hdr.startswith("Bearer ") else ""
        nid, _ = find_node_by_token(nodes, token)
        if not nid:
            return self._send(401, {"error": "invalid node token"})
        with _api_lock:
            nm = node_remove(Handler.deps, nid)
        return self._send(200, {"ok": True, "removed": nm or nid})

    def do_GET(self):
        u = urlparse(self.path)
        path = strip_base(u.path)
        if path is None:
            return self.send_error(404)
        if path in STATIC:                 # SPA assets are public so the login page can load
            return self._static(path)
        if not self._require_auth():       # everything else (data) needs a session
            return
        if path.startswith("/wgstats/"):
            return self._wgstats(path)
        if path.startswith("/api/"):
            try:
                code, obj = api("GET", path, parse_qs(u.query), {}, self.deps)
            except Exception as e:
                code, obj = 500, {"ok": False, "error": str(e), "code": "internal"}
            return self._send(code, obj)
        self.send_error(404)

    def do_POST(self):
        u = urlparse(self.path)
        path = strip_base(u.path)
        if path == "/api/node/sync":
            try:
                return self._node_sync()
            except Exception as e:        # never drop the connection (a proxy turns that into a 5xx/520) — a node skips a non-200 pass safely
                import traceback; traceback.print_exc()
                return self._send(500, {"ok": False, "error": str(e), "code": "internal"})
        if path == "/api/node/goodbye":
            return self._node_goodbye()
        if path == "/api/login":
            return self._login()
        if path == "/api/logout":
            return self._logout()
        if not self._require_auth():
            return
        if path is None or not path.startswith("/api/"):
            return self.send_error(404)
        try:
            length = int(self.headers.get("Content-Length", 0) or 0)
        except ValueError:
            length = 0
        raw = self.rfile.read(length) if length else b"{}"
        try:
            bodyobj = json.loads(raw or b"{}")
            if not isinstance(bodyobj, dict):
                raise ValueError
        except (json.JSONDecodeError, ValueError):
            return self._send(400, {"ok": False, "error": "invalid JSON body", "code": "bad_request"})
        try:
            with _api_lock:                       # mutations are read-modify-write; serialize them
                code, obj = api("POST", path, {}, bodyobj, self.deps)
        except Exception as e:
            code, obj = 500, {"ok": False, "error": str(e), "code": "internal"}
        self._send(code, obj)

    def log_message(self, *a):
        pass


def main():
    fleet = load_json(FLEET_PATH, None)
    if fleet is None:
        raise SystemExit(f"cannot read fleet config: {FLEET_PATH}")
    nodes_path = fleet.get("nodes_path", "/var/lib/swg-panel/nodes.json")
    _rp = fleet.get("roster_path", "/var/lib/swg-panel/users.json")
    _sc = fleet.get("store_configs", True) is not False
    _cd = fleet.get("config_dir") or os.path.join(os.path.dirname(_rp) or ".", "configs")
    migrate_node_ids(nodes_path, _rp, _sc, _cd)        # legacy name-keyed -> stable id-keyed (one-time)
    Handler.deps = {"fleet": fleet,
                    "roster_path": fleet.get("roster_path", "/var/lib/swg-panel/users.json"),
                    "stats_dir": fleet.get("stats_dir", "/var/www/wgstats"),
                    "nodes_path": nodes_path, "nodes": nodes_load(nodes_path),
                    "node_snaps": {}, "node_seen": {},
                    "auth": load_auth(),
                    "session_secret": load_session_secret(fleet.get("roster_path", "/var/lib/swg-panel/users.json")),
                    "now": lambda: int(time.time())}
    # TLS is wrapped PER CONNECTION in the worker thread (not on the listening socket): wrapping
    # the listener does the handshake inside accept(), so one stalled/half-open client (a scanner,
    # a Cloudflare probe, a dropped packet) wedges the accept loop and the whole panel stops
    # answering — the cause of intermittent Cloudflare 522s that a restart "fixes". Each socket
    # also gets a timeout so a slow handshake can't pin a thread forever.
    class _TLSServer(ThreadingHTTPServer):
        daemon_threads = True
        ssl_ctx = None
        def get_request(self):                       # main accept loop — stays cheap, no handshake here
            sock, addr = self.socket.accept(); sock.settimeout(60); return sock, addr
        def finish_request(self, request, client_address):
            if self.ssl_ctx is not None:             # handshake happens here, in the spawned thread
                request = self.ssl_ctx.wrap_socket(request, server_side=True)
            super().finish_request(request, client_address)
        def handle_error(self, request, client_address):
            pass                                     # failed handshake / scanner / client vanished — routine noise
    scheme = "http"
    if TLS_CERT and TLS_KEY:
        ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
        ctx.load_cert_chain(TLS_CERT, TLS_KEY)
        srv = _TLSServer((BIND_HOST, BIND_PORT), Handler); srv.ssl_ctx = ctx
        scheme = "https"
        # SIGHUP reloads the cert into the live context (new connections pick it up) so
        # automated renewal — e.g. acme.sh --reloadcmd in the container — has zero downtime.
        def _reload_tls(_sig, _frm):
            try:
                ctx.load_cert_chain(TLS_CERT, TLS_KEY)
                print("reloaded TLS certificate (SIGHUP)", flush=True)
            except Exception as e:
                print(f"TLS reload failed (keeping old cert): {e}", flush=True)
        with contextlib.suppress(ValueError, OSError, AttributeError):
            signal.signal(signal.SIGHUP, _reload_tls)
    else:
        srv = ThreadingHTTPServer((BIND_HOST, BIND_PORT), Handler)
    threading.Thread(target=_remote_version_loop, daemon=True).start()   # poll the repo for newer releases
    auth_note = "" if Handler.deps["auth"] else "  [no auth!]"
    print(f"swg-panel-server on {scheme}://{BIND_HOST}:{BIND_PORT}{auth_note}")
    with contextlib.suppress(KeyboardInterrupt):
        srv.serve_forever()


if __name__ == "__main__":
    main()
