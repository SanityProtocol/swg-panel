        tid = str(body.get("id") or "")
        cur = dict(deps.get("panel_settings") or {})
        a = dict(cur.get("api") or {})
        before = a.get("tokens") or []
        gone = next((t for t in before if t.get("id") == tid), None)
        a["tokens"] = [t for t in before if t.get("id") != tid]
        cur["api"] = a; _save_api(cur)
        if gone:
            ev_append(roster_path, "panel", "integrations", "Revoked API token", gone.get("label", tid))
        return 200, {"ok": True, "data": {"id": tid}}

    if method == "POST" and path == "/api/integrations/webhook":     # upsert a webhook (secret returned once)
        url = str(body.get("url") or "").strip()[:512]
        if not (url.startswith("http://") or url.startswith("https://")):
            return 400, {"ok": False, "error": "webhook url must start with http:// or https://", "code": "bad_request"}
        if not webhook_host_ok(url):        # block SSRF to cloud-metadata / link-local / reserved (loopback + RFC1918 allowed)
            return 400, {"ok": False, "error": "webhook host must not be a link-local / reserved address", "code": "bad_request"}
        events = [e for e in (body.get("events") or []) if e in WEBHOOK_EVENTS] or list(WEBHOOK_EVENTS)
        cur = dict(deps.get("panel_settings") or {})
        a = dict(cur.get("api") or {})
        hooks = list(a.get("webhooks") or [])
        wid = str(body.get("id") or "")
        rec = next((h for h in hooks if h.get("id") == wid), None)
        secret = str(body.get("secret") or "").strip()
        if rec is None:
            wid = gen_id()
            secret = secret or (API_TOKEN_PREFIX + secrets.token_hex(16))
            rec = {"id": wid}; hooks.append(rec)
        rec["url"] = url; rec["events"] = events; rec["enabled"] = body.get("enabled", True) is not False
        if secret:
            rec["secret"] = secret
        a["webhooks"] = hooks; a.setdefault("enabled", bool(a.get("tokens")))
        cur["api"] = a; _save_api(cur)
        ev_append(roster_path, "panel", "integrations", "Saved webhook", url)
        return 200, {"ok": True, "data": {"id": wid, "url": url, "events": events,
                                          "enabled": rec["enabled"], "secret": rec.get("secret")}}

    if method == "POST" and path == "/api/integrations/webhook/delete":
