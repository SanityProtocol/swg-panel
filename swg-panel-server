def _check_latest_remote():
    ok = False                                       # True only if we actually reached the repo
    try:
        # Bypass the CDN cache so a just-published release is seen promptly. A no-cache HEADER alone is NOT enough
        # — raw.githubusercontent's Fastly edges can still serve a stale copy to a long-lived process — so append a
        # unique ?cb= query: a distinct cache key forces a fresh origin fetch every time.
        url = REMOTE_VERSION_URL + (("&" if "?" in REMOTE_VERSION_URL else "?") + "cb=" + str(int(time.time())))
        req = urllib.request.Request(url, headers={"User-Agent": "swg-panel", "Cache-Control": "no-cache"})
        with urllib.request.urlopen(req, timeout=8) as r:
            v = _short_ver(r.read(64).decode("utf-8", "replace").strip())
            if v:
                LATEST_REMOTE["version"] = v
                ok = True
    except Exception:
        pass
    LATEST_REMOTE["checked"] = int(time.time())
    return ok


def _resolve_turn_tag(owner):
    """Latest release tag of a turn-proxy fork repo, read from the 302 of releases/latest/download (no API →
    no rate limit). Mirrors swg-noded's _turn_resolve_tag. "" if unreachable. Used by /api/turn/check-updates."""
    if not owner or "/" not in owner:
        return ""
    url = "https://github.com/" + owner + "/releases/latest/download/server-linux-amd64"
    try:
        r = subprocess.run(["curl", "-fsS", "-o", os.devnull, "-w", "%{redirect_url}",
                            "--connect-timeout", "12", "--max-time", "25", url],
                           capture_output=True, text=True, timeout=30)
        m = re.search(r"/releases/download/([^/]+)/", r.stdout or "")
        return m.group(1) if m else ""
    except Exception:
        return ""


def _remote_version_loop():
    while True:
        _check_latest_remote()
        time.sleep(60 * 60)   # every hour — the header reflects a freshly-published release within the hour (the "check" icon is still there for an instant, on-demand refresh)


# ── turn-proxy auto-update (panel-driven; see PANEL_SETTINGS_DEFAULTS["turn_update"]) ──
def _turn_update_due(sched, last_ts, now_ts):
    """every_days=0 → never (OFF). Else due when >= every_days elapsed since the last check AND now is inside the
    60-min window opening at the panel-local `at` time — so the fleet-wide restart lands at a chosen quiet hour."""
    ev = int((sched or {}).get("every_days") or 0)
    if ev <= 0:
        return False
    if now_ts - last_ts < ev * 86400 - 1800:              # not enough days since the last check (30-min slack)
        return False
    at = str((sched or {}).get("at") or "04:00")
    try:    hh, mm = int(at.split(":")[0]), int(at.split(":")[1])
    except Exception: hh, mm = 4, 0
    lt = time.localtime(now_ts); cur = lt.tm_hour * 60 + lt.tm_min; start = hh * 60 + mm
    return start <= cur < start + 60


def _turn_autoupdate_tick():
    deps = getattr(Handler, "deps", None) or {}
    psp = deps.get("panel_settings_path")
    if not psp:
        return
    sched = (load_panel_settings(psp) or {}).get("turn_update") or {}
    if int(sched.get("every_days") or 0) <= 0:            # OFF — nothing scheduled
        return
    marker = os.path.join(os.path.dirname(deps.get("nodes_path") or ".") or ".", "turn_update_last")
    try:    last_ts = int((open(marker).read().strip() or "0"))
    except Exception: last_ts = 0
    now_ts = int(time.time())
    if not _turn_update_due(sched, last_ts, now_ts):
        return
    snaps = deps.get("node_snaps") or {}
    nodes = nodes_load(deps["nodes_path"])
    latest = {}                                           # fork -> latest release tag (one resolve per fork)
    changed = False
    for nid, snap in snaps.items():
        if nid not in nodes or not isinstance(snap, dict):
            continue
        for tp in (snap.get("turn_proxies") or []):
            svc = (tp.get("service") or "").strip(); ver = (tp.get("version") or "").strip()
            if not svc or not ver:
                continue
            fork = turn_fork(svc); owner = fork + "/vk-turn-proxy"
            if fork not in latest:
                latest[fork] = _resolve_turn_tag(owner)
            tag = latest[fork]
            if not tag or tag == ver:                    # unreachable, or already current
                continue
            pend = (nodes[nid].get("turn") or {}).get(svc)
            if pend and pend.get("action") == "reinstall":   # a reinstall is already staged — don't double-stage
                continue
            nodes[nid].setdefault("turn", {})[svc] = {"action": "reinstall", "at": now_ts, "owner": owner, "auto": True}
            changed = True
            with contextlib.suppress(Exception):
                ev_append(deps["roster_path"], "node", nid, "Auto-updating turn-proxy", svc + " → " + tag)
    if changed:
        nodes_save(deps["nodes_path"], nodes)
        _invalidate_state_cache()
    with contextlib.suppress(Exception):                 # record the check ran (even if nothing changed) → fire once per window
        atomic_write(marker, str(now_ts))


def _turn_update_loop():
    while True:
        with contextlib.suppress(Exception):
            _turn_autoupdate_tick()
        time.sleep(15 * 60)                              # re-evaluate the schedule window every 15 min

