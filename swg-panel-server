def _prov_status_load():
    with contextlib.suppress(Exception):
        _PROV_STATUS.update(json.load(open(PROV_STATUS_PATH)))
def _prov_status_save():
    with contextlib.suppress(Exception):
        atomic_write(PROV_STATUS_PATH, json.dumps(_PROV_STATUS))

_PROV_DOWNLOADING = {"on": False}
def provider_download(pids):
    """A provider was just ENABLED → refresh its catalog so its lists show (fresh) in the picker search. Shows
    status 'downloading' while the git-tree index re-fetches, then clears to uptodate/failed. Background; the UI
    polls /api/state for the status."""
    pids = [p for p in pids if p in CATALOG_PROVIDERS]
    if not pids or _PROV_DOWNLOADING["on"]:
        return
    _PROV_DOWNLOADING["on"] = True
    for p in pids:
        _PROV_STATUS.setdefault(p, {})["status"] = "downloading"
    _prov_status_save()
    def _work():
        try:
            catalog_index(force=True)                          # re-fetch provider git-trees → fresh id index for search
        except Exception:
            pass
        finally:
            for p in pids:
                st = _PROV_STATUS.setdefault(p, {})
                perr = (_CATALOG.get("perr") or {}).get(p, "")
                st["status"] = "failed" if perr else "uptodate"
                if perr: st["error"] = perr[:120]
                else:    st.pop("error", None)
            _prov_status_save()
            _PROV_DOWNLOADING["on"] = False
    threading.Thread(target=_work, daemon=True).start()

def catalog_provider_label(prov):
