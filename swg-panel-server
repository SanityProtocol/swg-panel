def _check_latest_remote():
    ok = False                                       # True only if we actually reached the repo
    try:
        # bypass any CDN cache so a just-published release is seen promptly
        req = urllib.request.Request(REMOTE_VERSION_URL,
                                     headers={"User-Agent": "swg-panel", "Cache-Control": "no-cache"})
        with urllib.request.urlopen(req, timeout=8) as r:
            v = _short_ver(r.read(64).decode("utf-8", "replace").strip())
            if v:
                LATEST_REMOTE["version"] = v
                ok = True
    except Exception:
        pass
    LATEST_REMOTE["checked"] = int(time.time())
    return ok


def _remote_version_loop():
    while True:
        _check_latest_remote()
        time.sleep(6 * 3600)

