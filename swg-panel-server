def make_token_hash(token, iters=200000):
    salt = os.urandom(16)
    h = hashlib.pbkdf2_hmac("sha256", token.encode(), salt, iters)
    return f"pbkdf2_sha256${iters}${base64.b64encode(salt).decode()}${base64.b64encode(h).decode()}"


# password hashing reuses the same pbkdf2_sha256 format verify_password() understands
make_pw_hash = make_token_hash


def nodes_load(path):
    d = load_json(path, {})
    return d if isinstance(d, dict) else {}


def nodes_save(path, nodes):
    atomic_write(path, json.dumps(nodes, indent=2) + "\n", mode=0o600)


def migrate_node_ids(nodes_path, roster_path, store_configs, config_dir):
    """One-time: nodes keyed by their (mutable) name -> keyed by a stable opaque id, with the
    name kept as a free-to-change display title. Rewrites roster peer targets (node name -> id)
    and renames any stored config files. Idempotent: a no-op once every node is id-keyed."""
    nodes = load_json(nodes_path, {})
    if not isinstance(nodes, dict) or not nodes:
        return
    if all(isinstance(v, dict) and v.get("id") == k for k, v in nodes.items()):
        return                                      # already migrated
    name_to_id, new_nodes = {}, {}
    for key, v in nodes.items():
        if not isinstance(v, dict):
            continue
        nid = v.get("id") or gen_id()
        while nid in new_nodes:
            nid = gen_id()
        v["id"] = nid
        v["name"] = v.get("name", key)              # the old dict key was the (display) name
        new_nodes[nid] = v
        for nm in {key, v["name"]}:
            if nm and nm != nid:
                name_to_id[nm] = nid
    nodes_save(nodes_path, new_nodes)
    roster = roster_load(roster_path)
    changed = False
    for p in (roster.get("peers") or {}).values():
        if not isinstance(p, dict):
            continue
        for t in p.get("targets", []):
            old, new = t.get("node"), name_to_id.get(t.get("node"))
            if new and new != old:
                if store_configs and config_dir and p.get("pubkey") and t.get("iface"):
                    with contextlib.suppress(OSError):
                        os.replace(os.path.join(config_dir, cfg_hash(p["pubkey"], old, t["iface"])),
                                   os.path.join(config_dir, cfg_hash(p["pubkey"], new, t["iface"])))
                t["node"] = new
                changed = True
    if changed:
        roster_save(roster_path, roster)
    print(f"migrated {len(new_nodes)} node(s) to stable ids", flush=True)


def migrate_ru_split(nodes_path, panel_settings_path):
    """One-time: the single 'ru' category (which meant all-RU GeoIP in Kernel mode but the blocked-in-RU
    circumvention DOMAIN list in DNS mode — two different things) was split into 'ru_net' (GeoIP, every mode) +
    'ru_blocked' (circumvention domains, DNS/SNI only). Rewrite the now-ambiguous 'ru' → 'ru_net' (the country/IP
    meaning, which keeps working in every mode); 'ru_blocked' is then an explicit opt-in. Idempotent."""
    def _sub(lst):   # replace ru→ru_net in a category-id list, order-preserving + de-duped
        return list(dict.fromkeys("ru_net" if c == "ru" else c for c in lst))
    changed = False
    nodes = load_json(nodes_path, {})
    if isinstance(nodes, dict):
        for n in nodes.values():
            if not isinstance(n, dict):
                continue
            ec = n.get("enabled_categories")
            if isinstance(ec, list) and "ru" in ec:
                n["enabled_categories"] = _sub(ec); changed = True
            for ifo in (n.get("ifaces") or {}).values():
                if not isinstance(ifo, dict):
                    continue
                for r in (ifo.get("routing") or []):
                    if isinstance(r, dict) and r.get("category") == "ru":
                        r["category"] = "ru_net"; changed = True
        if changed:
            nodes_save(nodes_path, nodes)
    ps = load_json(panel_settings_path, {})
    if isinstance(ps, dict):
        hc = ps.get("hidden_categories")
        if isinstance(hc, list) and "ru" in hc:
            ps["hidden_categories"] = _sub(hc)
            atomic_write(panel_settings_path, json.dumps(ps, indent=2) + "\n")
            changed = True
    if changed:
        print("migrated 'ru' category → 'ru_net' (ru_blocked is now a separate opt-in list)", flush=True)


def migrate_provider_defaults(nodes_path, panel_settings_path):
    """One-time: providers now default OFF (a fresh fleet opts in). To keep an EXISTING fleet's routing working
    across that flip, explicitly enable every provider a node already routes. Idempotent — runs once (marked by
    `providers_defaulted`), only adds True entries, never disables, and respects later manual toggles."""
    ps = load_json(panel_settings_path, {})
    if not isinstance(ps, dict) or ps.get("providers_defaulted"):
        return
    prov = dict(ps.get("providers") or {})
    inuse = {c.split(":", 1)[0] for c in routed_catalog_cats(load_json(nodes_path, {}) or {}) if ":" in c}
    for pid in inuse:
        prov.setdefault(pid, True)                              # keep an already-routed provider enabled
    ps["providers"] = prov
    ps["providers_defaulted"] = True
    atomic_write(panel_settings_path, json.dumps(ps, indent=2) + "\n")
    print("provider defaults: kept %d in-use provider(s) enabled; new providers now default off" % len(inuse), flush=True)


def normalize_stats_files(nodes_path, stats_dir):
    """Make every node's snapshot mirror id-keyed: `stats_file` -> `stats-<id>.json`, renaming the file
    on disk if it's still under a legacy name (auto-enrolled nodes were written `stats-<hostname>.json`).
    The health RRD is already `health-<id>.rrd`, so after this BOTH health files share the stable id —
    they always travel together (e.g. through a convert) and the warm-start can't be orphaned by a
    hostname change. Idempotent."""
    nodes = load_json(nodes_path, {})
    if not isinstance(nodes, dict) or not nodes:
        return
    changed = False
    for nid, c in nodes.items():
        if not isinstance(c, dict):
            continue
        canon = f"stats-{nid}.json"
        old = c.get("stats_file")
        if old == canon:
            continue
        if old and stats_dir:                       # carry the existing mirror over to the canonical name
            with contextlib.suppress(OSError):
                src = os.path.join(stats_dir, old)
                if os.path.exists(src) and not os.path.exists(os.path.join(stats_dir, canon)):
                    os.replace(src, os.path.join(stats_dir, canon))
        c["stats_file"] = canon
        changed = True
    if changed:
        nodes_save(nodes_path, nodes)
        print("normalized node stats_file -> stats-<id>.json", flush=True)


def find_node_by_token(nodes, token):
    if not token:
        return None, None
    for nid, n in nodes.items():
        if verify_password(n.get("token_hash", ""), token):
            return nid, n
    return None, None


def _archive_node(deps, nid, nm, node_entry, peers, sf):
    """Back a node up before it's purged → <state_dir>/archive/<name>-<nid>-<ts>/ with node.json,
    peers.json (the peer entries that referenced it), and its MOVED stats + health files. Best-effort:
    a backup must never block the delete."""
    try:
        state_dir = os.path.dirname(deps["nodes_path"]) or "."
        safe = "".join(c if (c.isalnum() or c in "-_.") else "_" for c in str(nm))[:40] or nid
        dest = os.path.join(state_dir, "archive", f"{safe}-{nid}-{int(time.time())}")
        os.makedirs(dest, exist_ok=True)
        atomic_write(os.path.join(dest, "node.json"), json.dumps(node_entry, indent=2) + "\n", mode=0o600)
        atomic_write(os.path.join(dest, "peers.json"), json.dumps(peers, indent=2) + "\n", mode=0o600)
        sd = deps.get("stats_dir")
        if sd:
            for fn in (sf, f"health-{nid}.rrd"):
                src = os.path.join(sd, fn)
                if os.path.exists(src):
                    with contextlib.suppress(Exception):
                        shutil.move(src, os.path.join(dest, fn))   # cross-fs safe (state vs stats may differ)
        return dest
    except Exception:
        return None

def node_remove(deps, nid):
    """Drop a node from the store and cascade: ARCHIVE its data (node + peer targets + stats/health) as a
    recoverable backup, then purge its peer targets (deleting peers whose only deployment was here), forget
    its live snapshot, and remove its stats + health files. Returns the removed node's display name, or None
    if it wasn't there. Shared by force-remove + goodbye."""
    nodes = nodes_load(deps["nodes_path"])
    if nid not in nodes:
        return None
    nm = nodes[nid].get("name", nid)
    sf = nodes[nid].get("stats_file", f"stats-{nid}.json")
    node_entry = dict(nodes[nid])
    roster = roster_load(deps["roster_path"])
    affected = {pid: p for pid, p in roster["peers"].items()
                if any(t.get("node") == nid for t in p.get("targets", []))}
    _archive_node(deps, nid, nm, node_entry, affected, sf)   # back up BEFORE purging (moves stats/health out)
    mesh_unlink_node(nodes, nid)                              # tear down this node's mesh links on every survivor
    del nodes[nid]
    nodes_save(deps["nodes_path"], nodes)
    changed = False
    for pid in list(roster["peers"].keys()):
        p = roster["peers"][pid]
        kept = [t for t in p.get("targets", []) if t.get("node") != nid]
        if len(kept) != len(p.get("targets", [])):
            changed = True
            if kept:
                p["targets"] = kept; p["modified_at"] = int(time.time())
            else:
                del roster["peers"][pid]
    if changed:
        roster_save(deps["roster_path"], roster)
    (deps.get("node_snaps") or {}).pop(nid, None)
    (deps.get("node_seen") or {}).pop(nid, None)
    sd = deps.get("stats_dir")            # _archive_node moved these out; unlink any leftover
    if sd:
        with contextlib.suppress(OSError):
            os.unlink(os.path.join(sd, sf))
        with contextlib.suppress(OSError):
            os.unlink(os.path.join(sd, f"health-{nid}.rrd"))
    ev_append(deps["roster_path"], "node", nid, "Removed node", nm)
    return nm


def desired_for_node(roster, node_id):
    """The peer set the roster assigns to one node, grouped by interface.

    Derived entirely from peers→targets: a node may serve several interfaces
    (e.g. awg100 + wg99); each target names the (node, iface, ip) it lands on, so
    we never push a peer onto the wrong one. The wire shape is unchanged from the
    flat-roster era — a node still receives
        { "<iface>": [ {public_key, allowed_ips, preshared_key, name}, ... ] }
    — so swg-noded / swg-agent are untouched by the schema change.
    """
    users = roster.get("users") or {}
    out = {}
    for p in (roster.get("peers") or {}).values():
        if not isinstance(p, dict):
            continue
        uname = (users.get(p.get("user_id")) or {}).get("name", "")
        # node-side label (a .conf comment): "user · title" so the operator can tell devices apart
        name = " · ".join(x for x in (uname, p.get("title", "")) if x)
        for t in p.get("targets", []):
            if t.get("node") != node_id:
                continue
            iface = t.get("iface") or ""
            if not iface:
                continue
            ip = (t.get("ip") or "").split("/")[0]
            out.setdefault(iface, []).append({
                "public_key": p.get("pubkey"),
                "allowed_ips": (ip + "/32") if ip else "",
                "preshared_key": p.get("psk") or "none",
                "name": name,
            })
    return out


