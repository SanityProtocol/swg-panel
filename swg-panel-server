def _read_version():
    for p in (os.path.join(WEB_DIR, "VERSION"),
              os.path.join(os.path.dirname(os.path.abspath(__file__)), "VERSION")):
        try:
            with open(p) as f:
                v = f.read().strip()
                if v:
                    return v
        except OSError:
            pass
    return ""


def _short_ver(s):
    for tok in s.replace(",", " ").split():
        t = tok.lstrip("vV")
        if t and t[0].isdigit():
            return t
    return s.strip()


def _detect_versions():
    """swg-panel version + whatever stack tooling is present on the panel host
    (awg / wg / docker). Computed once at startup; nodes vary, this is the host."""
    out = {"panel": _read_version()}
    for key, args in (("awg", ["awg", "--version"]),
                      ("wg", ["wg", "--version"]),
                      ("docker", ["docker", "--version"])):
        try:
            p = subprocess.run(args, capture_output=True, text=True, timeout=3)
            line = ((p.stdout or "") + (p.stderr or "")).strip().splitlines()
            if line:
                out[key] = _short_ver(line[0])
        except Exception:
            pass
    return {k: v for k, v in out.items() if v}


VERSIONS = _detect_versions()

def _vtuple(v):
    """'1.24.16-alpha' -> (1, 24, 16); anything unparseable -> (0, 0, 0)."""
    import re
    m = re.match(r"\s*(\d+)\.(\d+)\.(\d+)", str(v or ""))
    return tuple(int(x) for x in m.groups()) if m else (0, 0, 0)

def _ver_behind(have, ref):
    """True only if `have` is a real version strictly older than `ref` (never on a newer node)."""
    h, r = _vtuple(have), _vtuple(ref)
    return bool(h != (0, 0, 0) and r != (0, 0, 0) and h < r)

def _ver_ahead(have, ref):
    """True if `have` is strictly newer than `ref` (e.g. a node updated past a lagging panel)."""
    h, r = _vtuple(have), _vtuple(ref)
    return bool(h != (0, 0, 0) and r != (0, 0, 0) and h > r)

