# ─────────────── browser sessions (signed cookie; no Basic-auth popup) ───────────────
# A small hmac-signed token in an HttpOnly cookie replaces the browser's Basic-auth prompt,
# giving a real login page + a working logout. Same pbkdf2 credentials; the node-sync path
# keeps its Bearer token, untouched. The signing secret is persisted next to the roster so
# sessions survive a panel restart.
SESSION_TTL = 7 * 24 * 3600
_B64PAD = lambda s: s + "=" * (-len(s) % 4)


def load_session_secret(roster_path):
    p = os.path.join(os.path.dirname(roster_path) or ".", "session.key")
    try:
        with open(p, "rb") as f:
            s = f.read().strip()
        if len(s) >= 32:
            return s
    except OSError:
        pass
    s = base64.b64encode(os.urandom(48))
    with contextlib.suppress(OSError):
        os.makedirs(os.path.dirname(p) or ".", exist_ok=True)
        fd = os.open(p, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "wb") as f:
            f.write(s)
    return s


def rotate_session_secret(roster_path):
    """Mint a NEW session-signing secret → every outstanding session cookie stops validating. Called on a
    password change so a captured cookie can't outlive the reset; the admin simply re-signs-in (the panel
    already documents 'you'll be asked to sign in again')."""
    p = os.path.join(os.path.dirname(roster_path) or ".", "session.key")
    s = base64.b64encode(os.urandom(48))
    with contextlib.suppress(OSError):
        os.makedirs(os.path.dirname(p) or ".", exist_ok=True)
        fd = os.open(p, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "wb") as f:
            f.write(s)
    return s


def make_session(user, secret, ttl=SESSION_TTL):
    payload = (user + "|" + str(int(time.time()) + ttl)).encode()
    sig = hmac.new(secret, payload, hashlib.sha256).digest()
    return (base64.urlsafe_b64encode(payload).rstrip(b"=").decode() + "."
            + base64.urlsafe_b64encode(sig).rstrip(b"=").decode())


def verify_session(token, secret):
    try:
        p_s, sig_s = token.split(".", 1)
        payload = base64.urlsafe_b64decode(_B64PAD(p_s))
        sig = base64.urlsafe_b64decode(_B64PAD(sig_s))
        if not hmac.compare_digest(sig, hmac.new(secret, payload, hashlib.sha256).digest()):
            return None
        user, exp = payload.decode().rsplit("|", 1)
        return user if int(exp) >= int(time.time()) else None
    except Exception:
        return None


def cfg_hash(pubkey, node, iface=""):
    return hashlib.sha256((pubkey + "|" + node + "|" + iface).encode()).hexdigest() + ".conf"


def atomic_write(path, text, mode=0o600):
    os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
    tmp = path + ".tmp." + uuid.uuid4().hex[:8]
    try:
        fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, mode)
        os.fchmod(fd, mode)   # force the exact mode regardless of the process umask (0640 must stay group-readable for swg-sub)
        with os.fdopen(fd, "w") as f:
            f.write(text); f.flush(); os.fsync(f.fileno())
        os.replace(tmp, path)
    except Exception:
        with contextlib.suppress(OSError):
            os.unlink(tmp)
        raise


def load_json(path, default):
    try:
        with open(path) as f:
            return json.load(f)
    except FileNotFoundError:
        return default
    except (json.JSONDecodeError, OSError):
        return default


# ── Critical-state durability (users.json / nodes.json) ─────────────────────────────────────────────────────
# Atomic writes stop partial-write corruption, but not LOGICAL loss (a truncating tool, disk damage, a botched
# migration). load_json can't tell "absent" (fresh install → empty is correct) from "present but corrupt"
# (→ empty would WIPE the roster / node store). The critical stores keep rotating known-good backups on save and,
# on a corrupt primary, recover from the newest good backup — or refuse to come up empty over data that existed.
def _state_backups(path):
    d = os.path.dirname(path) or "."; base = os.path.basename(path) + ".bak."
    try:
        names = [n for n in os.listdir(d) if n.startswith(base)]
    except OSError:
        return []
    return [os.path.join(d, n) for n in sorted(names, reverse=True)]   # ts suffix → name sort == newest first

def save_critical(path, text, mode=0o600, keep=8):
    atomic_write(path, text, mode)                                     # primary (atomic)
    with contextlib.suppress(Exception):                              # + a rotating known-good backup (never fatal)
        atomic_write(path + ".bak." + str(int(time.time())), text, mode)
        for old in _state_backups(path)[keep:]:
            with contextlib.suppress(OSError):
                os.unlink(old)

def load_critical(path, default):
    try:
        with open(path) as f:
            return json.load(f)
    except FileNotFoundError:
        return default                                                # legitimately absent → fresh install
    except (json.JSONDecodeError, OSError) as e:
        for b in _state_backups(path):                               # present but corrupt → recover newest good backup
            try:
                with open(b) as f:
                    data = json.load(f)
            except Exception:
                continue
            sys.stderr.write("swg-panel: %s unreadable (%s) — recovered from %s\n" % (path, e, b))
            with contextlib.suppress(Exception):
                atomic_write(path, json.dumps(data, indent=2) + "\n", mode=0o600)   # promote back → stop limping
            return data
        raise RuntimeError("critical state %s is corrupt and no good backup exists — refusing to start empty" % path)

def load_settings_critical(path):
    """Panel settings loader with the same backup safety net as the roster/node store — but softer: settings can be
    re-entered, so a corrupt/lost primary recovers the newest good backup and, failing that, falls back to defaults
    ({}) instead of refusing to start. Crucially it ALSO recovers when the primary parsed but is EMPTY {} while a
    backup has real content — i.e. it was clobbered/truncated to nothing (how vk_link + other settings kept vanishing;
    settings had no backup at all before). A genuine {} only arises from a clobber — the settings API always writes a
    populated dict — so preferring a non-empty backup is safe."""
    primary, primary_ok = {}, False
    try:
        with open(path) as f:
            primary = json.load(f); primary_ok = isinstance(primary, dict)
    except FileNotFoundError:
        return {}                                                          # legitimately absent → fresh install
    except (json.JSONDecodeError, OSError):
        primary_ok = False                                                 # corrupt/unreadable
    if primary_ok and primary:
        return primary                                                     # healthy, non-empty
    for b in _state_backups(path):                                         # corrupt OR clobbered-empty → newest good backup
        try:
            with open(b) as f:
                cand = json.load(f)
        except Exception:
            continue
        if isinstance(cand, dict) and cand:
            sys.stderr.write("swg-panel: panel-settings %s — recovered from %s\n"
                             % ("corrupt" if not primary_ok else "empty", b))
            with contextlib.suppress(Exception):
                atomic_write(path, json.dumps(cand, indent=2) + "\n", mode=0o600)   # promote back → stop losing it
            return cand
    return primary if primary_ok else {}                                   # nothing to recover → defaults


# Disk-space guard: the snapshot mirror + per-node/peer/cat/turn RRDs are frequent, growth-prone, and NON-essential
# (the panel runs fine without fresh stats). On a critically-low stats volume, skip those writes so a full disk
# degrades gracefully instead of wedging — critical state (users/nodes) is small and always still written.
_DISK_WARN = {"t": 0.0}
def stats_disk_ok(path, min_free_mb=64, min_pct=2):
    try:
        st = os.statvfs(path)
        free = st.f_bavail * st.f_frsize; total = (st.f_blocks * st.f_frsize) or 1
        if free >= min_free_mb * 1048576 and (free * 100 // total) >= min_pct:
            return True
    except OSError:
        return True                                   # can't stat → don't block on a false alarm
    now = time.time()
    if now - _DISK_WARN["t"] > 300:
        _DISK_WARN["t"] = now
        sys.stderr.write("swg-panel: stats volume critically low — pausing snapshot/RRD writes (critical state still saved)\n")
    return False


# ───────────────────────── roster: users + peers ─────────────────────────
#
# users.json is a versioned envelope, NOT a flat dict:
#   { "version": 1,
#     "users": { "<user_id>": {id, name, tag, note, created_at, modified_at} },
#     "peers": { "<peer_id>": {id, user_id|None, pubkey, psk,
#                              targets:[{node, iface, ip, type}],
#                              created_at, modified_at} } }
# A User is identity only. A Peer is one credential (pubkey+psk) deployed to one
# or more targets; a target is one (node, iface, ip, type). user_id None means the
# peer is unassigned. desired_for_node() derives the node-facing peer set entirely
# from peers→targets and emits the SAME wire shape nodes have always consumed, so
# swg-noded / swg-agent need no changes.

ROSTER_VERSION = 1


def roster_load(path):
    r = load_critical(path, {})
    if not isinstance(r, dict):
        r = {}
    r.setdefault("version", ROSTER_VERSION)
    if not isinstance(r.get("users"), dict):
        r["users"] = {}
    if not isinstance(r.get("peers"), dict):
        r["peers"] = {}
    return r


def roster_save(path, roster):
    d = os.path.dirname(path) or "."
    os.makedirs(d, exist_ok=True)
    tmp = path + ".tmp." + uuid.uuid4().hex[:8]
    with open(tmp, "w") as f:
        os.fchmod(f.fileno(), 0o640)   # group(swg)-readable: the read-only swg-sub user reads the roster, no others
        fcntl.flock(f, fcntl.LOCK_EX)
        json.dump(roster, f, indent=2); f.write("\n"); f.flush(); os.fsync(f.fileno())
    os.replace(tmp, path)
    with contextlib.suppress(Exception):   # rotating known-good backup — recovered by load_critical if the primary corrupts
        atomic_write(path + ".bak." + str(int(time.time())), json.dumps(roster, indent=2) + "\n", mode=0o600)
        for old in _state_backups(path)[8:]:
            with contextlib.suppress(OSError):
                os.unlink(old)


# ─────────────── audit / activity log (panel host only) ───────────────
# An append-only event log of operator actions, kept ONLY on the panel host next to the
# roster. Nothing here touches the nodes or the sync wire format — events are recorded
# in the panel's own API handlers when the admin mutates the roster. Stored as JSON-lines
# and capped, so it never grows unbounded. Read back newest-first by the Overview.

EVENTS_CAP = 1000          # keep at most this many events
EVENTS_TRIM_BYTES = 300_000

def events_path(roster_path):
    return os.path.join(os.path.dirname(roster_path) or ".", "events.jsonl")


def _ev_eid():
    return uuid.uuid4().hex[:10]


def _ev_synth_eid(raw_line):
    """A stable id for a legacy record written before `eid` existed: a content hash, so the
    Activity-history grid can still delete that exact row."""
    return "L" + hashlib.sha1(raw_line.encode()).hexdigest()[:9]


def ev_append(roster_path, kind, ident, verb, name, detail=""):
    """Record one operator action. kind=user|peer|node|panel, verb is the human action
    ("Created peer"), name is the display label, detail is optional context."""
    rec = {"eid": _ev_eid(), "ts": int(time.time()), "kind": kind, "id": ident or "",
           "verb": verb, "name": name or "", "detail": detail or ""}
    p = events_path(roster_path)
    try:
        os.makedirs(os.path.dirname(p) or ".", exist_ok=True)
        with open(p, "a") as f:
            fcntl.flock(f, fcntl.LOCK_EX)
            f.write(json.dumps(rec, separators=(",", ":")) + "\n")
        if os.path.getsize(p) > EVENTS_TRIM_BYTES:        # trim to the last EVENTS_CAP lines
            with open(p) as f:
                lines = f.readlines()
            if len(lines) > EVENTS_CAP:
                tmp = p + ".tmp." + uuid.uuid4().hex[:8]
                with open(tmp, "w") as f:
                    f.writelines(lines[-EVENTS_CAP:])
                os.replace(tmp, p)
    except OSError:
        pass          # the log is best-effort; never fail a mutation because it couldn't be recorded


def _ev_load(roster_path):
    """All events oldest→newest, each guaranteed an `eid` (legacy lines get a content hash)."""
    p = events_path(roster_path)
    out = []
    try:
        with open(p) as f:
            for ln in f:
                s = ln.strip()
                if not s:
                    continue
                try:
                    rec = json.loads(s)
                except Exception:
                    continue
                if not rec.get("eid"):
                    rec["eid"] = _ev_synth_eid(s)
                out.append(rec)
    except OSError:
        pass
    return out


def ev_read(roster_path, limit=12):
    """Return (newest `limit` events newest-first, total count)."""
    recs = _ev_load(roster_path)
    total = len(recs)
    recs.reverse()
    return recs[:max(1, limit)], total


def ev_delete(roster_path, eid):
    """Drop one record by eid (or its synthesized content-hash id). Returns how many were removed."""
    p = events_path(roster_path)
    removed = 0
    try:
        with open(p, "r") as f:
            fcntl.flock(f, fcntl.LOCK_EX)
            lines = f.readlines()
            kept = []
            for ln in lines:
                s = ln.strip()
                if not s:
                    continue
                try:
                    rec = json.loads(s)
                except Exception:
                    kept.append(ln if ln.endswith("\n") else ln + "\n")
                    continue
                rid = rec.get("eid") or _ev_synth_eid(s)
                if rid == eid:
                    removed += 1
                    continue
                kept.append(ln if ln.endswith("\n") else ln + "\n")
            tmp = p + ".tmp." + uuid.uuid4().hex[:8]
            with open(tmp, "w") as g:
                g.writelines(kept)
            os.replace(tmp, p)
    except OSError:
        pass
    return removed


def ev_clear(roster_path):
    """Flush the whole activity log."""
    with contextlib.suppress(OSError):
        os.remove(events_path(roster_path))


def gen_id():
    """Short opaque id for users and peers — decoupled from the pubkey so a peer's
    key can rotate in place without losing its identity or history."""
    return uuid.uuid4().hex[:12]


def sanitize_color(v, fallback=None):
    """A themed colour {dark,light} (each #rrggbb). A legacy string is accepted and applied to both modes.
    Returns `fallback` if nothing valid was supplied."""
    hx = lambda s: bool(re.match(r"^#[0-9a-fA-F]{6}$", str(s)))
    if isinstance(v, dict):
        out = {}
        if hx(v.get("dark")):  out["dark"] = str(v["dark"])
        if hx(v.get("light")): out["light"] = str(v["light"])
        if out:
            return out
    if hx(v):
        return {"dark": str(v), "light": str(v)}
    return fallback


def gen_psk():
    """A WireGuard/AmneziaWG preshared key: 32 random bytes, base64 (stdlib only)."""
    return base64.b64encode(os.urandom(32)).decode()


def peer_label(roster, p):
    """Best display label for a peer in the activity log: title → owner name → unassigned."""
    if p.get("title"):
        return p["title"]
    uid = p.get("user_id")
    if uid and uid in (roster.get("users") or {}):
        return (roster["users"][uid] or {}).get("name", "") or "unassigned peer"
    return "unassigned peer"


def clean_target(t):
    """Normalise one deployment target: {node, iface, ip, type}."""
    return {
        "node": t.get("node", ""),
        "iface": t.get("iface", ""),
        "ip": (t.get("ip", "") or "").split("/")[0],
        "type": t.get("type", "") or "wg",
    }


def find_peer_by_pubkey(roster, pubkey):
    for p in roster.get("peers", {}).values():
        if isinstance(p, dict) and p.get("pubkey") == pubkey:
            return p
    return None


def valid_addr(s):
    """A bare IP (v4 or v6); a trailing /prefix is tolerated and ignored."""
    try:
        ipaddress.ip_address((s or "").split("/")[0].strip())
        return True
    except ValueError:
        return False


# ── input hardening ──────────────────────────────────────────────────────────────────────────────
# Operator strings that a NODE later turns into a subprocess arg, systemd unit, or config line must
# not carry shell/heredoc-breakout metacharacters. These validators reject ONLY control chars /
# injection payloads — every legitimate value (IPs, ports, hex keys, repo slugs, NIC names) passes.
# Cheap: compiled regex / one ipaddress parse. Defence-in-depth pairs with argv writes on the node.
_CTRL_RE = re.compile(r"[\x00-\x1f\x7f]")
def no_ctrl(s):                                   # no newline/control chars (heredoc + config-line injection)
    return not _CTRL_RE.search(s or "")
def strip_ctrl(s):                                # drop control chars from a cosmetic free-text field (title/name)
    return _CTRL_RE.sub("", s or "")
def valid_hostport(s):
    """host:port — host an IP or a safe hostname, port 1-65535, no shell metacharacters."""
    if not s or _CTRL_RE.search(s):
        return False
    host, sep, port = s.rpartition(":")
    if not sep or not host or not port.isdigit() or not (1 <= int(port) <= 65535):
        return False
    h = host.strip("[]")
    try:
        ipaddress.ip_address(h)
        return True
    except ValueError:
        return bool(re.match(r"^[A-Za-z0-9._-]+$", h))
_OWNER_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]*/[A-Za-z0-9][A-Za-z0-9._-]*$")   # GitHub owner/repo slug
_TURN_SVC_RE = re.compile(r"^vk-turn-proxy-[A-Za-z0-9._-]+-\d{1,5}$")                 # node writes this as a path/unit component
_WANIF_RE = re.compile(r"^[A-Za-z0-9._-]{1,15}$")                                     # Linux NIC name (IFNAMSIZ 16); blocks ; ` $ | & etc.


def bad_targets(targets):
    """First validation error across a target list, or None. Defence-in-depth behind the UI."""
    for t in targets:
        if not valid_addr(t.get("ip", "")):
            return f"invalid address {t.get('ip')!r} for {t.get('node')}/{t.get('iface')}"
    return None


def iface_type(snaps, node, iface):
    """wg vs awg, read from the node's pushed snapshot (awg interfaces carry awg_params)."""
    blk = ((snaps.get(node) or {}).get("interfaces") or {}).get(iface) or {}
    return "awg" if (blk.get("meta") or {}).get("awg_params") else "wg"


def save_config(store_configs, config_dir, pubkey, node, iface, conf):
    if store_configs and config_dir and isinstance(conf, str) and conf:
        with contextlib.suppress(OSError):
            atomic_write(os.path.join(config_dir, cfg_hash(pubkey, node, iface)), conf, mode=0o600)


def del_config(store_configs, config_dir, pubkey, node, iface):
    if store_configs and config_dir:
        with contextlib.suppress(OSError):
            os.unlink(os.path.join(config_dir, cfg_hash(pubkey, node, iface)))


def user_set(roster, uid, fields, now):
    u = roster["users"].get(uid) or {}
    roster["users"][uid] = {
        "id": uid,
        "name": fields.get("name", u.get("name", "")),
        "tag": fields.get("tag", u.get("tag", "")),
        "note": fields.get("note", u.get("note", "")),
        "created_at": u.get("created_at", now),
        "modified_at": now,
    }
    return roster["users"][uid]


def peer_set(roster, pid, fields, now):
    p = roster["peers"].get(pid) or {}
    targets = fields.get("targets", p.get("targets", []))
    roster["peers"][pid] = {
        "id": pid,
        "user_id": fields.get("user_id", p.get("user_id")),   # None => unassigned
        "title": (fields.get("title", p.get("title", "")) or "")[:64],   # operator label to tell devices apart
        "pubkey": fields.get("pubkey", p.get("pubkey", "")),
        "psk": fields.get("psk", p.get("psk", "")),
        "targets": [clean_target(t) for t in targets],
        "created_at": p.get("created_at", now),
        "modified_at": now,
    }
    return roster["peers"][pid]


def unassign_peer(p, store_configs, config_dir, now):
    """Detach a peer from its user AND revoke the old holder's access.

    The PSK is panel-owned and mixed into every WireGuard handshake, so rotating it
    here makes the config already on the previous owner's device fail on the node's
    next sync — instant revocation with no client in the loop. The keypair is left
    intact (re-keying needs the browser, where the private key lives); the peer is
    parked, present on its nodes but unusable until it's re-issued to someone.
    """
    p["user_id"] = None
    p["psk"] = gen_psk()
    p["modified_at"] = now
    for t in p.get("targets", []):
        del_config(store_configs, config_dir, p.get("pubkey", ""), t["node"], t["iface"])


def retire_pubkey(nodes, nodes_path, targets, old_pubkey):
    """Queue a pubkey for EXPLICIT removal on each target's node/iface. The node drops it even on an
    add-only (onboarded) interface — so a key the panel rotated/deleted is removed, while genuine
    external orphans (keys the panel never owned) are still left alone. Cleared once the node stops
    reporting the key (in _node_sync)."""
    if not old_pubkey:
        return
    changed = False
    for t in targets or []:
        nid = t.get("node"); iface = t.get("iface")
        if not nid or not iface or nid not in nodes:
            continue
        lst = nodes[nid].setdefault("retire", {}).setdefault(iface, [])
        if old_pubkey not in lst:
            lst.append(old_pubkey); changed = True
    if changed:
        with contextlib.suppress(Exception):
            nodes_save(nodes_path, nodes)


# ───────────────────────── node store + sync ─────────────────────────

def make_token_hash(token, iters=200000):
    salt = os.urandom(16)
    h = hashlib.pbkdf2_hmac("sha256", token.encode(), salt, iters)
    return f"pbkdf2_sha256${iters}${base64.b64encode(salt).decode()}${base64.b64encode(h).decode()}"


# password hashing reuses the same pbkdf2_sha256 format verify_password() understands
make_pw_hash = make_token_hash


# ── two-factor auth (TOTP / Google Authenticator, RFC 6238) — stdlib only ────────────────────────────
# The TOTP secret + recovery-code hashes live in their own 0o600 file (2fa.json) next to the roster; the
# raw secret is shown ONCE at setup and never returned again, recovery codes are stored only as sha256.
def totp_secret():
    return base64.b32encode(os.urandom(20)).decode().rstrip("=")          # 160-bit base32, no padding

def _hotp(secret_b32, counter, digits=6):
    key = base64.b32decode(secret_b32.upper() + "=" * (-len(secret_b32) % 8))
    h = hmac.new(key, struct.pack(">Q", counter), hashlib.sha1).digest()
    off = h[-1] & 0x0F
    num = struct.unpack(">I", h[off:off + 4])[0] & 0x7FFFFFFF
    return str(num % (10 ** digits)).zfill(digits)

def totp_verify(secret_b32, code, step=30, window=1):
    """True if `code` is a valid TOTP for `secret_b32` within ±window steps (clock skew tolerance)."""
    code = (code or "").strip().replace(" ", "")
    if not (secret_b32 and code.isdigit() and len(code) == 6):
        return False
    now = int(time.time() // step)
    for w in range(-window, window + 1):
        if hmac.compare_digest(_hotp(secret_b32, now + w), code):
            return True
    return False

def otpauth_uri(user, secret_b32, issuer="swgPanel"):
    return ("otpauth://totp/%s?secret=%s&issuer=%s&algorithm=SHA1&digits=6&period=30"
            % (quote("%s:%s" % (issuer, user)), secret_b32, quote(issuer)))

def gen_recovery_codes(n=10):
    # 10 chars of base32 (~50 bits) each, grouped for readability; compared case-insensitively, dashes ignored
    def one(): s = base64.b32encode(os.urandom(7)).decode().rstrip("=").lower()[:10]; return s[:5] + "-" + s[5:]
    return [one() for _ in range(n)]

def _recovery_hash(code):
    return hashlib.sha256(("swg-2fa\x00" + (code or "").strip().lower().replace("-", "").replace(" ", "")).encode()).hexdigest()

def recovery_consume(tf, code):
    """If `code` matches a stored recovery hash, remove it from tf (single use) and return True."""
    h = _recovery_hash(code); recs = tf.get("recovery") or []
    for i, r in enumerate(recs):
        if hmac.compare_digest(str(r), h):
            recs.pop(i); tf["recovery"] = recs; return True
    return False

def load_2fa(path):
    d = load_json(path, {}) if path else {}
    return d if isinstance(d, dict) else {}

def save_2fa(path, data):
    atomic_write(path, json.dumps(data, indent=2) + "\n", mode=0o600)


# ───────────────────────── subscriptions: per-user shareable QR pages ─────────────────────────
#
# The panel NEVER holds a usable key here. Every secret is encrypted/wrapped in the ADMIN BROWSER
# (WebCrypto) and the panel stores only opaque blobs it cannot read:
#   vault.json   {salt, sk_by_pw, sk_check}   the panel-wide Subscription Key wrapped by the admin
#                                             password (convenience cache). SK plaintext is shown once
#                                             and never stored here.
#   users.json   {user_id: {token_sha, token_hash, unlock_by_sk, enabled, created, rotated}}
#                                             per-user: the URL token (hashed like a node token) + the
#                                             user's unlock-key wrapped by the SK.
#   blobs/<uid>.json {peer_id: {sec, at}}     per-peer secret (privkey‖psk) AES-GCM'd with the user's
#                                             unlock-key. The user's URL FRAGMENT *is* that unlock-key.
# There is deliberately NO code path here that decrypts a secret. The read side returns ciphertext +
# non-secret params only, filtered at read time to peers CURRENTLY assigned to the user (the roster is
# authoritative), so a stale blob can never surface.

def _sub_dir(deps):
    return deps.get("sub_dir") or os.path.join(os.path.dirname(deps["roster_path"]) or ".", "subs")

def _sub_vault_path(deps): return os.path.join(_sub_dir(deps), "vault.json")
def _sub_users_path(deps): return os.path.join(_sub_dir(deps), "users.json")
def _sub_blob_path(deps, uid):
    return os.path.join(_sub_dir(deps), "blobs", re.sub(r"[^A-Za-z0-9_-]", "_", str(uid)) + ".json")

def _load_sub_json(path):
    d = load_json(path, {}) if path else {}
    return d if isinstance(d, dict) else {}

# File modes matter here: the read-only `swg-sub` process runs as a SEPARATE, unprivileged user in
# group `swg`. The files it must read are group-readable (0640); the ones it must NEVER read — the
# vault (the SK escrow that could unwrap every peer's key) — stay owner-only (0600), so a compromised
# swg-sub simply cannot open them. See swg-sub's "least privilege" note.
def load_sub_vault(deps): return _load_sub_json(_sub_vault_path(deps))
def save_sub_vault(deps, d):
    os.makedirs(_sub_dir(deps), exist_ok=True)
    atomic_write(_sub_vault_path(deps), json.dumps(d, indent=2) + "\n", mode=0o600)   # owner-only — swg-sub must never read the SK escrow

def load_sub_users(deps): return _load_sub_json(_sub_users_path(deps))
def save_sub_users(deps, d):
    os.makedirs(_sub_dir(deps), exist_ok=True)
    atomic_write(_sub_users_path(deps), json.dumps(d, indent=2) + "\n", mode=0o640)   # group-readable: swg-sub maps token→uid

def load_sub_blobs(deps, uid): return _load_sub_json(_sub_blob_path(deps, uid))
def save_sub_blobs(deps, uid, d):
    os.makedirs(os.path.dirname(_sub_blob_path(deps, uid)), exist_ok=True)
    atomic_write(_sub_blob_path(deps, uid), json.dumps(d, indent=2) + "\n", mode=0o640)   # group-readable: swg-sub serves the ciphertext
def drop_sub_blobs(deps, uid):
    with contextlib.suppress(OSError):
        os.remove(_sub_blob_path(deps, uid))

# The escrow is split OUT of the public token map (users.json). users.json holds ONLY {token_sha,
# enabled} — the minimum swg-sub needs — and is group-readable (0640). escrow.json holds the SK-wrapped
# unlock-key + token (so the admin can rebuild a URL and encrypt new peers later) and stays 0600
# owner-only, so the public surface never even has the option of reading it. Both are opaque to the
# panel: unlock_by_sk / token_by_sk are ciphertext it can't unwrap (the SK never reaches the server).
def _sub_escrow_path(deps): return os.path.join(_sub_dir(deps), "escrow.json")
def load_sub_escrow(deps): return _load_sub_json(_sub_escrow_path(deps))
def save_sub_escrow(deps, d):
    os.makedirs(_sub_dir(deps), exist_ok=True)
    atomic_write(_sub_escrow_path(deps), json.dumps(d, indent=2) + "\n", mode=0o600)   # owner-only — swg-sub must never read the escrow

def _sub_serve_path(deps): return os.path.join(_sub_dir(deps), "serve.json")
def write_sub_serve(deps):
    """Mirror JUST {enabled, serve} to subs/serve.json (group-readable) so swg-sub reads its own config
    from a tiny dedicated file and never has to open panel-settings.json — which also carries webhook
    signing secrets and API token hashes that the public subscription surface has no business seeing."""
    ps = deps.get("panel_settings") or {}
    subs = ps.get("subscriptions") or {}
    # The sub's bind + TLS now come from the Access & TLS block (access.sub / access.tls) — the single source
    # both the Access & TLS and Subscriptions cards edit. tls.mode ""/skip = plain HTTP (behind a proxy);
    # anything else = swg-sub terminates its own TLS from its default cert path. Falls back to the legacy
    # subscriptions.serve for an install that set that but never touched Access & TLS.
    acc = ps.get("access") or {}
    asub = acc.get("sub") if isinstance(acc.get("sub"), dict) else {}
    amode = ((acc.get("tls") or {}).get("mode") or "")
    _legacy = subs.get("serve") if isinstance(subs.get("serve"), dict) else {}
    serve = {"host": asub.get("host") or _legacy.get("host") or "0.0.0.0",
             "port": asub.get("port") or _legacy.get("port") or 8444,
             "tls_mode": ("reverse-proxy" if amode in ("", "skip") else amode),
             "cert_path": "", "key_path": ""}
    # turn_enabled + vk_link ride along so swg-sub can offer the TURN tab + build turn-proxy client artifacts
    # without reading panel-settings.json (which also holds webhook secrets). Neither is a secret: vk_link is
    # embedded in every turn config a client already receives.
    out = {"enabled": bool(subs.get("enabled")),
           "serve": serve,
           "turn_enabled": ps.get("turn_enabled") is not False,
           "vk_link": (ps.get("vk_link") or ""),
           # brand theme colours (per light/dark) so the subscription page's logo + favicon follow the panel
           "theme_color": (ps.get("theme_color") or ""),
           "theme_color_light": (ps.get("theme_color_light") or ""),
           # offered UI languages + the default (the page hides its selector when only one is enabled)
           "languages": subs.get("languages") if isinstance(subs.get("languages"), dict) else {"enabled": ["en"], "default": "en"}}
    with contextlib.suppress(Exception):
        os.makedirs(_sub_dir(deps), exist_ok=True)
        atomic_write(_sub_serve_path(deps), json.dumps(out, indent=2) + "\n", mode=0o640)

def normalize_sub_perms(deps):
    """On startup, make the files swg-sub is allowed to read group(swg)-readable (0640), and keep the
    vault owner-only (0600). New writes already use these modes; this fixes files left 0600 by an older
    build so an upgraded panel doesn't leave swg-sub unable to read the roster until the next write."""
    grp = [deps.get("roster_path"), deps.get("nodes_path"),
           _sub_users_path(deps), _sub_serve_path(deps)]
    blobdir = os.path.join(_sub_dir(deps), "blobs")
    with contextlib.suppress(Exception):
        grp += [os.path.join(blobdir, n) for n in os.listdir(blobdir) if n.endswith(".json")]
    for p in grp:
        if p:
            with contextlib.suppress(OSError):
                os.chmod(p, 0o640)
    for p in (_sub_vault_path(deps), _sub_escrow_path(deps)):
        with contextlib.suppress(OSError):
            os.chmod(p, 0o600)   # belt-and-suspenders: the SK vault + the wrapped-key escrow stay owner-only


def subs_enabled(deps):
    return bool(((deps.get("panel_settings") or {}).get("subscriptions") or {}).get("enabled"))


# ── Access & TLS validation (shared by the settings save +, later, the live-apply path) ──────────────
# Cloudflare's proxy only connects back to origin HTTPS on this fixed set of ports (everything else is
# unreachable behind the orange cloud). cf15 certs are ONLY valid behind CF, so a non-CF port is a hard
# error; a DNS-01 "cloudflare" LE cert also works direct, so there it's just a warning.
CF_HTTPS_PORTS = {443, 8443, 2053, 2083, 2087, 2096}
TLS_MODES = ("", "letsencrypt", "cloudflare", "cf15", "letsencrypt-ip", "selfsigned", "skip")
CA_DOMAIN_MODES = ("letsencrypt", "cloudflare", "cf15")   # a public CA validates a domain, not an IP


def _url_host(url):
    """Bare host from a URL (no scheme/port/path). '' if unparseable."""
    s = (str(url or "")).strip()
    s = re.sub(r"^[a-zA-Z][a-zA-Z0-9+.-]*://", "", s)      # drop scheme
    s = s.split("/")[0].split("?")[0]                       # drop path/query
    if s.startswith("[") and "]" in s:                     # [v6]:port
        return s[1:s.index("]")]
    return s.rsplit(":", 1)[0] if s.count(":") == 1 else s  # host:port (v4/name) → host


def _is_ip(host):
    try:
        ipaddress.ip_address(host)
        return True
    except ValueError:
        return False


def _bindable_ips():
    """The box's own bindable addresses (global scope — excludes loopback + link-local). You can only
    bind to IPs the host actually holds; behind NAT the public IP may differ, so these are annotated with
    the interface. The UI prepends the synthetic 0.0.0.0/127.0.0.1 rows itself."""
    out, seen = [], set()
    with contextlib.suppress(Exception):
        r = subprocess.run(["ip", "-o", "addr", "show", "scope", "global"],
                           stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True, timeout=5)
        for line in r.stdout.splitlines():
            p = line.split()
            if len(p) >= 4 and p[2] in ("inet", "inet6"):
                ip = p[3].split("/")[0]
                if ip not in seen:
                    seen.add(ip)
                    out.append({"ip": ip, "iface": p[1], "family": 4 if p[2] == "inet" else 6})
    return out


def _clean_endpoint(inc, cur, default_port):
    """Sanitize one {url,base,host,port} block, MERGING per-field over the current value so a partial edit
    (e.g. the Subscriptions card sending just {url}) keeps the rest. No cross-field checks here."""
    inc = inc if isinstance(inc, dict) else {}
    cur = cur if isinstance(cur, dict) else {}
    pick = lambda k, d: inc[k] if k in inc else cur.get(k, d)
    host = (str(pick("host", "0.0.0.0") or "0.0.0.0")).strip()[:120] or "0.0.0.0"
    if not _is_ip(host):
        host = "0.0.0.0"                                    # never bind to a non-IP
    try:
        port = max(1, min(65535, int(pick("port", default_port) or default_port)))
    except (TypeError, ValueError):
        port = default_port
    base = (str(pick("base", "/") or "/")).strip()[:200] or "/"
    if not base.startswith("/"):
        base = "/" + base
    return {"url": (str(pick("url", "") or "")).strip()[:300], "base": base, "host": host, "port": port}


def validate_access(incoming, current):
    """Validate + sanitize an incoming `access` block, MERGED over `current` — a partial block (any of
    panel/sub/tls absent, or a sub-block with only some fields) updates just what it carries and keeps the
    rest, so any settings card can edit its own slice. Returns (cleaned, errors, warnings)."""
    inc = incoming if isinstance(incoming, dict) else {}
    cur = current if isinstance(current, dict) else {}
    errors, warnings = [], []

    panel = _clean_endpoint(inc.get("panel"), cur.get("panel"), 443)
    sub = _clean_endpoint(inc.get("sub"), cur.get("sub"), 8444)

    tin = inc.get("tls") if isinstance(inc.get("tls"), dict) else {}
    tcur = cur.get("tls") if isinstance(cur.get("tls"), dict) else {}
    mode = (str((tin["mode"] if "mode" in tin else tcur.get("mode")) or "")).strip()
    if mode not in TLS_MODES:
        mode = ""
    email = (str((tin["email"] if "email" in tin else tcur.get("email")) or "")).strip()[:200]
    # secrets: an empty incoming value KEEPS the stored one (the browser never receives them, so a blank
    # field means "unchanged", not "clear"). A literal "-" clears it.
    def _secret(key):
        v = tin.get(key)
        if v is None or (isinstance(v, str) and v.strip() == ""):
            return (tcur.get(key) or "")
        v = str(v).strip()
        return "" if v == "-" else v[:400]
    tls = {"mode": mode, "email": email,
           "cf_token": _secret("cf_token"), "cf_origin_token": _secret("cf_origin_token")}

    # ── cross-field rules ──
    for name, ep in (("Panel", panel), ("Subscription", sub)):
        host = _url_host(ep["url"])
        if ep["url"] and mode in CA_DOMAIN_MODES and _is_ip(host):
            errors.append("%s: %s needs a domain URL, not an IP address." % (name, mode))
        if mode == "cf15" and ep["port"] not in CF_HTTPS_PORTS:
            errors.append("%s: port %d can't be reached behind Cloudflare — a cf15 origin cert is only valid there. Use one of: %s."
                          % (name, ep["port"], ", ".join(map(str, sorted(CF_HTTPS_PORTS)))))
        elif mode == "cloudflare" and ep["port"] not in CF_HTTPS_PORTS:
            warnings.append("%s: if this panel is behind Cloudflare, port %d won't be reachable (CF connects to %s)."
                            % (name, ep["port"], ", ".join(map(str, sorted(CF_HTTPS_PORTS)))))

    # panel and sub can't occupy the same (bind, port); 0.0.0.0 collides with everything on that port.
    def _collide(a, b):
        if a["port"] != b["port"]:
            return False
        return a["host"] == b["host"] or "0.0.0.0" in (a["host"], b["host"]) or "::" in (a["host"], b["host"])
    if _collide(panel, sub):
        errors.append("Panel and subscription can't share the same address and port (%s:%d)." % (panel["host"], panel["port"]))

    # same host + same port + different path is impossible with two independent processes (needs a shared front)
    ph, sh = _url_host(panel["url"]), _url_host(sub["url"])
    if ph and ph == sh and panel["port"] == sub["port"] and panel["base"] != sub["base"]:
        errors.append("Panel and subscription are on the same host and port but different paths — two separate "
                      "servers can't share host:port. Use a different subdomain or a different port.")

    return {"panel": panel, "sub": sub, "tls": tls}, errors, warnings


def _access_public_view(deps):
    """Redacted `access` for the browser: the CF tokens never leave the panel (has_* booleans instead)."""
    acc = (deps.get("panel_settings") or {}).get("access") or {}
    tls = acc.get("tls") or {}
    return {"panel": acc.get("panel") or {}, "sub": acc.get("sub") or {},
            "tls": {"mode": tls.get("mode") or "", "email": tls.get("email") or "",
                    "has_cf_token": bool(tls.get("cf_token")),
                    "has_cf_origin_token": bool(tls.get("cf_origin_token"))}}

def sub_token_lookup(deps, token):
    """Raw token → user_id via constant-time sha256 match; None if not found or that user is disabled."""
    if not token:
        return None
    sha = hashlib.sha256(token.encode()).hexdigest()
    for uid, rec in load_sub_users(deps).items():
        if rec.get("enabled") and hmac.compare_digest(str(rec.get("token_sha", "")), sha):
            return uid
    return None

def sub_live_peers(roster, uid):
    """Peers CURRENTLY assigned to uid — the roster is authoritative, so this is the read-time gate."""
    return {pid: p for pid, p in ((roster.get("peers") or {}).items()) if p.get("user_id") == uid}

def sub_gc_user(deps, uid, roster):
    """Prune the user's blob file to peers still assigned to them (housekeeping). Returns the live blobs."""
    live = sub_live_peers(roster, uid)
    blobs = load_sub_blobs(deps, uid)
    pruned = {pid: v for pid, v in blobs.items() if pid in live}
    if pruned != blobs:
        if pruned:
            save_sub_blobs(deps, uid, pruned)
        else:
            drop_sub_blobs(deps, uid)
    return pruned

def sub_read_data(deps, roster, describe, token):
    """The public page's data for a token: the user's CURRENT peers, each target's NON-SECRET params +
    the encrypted secret blob. Never returns a plaintext key. None if subscriptions are off or the token
    is invalid. This is what `swg-sub` will serve (it reads the same files)."""
    if not subs_enabled(deps):
        return None
    uid = sub_token_lookup(deps, token)
    if uid is None:
        return None
    user = (roster.get("users") or {}).get(uid) or {}
    live = sub_live_peers(roster, uid)
    blobs = sub_gc_user(deps, uid, roster)            # read-time reconcile against the roster
    peers_out = []
    for pid, p in live.items():
        sec = (blobs.get(pid) or {}).get("sec")       # None until the admin browser provisions it
        n_t = len(p.get("targets") or [])
        tgts = []
        for i, t in enumerate(p.get("targets") or []):
            meta = ((describe or {}).get(t.get("node")) or {}).get(t.get("iface")) or {}
            tgts.append({
                "node": t.get("node"), "iface": t.get("iface"), "type": t.get("type") or "wg",
                "ip": t.get("ip"),
                "endpoint": meta.get("endpoint"), "server_pubkey": meta.get("public_key"),
                "dns": meta.get("dns") or [], "subnet": meta.get("subnet"),
                "mtu": meta.get("mtu") or 1280,
                "awg": meta.get("awg_params") or {},
                "primary": (n_t > 1 and i == 0),      # the default deployment, tagged first
            })
        peers_out.append({"peer_id": pid, "title": p.get("title") or "", "sec": sec, "targets": tgts})
    return {"user": {"id": uid, "name": user.get("name") or ""}, "peers": peers_out}


def nodes_load(path):
    d = load_critical(path, {})
    return d if isinstance(d, dict) else {}


def nodes_save(path, nodes):
    save_critical(path, json.dumps(nodes, indent=2) + "\n", mode=0o640)   # group(swg)-readable for swg-sub (token HASHES only, no raw secrets)


def migrate_node_ids(nodes_path, roster_path, store_configs, config_dir):
    """One-time: nodes keyed by their (mutable) name -> keyed by a stable opaque id, with the
    name kept as a free-to-change display title. Rewrites roster peer targets (node name -> id)
    and renames any stored config files. Idempotent: a no-op once every node is id-keyed."""
    nodes = load_json(nodes_path, {})
    if not isinstance(nodes, dict) or not nodes:
        return
    if all(isinstance(v, dict) and v.get("id") == k for k, v in nodes.items()):
        return                                      # already migrated
    name_to_id, new_nodes = {}, {}
    for key, v in nodes.items():
        if not isinstance(v, dict):
            continue
        nid = v.get("id") or gen_id()
        while nid in new_nodes:
            nid = gen_id()
        v["id"] = nid
        v["name"] = v.get("name", key)              # the old dict key was the (display) name
        new_nodes[nid] = v
        for nm in {key, v["name"]}:
            if nm and nm != nid:
                name_to_id[nm] = nid
    nodes_save(nodes_path, new_nodes)
    roster = roster_load(roster_path)
    changed = False
    for p in (roster.get("peers") or {}).values():
        if not isinstance(p, dict):
            continue
        for t in p.get("targets", []):
            old, new = t.get("node"), name_to_id.get(t.get("node"))
            if new and new != old:
                if store_configs and config_dir and p.get("pubkey") and t.get("iface"):
                    with contextlib.suppress(OSError):
                        os.replace(os.path.join(config_dir, cfg_hash(p["pubkey"], old, t["iface"])),
                                   os.path.join(config_dir, cfg_hash(p["pubkey"], new, t["iface"])))
                t["node"] = new
                changed = True
    if changed:
        roster_save(roster_path, roster)
    print(f"migrated {len(new_nodes)} node(s) to stable ids", flush=True)


def migrate_ru_split(nodes_path, panel_settings_path):
    """One-time: the single 'ru' category (which meant all-RU GeoIP in Kernel mode but the blocked-in-RU
    circumvention DOMAIN list in DNS mode — two different things) was split into 'ru_net' (GeoIP, every mode) +
    'ru_blocked' (circumvention domains, DNS/SNI only). Rewrite the now-ambiguous 'ru' → 'ru_net' (the country/IP
    meaning, which keeps working in every mode); 'ru_blocked' is then an explicit opt-in. Idempotent."""
    def _sub(lst):   # replace ru→ru_net in a category-id list, order-preserving + de-duped
        return list(dict.fromkeys("ru_net" if c == "ru" else c for c in lst))
    changed = False
    nodes = load_json(nodes_path, {})
    if isinstance(nodes, dict):
        for n in nodes.values():
            if not isinstance(n, dict):
                continue
            ec = n.get("enabled_categories")
            if isinstance(ec, list) and "ru" in ec:
                n["enabled_categories"] = _sub(ec); changed = True
            for ifo in (n.get("ifaces") or {}).values():
                if not isinstance(ifo, dict):
                    continue
                for r in (ifo.get("routing") or []):
                    if isinstance(r, dict) and r.get("category") == "ru":
                        r["category"] = "ru_net"; changed = True
        if changed:
            nodes_save(nodes_path, nodes)
    ps = load_settings_critical(panel_settings_path)   # recover before migrating (never modify a clobbered stub)
    if isinstance(ps, dict):
        hc = ps.get("hidden_categories")
        if isinstance(hc, list) and "ru" in hc:
            ps["hidden_categories"] = _sub(hc)
            save_critical(panel_settings_path, json.dumps(ps, indent=2) + "\n")   # rotating backups (recoverable)
            changed = True
    if changed:
        print("migrated 'ru' category → 'ru_net' (ru_blocked is now a separate opt-in list)", flush=True)


def migrate_provider_defaults(nodes_path, panel_settings_path):
    """One-time: providers now default OFF (a fresh fleet opts in). To keep an EXISTING fleet's routing working
    across that flip, explicitly enable every provider a node already routes. Idempotent — runs once (marked by
    `providers_defaulted`), only adds True entries, never disables, and respects later manual toggles."""
    ps = load_settings_critical(panel_settings_path)   # recover before migrating (never modify a clobbered stub)
    if not isinstance(ps, dict) or ps.get("providers_defaulted"):
        return
    prov = dict(ps.get("providers") or {})
    inuse = {c.split(":", 1)[0] for c in routed_catalog_cats(load_json(nodes_path, {}) or {}) if ":" in c}
    for pid in inuse:
        prov.setdefault(pid, True)                              # keep an already-routed provider enabled
    ps["providers"] = prov
    ps["providers_defaulted"] = True
    save_critical(panel_settings_path, json.dumps(ps, indent=2) + "\n")   # rotating backups (recoverable)
    print("provider defaults: kept %d in-use provider(s) enabled; new providers now default off" % len(inuse), flush=True)


def normalize_stats_files(nodes_path, stats_dir):
    """Make every node's snapshot mirror id-keyed: `stats_file` -> `stats-<id>.json`, renaming the file
    on disk if it's still under a legacy name (auto-enrolled nodes were written `stats-<hostname>.json`).
    The health RRD is already `health-<id>.rrd`, so after this BOTH health files share the stable id —
    they always travel together (e.g. through a convert) and the warm-start can't be orphaned by a
    hostname change. Idempotent."""
    nodes = load_json(nodes_path, {})
    if not isinstance(nodes, dict) or not nodes:
        return
    changed = False
    for nid, c in nodes.items():
        if not isinstance(c, dict):
            continue
        canon = f"stats-{nid}.json"
        old = c.get("stats_file")
        if old == canon:
            continue
        if old and stats_dir:                       # carry the existing mirror over to the canonical name
            with contextlib.suppress(OSError):
                src = os.path.join(stats_dir, old)
                if os.path.exists(src) and not os.path.exists(os.path.join(stats_dir, canon)):
                    os.replace(src, os.path.join(stats_dir, canon))
        c["stats_file"] = canon
        changed = True
    if changed:
        nodes_save(nodes_path, nodes)
        print("normalized node stats_file -> stats-<id>.json", flush=True)


def find_node_by_token(nodes, token):
    # Fast path: a per-node sha256(token) index (`token_sha`) gives O(N) constant-time compares — no pbkdf2.
    # The node token is 144-bit os.urandom, so a plain sha256 is a secure verifier (same as the API tokens).
    # This removes the N×200k-iter-pbkdf2 amplification a bogus token used to force on every unauth request.
    # Legacy nodes (enrolled before token_sha) fall back to pbkdf2 and get upgraded on their next sync.
    if not token:
        return None, None
    tsha = hashlib.sha256(token.encode()).hexdigest()
    for nid, n in nodes.items():
        ts = n.get("token_sha")
        if ts and hmac.compare_digest(ts, tsha):
            return nid, n
    for nid, n in nodes.items():
        if n.get("token_sha"):
            continue                                  # already indexed → not a legacy candidate
        if verify_password(n.get("token_hash", ""), token):
            return nid, n
    return None, None


def _archive_node(deps, nid, nm, node_entry, peers, sf):
    """Back a node up before it's purged → <state_dir>/archive/<name>-<nid>-<ts>/ with node.json,
    peers.json (the peer entries that referenced it), and its MOVED stats + health files. Best-effort:
    a backup must never block the delete."""
    try:
        state_dir = os.path.dirname(deps["nodes_path"]) or "."
        safe = "".join(c if (c.isalnum() or c in "-_.") else "_" for c in str(nm))[:40] or nid
        dest = os.path.join(state_dir, "archive", f"{safe}-{nid}-{int(time.time())}")
        os.makedirs(dest, exist_ok=True)
        atomic_write(os.path.join(dest, "node.json"), json.dumps(node_entry, indent=2) + "\n", mode=0o600)
        atomic_write(os.path.join(dest, "peers.json"), json.dumps(peers, indent=2) + "\n", mode=0o600)
        sd = deps.get("stats_dir")
        if sd:
            for fn in (sf, f"health-{nid}.rrd"):
                src = os.path.join(sd, fn)
                if os.path.exists(src):
                    with contextlib.suppress(Exception):
                        shutil.move(src, os.path.join(dest, fn))   # cross-fs safe (state vs stats may differ)
        return dest
    except Exception:
        return None

def node_remove(deps, nid):
    """Drop a node from the store and cascade: ARCHIVE its data (node + peer targets + stats/health) as a
    recoverable backup, then purge its peer targets (deleting peers whose only deployment was here), forget
    its live snapshot, and remove its stats + health files. Returns the removed node's display name, or None
    if it wasn't there. Shared by force-remove + goodbye."""
    nodes = nodes_load(deps["nodes_path"])
    if nid not in nodes:
        return None
    nm = nodes[nid].get("name", nid)
    sf = nodes[nid].get("stats_file", f"stats-{nid}.json")
    node_entry = dict(nodes[nid])
    roster = roster_load(deps["roster_path"])
    affected = {pid: p for pid, p in roster["peers"].items()
                if any(t.get("node") == nid for t in p.get("targets", []))}
    _archive_node(deps, nid, nm, node_entry, affected, sf)   # back up BEFORE purging (moves stats/health out)
    mesh_unlink_node(nodes, nid)                              # tear down this node's mesh links on every survivor
    del nodes[nid]
    nodes_save(deps["nodes_path"], nodes)
    changed = False
    for pid in list(roster["peers"].keys()):
        p = roster["peers"][pid]
        kept = [t for t in p.get("targets", []) if t.get("node") != nid]
        if len(kept) != len(p.get("targets", [])):
            changed = True
            if kept:
                p["targets"] = kept; p["modified_at"] = int(time.time())
            else:
                del roster["peers"][pid]
    if changed:
        roster_save(deps["roster_path"], roster)
    (deps.get("node_snaps") or {}).pop(nid, None)
    (deps.get("node_seen") or {}).pop(nid, None)
    sd = deps.get("stats_dir")            # _archive_node moved these out; unlink any leftover
    if sd:
        with contextlib.suppress(OSError):
            os.unlink(os.path.join(sd, sf))
        with contextlib.suppress(OSError):
            os.unlink(os.path.join(sd, f"health-{nid}.rrd"))
    ev_append(deps["roster_path"], "node", nid, "Removed node", nm)
    return nm


def desired_for_node(roster, node_id):
    """The peer set the roster assigns to one node, grouped by interface.

    Derived entirely from peers→targets: a node may serve several interfaces
    (e.g. awg100 + wg99); each target names the (node, iface, ip) it lands on, so
    we never push a peer onto the wrong one. The wire shape is unchanged from the
    flat-roster era — a node still receives
        { "<iface>": [ {public_key, allowed_ips, preshared_key, name}, ... ] }
    — so swg-noded / swg-agent are untouched by the schema change.
    """
    users = roster.get("users") or {}
    out = {}
    for p in (roster.get("peers") or {}).values():
        if not isinstance(p, dict):
            continue
        uname = (users.get(p.get("user_id")) or {}).get("name", "")
        # node-side label (a .conf comment): "user · title" so the operator can tell devices apart
        name = " · ".join(x for x in (uname, p.get("title", "")) if x)
        for t in p.get("targets", []):
            if t.get("node") != node_id:
                continue
            iface = t.get("iface") or ""
            if not iface:
                continue
            ip = (t.get("ip") or "").split("/")[0]
            out.setdefault(iface, []).append({
                "public_key": p.get("pubkey"),
                "allowed_ips": (ip + "/32") if ip else "",
                "preshared_key": p.get("psk") or "none",
                "name": name,
            })
    return out


