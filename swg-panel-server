    if method == "POST" and path == "/api/events/clear":
        ev_clear(roster_path)
        return 200, {"ok": True, "data": {"cleared": True}}

    if method == "GET" and path == "/api/node-history":
        node = (qs.get("node") or [""])[0]
        rng = (qs.get("range") or ["live"])[0]
        if not known(node):
            return 400, {"ok": False, "error": f"unknown node {node!r}", "code": "bad_request"}
        rrd = os.path.join(stats_dir, f"health-{node}.rrd") if stats_dir else None
        # each range = one ring's most-recent points: hour=15s(250) day=5min(300) week=30min(350) month=2h(400).
        # live also comes straight off the 15s ring as a fallback (the SPA prefers the raw 5s buffer).
        spec = RANGE_SPEC.get(rng)
        if not spec:
            return 400, {"ok": False, "error": "range must be live|hour|day|week|month", "code": "bad_request"}
        ring, want, win = spec
        data = hrrd_read(rrd, ring=ring, want=want, since=time.time() - win) if rrd else None
        return 200, {"ok": True, "data": data or {"t": [], "cpu": [], "mem": [], "disk": [], "rx": [], "tx": []}}

    # Per-entity throughput SERIES (on-demand; never in /api/state → 5s hot path untouched). {t,rx,tx} from the
    # entity's own RRD ring. Interface = per-(node,iface); turn = per-(node,fork); mesh = per link (this node's view).
    if method == "GET" and path == "/api/iface-series":
        node = (qs.get("node") or [""])[0]; ifn = (qs.get("iface") or [""])[0]
        if not known(node) or not ifn:
            return 400, {"ok": False, "error": "node and iface required", "code": "bad_request"}
        s = _rrd_series(iface_rrd_path(stats_dir, node, ifn) if stats_dir else None, (qs.get("range") or ["live"])[0])
        if s is None:
            return 400, {"ok": False, "error": "range must be live|hour|day|week|month", "code": "bad_request"}
        return 200, {"ok": True, "data": s}

    if method == "GET" and path == "/api/turn-series":
        node = (qs.get("node") or [""])[0]; fork = (qs.get("fork") or [""])[0]
        if not known(node) or not fork:
            return 400, {"ok": False, "error": "node and fork required", "code": "bad_request"}
        s = _rrd_series(turn_rrd_path(stats_dir, node, fork) if stats_dir else None, (qs.get("range") or ["live"])[0])
        if s is None:
            return 400, {"ok": False, "error": "range must be live|hour|day|week|month", "code": "bad_request"}
        return 200, {"ok": True, "data": s}

    if method == "GET" and path == "/api/mesh-series":
        node = (qs.get("node") or [""])[0]; peer = (qs.get("peer") or [""])[0]
        if not known(node) or not known(peer):
            return 400, {"ok": False, "error": "node and peer required", "code": "bad_request"}
        s = _rrd_series(mesh_rrd_path(stats_dir, node, peer) if stats_dir else None, (qs.get("range") or ["live"])[0])
        if s is None:
            return 400, {"ok": False, "error": "range must be live|hour|day|week|month", "code": "bad_request"}
        if node < peer:                              # RRD stores rx = x→y (x<y). node is x → its INbound is y→x = tx: swap so rx = into-node.
            s = {"t": s["t"], "rx": s["tx"], "tx": s["rx"]}
        return 200, {"ok": True, "data": s}

    if method == "GET" and path == "/api/turn-ips":
        # Unique client source IPs seen connecting to each node's turn-proxies. Merges the stored history (first/last
        # seen + which proxies) with the LIVE snapshot (active_by = proxies currently reporting the IP). On-demand only.
        store = deps.get("turn_ips") or {}
        out = {}
        for nid in nodes:
            cur = {}                                     # ip -> set(services currently established)
            for tp in ((snaps.get(nid) or {}).get("turn_proxies") or []):
                for ip in (tp.get("src_ips") or []):
                    cur.setdefault(ip, set()).add(tp.get("service") or "")
            recs = store.get(nid) or {}
            merged = {}
            for ip in set(recs) | set(cur):
                r = recs.get(ip) or {}
                merged[ip] = {"first": r.get("first"), "last": r.get("last"),
                              "by": sorted(set(r.get("by") or []) | cur.get(ip, set())),
                              "active_by": sorted(x for x in cur.get(ip, set()) if x)}
            if merged:
                out[nid] = merged
        return 200, {"ok": True, "data": {"nodes": out}}

    if method == "POST" and path == "/api/turn-ips/flush":
        # Drop collected IP history, KEEPING the ones currently established (online). node="" → whole fleet.
        # With `ip` set, delete just that one record (the grid's ✕) instead of the whole inactive set.
        nid = (body.get("node") or "").strip(); one = (body.get("ip") or "").strip(); svc = (body.get("service") or "").strip()
        store = deps.setdefault("turn_ips", {})
        removed = 0
        if one:                                          # grid ✕ — delete one record
            if (store.get(nid) or {}).pop(one, None) is not None:
                removed = 1
        elif svc:                                        # bubble Flush — drop THIS proxy's offline IPs (keep online); un-tag shared ones
            recs = store.get(nid) or {}
            cur = set()
            for tp in ((snaps.get(nid) or {}).get("turn_proxies") or []):
                if (tp.get("service") or "") == svc:
                    cur.update(tp.get("src_ips") or [])
            for ip in list(recs):
                rec = recs[ip]
                if svc in (rec.get("by") or []) and ip not in cur:
                    rec["by"] = [s for s in rec["by"] if s != svc]
                    removed += 1
                    if not rec["by"]:
                        recs.pop(ip, None)
        else:                                            # whole node / fleet — drop inactive (keep online)
            for tn in ([nid] if nid else list(store.keys())):
                recs = store.get(tn) or {}
                cur = set()
                for tp in ((snaps.get(tn) or {}).get("turn_proxies") or []):
                    cur.update(tp.get("src_ips") or [])
                keep = {ip: r for ip, r in recs.items() if ip in cur}
                removed += len(recs) - len(keep)
                store[tn] = keep
        with contextlib.suppress(Exception):
            atomic_write(_turn_ips_path(deps), json.dumps(store))
        return 200, {"ok": True, "data": {"removed": removed}}

    if method == "GET" and path == "/api/mesh-history":
        # Per node-PAIR directed mesh flow over a range — drives the flow-map ranges. Reads each pair's tiny ring
        # (rx slot = a→b, tx slot = b→a) and returns the MEAN rate over the window (the map shows one value/edge).
        rng = (qs.get("range") or ["day"])[0]
        spec = RANGE_SPEC.get(rng)
        if not spec:
            return 400, {"ok": False, "error": "range must be live|hour|day|week|month", "code": "bad_request"}
        ring, want, win = spec
        mean = lambda xs: (round(sum(xs) / len(xs)) if xs else 0)
        pairs, seen = [], set()
        for anid, c in nodes.items():
            for peer in (c.get("links") or {}):
                if peer not in nodes:
                    continue
                a, b = sorted((anid, peer)); key = f"{a}|{b}"
                if key in seen:
                    continue
                seen.add(key)
                d = hrrd_read(mesh_rrd_path(stats_dir, a, b), ring=ring, want=want, since=time.time() - win) if stats_dir else None
                pairs.append({"a": a, "b": b, "ab": mean((d or {}).get("rx") or []), "ba": mean((d or {}).get("tx") or [])})
        return 200, {"ok": True, "data": {"range": rng, "pairs": pairs}}

    if method == "GET" and path == "/api/presence":
        # DISTINCT peers/users seen online over a range — drives the Online-peers bars, the node cards' "N users",
        # and the "online" figure in the peers doughnuts. Everything here is a SET UNION over per-bucket sets of
        # pubkeys; nothing is a mean or a max, so an idle-but-connected peer is counted and a peer that reconnects
        # twice is counted once.
        #
        # Two sources, unioned per (node, bucket):
        #   (a) the presence bitmaps — authoritative, recorded from each peer's `online` flag.
        #   (b) the per-peer TRAFFIC rings — a peer that moved bytes in a bucket was certainly online then.
        # (b) exists because the presence rings only start recording when the panel is upgraded: without it every
        # historical range reads 0 while the traffic charts show gigabytes from last week. It is a LOWER BOUND
        # (peer rings skip peers under PEER_MIN_BPS, so an idle-but-connected peer is invisible to it), which is
        # exactly why (a) supersedes it going forward rather than replacing it.
        rng = (qs.get("range") or ["day"])[0]
        spec = RANGE_SPEC.get(rng)
        if not spec:
            return 400, {"ok": False, "error": "range must be live|hour|day|week|month", "code": "bad_request"}
        ring, want, win = spec
        try:
            nblocks = max(1, min(64, int((qs.get("blocks") or ["24"])[0])))
            bstep = max(HRRD_RINGS[0][0], int((qs.get("step") or [str(win // 24)])[0]))
        except ValueError:
            return 400, {"ok": False, "error": "blocks/step must be integers", "code": "bad_request"}
        want_nodes = [n for n in ((qs.get("nodes") or [""])[0].split(",")) if n] or list(nodes.keys())
        want_nodes = [n for n in want_nodes if n in nodes]

        idx = {}
        with contextlib.suppress(Exception):
            idx = json.loads(open(pres_index_path(stats_dir)).read()) if stats_dir else {}
        bit2pk = {b: pk for pk, b in idx.items()}
        _ros = roster_load(roster_path)
        users_by_id = _ros.get("users") or {}
        peers_by_pk, h2pk = {}, {}
        for p in (_ros.get("peers") or {}).values():
            pk = p.get("pubkey")
            if pk:
                peers_by_pk[pk] = p
                h2pk[hashlib.sha256(pk.encode()).hexdigest()[:16]] = pk

        end = time.time()
        start = end - nblocks * bstep                       # the bars span exactly what they claim to
        floor = min(start, end - win)
        seen = {nid: {} for nid in want_nodes}              # nid -> {bucket_epoch: set(pubkey)}

        # (a) presence bitmaps
        for nid in want_nodes:
            if not stats_dir:
                break
            for ep, bm in pres_scan(pres_path(stats_dir, nid), ring, since=floor):
                s = seen[nid].setdefault(ep, set())
                for bit in _bm_bits(bm):
                    pk = bit2pk.get(bit)
                    if pk:
                        s.add(pk)

        # (b) per-peer traffic rings (the same files /api/peer-history reads, so no new scan cost class)
        try:
            files = os.listdir(stats_dir) if stats_dir else []
        except OSError:
            files = []
        for fn in files:
            if not (fn.startswith("peer-") and fn.endswith(".rrd")):
                continue
            body = fn[5:-4]
            if "-" not in body:
                continue
            nid, h = body.rsplit("-", 1)
            if nid not in seen:
                continue
            pk = h2pk.get(h)
            if not pk:
                continue                                    # orphaned ring → deleted peer
            d = hrrd_read(os.path.join(stats_dir, fn), ring=ring, want=want, since=floor)
            if not d:
                continue
            for t, rx, tx in zip(d["t"], d["rx"], d["tx"]):
                if (rx or 0) + (tx or 0) > 0:
                    seen[nid].setdefault(t, set()).add(pk)

        blocks = [set() for _ in range(nblocks)]
        per_node = {nid: set() for nid in want_nodes}
        total = set()
        for nid, buckets in seen.items():
            for ep, pks in buckets.items():
                if ep >= end - win:                         # range totals use the FULL window …
                    per_node[nid] |= pks; total |= pks
                b = int((ep - start) // bstep)
                if 0 <= b < nblocks:
                    blocks[b] |= pks                        # … a bar, only what falls inside that bar

        def live(pks):
            """Pubkeys that still map to a roster peer. A deleted peer keeps its bit/ring — counting it would
            resurrect it in historical bars."""
            for pk in pks:
                pr = peers_by_pk.get(pk)
                if pr:
                    yield pr

        def summarise(pks, nid=None):
            uids, ifc, npeers = {}, {}, 0
            for pr in live(pks):
                npeers += 1
                uid = pr.get("user_id") or "_un"            # mirrors onlineUserRows: all unassigned = one group
                uids[uid] = uids.get(uid, 0) + 1
                if nid:
                    for t in (pr.get("targets") or []):
                        if t.get("node") == nid and t.get("iface"):
                            ifc[t["iface"]] = ifc.get(t["iface"], 0) + 1
            rows = sorted(({"id": None if u == "_un" else u, "unassigned": u == "_un",
                            "name": "Unassigned" if u == "_un" else ((users_by_id.get(u) or {}).get("name") or "(unnamed)"),
                            "count": c} for u, c in uids.items()), key=lambda r: -r["count"])[:50]
            return {"peers": npeers, "users": len(uids), "ifaces": ifc, "userRows": rows}

        out_nodes = {nid: summarise(pks, nid) for nid, pks in per_node.items()}
        tot = summarise(total)
        return 200, {"ok": True, "data": {
            "range": rng, "step": bstep, "start": int(start), "end": int(end),
            "blocks": [sum(1 for _ in live(b)) for b in blocks],
            "nodes": out_nodes, "total": {"peers": tot["peers"], "users": tot["users"]}}}

    if method == "GET" and path == "/api/category-history":
        # Per-(node,category) destination traffic over a range — drives the "Traffic by category" doughnut. Reads
        # each cat-<nid>-<cat>.rrd (up slot = rx, dn slot = tx) → MEAN rate over the window; the SPA converts to
        # volume (× window secs) and sums across the selected nodes. Category ids are sanitised → no '-', so the
        # filename splits on the LAST '-' even when a node id contains one.
        rng = (qs.get("range") or ["day"])[0]
        spec = RANGE_SPEC.get(rng)
        if not spec:
            return 400, {"ok": False, "error": "range must be live|hour|day|week|month", "code": "bad_request"}
        ring, want, win = spec
        step = HRRD_RINGS[ring][0]                              # seconds/bucket → volume = Σ(per-bucket mean B/s)·step
        vol = lambda xs: int(sum(xs or []) * step)
        out = []
        try:
            files = os.listdir(stats_dir) if stats_dir else []
        except OSError:
            files = []
        for fn in files:
            if not (fn.startswith("cat-") and fn.endswith(".rrd")):
                continue
            body = fn[4:-4]
            if "-" not in body:
                continue
            nid, cat = body.rsplit("-", 1)
            if nid not in nodes:
                continue
            d = hrrd_read(os.path.join(stats_dir, fn), ring=ring, want=want, since=time.time() - win)
            if d:
                out.append({"node": nid, "cat": cat, "up": vol(d.get("rx")), "dn": vol(d.get("tx"))})   # total bytes over the window
        return 200, {"ok": True, "data": {"range": rng, "cats": out}}

    if method == "GET" and path == "/api/turn-history":
        # Per-(node,fork) turn-proxy stats over a range — drives the "by turn-proxy" doughnuts. Reads each
        # turn-<nid>-<fork>.rrd (rx/tx slots = throughput, pon/ptot = peers online/total). Fork ids are
        # sanitised → no '-', so the filename splits on the LAST '-'.
        #
        # rx/tx are SUMMED into a volume; pon/ptot must therefore NOT be meaned. Averaging a headcount over the
        # window divides by every idle bucket: a proxy that carried one peer for ten minutes of a day read
        # `mean(pon) = 0.003` → rounded to 0, and the card showed "0 / 0 peers" beside 72 MB of its traffic.
        # `peak` (max over the in-window buckets) is the honest scalar a single ring can give — it is a lower
        # bound on the distinct peers seen, and never zero when the proxy actually carried someone.
        rng = (qs.get("range") or ["day"])[0]
        spec = RANGE_SPEC.get(rng)
        if not spec:
            return 400, {"ok": False, "error": "range must be live|hour|day|week|month", "code": "bad_request"}
        ring, want, win = spec
        step = HRRD_RINGS[ring][0]
        vol = lambda xs: int(sum(xs or []) * step)
        peak = lambda xs: (max(xs) if xs else 0)
        out = []
        try:
            files = os.listdir(stats_dir) if stats_dir else []
        except OSError:
            files = []
        for fn in files:
            if not (fn.startswith("turn-") and fn.endswith(".rrd")):
                continue
            body = fn[5:-4]
            if "-" not in body:
                continue
            nid, fork = body.rsplit("-", 1)
            if nid not in nodes:
                continue
            d = hrrd_read(os.path.join(stats_dir, fn), ring=ring, want=want, since=time.time() - win)
            if d:
                out.append({"node": nid, "fork": fork, "rx": vol(d.get("rx")), "tx": vol(d.get("tx")),
                            "pon": peak(d.get("pon")), "ptot": peak(d.get("ptot"))})
        return 200, {"ok": True, "data": {"range": rng, "turn": out}}

    if method == "GET" and path == "/api/peer-history":
        # Per-(node,peer) throughput over a range — drives the ranged Top-talkers. Reads each peer-<nid>-<hash>.rrd,
        # reverses the pubkey hash via the roster (orphaned files → deleted peers → unlinked), and returns only the
        # top-N peers by fleet-total volume so the scan/payload stays bounded. The SPA sums per selected node + ranks.
        rng = (qs.get("range") or ["day"])[0]
        spec = RANGE_SPEC.get(rng)
        if not spec:
            return 400, {"ok": False, "error": "range must be live|hour|day|week|month", "code": "bad_request"}
        ring, want, win = spec
        step = HRRD_RINGS[ring][0]
        vol = lambda xs: int(sum(xs or []) * step)
        h2pk = {}
        for p in (roster_load(roster_path).get("peers") or {}).values():
            pk = p.get("pubkey")
            if pk:
                h2pk[hashlib.sha256(pk.encode()).hexdigest()[:16]] = pk
        try:
            files = os.listdir(stats_dir) if stats_dir else []
        except OSError:
            files = []
        rows = []
        for fn in files:
            if not (fn.startswith("peer-") and fn.endswith(".rrd")):
                continue
            body = fn[5:-4]
            if "-" not in body:
                continue
            nid2, hsh = body.rsplit("-", 1)
            if nid2 not in nodes:
                continue
            pk = h2pk.get(hsh)
            if not pk:                                             # orphan (peer deleted) — housekeep + skip
                with contextlib.suppress(Exception):
                    os.unlink(os.path.join(stats_dir, fn))
                continue
            d = hrrd_read(os.path.join(stats_dir, fn), ring=ring, want=want, since=time.time() - win)
            if d:
                rows.append({"node": nid2, "pubkey": pk, "rx": vol(d.get("rx")), "tx": vol(d.get("tx"))})
        tot = {}
        for r in rows:
            tot[r["pubkey"]] = tot.get(r["pubkey"], 0) + r["rx"] + r["tx"]
        keep = set(sorted(tot, key=lambda k: -tot[k])[:PEER_TOPN])   # only the top-N talkers' rows travel to the SPA
        rows = [r for r in rows if r["pubkey"] in keep]
        return 200, {"ok": True, "data": {"range": rng, "peers": rows}}

    if method == "GET" and path == "/api/next-ip":
        sel = [n for n in (qs.get("nodes") or [""])[0].split(",") if n]
        iface = (qs.get("iface") or [""])[0]
        if not sel or not iface:
            return 400, {"ok": False, "error": "need nodes and iface", "code": "bad_request"}
        bad = [n for n in sel if not known(n)]
        if bad:
            return 400, {"ok": False, "error": f"unknown node(s): {', '.join(bad)}", "code": "bad_request"}
        r = panel_next_ip(snaps, roster_load(roster_path), sel, iface)
        return (200 if r.get("ok") else 400), r

    # ─────────────── users (identity) ───────────────

    if method == "POST" and path == "/api/users/create":
        name = (body.get("name") or "").strip()
        if not name:
            return 400, {"ok": False, "error": "name is required", "code": "bad_request"}
        roster = roster_load(roster_path)
        uid = gen_id()
        while uid in roster["users"]:
            uid = gen_id()
        u = user_set(roster, uid, {"name": name, "tag": (body.get("tag") or "").strip(),
                                   "note": body.get("note", "")}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "user", uid, "Created user", name)
        return 200, {"ok": True, "data": u}

    if method == "POST" and path == "/api/users/update":
        uid = body.get("id") or ""
        roster = roster_load(roster_path)
        if uid not in roster["users"]:
            return 404, {"ok": False, "error": "unknown user", "code": "not_found"}
        fields = {}
        for k in ("name", "tag", "note"):
            if k in body:
                v = body[k]
                fields[k] = v.strip() if (isinstance(v, str) and k != "note") else v
        if "name" in fields and not fields["name"]:
            return 400, {"ok": False, "error": "name cannot be empty", "code": "bad_request"}
        renamed = "name" in fields
        u = user_set(roster, uid, fields, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "user", uid, "Renamed user" if renamed else "Updated user",
                  u.get("name", ""), "" if renamed else ", ".join(sorted(fields)) or "")
        return 200, {"ok": True, "data": u}

    if method == "POST" and path == "/api/users/delete":
        uid = body.get("id") or ""
        roster = roster_load(roster_path)
        if uid not in roster["users"]:
            return 404, {"ok": False, "error": "unknown user", "code": "not_found"}
        # Deleting a user never silently wipes their peers — they go unassigned. But each
        # is PSK-rotated so the (now ex-)user's saved configs stop working immediately.
        uname = (roster["users"][uid] or {}).get("name", "")
        freed = 0
        for p in roster["peers"].values():
            if p.get("user_id") == uid:
                unassign_peer(p, store_configs, config_dir, now()); freed += 1
        del roster["users"][uid]
        roster_save(roster_path, roster)
        ev_append(roster_path, "user", uid, "Deleted user", uname,
                  f"{freed} peer{'' if freed == 1 else 's'} unassigned" if freed else "")
        return 200, {"ok": True, "data": {"id": uid, "unassigned_peers": freed}}

    # ─────────────── peers (credential + targets) ───────────────

    if method == "POST" and path == "/api/peers/create":
        # Mint a NEW credential (own key + PSK) and deploy it to one or more targets in a
        # single atomic write. Accepts targets:[{node,iface,ip}, ...]; a lone `target` is
        # still honoured. Per-target client configs come in body.configs keyed "node|iface".
        pubkey = (body.get("pubkey") or "").strip()
        targets = body.get("targets")
        if not isinstance(targets, list) or not targets:
            t = body.get("target")
            targets = [t] if t else []
        if not pubkey:
            return 400, {"ok": False, "error": "pubkey is required", "code": "bad_request"}
        if not targets:
            return 400, {"ok": False, "error": "at least one target is required", "code": "bad_request"}
        for t in targets:
            for f in ("node", "iface", "ip"):
                if not (t or {}).get(f):
                    return 400, {"ok": False, "error": f"target.{f} is required", "code": "bad_request"}
            if not known(t["node"]):
                return 400, {"ok": False, "error": f"unknown node {t['node']!r}", "code": "bad_request"}
            if is_system_iface(deps, nodes, t["node"], t["iface"]):
                return 400, {"ok": False, "error": f"{t['iface']} is a system mesh link — not a peer interface", "code": "system_iface"}
        seen = set()
        for t in targets:
            k = (t["node"], t["iface"])
            if k in seen:
                return 400, {"ok": False, "error": f"duplicate target {t['node']}/{t['iface']}", "code": "bad_request"}
            seen.add(k)
        be = bad_targets(targets)
        if be:
            return 400, {"ok": False, "error": be, "code": "bad_request"}
        roster = roster_load(roster_path)
        if find_peer_by_pubkey(roster, pubkey):
            return 409, {"ok": False, "error": "a peer with this key already exists "
                         "(use add-target to deploy it elsewhere)", "code": "exists"}
        uid = body.get("user_id")
        if uid and uid not in roster["users"]:
            return 400, {"ok": False, "error": "unknown user", "code": "bad_request"}
        for t in targets:
            if not t.get("type"):
                t["type"] = iface_type(snaps, t["node"], t["iface"])
        psk = body.get("psk") or gen_psk()      # PSK is panel-owned; auto-mint when the client omits one
        pid = gen_id()
        while pid in roster["peers"]:
            pid = gen_id()
        p = peer_set(roster, pid, {"user_id": uid or None, "title": strip_ctrl(body.get("title", "")),
                                   "pubkey": pubkey, "psk": psk, "targets": targets}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Created peer", peer_label(roster, p),
                  f"{len(targets)} target{'' if len(targets) == 1 else 's'} · {targets[0]['node']}/{targets[0]['iface']}")
        webhook_emit(deps, "peer.added", {"peer_id": pid, "title": p.get("title") or None,
                     "user": (roster["users"].get(uid) or {}).get("name") if uid else None,
                     "targets": [{"node": t["node"], "iface": t["iface"], "address": t.get("ip")} for t in targets]})
        configs = body.get("configs") or {}
        for t in targets:
            conf = configs.get(t["node"] + "|" + t["iface"])
            if conf is None and len(targets) == 1:
                conf = body.get("config")   # single-target back-compat
            save_config(store_configs, config_dir, pubkey, t["node"], t["iface"], conf)
        return 200, {"ok": True, "data": p}

    if method == "POST" and path == "/api/peers/add-target":
        # "Copy peer interface→interface" — SAME key + SAME PSK on a new (node, iface, ip).
        pid = body.get("peer_id") or ""
        target = body.get("target") or {}
        for f in ("node", "iface", "ip"):
            if not target.get(f):
                return 400, {"ok": False, "error": f"target.{f} is required", "code": "bad_request"}
        if not known(target["node"]):
            return 400, {"ok": False, "error": f"unknown node {target['node']!r}", "code": "bad_request"}
        if is_system_iface(deps, nodes, target["node"], target["iface"]):
            return 400, {"ok": False, "error": f"{target['iface']} is a system mesh link — not a peer interface", "code": "system_iface"}
        if not valid_addr(target["ip"]):
            return 400, {"ok": False, "error": f"invalid address {target['ip']!r}", "code": "bad_request"}
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        if any(t["node"] == target["node"] and t["iface"] == target["iface"] for t in p["targets"]):
            return 409, {"ok": False, "error": "peer already has a target on that node/interface",
                         "code": "exists"}
        if not target.get("type"):
            target["type"] = iface_type(snaps, target["node"], target["iface"])
        p2 = peer_set(roster, pid, {"targets": p["targets"] + [target]}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Added deployment", peer_label(roster, p2),
                  f"{target['node']}/{target['iface']}")
        save_config(store_configs, config_dir, p["pubkey"], target["node"], target["iface"], body.get("config"))
        return 200, {"ok": True, "data": p2}

    if method == "POST" and path == "/api/peers/remove-target":
        pid = body.get("peer_id") or ""
        node = body.get("node") or ""; iface = body.get("iface") or ""
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        kept = [t for t in p["targets"] if not (t["node"] == node and t["iface"] == iface)]
        if not kept:
            # Never silently delete via the last target — deletion is an explicit, gated act
            # (and only for unassigned peers). Caller must use peers/delete instead.
            return 409, {"ok": False, "error": "this is the peer's only deployment — "
                         "delete the peer instead (unassign it first)", "code": "last_target"}
        del_config(store_configs, config_dir, p["pubkey"], node, iface)
        retire_pubkey(nodes, deps["nodes_path"], [{"node": node, "iface": iface}], p["pubkey"])   # drop it even on add-only ifaces
        p2 = peer_set(roster, pid, {"targets": kept}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Removed deployment", peer_label(roster, p2),
                  f"{node}/{iface}")
        return 200, {"ok": True, "data": p2}

    if method == "POST" and path == "/api/peers/update":
        # Edit a peer's operator-facing label (title) and/or owner (user_id). Metadata only —
        # the key/PSK/config are untouched, so assigning an unassigned peer keeps the credential
        # it already has (a config that's been handed out keeps working). Reassigning a peer
        # between users (which must rotate keys) goes through /api/peers/rekey instead.
        pid = body.get("peer_id") or ""
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        changed = {}
        if "title" in body:
            changed["title"] = strip_ctrl(body.get("title", ""))
        if "user_id" in body:
            uid = body.get("user_id")
            if uid and uid not in roster["users"]:
                return 400, {"ok": False, "error": "unknown user", "code": "bad_request"}
            changed["user_id"] = uid or None
        if not changed:
            return 400, {"ok": False, "error": "nothing to update", "code": "bad_request"}
        p2 = peer_set(roster, pid, changed, now())
        roster_save(roster_path, roster)
        if "title" in changed:
            ev_append(roster_path, "peer", pid, "Renamed peer", peer_label(roster, p2))
        if "user_id" in changed:
            ev_append(roster_path, "peer", pid,
                      "Assigned peer" if changed["user_id"] else "Unassigned peer", peer_label(roster, p2))
        return 200, {"ok": True, "data": p2}

    if method == "POST" and path == "/api/peers/update-target":
        # Change a target's assigned address — a real connectivity change (its allowed_ips moves),
        # reconciled to the node on the next sync. Validates the IP and guards against a collision
        # with another peer on the same interface.
        pid = body.get("peer_id") or ""
        node = body.get("node") or ""; iface = body.get("iface") or ""
        ip = (body.get("ip") or "").split("/")[0].strip()
        if not valid_addr(ip):
            return 400, {"ok": False, "error": f"invalid address {body.get('ip')!r}", "code": "bad_request"}
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        if not any(t["node"] == node and t["iface"] == iface for t in p["targets"]):
            return 404, {"ok": False, "error": "peer has no target on that node/interface", "code": "not_found"}
        for op in roster["peers"].values():     # uniqueness within the (node, iface) subnet
            if op.get("id") == pid:
                continue
            for t in op.get("targets", []):
                if t.get("node") == node and t.get("iface") == iface and (t.get("ip") or "").split("/")[0] == ip:
                    return 409, {"ok": False, "error": f"{ip} is already used on {node}/{iface}", "code": "exists"}
        targets = [dict(t, ip=ip) if (t["node"] == node and t["iface"] == iface) else t for t in p["targets"]]
        p2 = peer_set(roster, pid, {"targets": targets}, now())
        roster_save(roster_path, roster)
        if isinstance(body.get("config"), str) and body["config"]:
            save_config(store_configs, config_dir, p["pubkey"], node, iface, body["config"])
        ev_append(roster_path, "peer", pid, "Changed address", peer_label(roster, p2), f"{node}/{iface} → {ip}")
        return 200, {"ok": True, "data": p2}

    if method == "POST" and path == "/api/peers/delete":
        pid = body.get("peer_id") or ""
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        if p.get("user_id"):
            # Deletion is for unassigned peers only — unassign first (which also revokes the
            # holder by rotating the PSK). Keeps an assigned peer from vanishing in one click.
            return 409, {"ok": False, "error": "peer is assigned to a user — unassign it first",
                         "code": "assigned"}
        label = peer_label(roster, p)
        ntargets = len(p.get("targets") or [])
        for t in p["targets"]:
            del_config(store_configs, config_dir, p["pubkey"], t["node"], t["iface"])
        retire_pubkey(nodes, deps["nodes_path"], p.get("targets", []), p["pubkey"])   # drop it even on add-only ifaces
        _tgts = [{"node": t.get("node"), "iface": t.get("iface"), "address": t.get("ip")} for t in (p.get("targets") or [])]
        del roster["peers"][pid]
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Deleted peer", label,
                  ("%d target%s" % (ntargets, "" if ntargets == 1 else "s")) if ntargets else "")
        webhook_emit(deps, "peer.removed", {"peer_id": pid, "title": p.get("title") or None, "targets": _tgts})
        return 200, {"ok": True, "data": {"id": pid, "deleted": True}}

    if method == "POST" and path == "/api/peers/unassign":
        # Detach from the user and REVOKE the old holder (rotate PSK). Server-side, no
        # browser needed — used directly, and as the first half of a reassignment.
        pid = body.get("peer_id") or ""
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        label = peer_label(roster, p)
        former = ((roster.get("users") or {}).get(p.get("user_id")) or {}).get("name", "") if p.get("user_id") else ""
        unassign_peer(p, store_configs, config_dir, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Unassigned peer", p.get("title") or label,
                  ("was " + former) if former else "")
        return 200, {"ok": True, "data": p}

    if method == "POST" and path == "/api/peers/rekey":
        # Assign a peer to a user with a FRESH credential. The browser mints a new keypair
        # + PSK and rebuilds the config for every target, so the new owner gets a working
        # config and never inherits a key a previous owner could still hold. Used for both
        # first assignment (unassigned -> user) and reassignment (after unassign).
        pid = body.get("peer_id") or ""
        uid = body.get("user_id") or ""
        pubkey = (body.get("pubkey") or "").strip()
        if not pubkey:
            return 400, {"ok": False, "error": "pubkey is required (reassignment mints a fresh key)",
                         "code": "bad_request"}
        roster = roster_load(roster_path)
        p = roster["peers"].get(pid)
        if not p:
            return 404, {"ok": False, "error": "unknown peer", "code": "not_found"}
        if uid and uid not in roster["users"]:   # empty uid is allowed — rotate keeps it unassigned
            return 400, {"ok": False, "error": "unknown user", "code": "bad_request"}
        clash = find_peer_by_pubkey(roster, pubkey)
        if clash and clash["id"] != pid:
            return 409, {"ok": False, "error": "another peer already uses this key", "code": "exists"}
        old_pubkey = p.get("pubkey", "")
        if old_pubkey and old_pubkey != pubkey:
            for t in p.get("targets", []):
                del_config(store_configs, config_dir, old_pubkey, t["node"], t["iface"])
            retire_pubkey(nodes, deps["nodes_path"], p.get("targets", []), old_pubkey)   # drop the old key even on add-only ifaces
        psk = body.get("psk") or gen_psk()
        p2 = peer_set(roster, pid, {"user_id": uid or None, "pubkey": pubkey, "psk": psk}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Assigned peer", peer_label(roster, p2),
                  "fresh key issued")
        configs = body.get("configs") or {}
        for t in p2["targets"]:
            save_config(store_configs, config_dir, pubkey, t["node"], t["iface"],
                        configs.get(t["node"] + "|" + t["iface"]))
        return 200, {"ok": True, "data": p2}

    if method == "POST" and path == "/api/peers/adopt":
        # Pull a peer observed on a node (an orphan) into the roster. Known key → add the
        # target to the existing credential; new key → mint a peer (unassigned by default).
        pubkey = (body.get("pubkey") or "").strip()
        target = body.get("target") or {}
        for f in ("node", "iface", "ip"):
            if not target.get(f):
                return 400, {"ok": False, "error": f"target.{f} is required", "code": "bad_request"}
        if not pubkey:
            return 400, {"ok": False, "error": "pubkey is required", "code": "bad_request"}
        if not known(target["node"]):
            return 400, {"ok": False, "error": f"unknown node {target['node']!r}", "code": "bad_request"}
        if is_system_iface(deps, nodes, target["node"], target["iface"]):
            return 400, {"ok": False, "error": f"{target['iface']} is a system mesh link — not a peer interface", "code": "system_iface"}
        if not valid_addr(target["ip"]):
            return 400, {"ok": False, "error": f"invalid address {target['ip']!r}", "code": "bad_request"}
        roster = roster_load(roster_path)
        uid = body.get("user_id")
        if uid and uid not in roster["users"]:
            return 400, {"ok": False, "error": "unknown user", "code": "bad_request"}
        if not target.get("type"):
            target["type"] = iface_type(snaps, target["node"], target["iface"])
        existing = find_peer_by_pubkey(roster, pubkey)
        if existing:
            pid = existing["id"]
            if not any(t["node"] == target["node"] and t["iface"] == target["iface"]
                       for t in existing["targets"]):
                peer_set(roster, pid, {"targets": existing["targets"] + [target]}, now())
        else:
            pid = gen_id()
            while pid in roster["peers"]:
                pid = gen_id()
            peer_set(roster, pid, {"user_id": uid or None, "pubkey": pubkey,
                                   "psk": body.get("psk") or "", "targets": [target]}, now())
        roster_save(roster_path, roster)
        ev_append(roster_path, "peer", pid, "Adopted peer", peer_label(roster, roster["peers"][pid]),
                  f"{target['node']}/{target['iface']}")
        return 200, {"ok": True, "data": roster["peers"][pid]}

    if method == "POST" and path == "/api/peers/save-config":
        # Persist a re-issued client config (e.g. after an edit). Only meaningful with
        # store_configs on; the config carries the private key, so it must match a real target.
        pubkey = (body.get("pubkey") or "").strip()
        node = body.get("node") or ""; iface = body.get("iface") or ""
        conf = body.get("config")
        if not (pubkey and node and iface and isinstance(conf, str) and conf):
            return 400, {"ok": False, "error": "need pubkey, node, iface, config", "code": "bad_request"}
        if not store_configs:
            return 400, {"ok": False, "error": "store_configs is off — nothing is persisted", "code": "disabled"}
        roster = roster_load(roster_path)
        p = find_peer_by_pubkey(roster, pubkey)
        if not p or not any(t["node"] == node and t["iface"] == iface for t in p["targets"]):
            return 404, {"ok": False, "error": "no such target for this key", "code": "not_found"}
        save_config(store_configs, config_dir, pubkey, node, iface, conf)
        return 200, {"ok": True, "data": {"pubkey": pubkey, "node": node, "iface": iface}}

    if method == "POST" and path == "/api/nodes/create":
        name = (body.get("name") or "").strip()
        if not name or len(name) > 40 or not all(c.isalnum() or c in "-_" for c in name):
            return 400, {"ok": False, "error": "name must be 1–40 chars: letters, digits, - or _",
                         "code": "bad_request"}
        nid = gen_id()
        while nid in nodes:
            nid = gen_id()
        token = base64.urlsafe_b64encode(os.urandom(18)).decode().rstrip("=")
        nodes[nid] = {"id": nid, "name": name, "color": sanitize_color(body.get("color"), {"dark": "#34d399", "light": "#12A46B"}),
                      "endpoint_host": (body.get("endpoint_host") or "").strip(),
                      "stats_file": f"stats-{nid}.json",
                      "token_hash": make_token_hash(token), "token_sha": hashlib.sha256(token.encode()).hexdigest(),
                      "created": now()}
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Enrolled node", name)
        reconcile_mesh(nodes, deps.get("node_snaps") or {}, deps)   # full-mesh link to every existing node
        nodes_save(deps["nodes_path"], nodes)
        return 200, {"ok": True, "data": {"id": nid, "name": name, "token": token}}

    if method == "POST" and path == "/api/nodes/update":
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if "name" in body:                      # name is a free-to-change display title (no refs to migrate)
            nm = (body.get("name") or "").strip()
            if not nm or len(nm) > 40 or not all(c.isalnum() or c in "-_" for c in nm):
                return 400, {"ok": False, "error": "name must be 1–40 chars: letters, digits, - or _", "code": "bad_request"}
            nodes[nid]["name"] = nm
        if "color" in body:
            nodes[nid]["color"] = sanitize_color(body.get("color"), nodes[nid].get("color"))
        if "endpoint_host" in body:
            nodes[nid]["endpoint_host"] = (body.get("endpoint_host") or "").strip()
        for k in ("default_egress_ip", "panel_ip"):   # node IP roles: SNAT source for direct egress / source to dial the panel
            if k in body:
                v = (body.get(k) or "").strip()
                if v:
                    try:
                        if ipaddress.ip_address(v).version != 4:
                            raise ValueError
                    except ValueError:
                        return 400, {"ok": False, "error": k + " must be a valid IPv4 address (or blank)", "code": "bad_request"}
                nodes[nid][k] = v
        if "routing_mode" in body:              # how THIS node adds a HOST layer on top of the always-on IP layer:
            rm = (body.get("routing_mode") or "kernel").strip()   # kernel (IP only) | forcedns (host via dnsmasq, blocks
            # client DoH) | sni (host via userspace SNI reader) | sni_kernel (host via in-kernel xt_string SNI reader).
            if rm not in ("kernel", "forcedns", "sni", "sni_kernel"):
                return 400, {"ok": False, "error": "routing_mode must be kernel|forcedns|sni|sni_kernel", "code": "bad_request"}
            nodes[nid]["routing_mode"] = rm
        if "ip_learning" in body:               # keep learned SNI IPs (True) vs stay fresh / no remembered IPs (False)
            nodes[nid]["ip_learning"] = bool(body.get("ip_learning"))
        if "enabled_categories" in body:        # built-in categories shown for THIS node's interfaces ([]/absent = all)
            ec = body.get("enabled_categories")
            if isinstance(ec, list):
                nodes[nid]["enabled_categories"] = [c for c in ec if c in SMART_CATEGORIES and c != "all"]
        if "catalog_cats" in body:              # categories the operator opted THIS node into (node-lens): provider-catalog
            cc = body.get("catalog_cats")       # ids (<prov>:<id>) AND curated built-ins (bare id) — both first-class + pullable
            if isinstance(cc, list):
                _cix = catalog_index()          # keep real catalog ids OR curated built-ins; drop unknown/"all"/custom_*
                _was = set(nodes[nid].get("catalog_cats") or [])
                nodes[nid]["catalog_cats"] = [c for c in dict.fromkeys(cc)
                                              if (c in _cix and c not in SMART_CATEGORIES) or (c in SMART_CATEGORIES and c != "all")]
                for _c in nodes[nid]["catalog_cats"]:          # newly opted-in → resolve now so its size/lists are ready (non-blocking)
                    if _c not in _was:
                        _caps = SMART_CAPS.get(_c, {}) if ":" not in _c else (_cix.get(_c) or {})
                        for _t in ("ip", "host"):
                            if _caps.get(_t) and not list_meta(_c, _t):
                                list_ensure(_c, _t)
        # per-node mesh overrides — a CHANGE re-provisions THIS node's links (it briefly drops off the mesh
        # while peers reconnect with the new config); a blank value falls back to the panel default.
        _mesh_before = (nodes[nid].get("mesh_subnet") or "", str(nodes[nid].get("mesh_port") or ""), nodes[nid].get("mesh_prefix") or "")
        if "mesh_port" in body:
            mp = (str(body.get("mesh_port") or "")).strip()
            if mp and not (mp.isdigit() and 1 <= int(mp) <= 65535):
                return 400, {"ok": False, "error": "mesh port must be 1–65535 (or blank)", "code": "bad_request"}
            nodes[nid]["mesh_port"] = int(mp) if mp else ""
        if "mesh_subnet" in body:
            ms = (body.get("mesh_subnet") or "").strip()
            if ms:
                try:
                    ipaddress.ip_network(ms, strict=False)
                except Exception:
                    return 400, {"ok": False, "error": "mesh subnet must be a CIDR (or blank)", "code": "bad_request"}
            nodes[nid]["mesh_subnet"] = ms
        if "mesh_prefix" in body:
            nodes[nid]["mesh_prefix"] = re.sub(r"[^a-z0-9_]", "", (body.get("mesh_prefix") or "").lower())[:6]
        _awg_before = sanitize_awg_params(nodes[nid].get("mesh_awg"))
        if "mesh_awg" in body:                  # per-node mesh obfuscation; links this node anchors adopt it (both ends match)
            nodes[nid]["mesh_awg"] = sanitize_awg_params(body.get("mesh_awg"))
        _mesh_after = (nodes[nid].get("mesh_subnet") or "", str(nodes[nid].get("mesh_port") or ""), nodes[nid].get("mesh_prefix") or "")
        if _mesh_after[0] != _mesh_before[0] or _mesh_after[2] != _mesh_before[2] or sanitize_awg_params(nodes[nid].get("mesh_awg")) != _awg_before:
            # subnet / PREFIX / AWG changed → the link is re-addressed / renamed / re-obfuscated: must re-provision (rebuild)
            mesh_reprovision_node(nodes, nid)
            reconcile_mesh(nodes, deps.get("node_snaps") or {}, deps)   # rebuild its links with the new config
            ev_append(roster_path, "node", nid, "Re-provisioned mesh links", nodes[nid].get("name", nid))
        elif _mesh_after[1] != _mesh_before[1]:
            # ONLY the mesh port changed → LIVE re-port, no iface rebuild: re-point each of this node's links to
            # a port off the new base, set it on the link record + the iface override. The node then changes the
            # live listen_port in place (reconcile_ifaces set-iface) and every peer re-dials the new endpoint
            # (desired_mesh_for_node carries the new port → the reconcile endpoint re-dial). No tunnel teardown.
            me = nodes[nid]; nmc = node_mesh_cfg(deps, me)
            used = {p for p in _used_ports(nodes, deps.get("node_snaps") or {}, nid)}
            for lr in (me.get("links") or {}).values():
                if str(lr.get("listen_port")).isdigit():
                    used.discard(int(lr["listen_port"]))            # free this node's current mesh ports for reassignment
            for lr in (me.get("links") or {}).values():
                np = _alloc_port(used, nmc["port_base"]); used.add(np)
                lr["listen_port"] = np
                me.setdefault("ifaces", {}).setdefault(lr.get("iface"), {})["listen_port"] = np   # push via reconcile_ifaces
            ev_append(roster_path, "node", nid, "Re-ported mesh links (live)", me.get("name", nid))
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Updated node", nodes[nid].get("name", nid))
        return 200, {"ok": True, "data": {"id": nid, "name": nodes[nid].get("name")}}

    if method == "POST" and path == "/api/node/routing-reset":   # per-node: wipe + rebuild + re-pull ALL smart-routing state
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        scope = (body.get("scope") or "all").strip()   # "learned" = clear only the node's learned-IP sets; else full wipe+rebuild+re-pull
        key = "routing_reset_learned" if scope == "learned" else "routing_reset"
        nodes[nid][key] = int(nodes[nid].get(key) or 0) + 1   # the node acts when its counter changes
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Reset learned IPs" if scope == "learned" else "Reset routing", nodes[nid].get("name", nid))
        return 200, {"ok": True, "data": {"id": nid, key: nodes[nid][key]}}

    if method == "POST" and path == "/api/connection/update":
        # per-mesh-link overrides: the local source IP this node dials FROM (dial_src), and which of the
        # peer's IPs it dials TO (dial_endpoint, overriding the peer's ingress). Changing the endpoint
        # re-dials the existing link automatically (the reconcile endpoint re-dial).
        nid = body.get("node") or ""; peer = body.get("peer") or ""
        if nid not in nodes or peer not in (nodes[nid].get("links") or {}):
            return 404, {"ok": False, "error": "unknown connection", "code": "not_found"}
        for key in ("dial_src", "dial_endpoint"):
            if key in body:
                v = (body.get(key) or "").strip()
                if v:
                    try:
                        if ipaddress.ip_address(v).version != 4:
                            raise ValueError
                    except ValueError:
                        return 400, {"ok": False, "error": key + " must be a valid IPv4 address (or blank)", "code": "bad_request"}
                nodes[nid]["links"][peer][key] = v
        nodes_save(deps["nodes_path"], nodes)
        return 200, {"ok": True, "data": {"node": nid, "peer": peer,
                                          "dial_src": nodes[nid]["links"][peer].get("dial_src", ""),
                                          "dial_endpoint": nodes[nid]["links"][peer].get("dial_endpoint", "")}}

    if method == "POST" and path == "/api/order":
        # operator drag-to-reorder. kind=node → set per-node `pos`; kind=iface/turn → a per-node order
        # list the UI overlays on the node's reported interfaces / turn-proxies. Stored in nodes.json so
        # it survives reloads (and rides along through a convert, like the rest of the node store).
        kind = (body.get("kind") or "").strip()
        order = body.get("order")
        if not isinstance(order, list):
            return 400, {"ok": False, "error": "order must be a list", "code": "bad_request"}
        order = [str(x) for x in order]
        if kind == "node":
            for i, oid in enumerate(order):
                if oid in nodes:
                    nodes[oid]["pos"] = i
        elif kind in ("iface", "turn"):
            nid = body.get("node") or ""
            if nid not in nodes:
                return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
            nodes[nid]["iface_order" if kind == "iface" else "turn_order"] = order
        else:
            return 400, {"ok": False, "error": "kind must be node|iface|turn", "code": "bad_request"}
        nodes_save(deps["nodes_path"], nodes)
        return 200, {"ok": True}

    if method == "POST" and path == "/api/iface/update":
        # Panel-side per-interface overrides: public endpoint host/port (what clients dial) and the
        # default DNS / MTU. Affects only the configs the panel emits (existing peers keep their
        # stored configs; new peers pick up the defaults). The node itself is untouched.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface:
            return 400, {"ok": False, "error": "iface is required", "code": "bad_request"}
        ov = dict((nodes[nid].get("ifaces") or {}).get(iface) or {})
        if "endpoint_host" in body:
            h = (body.get("endpoint_host") or "").strip()
            if h and (" " in h or "/" in h):
                return 400, {"ok": False, "error": "endpoint host must be a bare hostname or IP", "code": "bad_request"}
            ov["endpoint_host"] = h if h else None
            if not h:
                ov.pop("endpoint_host", None)
        if "listen_port" in body:
            raw = body.get("listen_port")
            if raw in (None, "", 0, "0"):
                ov.pop("listen_port", None)
            else:
                try:
                    p = int(raw)
                except (TypeError, ValueError):
                    return 400, {"ok": False, "error": "port must be a number", "code": "bad_request"}
                if not (1 <= p <= 65535):
                    return 400, {"ok": False, "error": "port must be 1–65535", "code": "bad_request"}
                rc = reserved_conflict(deps, nodes, nodes[nid], port=p)
                if rc:
                    return 400, {"ok": False, "error": rc, "code": "bad_request"}
                ov["listen_port"] = p
        if "dns" in body:
            dns = body.get("dns")
            if isinstance(dns, str):
                dns = [s.strip() for s in dns.split(",") if s.strip()]
            ov["dns"] = dns or []
        if "mtu" in body:
            raw = body.get("mtu")
            if raw in (None, "", 0, "0"):
                ov.pop("mtu", None)
            else:
                try:
                    m = int(raw)
                except (TypeError, ValueError):
                    return 400, {"ok": False, "error": "mtu must be a number", "code": "bad_request"}
                if not (576 <= m <= 9200):
                    return 400, {"ok": False, "error": "mtu must be 576–9200", "code": "bad_request"}
                ov["mtu"] = m
        if "awg_params" in body:
            awg = body.get("awg_params")
            if not awg:
                ov.pop("awg_params", None)
            elif isinstance(awg, dict):
                clean = {k: str(awg[k]).strip() for k in AWG_PARAM_KEYS
                         if k in awg and str(awg.get(k, "")).strip() != ""}
                if clean:
                    ov["awg_params"] = clean
                else:
                    ov.pop("awg_params", None)
            else:
                return 400, {"ok": False, "error": "awg_params must be an object", "code": "bad_request"}
        if "egress_ip" in body:                          # per-interface source/egress IP ("" = clear → MASQUERADE)
            e = (body.get("egress_ip") or "").strip()
            if e:
                try:
                    if ipaddress.ip_address(e).version != 4:
                        raise ValueError
                except ValueError:
                    return 400, {"ok": False, "error": "egress IP must be an IPv4 address", "code": "bad_request"}
                ov["egress_ip"] = e
            else:
                ov.pop("egress_ip", None)
        if "wan_iface" in body:                          # egress WAN NIC ("" = clear → auto-detect)
            w = (body.get("wan_iface") or "").strip()
            # the node splices this into an iptables rule; a shell metachar here would be RCE when a stale
            # rule is later replaced. A real NIC name (eth0, ens3, br-lan, eth0.100) passes; ; ` $ | & don't.
            if w and not _WANIF_RE.match(w):
                return 400, {"ok": False, "error": "WAN interface must be a bare device name", "code": "bad_request"}
            if w:
                ov["wan_iface"] = w
            else:
                ov.pop("wan_iface", None)
        if "egress_mode" in body:                        # direct = SNAT a NIC | forward = whole-iface cascade (P2) | smart = per-destination rules (P3)
            mode = (body.get("egress_mode") or "direct").strip()
            if mode not in ("direct", "forward", "smart"):
                return 400, {"ok": False, "error": "egress_mode must be direct|forward|smart", "code": "bad_request"}
            if mode == "forward":
                en = (body.get("egress_node") or "").strip()
                if en not in nodes or en == nid:
                    return 400, {"ok": False, "error": "egress_node must be another known node", "code": "bad_request"}
                ov["egress_mode"] = "forward"; ov["egress_node"] = en; ov.pop("routing", None)
            elif mode == "smart":
                rules, err = _validate_routing(body.get("routing"), nodes, nid, [cl.get("id") for cl in ((deps.get("panel_settings") or {}).get("custom_lists") or []) if cl.get("id")])
                if err:
                    return 400, {"ok": False, "error": err, "code": "bad_request"}
                ov["egress_mode"] = "smart"; ov["routing"] = rules; ov.pop("egress_node", None)
            else:
                ov["egress_mode"] = "direct"; ov.pop("egress_node", None); ov.pop("routing", None)
        elif "routing" in body and ov.get("egress_mode") == "smart":   # rule-only edit (mode already smart)
            rules, err = _validate_routing(body.get("routing"), nodes, nid, [cl.get("id") for cl in ((deps.get("panel_settings") or {}).get("custom_lists") or []) if cl.get("id")])
            if err:
                return 400, {"ok": False, "error": err, "code": "bad_request"}
            ov["routing"] = rules
        for k in ("listen_port", "awg_params"):     # a user-set value re-asserts: drop its drift + synced so it re-pushes
            if k in body:
                (ov.get("_synced") or {}).pop(k, None); (ov.get("_drift") or {}).pop(k, None)
        ifaces = nodes[nid].setdefault("ifaces", {})
        if ov:
            ifaces[iface] = ov
        else:
            ifaces.pop(iface, None)
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Updated interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface, "override": ov}}

    if method == "POST" and path == "/api/iface/onboard":
        # Ask a node to start managing an existing wg/awg interface the panel didn't auto-detect.
        # The node pulls this on its next sync, adds it to its config if the interface really exists,
        # and then reports it in its snapshot (which closes the request). Endpoint host is a panel-
        # side config-render override (the node only needs the tool + .conf path).
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        conf = (body.get("conf") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface or " " in iface or "/" in iface:
            return 400, {"ok": False, "error": "interface name is required (no spaces or /)", "code": "bad_request"}
        if not conf or " " in conf or not conf.startswith("/"):
            return 400, {"ok": False, "error": "an absolute config path is required", "code": "bad_request"}
        proto = (body.get("protocol") or "awg").lower()
        cmd = ["wg"] if proto == "wg" else (["auto"] if proto == "auto" else ["awg"])
        nodes[nid].setdefault("onboard", {})[iface] = {"cmd": cmd, "conf": conf}
        eh = (body.get("endpoint_host") or "").strip()
        if eh:
            nodes[nid].setdefault("ifaces", {}).setdefault(iface, {})["endpoint_host"] = eh
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Onboarding interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface}}

    if method == "POST" and path == "/api/iface/create":
        # Ask a node to create a BRAND-NEW wg/awg interface (the node genkeys + writes the conf +
        # auto-NATs + brings it up on its next sync, then manages it). Native datapath per node type.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        subnet = (body.get("subnet") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface or " " in iface or "/" in iface:
            return 400, {"ok": False, "error": "interface name is required (no spaces or /)", "code": "bad_request"}
        try:
            ipaddress.ip_network(subnet, strict=False)
        except Exception:
            return 400, {"ok": False, "error": "subnet must be a CIDR like 10.8.0.0/24", "code": "bad_request"}
        rc = reserved_conflict(deps, nodes, nodes[nid], subnet=subnet, port=body.get("listen_port"), name=iface)
        if rc:
            return 400, {"ok": False, "error": rc, "code": "bad_request"}
        cmd = ["wg"] if (body.get("protocol") or "awg").lower() == "wg" else ["awg"]
        req = {"cmd": cmd, "subnet": subnet}
        if str(body.get("listen_port") or "").isdigit():
            req["listen_port"] = int(body["listen_port"])
        if str(body.get("mtu") or "").strip():
            req["mtu"] = str(body["mtu"]).strip()
        nodes[nid].setdefault("create", {})[iface] = req
        ov = nodes[nid].setdefault("ifaces", {}).setdefault(iface, {})   # config-render overrides
        if (body.get("endpoint_host") or "").strip():
            ov["endpoint_host"] = body["endpoint_host"].strip()
        if (body.get("dns") or "").strip():
            ov["dns"] = [s.strip() for s in body["dns"].split(",") if s.strip()]   # list, like /iface/update
        if str(body.get("keepalive") or "").strip().isdigit():
            ov["keepalive"] = int(body["keepalive"])
        if (body.get("egress_ip") or "").strip():       # per-interface source/egress IP
            e = body["egress_ip"].strip()
            try:
                if ipaddress.ip_address(e).version == 4:
                    ov["egress_ip"] = e
            except ValueError:
                pass
        if (body.get("wan_iface") or "").strip():        # per-interface egress WAN NIC
            w = body["wan_iface"].strip()
            if " " not in w and "/" not in w:
                ov["wan_iface"] = w
        _cm = (body.get("egress_mode") or "direct").strip()
        if _cm == "forward":                              # cascade exit to another node (routing is Phase 2)
            en = (body.get("egress_node") or "").strip()
            if en in nodes and en != nid:
                ov["egress_mode"] = "forward"; ov["egress_node"] = en
        elif _cm == "smart":                              # per-destination smart routing (Phase 3)
            rules, err = _validate_routing(body.get("routing"), nodes, nid, [cl.get("id") for cl in ((deps.get("panel_settings") or {}).get("custom_lists") or []) if cl.get("id")])
            if err:
                return 400, {"ok": False, "error": err, "code": "bad_request"}
            ov["egress_mode"] = "smart"; ov["routing"] = rules
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Creating interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface}}

    if method == "POST" and path == "/api/iface/cancel":
        # Drop a pending create/onboard request (clears a stuck "creating"/"onboarding" card). Does
        # NOT touch anything the node already brought up — it only removes the panel-side request.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        removed = False
        for key in ("create", "onboard"):
            d = nodes[nid].get(key)
            if isinstance(d, dict) and iface in d:
                d.pop(iface, None)
                if not d:
                    nodes[nid].pop(key, None)
                removed = True
        if removed:
            nodes_save(deps["nodes_path"], nodes)
            ev_append(roster_path, "node", nid, "Cancelled interface request", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface, "removed": removed}}

    if method == "POST" and path in ("/api/iface/adopt", "/api/iface/restore"):
        # Resolve a drift (a setting edited directly on the server): ADOPT pulls the node's value into
        # the panel override (the panel stops fighting it); RESTORE re-asserts the panel's value.
        nid = body.get("node") or ""; iface = (body.get("iface") or "").strip(); key = (body.get("key") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        ov = (nodes[nid].get("ifaces") or {}).get(iface)
        if not ov or key not in (ov.get("_drift") or {}):
            return 400, {"ok": False, "error": "no pending drift for that setting", "code": "bad_request"}
        if key == "public_key":
            # the server keypair is NODE-owned (the panel never holds the private key), so this is driven
            # by a node request, not a pushed override. ADOPT re-blesses the new key + tells the node to
            # re-baseline its on-disk backup; RESTORE tells the node to revert from that backup (the drift
            # clears on its own once the node reports the original key again).
            if path.endswith("/adopt"):
                ov["public_key"] = ov["_drift"]["public_key"]
                nodes[nid].setdefault("iface_key", {})[iface] = {"action": "rebaseline", "at": int(time.time())}
                ov.get("_drift", {}).pop("public_key", None)
                if not ov.get("_drift"):
                    ov.pop("_drift", None)
                verb = "Adopted new server key on"
            else:
                nodes[nid].setdefault("iface_key", {})[iface] = {"action": "restore", "at": int(time.time())}
                verb = "Restoring original server key on"
            nodes_save(deps["nodes_path"], nodes)
            ev_append(roster_path, "node", nid, verb, iface)
            return 200, {"ok": True, "data": {"node": nid, "iface": iface, "key": key}}
        if path.endswith("/adopt"):
            ov[key] = ov["_drift"][key]                 # panel override ← the node's actual value
            ov.setdefault("_synced", {})[key] = ov[key]
            verb = "Adopted server-edited"
        else:                                           # restore → re-push the panel value
            (ov.get("_synced") or {}).pop(key, None)
            verb = "Restored panel"
        ov.get("_drift", {}).pop(key, None)
        if not ov.get("_drift"):
            ov.pop("_drift", None)
        if not ov.get("_synced"):
            ov.pop("_synced", None)
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, verb + " " + key, iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface, "key": key}}

    # ── turn-proxy management (only on nodes that report turn_manage=true) ──
    if method == "POST" and path == "/api/turn/check-updates":
        # Resolve the latest release tag for each requested fork (the SPA compares to deployed versions).
        forks = body.get("forks") if isinstance(body.get("forks"), list) else []
        latest = {}
        for f in forks[:32]:
            fid = re.sub(r"[^A-Za-z0-9_-]", "", str((f or {}).get("id") or ""))[:48]
            owner = str((f or {}).get("owner") or "").strip()
            if fid and "/" in owner:
                latest[fid] = _resolve_turn_tag(owner)
        return 200, {"ok": True, "data": {"latest": latest}}
    if method == "POST" and path == "/api/turn/install":
        # Install a NEW turn-proxy: the node downloads the fork's prebuilt binary, writes the systemd
        # unit (listen → connect, + the fork's wrap flags & a fresh key), and enables it. Keyed by the
        # service name the node will create (vk-turn-proxy-<fork>-<port>) so it self-clears on appear.
        nid = body.get("node") or ""
        fork = (body.get("fork") or "").strip()
        owner = (body.get("owner") or "").strip()
        listen = (body.get("listen") or "").strip()
        connect = (body.get("connect") or "").strip()
        wrap_flags = (body.get("wrap_flags") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        # STRICT validation — these values become a systemd unit + subprocess args on the node; a shell/heredoc
        # metacharacter here would be RCE. Legit forks/owners/ip:port/params all pass; injection payloads don't.
        if not re.match(r"^[A-Za-z0-9._-]+$", fork) or not _OWNER_RE.match(owner):
            return 400, {"ok": False, "error": "a fork + owner repo are required (letters, digits, . _ - and one /)", "code": "bad_request"}
        if not valid_hostport(listen) or not valid_hostport(connect):
            return 400, {"ok": False, "error": "listen and connect must be ip:port", "code": "bad_request"}
        if not no_ctrl(wrap_flags) or not no_ctrl(body.get("params") or "") or not no_ctrl(body.get("title") or ""):
            return 400, {"ok": False, "error": "control characters are not allowed", "code": "bad_request"}
        rc = reserved_conflict(deps, nodes, nodes[nid], port=listen.rsplit(":", 1)[1])
        if rc:
            return 400, {"ok": False, "error": rc, "code": "bad_request"}
        svc = "vk-turn-proxy-" + fork + "-" + listen.rsplit(":", 1)[1]
        if svc in (nodes[nid].get("turn") or {}):
            return 409, {"ok": False, "error": "an install for this fork+port is already pending", "code": "conflict"}
        ireq = {"action": "install", "owner": owner, "listen": listen, "connect": connect,
                "wrap_flags": wrap_flags, "title": (body.get("title") or "").strip(), "at": now()}
        if "params" in body:   # explicit ExecStart tail from the create form (the node uses it verbatim, incl. its wrap key)
            ireq["params"] = body.get("params") or ""
        nodes[nid].setdefault("turn", {})[svc] = ireq
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Installing turn-proxy", svc)
        return 200, {"ok": True, "data": {"node": nid, "service": svc}}

    if method == "POST" and path in ("/api/turn/manage", "/api/turn/rotate", "/api/turn/delete", "/api/turn/restart", "/api/turn/reinstall", "/api/turn/stop", "/api/turn/start"):
        # The node pulls these on its next sync, rewrites the unit's ExecStart / regenerates the wrap
        # key / removes it, restarts, and reports the new state (which clears the request).
        nid = body.get("node") or ""; svc = (body.get("service") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not _TURN_SVC_RE.match(svc):                  # svc becomes a unit/path/subprocess component on the node
            return 400, {"ok": False, "error": "invalid service name", "code": "bad_request"}
        if path.endswith("/manage"):
            req = {"action": "manage", "at": now()}
            for k in ("listen", "connect"):
                if (body.get(k) or "").strip():
                    if not valid_hostport(body[k].strip()):
                        return 400, {"ok": False, "error": k + " must be ip:port", "code": "bad_request"}
                    req[k] = body[k].strip()
            if "params" in body:                        # free-text ExecStart tail after -connect (node uses it verbatim)
                if not no_ctrl(body.get("params") or ""):
                    return 400, {"ok": False, "error": "control characters are not allowed", "code": "bad_request"}
                req["params"] = body.get("params") or ""
            if "title" in body:                          # optional display label (node stores it on the record)
                if not no_ctrl(body.get("title") or ""):
                    return 400, {"ok": False, "error": "control characters are not allowed", "code": "bad_request"}
                req["title"] = (body.get("title") or "").strip()
            verb = "Editing turn-proxy"
        elif path.endswith("/rotate"):
            req = {"action": "rotate", "at": now()}; verb = "Rotating turn-proxy key"
        elif path.endswith("/restart"):
            req = {"action": "restart", "at": now()}; verb = "Restarting turn-proxy"
        elif path.endswith("/stop"):
            req = {"action": "stop", "at": now()}; verb = "Stopping turn-proxy"
        elif path.endswith("/start"):
            req = {"action": "start", "at": now()}; verb = "Starting turn-proxy"
        elif path.endswith("/reinstall"):
            req = {"action": "reinstall", "at": now()}; verb = "Reinstalling turn-proxy"
            if (body.get("owner") or "").strip():   # repo to re-fetch the binary from (UI maps fork → owner)
                if not _OWNER_RE.match(body["owner"].strip()):
                    return 400, {"ok": False, "error": "invalid owner repo", "code": "bad_request"}
                req["owner"] = body["owner"].strip()
        else:
            req = {"action": "delete", "at": now()}; verb = "Deleting turn-proxy"
        nodes[nid].setdefault("turn", {})[svc] = req
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, verb, svc)
        return 200, {"ok": True, "data": {"node": nid, "service": svc}}

    if method == "POST" and path == "/api/turn/title":
        # Set ONLY the display title — the node updates its turn record but does NOT restart the proxy
        # (a title is cosmetic). Keeps the running service untouched, unlike /manage.
        nid = body.get("node") or ""; svc = (body.get("service") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not _TURN_SVC_RE.match(svc) or not no_ctrl(body.get("title") or ""):
            return 400, {"ok": False, "error": "invalid service or title", "code": "bad_request"}
        nodes[nid].setdefault("turn", {})[svc] = {"action": "title", "title": (body.get("title") or "").strip(), "at": now()}
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Renaming turn-proxy", svc)
        return 200, {"ok": True, "data": {"node": nid, "service": svc}}

    if method == "POST" and path == "/api/turn/onboard":
        # Adopt an existing turn-proxy systemd unit by its .service path; the node reads it + reports it.
        nid = body.get("node") or ""; sp = (body.get("path") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not sp or " " in sp or not sp.startswith("/"):
            return 400, {"ok": False, "error": "an absolute .service path is required", "code": "bad_request"}
        lst = nodes[nid].setdefault("turn_onboard", [])
        if sp not in lst:
            lst.append(sp)
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Onboarding turn-proxy", sp)
        return 200, {"ok": True, "data": {"node": nid, "path": sp}}

    if method == "POST" and path == "/api/turn/cancel":
        nid = body.get("node") or ""; svc = (body.get("service") or "").strip(); sp = (body.get("path") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        removed = False
        d = nodes[nid].get("turn")
        if isinstance(d, dict) and svc and svc in d:
            d.pop(svc, None); removed = True
            if not d: nodes[nid].pop("turn", None)
        lst = nodes[nid].get("turn_onboard")
        if isinstance(lst, list) and sp and sp in lst:
            lst.remove(sp); removed = True
            if not lst: nodes[nid].pop("turn_onboard", None)
        if removed:
            nodes_save(deps["nodes_path"], nodes)
            ev_append(roster_path, "node", nid, "Cancelled turn-proxy request", svc or sp)
        return 200, {"ok": True, "data": {"node": nid, "removed": removed}}

    if method == "POST" and path == "/api/iface/restart":
        # Bounce the interface's service on the node (<tool>-quick down/up) — recovers a DOWN iface.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface:
            return 400, {"ok": False, "error": "interface name is required", "code": "bad_request"}
        nodes[nid].setdefault("restart", {})[iface] = int(time.time())   # node bounces it on its next sync
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Restarting interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface}}

    if method == "POST" and path in ("/api/iface/stop", "/api/iface/start"):
        # Stop (down + disable, conf kept) or start (up + enable) the interface's service on the node.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface:
            return 400, {"ok": False, "error": "interface name is required", "code": "bad_request"}
        stopping = path.endswith("/stop")
        key, other = ("iface_stop", "iface_start") if stopping else ("iface_start", "iface_stop")
        (nodes[nid].get(other) or {}).pop(iface, None)        # a new stop cancels a pending start (and vice-versa)
        nodes[nid].setdefault(key, {})[iface] = int(time.time())
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Stopping interface" if stopping else "Starting interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface}}

    if method == "POST" and path == "/api/iface/delete":
        # Tear an interface down on the node (down + remove conf) and purge it from the panel: its
        # peers' targets here go away (peers with no other deployment are deleted), and its overrides
        # + any pending create/onboard are dropped. Destructive — the UI gates it behind typed confirm.
        nid = body.get("node") or ""
        iface = (body.get("iface") or "").strip()
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        if not iface:
            return 400, {"ok": False, "error": "interface name is required", "code": "bad_request"}
        nodes[nid].setdefault("delete", {})[iface] = int(time.time())   # queue the node teardown
        for key in ("create", "onboard", "ifaces"):
            d = nodes[nid].get(key)
            if isinstance(d, dict):
                d.pop(iface, None)
                if not d:
                    nodes[nid].pop(key, None)
        nodes_save(deps["nodes_path"], nodes)
        roster = roster_load(roster_path); changed = False         # purge peer targets on this iface
        for pid in list(roster["peers"].keys()):
            p = roster["peers"][pid]
            kept = [t for t in p.get("targets", []) if not (t.get("node") == nid and t.get("iface") == iface)]
            if len(kept) != len(p.get("targets", [])):
                changed = True
                if kept:
                    p["targets"] = kept; p["modified_at"] = int(time.time())
                else:
                    del roster["peers"][pid]
        if changed:
            roster_save(roster_path, roster)
        ev_append(roster_path, "node", nid, "Deleting interface", iface)
        return 200, {"ok": True, "data": {"node": nid, "iface": iface}}

    if method == "POST" and path == "/api/node/update":
        # Flag a (remote) node to self-update on its next sync. The node pulls this, runs the swg-only
        # updater (detached, restarts swg-noded), and the flag clears once it reports the new version.
        nid = body.get("node") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        # capture the node's current version — we clear the request once it reports ANYTHING different
        # (it updates to latest, which can move past a docker panel's lagging-CI image version)
        frm = ((deps.get("node_snaps") or {}).get(nid) or {}).get("noded_version")
        nodes[nid].pop("proc_status", None)   # a fresh Update request clears any prior stuck/failed tag so it starts clean
        nodes[nid]["update"] = {"to": VERSIONS.get("panel") or "", "from": frm, "at": int(time.time())}
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Update requested", "")
        return 200, {"ok": True, "data": {"node": nid}}

    if method == "POST" and path == "/api/node/proc-clear":
        # operator dismisses a stuck/failed proc tag (re-install/convert/update that never reported back)
        nid = body.get("node") or ""
        if nid in nodes:
            nodes[nid].pop("proc_status", None); nodes[nid].pop("update", None)
            with contextlib.suppress(Exception): nodes_save(deps["nodes_path"], nodes)
        return 200, {"ok": True, "data": {"node": nid}}

    if method == "POST" and path == "/api/host/proc-clear":
        # operator dismisses the panel host's own stuck re-install tag (removes the host_proc marker file)
        with contextlib.suppress(Exception):
            os.remove(deps.get("host_proc_path") or "")
        return 200, {"ok": True, "data": {}}

    if method == "POST" and path == "/api/update/check":
        reached = _check_latest_remote()             # synchronous one-off poll (for the header "check" icon)
        return 200, {"ok": True, "data": {
            "checked": reached,                      # did we actually reach the repo this time?
            "latest_remote": LATEST_REMOTE.get("version"),
            # strictly-newer remote only (same rule as the data bundle) — never flag a dev build that's
            # AHEAD of main as "outdated", which would offer a downgrade and leave the header with no pill.
            "panel_outdated": _ver_behind(VERSIONS.get("panel"), LATEST_REMOTE.get("version"))}}

    if method == "POST" and path == "/api/host/update":
        # Update THIS host (panel + a co-located node) in place. The panel runs unprivileged, so it
        # can't (and shouldn't) run the privileged updater itself. The installer wires a root systemd
        # updater that watches a trigger file; we just touch it. If that's not present (older install
        # or Docker), hand back the exact command to run on the host instead of failing silently.
        manual_cmd = ("curl -fsSL https://raw.githubusercontent.com/SanityProtocol/swg-panel/main/"
                      "bootstrap.sh | sudo bash -s update -y --no-components")
        # write the trigger whenever one is configured — bare-metal (root systemd swg-update.path) OR Docker
        # (install-docker wires the SAME host-side path-unit, watching the panel's data/lib/.update-request, since a
        # container can't recreate itself). No trigger configured → hand back the manual command below.
        if UPDATE_TRIGGER:
            try:
                os.makedirs(os.path.dirname(UPDATE_TRIGGER) or ".", exist_ok=True)
                try:
                    with open(UPDATE_TRIGGER, "w") as f:
                        f.write(str(int(time.time())) + "\n")    # swg-update.path fires swg-update.service
                except PermissionError:
                    # the trigger may have been left root-owned (a convert staged it, or an older root updater
                    # touched it); the panel owns the dir, so drop the stale file and recreate it panel-owned.
                    with contextlib.suppress(FileNotFoundError):
                        os.unlink(UPDATE_TRIGGER)
                    with open(UPDATE_TRIGGER, "w") as f:
                        f.write(str(int(time.time())) + "\n")
                # Flag THIS panel host "updating" right now so the header survives a hard reload (the client-only
                # `hostUpdating` var is wiped by Ctrl+Shift+R). update.sh re-affirms it and writes the terminal
                # ("updated"); the post-update restart drops a stale non-converting tag (see startup, ~2716).
                with contextlib.suppress(Exception):
                    _hpp = deps.get("host_proc_path")
                    if _hpp:
                        with open(_hpp, "w") as _hf:
                            _hf.write("updating\n")
                # MASTER: also flag the co-located node "updating" right now, so its tile shows the status for the
                # WHOLE update — like the header. update.sh's own proc_status POST lands a few seconds in and the
                # update can finish before the ~5s poll catches that brief window, so the node would otherwise jump
                # straight to "updated". Local node = the one sharing this panel host's hostname. (We set proc_status
                # directly, NOT the `update` flag — the flag would trigger a SECOND, redundant node self-update.)
                with contextlib.suppress(Exception):
                    _hn = os.uname().nodename; _snaps = deps.get("node_snaps") or {}; _hit = False
                    for _nid, _c in nodes.items():
                        if (_snaps.get(_nid) or {}).get("hostname") == _hn:
                            _c["proc_status"] = {"state": "updating", "at": int(time.time())}; _hit = True
                    if _hit:
                        nodes_save(deps["nodes_path"], nodes)
                ev_append(roster_path, "node", "host", "Host update started", "")
                return 200, {"ok": True, "data": {"started": True}}
            except Exception as e:
                return 500, {"ok": False, "error": f"couldn't signal the updater: {e}", "code": "exec_failed"}
        reason = ("this panel runs in Docker — a container can't recreate itself" if IN_DOCKER
                  else "automatic host update isn't set up on this install (update once on the host to enable it)")
        return 200, {"ok": True, "data": {"manual": True, "cmd": manual_cmd, "reason": reason}}

    if method == "POST" and path == "/api/nodes/rotate":
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        token = base64.urlsafe_b64encode(os.urandom(18)).decode().rstrip("=")
        nodes[nid]["token_hash"] = make_token_hash(token)
        nodes[nid]["token_sha"] = hashlib.sha256(token.encode()).hexdigest()   # fast-lookup index (see find_node_by_token)
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Rotated node token", nodes[nid].get("name", nid))
        return 200, {"ok": True, "data": {"id": nid, "name": nodes[nid].get("name"), "token": token}}

    if method == "POST" and path == "/api/nodes/flag-remove":
        # Soft removal: mark the node "removing" but keep it (and its peers) working until it
        # signs off (uninstall -> /api/node/goodbye). Force-remove cuts it off without waiting.
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        nodes[nid]["removing"] = True
        nodes[nid]["removing_at"] = now()
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Flagged node for removal", nodes[nid].get("name", nid))
        return 200, {"ok": True, "data": {"id": nid}}

    if method == "POST" and path == "/api/nodes/unflag-remove":   # cancel a pending soft removal
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        nodes[nid].pop("removing", None); nodes[nid].pop("removing_at", None)
        nodes_save(deps["nodes_path"], nodes)
        ev_append(roster_path, "node", nid, "Cancelled node removal", nodes[nid].get("name", nid))
        return 200, {"ok": True, "data": {"id": nid}}

    if method == "POST" and path == "/api/nodes/delete":     # force-remove (no waiting for goodbye)
        nid = body.get("id") or ""
        if nid not in nodes:
            return 404, {"ok": False, "error": "unknown node", "code": "not_found"}
        nm = node_remove(deps, nid)
        return 200, {"ok": True, "data": {"id": nid, "name": nm}}

    return 404, {"ok": False, "error": "not found", "code": "bad_request"}


# ───────────────────────── external integration API (v1) ─────────────────────────
# A READ-ONLY REST surface + Prometheus /metrics + outbound webhooks so external systems
# (Grafana, Uptime Kuma, Prometheus, Terraform/Ansible) can observe the fleet. Nothing here
# mutates state: no API token is ever accepted on a POST mutation, so a leaked token can read
# but never change anything. Auth is a bearer API token (Settings → Integrations mints them;
# only the sha256 hash is stored) OR a normal admin session (so the settings page can preview).
# /healthz and /api/v1/health are unauthenticated liveness probes that expose no secrets.

API_TOKEN_PREFIX = "swgp_"
WEBHOOK_EVENTS = ("peer.added", "peer.removed", "node.online", "node.offline")


def _api_token_hash(tok):
    return hashlib.sha256(("swg-api\x00" + (tok or "")).encode()).hexdigest()


def _api_settings(deps):
    a = (deps.get("panel_settings") or {}).get("api")
    return a if isinstance(a, dict) else {}


def api_token_lookup(deps, tok):
    """The stored token record matching a presented raw token, or None. Constant-time compare;
    returns None when the API is disabled so a stale token stops working the moment it's turned off."""
    tok = (tok or "").strip()
    if not tok:
        return None
    a = _api_settings(deps)
    if not a.get("enabled"):
        return None
    h = _api_token_hash(tok)
    hit = None
    for t in (a.get("tokens") or []):
        if hmac.compare_digest(str(t.get("hash", "")), h):
            hit = t
    return hit


def _api_public_view(deps):
    """Redacted `api` settings for the browser (/api/state): token HASHES and webhook SECRETS never
    leave the panel. last_used is an in-memory best-effort timestamp (no disk write per scrape)."""
    a = _api_settings(deps)
    seen = deps.get("api_seen") or {}
    return {"enabled": bool(a.get("enabled")),
            "tokens": [{"id": t.get("id"), "label": t.get("label"), "created": t.get("created"),
                        "last_used": seen.get(t.get("hash"))} for t in (a.get("tokens") or [])],
            "webhooks": [{"id": w.get("id"), "url": w.get("url"), "events": w.get("events") or [],
                          "enabled": w.get("enabled", True) is not False, "has_secret": bool(w.get("secret"))}
                         for w in (a.get("webhooks") or [])]}


def _ipof(cidr):
    s = (str(cidr or "")).split(",")[0].strip()
    return (s.split("/")[0] or None)


def _pct(used, total):
    return round(100.0 * used / total, 1) if total else None


def _ext_health_pcts(h):
    """cpu/mem/disk percentages + uptime from a node's health block (see swg-noded collect_health).

    `cpu_percent` is real utilization (0-100, mean across cores) when the node reports it; it falls
    back to load-per-core for a node on an older swg-noded. Must track health_pcts() so /metrics and
    /api/v1 never disagree with the UI about the same node.
    """
    h = h or {}
    load = h.get("load") or []
    ncpu = h.get("ncpu") or 1
    cpu_pct = h.get("cpu_pct")
    if isinstance(cpu_pct, (int, float)):
        cpu = round(max(0.0, min(100.0, float(cpu_pct))), 1)
    else:
        cpu = round(min(100.0, 100.0 * (load[0] / ncpu)), 1) if load and ncpu else None
    mem = h.get("mem") or {}
    mem_pct = _pct(mem.get("used", 0), mem.get("total", 0)) if mem.get("total") else None
    disks = h.get("disk") or []
    disk_pct = _pct((disks[0] or {}).get("used", 0), (disks[0] or {}).get("total", 0)) if disks and disks[0].get("total") else None
    # Peak + saturated-vCPU count are DERIVED from the per-vCPU list the node sends — never inferred
    # from (max - mean), which cannot distinguish 1 pinned core from 5 and goes silent at 6-of-8.
    cores = [c for c in (h.get("cpu_cores") or []) if isinstance(c, (int, float))]
    cpu_max = round(max(cores), 1) if cores else None
    cpu_hot = sum(1 for c in cores if c >= CPU_SAT_PCT) if cores else None
    iow = h.get("cpu_iowait_pct")
    iow = round(max(0.0, min(100.0, float(iow))), 1) if isinstance(iow, (int, float)) else None
    return {"cpu_percent": cpu, "cpu_max_percent": cpu_max, "cpu_saturated_cores": cpu_hot,
            "cpu_cores": cores or None, "cpu_iowait_percent": iow,
            "mem_percent": mem_pct, "disk_percent": disk_pct, "uptime_s": h.get("uptime")}


# The external API reads the panel's live state (in-memory snapshots + the small nodes.json/users.json
# state files) — the SAME data the SPA polls, never a separate copy and never through the browser. To keep
# an aggressive scraper (or several dashboards) from re-parsing users.json on every hit, the whole-fleet
# derivation is built at most once per EXT_CACHE_TTL and shared by every v1 endpoint + /metrics. Monitoring
# tolerates a few seconds of staleness, so this is invisible to consumers and cheap on the panel.
_EXT_CACHE = {"at": 0.0, "data": None}
_ext_cache_lock = threading.Lock()
EXT_CACHE_TTL = float(os.environ.get("SWG_PANEL_EXT_TTL", "3") or 3)


def _ext_build(deps):
    """Load nodes + roster ONCE and derive {servers, peers}. Memoized (EXT_CACHE_TTL) and double-checked
    under a lock so concurrent scrapes build it a single time, then read the same result."""
    c = _EXT_CACHE
    if c["data"] is not None and (time.monotonic() - c["at"]) < EXT_CACHE_TTL:
        return c["data"]
    with _ext_cache_lock:
        if c["data"] is not None and (time.monotonic() - c["at"]) < EXT_CACHE_TTL:
            return c["data"]
        nodes = nodes_load(deps["nodes_path"])
        snaps = deps.get("node_snaps") or {}
        seen = deps.get("node_seen") or {}
        roster = roster_load(deps["roster_path"])
        data = {"servers": _ext_servers_from(deps, nodes, snaps, seen),
                "peers": _ext_peers_from(deps, nodes, snaps, seen, roster)}
        c["data"] = data
        c["at"] = time.monotonic()
        return data


def ext_servers(deps):
    return _ext_build(deps)["servers"]


def _ext_servers_from(deps, nodes, snaps, seen):
    """The fleet as an external client sees it: one dict per node, status derived from sync staleness."""
    now = deps.get("now", lambda: int(time.time()))()
    out = []
    for nid, c in sorted(nodes.items(), key=lambda kv: (kv[1].get("pos", 1 << 30), kv[1].get("created", 0), kv[0])):
        snap = snaps.get(nid) or {}
        ls = seen.get(nid)
        online = ls is not None and (now - ls) <= NODE_OFFLINE
        pc = pon = 0
        rx = tx = 0.0
        ifaces = []
        for ifn, blk in (snap.get("interfaces") or {}).items():
            if is_system_iface(deps, nodes, nid, ifn):    # skip panel-managed mesh links — client-facing view only
                continue
            ps = blk.get("peers") or []
            pc += len(ps)
            pon += sum(1 for p in ps if p.get("online"))
            rx += sum(p.get("rx_speed", 0) or 0 for p in ps)
            tx += sum(p.get("tx_speed", 0) or 0 for p in ps)
            ifaces.append(ifn)
        rec = {"id": nid, "name": c.get("name", nid),
               "status": "online" if online else ("never_seen" if ls is None else "offline"),
               "online": bool(online),
               "kind": snap.get("kind") or c.get("kind"),
               "version": snap.get("noded_version"),
               "hostname": snap.get("hostname"),
               "endpoint_host": c.get("endpoint_host") or None,
               "routing_mode": c.get("routing_mode") or "kernel",
               "interfaces": ifaces,
               "peers": pc, "peers_online": pon,
               "rx_bytes_per_sec": int(rx), "tx_bytes_per_sec": int(tx),
               "last_seen": ls, "last_seen_age_s": (now - ls) if ls is not None else None}
        rec.update(_ext_health_pcts(snap.get("health")))
        out.append(rec)
    return out


def _resolve_nid(nodes, ref):
    """Accept a node id OR a display name (friendlier for hand-written dashboards)."""
    if ref in nodes:
        return ref
    for k, c in nodes.items():
        if c.get("name") == ref:
            return k
    return None


def ext_peers_for_node(deps, ref):
    """Peers observed on ONE node, with last-handshake timing, enriched from the roster. None if unknown."""
    nodes = nodes_load(deps["nodes_path"])
    nid = _resolve_nid(nodes, ref)
    if nid is None:
        return None
    snap = (deps.get("node_snaps") or {}).get(nid) or {}
    roster = roster_load(deps["roster_path"])
    users = roster.get("users") or {}
    by_pub = {p.get("pubkey"): (pid, p) for pid, p in (roster.get("peers") or {}).items()}
    out = []
    for ifn, blk in (snap.get("interfaces") or {}).items():
        if is_system_iface(deps, nodes, nid, ifn):        # mesh links aren't user peers
            continue
        for p in (blk.get("peers") or []):
            pid, pr = by_pub.get(p.get("public_key"), (None, {}))
            uid = pr.get("user_id")
            out.append({"peer_id": pid, "public_key": p.get("public_key"), "iface": ifn,
                        "user": (users.get(uid) or {}).get("name") if uid else None,
                        "title": pr.get("title") or None,
                        "address": _ipof(p.get("allowed_ips")),
                        "online": bool(p.get("online")),
                        "endpoint": p.get("endpoint"),
                        "last_handshake": p.get("last_handshake") or None,
                        "handshake_age_s": p.get("handshake_age"),
                        "rx_bytes": int(p.get("rx_bytes", 0) or 0), "tx_bytes": int(p.get("tx_bytes", 0) or 0),
                        "rx_bytes_per_sec": int(p.get("rx_speed", 0) or 0), "tx_bytes_per_sec": int(p.get("tx_speed", 0) or 0)})
    return {"node": nid, "name": nodes[nid].get("name", nid), "peers": out}


def ext_peers_all(deps):
    return _ext_build(deps)["peers"]


def _ext_peers_from(deps, nodes, snaps, seen, roster):
    """Roster-wide peer identities with per-target presence. A peer is `online` if it's online on ANY
    of its deployed nodes (matches the panel's most-alive-wins view for multi-node peers)."""
    now = deps.get("now", lambda: int(time.time()))()
    users = roster.get("users") or {}
    obs = {}
    for nid, snap in snaps.items():
        for blk in (snap.get("interfaces") or {}).values():
            for p in (blk.get("peers") or []):
                obs[(nid, p.get("public_key"))] = p
    def node_live(nid):
        ls = seen.get(nid)
        return ls is not None and (now - ls) <= NODE_OFFLINE
    out = []
    for pid, p in (roster.get("peers") or {}).items():
        pub = p.get("pubkey")
        uid = p.get("user_id")
        online = False
        last_hs = None
        targets = []
        for t in (p.get("targets") or []):
            o = obs.get((t.get("node"), pub))
            on = bool(o and o.get("online"))
            online = online or on
            if o and o.get("last_handshake"):
                last_hs = max(last_hs or 0, o["last_handshake"])
            targets.append({"node": t.get("node"), "iface": t.get("iface"), "address": t.get("ip"),
                            "online": on, "node_live": node_live(t.get("node"))})
        out.append({"peer_id": pid, "public_key": pub, "title": p.get("title") or None,
                    "user": (users.get(uid) or {}).get("name") if uid else None, "user_id": uid,
                    "online": online, "last_handshake": last_hs, "targets": targets})
    return out


def ext_summary(deps):
    b = _ext_build(deps)
    servers = b["servers"]
    peers = b["peers"]
    now = deps.get("now", lambda: int(time.time()))()
    return {"version": VERSIONS.get("panel"),
            "nodes": {"total": len(servers), "online": sum(1 for s in servers if s["online"])},
            "peers": {"total": len(peers), "online": sum(1 for p in peers if p["online"])},
            "throughput": {"rx_bytes_per_sec": sum(s["rx_bytes_per_sec"] for s in servers),
                           "tx_bytes_per_sec": sum(s["tx_bytes_per_sec"] for s in servers)},
            "generated_at": now}


def _prom_esc(v):
    return str(v).replace("\\", "\\\\").replace('"', '\\"').replace("\n", " ")


def ext_metrics(deps):
    """Prometheus text exposition (v0.0.4). Per-node cardinality only — never per-peer, which would
    explode the series count on a large fleet; peer detail lives in the JSON API."""
    servers = ext_servers(deps)
    s = ext_summary(deps)
    L = []
    def g(name, help_, typ="gauge"):
        L.append("# HELP %s %s" % (name, help_))
        L.append("# TYPE %s %s" % (name, typ))
    def row(_metric, val, **labels):
        lbl = ",".join('%s="%s"' % (k, _prom_esc(v)) for k, v in labels.items() if v is not None)
        L.append("%s{%s} %s" % (_metric, lbl, val) if lbl else "%s %s" % (_metric, val))
    g("swg_panel_up", "1 whenever the panel answers a scrape.")
    row("swg_panel_up", 1)
    g("swg_panel_build_info", "Panel build/version info.")
    row("swg_panel_build_info", 1, version=s["version"])
    g("swg_nodes_total", "Configured nodes in the fleet.")
    row("swg_nodes_total", s["nodes"]["total"])
    g("swg_nodes_online", "Nodes that have synced within the offline window.")
    row("swg_nodes_online", s["nodes"]["online"])
    g("swg_peers_total", "Peer identities in the roster.")
    row("swg_peers_total", s["peers"]["total"])
    g("swg_peers_online", "Peers online on at least one node.")
    row("swg_peers_online", s["peers"]["online"])
    g("swg_fleet_rx_bytes_per_second", "Fleet aggregate download rate (bytes/s).")
    row("swg_fleet_rx_bytes_per_second", s["throughput"]["rx_bytes_per_sec"])
    g("swg_fleet_tx_bytes_per_second", "Fleet aggregate upload rate (bytes/s).")
    row("swg_fleet_tx_bytes_per_second", s["throughput"]["tx_bytes_per_sec"])
    g("swg_node_up", "1 if the node is online (synced within the offline window), else 0.")
    for n in servers:
        row("swg_node_up", 1 if n["online"] else 0, node=n["id"], name=n["name"])
    g("swg_node_peers", "Peers configured on the node.")
    for n in servers:
        row("swg_node_peers", n["peers"], node=n["id"], name=n["name"])
    g("swg_node_peers_online", "Peers currently online on the node.")
    for n in servers:
        row("swg_node_peers_online", n["peers_online"], node=n["id"], name=n["name"])
    g("swg_node_rx_bytes_per_second", "Node download rate (bytes/s).")
    for n in servers:
        row("swg_node_rx_bytes_per_second", n["rx_bytes_per_sec"], node=n["id"], name=n["name"])
    g("swg_node_tx_bytes_per_second", "Node upload rate (bytes/s).")
    for n in servers:
        row("swg_node_tx_bytes_per_second", n["tx_bytes_per_sec"], node=n["id"], name=n["name"])
    g("swg_node_last_seen_timestamp_seconds", "Unix time of the node's last sync.")
    for n in servers:
        if n["last_seen"] is not None:
            row("swg_node_last_seen_timestamp_seconds", n["last_seen"], node=n["id"], name=n["name"])
    # HELP is fleet-wide, so it must not say "vCPU" (VMs) or "core" (bare metal, where hyperthreads inflate
    # the count) — /proc/stat's cpuN are logical CPUs either way. Only the UI picks a per-node label.
    for metric, key, help_ in (("swg_node_cpu_percent", "cpu_percent", "Node CPU utilization, mean across logical CPUs (0-100)."),
                               ("swg_node_cpu_max_percent", "cpu_max_percent", "Node CPU utilization of its busiest single logical CPU (0-100)."),
                               ("swg_node_cpu_saturated_cores", "cpu_saturated_cores", "Number of the node's logical CPUs at or above %d%% utilization." % CPU_SAT_PCT),
                               ("swg_node_cpu_iowait_percent", "cpu_iowait_percent", "Node time waiting on I/O (0-100). Raises load average but is NOT CPU."),
                               ("swg_node_memory_percent", "mem_percent", "Node memory used as a percentage."),
                               ("swg_node_disk_percent", "disk_percent", "Node primary-disk used as a percentage."),
                               ("swg_node_uptime_seconds", "uptime_s", "Node uptime in seconds.")):
        g(metric, help_)
        for n in servers:
            if n.get(key) is not None:
                row(metric, n[key], node=n["id"], name=n["name"])
    return "\n".join(L) + "\n"


class _NoRedirect(urllib.request.HTTPRedirectHandler):
    def redirect_request(self, *a, **k):     # never follow a redirect → can't be bounced to an internal target
        return None
_WEBHOOK_OPENER = urllib.request.build_opener(_NoRedirect)


def webhook_host_ok(url):
    """Reject a webhook target that resolves to link-local (169.254 — cloud-metadata credential theft),
    multicast, reserved, or unspecified. Loopback and RFC1918 private ranges are deliberately ALLOWED — a
    local receiver or an internal alerting endpoint is a legitimate, common webhook target. The narrow block
    kills the metadata-SSRF escalation without breaking internal/localhost webhooks."""
    try:
        host = urlparse(url).hostname
    except Exception:
        return False
    if not host:
        return False
    try:
        infos = socket.getaddrinfo(host, None)
    except Exception:
        return True                      # unresolvable NOW → nothing to SSRF (the POST just fails); don't reject a legit host over a DNS hiccup
    for ai in infos:
        try:
            ip = ipaddress.ip_address(ai[4][0])
        except ValueError:
            continue
        if ip.is_link_local or ip.is_multicast or ip.is_reserved or ip.is_unspecified:
            return False
    return True


def _webhook_post(url, secret, body_bytes, timeout=8):
    if not webhook_host_ok(url):              # re-check at send time (config may pre-date the guard) — no redirects
        raise ValueError("webhook target resolves to a disallowed (internal) address")
    headers = {"Content-Type": "application/json", "User-Agent": "swg-panel-webhook"}
    if secret:
        headers["X-SWG-Signature"] = "sha256=" + hmac.new(secret.encode(), body_bytes, hashlib.sha256).hexdigest()
    req = urllib.request.Request(url, data=body_bytes, headers=headers, method="POST")
    with _WEBHOOK_OPENER.open(req, timeout=timeout) as r:
        return getattr(r, "status", None) or r.getcode()


def webhook_emit(deps, event, data):
    """Fire-and-forget delivery to every enabled webhook subscribed to `event`, in a daemon thread so a
    slow/unreachable endpoint never blocks the API. One retry on failure; delivery is best-effort."""
    a = _api_settings(deps)
    hooks = [h for h in (a.get("webhooks") or [])
             if h.get("enabled", True) is not False and h.get("url")
             and (not h.get("events") or event in h["events"])]
    if not hooks:
        return
    body = json.dumps({"event": event, "ts": int(time.time()), "data": data}, separators=(",", ":")).encode()
    def _deliver():
        for h in hooks:
            for attempt in range(2):
                try:
                    _webhook_post(h["url"], h.get("secret") or "", body)
                    break
                except Exception:
                    if attempt == 0:
                        time.sleep(1.5)
    threading.Thread(target=_deliver, daemon=True).start()


def _node_watch_loop(deps):
    """Detect node online↔offline transitions (derived from sync staleness) and emit webhooks. Seeds
    from the current state on the first pass so a panel restart doesn't replay a flood of transitions."""
    state = {}
    first = True
    while True:
        with contextlib.suppress(Exception):
            if not (_api_settings(deps).get("webhooks")):   # nothing subscribed → do no work at all (re-seed when one is added)
                first = True
                time.sleep(10)
                continue
            now = int(time.time())
            seen = deps.get("node_seen") or {}
            nodes = nodes_load(deps["nodes_path"])
            for nid in list(seen.keys()):
                ls = seen.get(nid)
                online = ls is not None and (now - ls) <= NODE_OFFLINE
                prev = state.get(nid)
                state[nid] = online
                if first or prev is None or prev == online:
                    continue
                nm = (nodes.get(nid) or {}).get("name", nid)
                webhook_emit(deps, "node.online" if online else "node.offline",
                             {"id": nid, "name": nm, "last_seen": ls})
            first = False
        time.sleep(10)


# ───────────────────────── HTTP shell ─────────────────────────

class Handler(BaseHTTPRequestHandler):
    deps = None
    # HTTP/1.1 keep-alive: the SPA polls several endpoints every few seconds. Without this the server is
    # HTTP/1.0, so EVERY request opens a fresh TLS connection + full handshake — over a network that churn
    # intermittently fails the handshake (ERR_SSL_PROTOCOL_ERROR in the browser). Keep-alive reuses one
    # connection. Safe because every response sets Content-Length (send_error does too); idle conns time out.
    protocol_version = "HTTP/1.1"
    timeout = 75

    def _send(self, code, obj):
        self._send_bytes(code, json.dumps(obj).encode())

    def _body_len(self, cap=MAX_BODY):
        """Validated Content-Length, or None (after sending 413) if malformed or over `cap` — read the body
        ONLY after this passes, so an oversized/streamed body can't exhaust memory before it's parsed."""
        try:
            n = int(self.headers.get("Content-Length", 0) or 0)
        except ValueError:
            n = -1
        if n < 0 or n > cap:
            self._send(413, {"ok": False, "error": "request body too large", "code": "too_large"})
            return None
        return n

    def _send_bytes(self, code, payload):
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(payload)))
        self.send_header("Cache-Control", "no-store")   # API replies may carry secrets — never cache
        self.end_headers()
        with contextlib.suppress(BrokenPipeError, ConnectionError):
            self.wfile.write(payload); self.wfile.flush()   # flush so the body reaches the client before the socket closes

    def _send_text(self, code, text, ctype="text/plain; charset=utf-8"):
        payload = text.encode() if isinstance(text, str) else text
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(payload)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        with contextlib.suppress(BrokenPipeError, ConnectionError):
            self.wfile.write(payload)

    def _ext_token(self, u):
        hdr = self.headers.get("Authorization", "")
        if hdr.startswith("Bearer "):
            return hdr[7:].strip()
        xk = self.headers.get("X-API-Key", "")
        if xk:
            return xk.strip()
        return (parse_qs(u.query).get("token") or [""])[0]   # ?token= for tools that can't set a header

    def _ext_authed(self, u):
        """A valid read-only API token (header or ?token=) OR a live admin session. On a token hit,
        record a best-effort in-memory last-used stamp (no disk write, so scrapes stay cheap)."""
        tok = self._ext_token(u)
        if tok and api_token_lookup(self.deps, tok) is not None:
            self.deps.setdefault("api_seen", {})[_api_token_hash(tok.strip())] = int(time.time())
            return True
        return self._authed_user() is not None

    def _ext_api(self, path, u):
        try:
            if path == "/healthz":                              # bare liveness for uptime probes (no auth, no data)
                return self._send_text(200, "ok\n")
            if path == "/api/v1/health":                        # liveness + coarse counts (no secrets) — unauthenticated
                s = ext_summary(self.deps)
                return self._send(200, {"status": "ok", "version": s["version"], "nodes": s["nodes"], "peers": s["peers"]})
            if not self._ext_authed(u):
                return self._send(401, {"error": "unauthorized",
                                        "detail": "send a read-only API token as 'Authorization: Bearer <token>' "
                                                  "(mint one in Settings → Integrations, then enable the API)"})
            if path == "/metrics":
                return self._send_text(200, ext_metrics(self.deps), "text/plain; version=0.0.4; charset=utf-8")
            if path == "/api/v1/servers":
                return self._send(200, {"servers": ext_servers(self.deps)})
            m = re.match(r"^/api/v1/servers/([^/]+)/peers$", path)
            if m:
                r = ext_peers_for_node(self.deps, unquote(m.group(1)))
                return self._send(404, {"error": "unknown server"}) if r is None else self._send(200, r)
            m = re.match(r"^/api/v1/servers/([^/]+)$", path)
            if m:
                sid = unquote(m.group(1))
                hit = next((sv for sv in ext_servers(self.deps) if sv["id"] == sid or sv["name"] == sid), None)
                return self._send(200, hit) if hit else self._send(404, {"error": "unknown server"})
            if path == "/api/v1/peers":
                return self._send(200, {"peers": ext_peers_all(self.deps)})
            if path == "/api/v1/summary":
                return self._send(200, ext_summary(self.deps))
            return self._send(404, {"error": "not found"})
        except Exception as e:
            return self._send(500, {"error": "internal", "detail": str(e)})

    def _send_state(self):
        # Serve the memoized /api/state bytes (see _STATE_CACHE). Double-checked under a lock so a cold
        # cache is built exactly once while concurrent pollers wait, then re-send the same fresh bytes.
        c = _STATE_CACHE
        if c["bytes"] is not None and (time.monotonic() - c["at"]) < STATE_CACHE_TTL:
            return self._send_bytes(200, c["bytes"])
        with _state_cache_lock:
            if c["bytes"] is not None and (time.monotonic() - c["at"]) < STATE_CACHE_TTL:
                return self._send_bytes(200, c["bytes"])
            try:
                code, obj = api("GET", "/api/state", {}, {}, self.deps)
            except Exception as e:
                return self._send(500, {"ok": False, "error": str(e), "code": "internal"})
            if code == 200:
                c["bytes"] = json.dumps(obj).encode()
                c["at"] = time.monotonic()
                return self._send_bytes(200, c["bytes"])
        return self._send(code, obj)   # an error build isn't cached

    def _static(self, key):
        full = os.path.normpath(os.path.join(WEB_DIR, STATIC[key]))
        if not full.startswith(os.path.realpath(WEB_DIR)) and not full.startswith(WEB_DIR):
            return self.send_error(403)
        try:
            with open(full, "rb") as f:
                data = f.read()
        except OSError:
            return self.send_error(404)
        if PANEL_BASE and STATIC[key] == "index.html":   # point the SPA's <base> at the mount point
            data = data.replace(b'<base href="/">', ('<base href="%s/">' % PANEL_BASE).encode())
        # Version-stamp the SPA entry points (?v=<panel version>). The assets are buildless (no content
        # hash in the filename), and a CDN in front (e.g. Cloudflare) caches .js/.css for hours regardless
        # of our no-cache header — so a browser can run a stale app.js against a freshly-updated backend.
        # A per-release query makes each version a distinct URL: index.html/HTML is never CDN-cached, so it's
        # always fresh and points at the current app.js?v=… , which the CDN then fetches anew on a version bump.
        _av = (VERSIONS.get("panel") or "").strip()
        if _av and STATIC[key] == "index.html":
            q = ("?v=" + _av).encode()
            data = (data.replace(b'href="app.css"', b'href="app.css' + q + b'"')
                        .replace(b'src="app.js"', b'src="app.js' + q + b'"')
                        .replace(b'src="turn-artifacts.js"', b'src="turn-artifacts.js' + q + b'"'))
        elif _av and STATIC[key] == "app.js":
            data = data.replace(b'"./reconcile.js"', b'"./reconcile.js' + ("?v=" + _av).encode() + b'"')
        _, ext = os.path.splitext(full)
        # The SPA is buildless (no content-hashed filenames), so a stale app.js/app.css served
        # against a freshly-updated backend silently breaks the UI (e.g. a schema change). Force
        # revalidation: clients must check with the server (304 if unchanged) rather than trust a
        # cached copy. ETag makes that cheap; fonts can cache long since they never change.
        if ext == ".woff2":
            self.send_response(200)
            self.send_header("Content-Type", CTYPES.get(ext, "application/octet-stream"))
            self.send_header("Content-Length", str(len(data)))
            self.send_header("Cache-Control", "public, max-age=31536000, immutable")
            self.end_headers()
            with contextlib.suppress(BrokenPipeError):
                self.wfile.write(data)
            return
        etag = '"%s"' % hashlib.sha256(data).hexdigest()[:16]
        if self.headers.get("If-None-Match") == etag:
            self.send_response(304)
            self.send_header("ETag", etag)
            self.send_header("Cache-Control", "no-cache")
            self.end_headers()
            return
        self.send_response(200)
        self.send_header("Content-Type", CTYPES.get(ext, "application/octet-stream"))
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Cache-Control", "no-cache")
        self.send_header("ETag", etag)
        self.send_header("X-Content-Type-Options", "nosniff")
        if STATIC[key] == "index.html":
            # Defence-in-depth CSP for the buildless SPA: everything is same-origin except QR/favicon data:
            # URIs; 'unsafe-inline' is required for the theme-bootstrap + importmap inline scripts and the
            # app's inline styles. Restricts connect/img/object and blocks framing (clickjacking).
            self.send_header("Content-Security-Policy",
                             "default-src 'self'; script-src 'self' 'unsafe-inline'; "
                             "style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; "
                             "connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'")
            self.send_header("X-Frame-Options", "DENY")
            self.send_header("Referrer-Policy", "same-origin")
        self.end_headers()
        with contextlib.suppress(BrokenPipeError):
            self.wfile.write(data)

    def _cookie(self, name):
        for part in self.headers.get("Cookie", "").split(";"):
            k, _, v = part.strip().partition("=")
            if k == name:
                return v
        return ""

    def _authed_user(self):
        """Authenticated username, True if auth is disabled, or None if unauthenticated.
        Accepts a session cookie (browser) or HTTP Basic (API clients / curl)."""
        creds = Handler.deps.get("auth")
        if not creds:
            return True
        secret = Handler.deps.get("session_secret")
        tok = self._cookie("swgsess")
        if tok and secret and verify_session(tok, secret) == creds[0]:
            return creds[0]
        hdr = self.headers.get("Authorization", "")
        if hdr.startswith("Basic "):
            try:
                user, _, pw = base64.b64decode(hdr[6:]).decode("utf-8", "replace").partition(":")
            except Exception:
                user, pw = "", ""
            if hmac.compare_digest(user, creds[0]) and verify_password(creds[1], pw):
                return creds[0]
        return None

    def _require_auth(self):
        if self._authed_user() is not None:
            return True
        # 401 JSON, deliberately WITHOUT WWW-Authenticate so the browser shows our login
        # page instead of its native Basic-auth popup.
        self._send(401, {"ok": False, "error": "authentication required", "code": "unauthorized"})
        return False

    def _session_cookie(self, value, max_age):
        base = (PANEL_BASE or "") + "/"
        secure = "; Secure" if (TLS_CERT and TLS_KEY) else ""
        return f"swgsess={value}; Path={base}; HttpOnly; SameSite=Strict; Max-Age={max_age}{secure}"

    def _send_with_cookie(self, code, obj, cookie):
        payload = json.dumps(obj).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(payload)))
        if cookie:
            self.send_header("Set-Cookie", cookie)
        self.end_headers()
        with contextlib.suppress(BrokenPipeError):
            self.wfile.write(payload)

    def _login(self):
        creds = Handler.deps.get("auth")
        length = self._body_len()
        if length is None:
            return
        try:
            body = json.loads(self.rfile.read(length) or b"{}")
        except Exception:
            body = {}
        if not creds:
            return self._send(200, {"ok": True, "data": {"auth": False}})
        user = (body.get("username") or "").strip()
        pw = body.get("password") or ""
        if not (hmac.compare_digest(user, creds[0]) and verify_password(creds[1], pw)):
            return self._send(401, {"ok": False, "error": "invalid username or password", "code": "bad_login"})
        tf = load_2fa(Handler.deps.get("twofa_path"))
        if tf.get("enabled"):                                 # password OK — now the second factor
            code = (body.get("code") or "").strip()
            if not code:                                      # first submit → tell the SPA to ask for a code
                return self._send(200, {"ok": False, "twofa_required": True})
            ok2 = totp_verify(tf.get("secret", ""), code)
            if not ok2 and recovery_consume(tf, code):        # a single-use recovery code
                save_2fa(Handler.deps["twofa_path"], tf); ok2 = True
            if not ok2:
                return self._send(200, {"ok": False, "twofa_required": True, "error": "that code isn't valid"})
        tok = make_session(creds[0], Handler.deps.get("session_secret"))
        return self._send_with_cookie(200, {"ok": True, "data": {"username": creds[0]}},
                                      self._session_cookie(tok, SESSION_TTL))

    def _logout(self):
        return self._send_with_cookie(200, {"ok": True}, self._session_cookie("", 0))

    def _wgstats(self, path):
        name = os.path.basename(path)          # basename strips any traversal
        if not name.endswith(".json") or "/" in name or name.startswith("."):
            return self.send_error(404)
        full = os.path.join(Handler.deps.get("stats_dir", "/var/www/wgstats"), name)
        try:
            with open(full, "rb") as f:
                data = f.read()
        except OSError:
            data = b"{}"                        # before the first snapshot lands
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        with contextlib.suppress(BrokenPipeError):
            self.wfile.write(data)

    def _node_sync(self):
        nodes = nodes_load(Handler.deps["nodes_path"])
        hdr = self.headers.get("Authorization", "")
        token = hdr[7:].strip() if hdr.startswith("Bearer ") else ""
        nid, node = find_node_by_token(nodes, token)
        if not nid:
            return self._send(401, {"error": "invalid node token"})
        if token and not node.get("token_sha"):        # one-time upgrade of a legacy node → fast-lookup index (H3)
            with contextlib.suppress(Exception):
                with _api_lock:
                    nn = nodes_load(Handler.deps["nodes_path"])
                    if nid in nn and not nn[nid].get("token_sha"):
                        nn[nid]["token_sha"] = hashlib.sha256(token.encode()).hexdigest()
                        nodes_save(Handler.deps["nodes_path"], nn)
        length = self._body_len(MAX_SYNC_BODY)
        if length is None:
            return
        try:
            body = json.loads(self.rfile.read(length) or "{}")
        except Exception:
            return self._send(400, {"error": "bad body"})
        snap = body.get("snapshot") or {}
        Handler.deps.setdefault("node_snaps", {})[nid] = snap
        Handler.deps.setdefault("node_seen", {})[nid] = int(time.time())
        if not (node.get("endpoint_host") or "").strip():   # mesh needs a dial host — auto-fill from the reported
            _pub = node_public_ip(snap)                      # public IP (operator can still override it later)
            if _pub:
                node["endpoint_host"] = _pub
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        if node.pop("uninstalled", None) is not None:   # node is back (re-installed with the same token) → clear the grey "Uninstalled" tag
            nodes_save(Handler.deps["nodes_path"], nodes)
        if snap.get("kind") and node.get("kind") != snap["kind"]:   # remember the method persistently, so a DOWN node (no live snapshot) still knows it (Recover shows the right command)
            node["kind"] = snap["kind"]
            with contextlib.suppress(Exception): nodes_save(Handler.deps["nodes_path"], nodes)
        # A convert is DONE the moment the node reports on its TARGET method (kind), even if the script's
        # terminal POST was lost (killed / power-cut / network) — otherwise "converting…" would hang until the
        # 10-min grace flips it to "failed", while the node is already reporting green. Staging keeps reporting
        # the OLD kind, so this never fires mid-convert; re-install/update don't change kind, so they're untouched.
        _cv = {"converting-docker": ("docker", "converted-docker"),
               "converting-bare":   ("baremetal", "converted-bare")}
        _tgt = _cv.get((node.get("proc_status") or {}).get("state"))
        if _tgt and snap.get("kind") == _tgt[0]:
            node["proc_status"] = {"state": _tgt[1], "at": int(time.time())}   # green confirmation for ~8s, then clears
            with contextlib.suppress(Exception): nodes_save(Handler.deps["nodes_path"], nodes)
        # NB: an in-progress proc_status (reinstalling / updating / converting…) is NOT cleared by a sync —
        # swg-noded keeps syncing right through a re-install/update, so clearing here would hide the tag
        # immediately. The lifecycle script's TERMINAL (success/aborted/failed) replaces it; a stuck op with
        # no terminal falls back to "<op> failed" after PROC_GRACE (see _proc_view). The re-install key
        # re-bless now happens when "reinstalling" is received (see _node_proc_status), not on sync.
        stats_dir = Handler.deps.get("stats_dir")
        if stats_dir and snap and stats_disk_ok(stats_dir):   # skip the non-essential stats/RRD writes on a full disk
            sf = node.get("stats_file", f"stats-{nid}.json")
            with contextlib.suppress(Exception):
                atomic_write(os.path.join(stats_dir, sf), json.dumps(snap), mode=0o644)
            cpu, mem, disk = health_pcts(snap.get("health")) or (HRRD_NA, HRRD_NA, HRRD_NA)
            agg = snap_aggregates(snap, node)        # rx/tx (total) + awg/mesh split + peer counts, panel-derived
            rx, tx = agg["rx"], agg["tx"]            # == snap_traffic — total across every iface
            _in = snap.get("inet") or {}             # node-measured internet up/down (B/s); absent on older noded → 0
            M = [cpu, mem, disk, rx, tx, agg["arx"], agg["atx"], agg["mrx"], agg["mtx"],
                 max(0, int(_in.get("up") or 0)), max(0, int(_in.get("down") or 0)),
                 agg["pon"], agg["ptot"], agg["paon"], agg["patot"]]
            with contextlib.suppress(Exception):
                hrrd_update(os.path.join(stats_dir, f"health-{nid}.rrd"), int(time.time()), M)
            # also keep a short raw buffer (one sample per sync) for a 5s-granular LIVE view. Mirrored to
            # disk so it survives a panel restart/update — otherwise LIVE appears to "reset to scratch"
            # after every update (the RRD-backed ranges already persist; this makes LIVE persist too).
            buf = Handler.deps.setdefault("live_samples", {}).setdefault(nid, [])
            buf.append((int(time.time()), cpu, mem, disk, rx, tx))
            if len(buf) > LIVE_MAX:
                del buf[:len(buf) - LIVE_MAX]
            with contextlib.suppress(Exception):
                atomic_write(os.path.join(stats_dir, f"live-{nid}.json"), json.dumps(buf), mode=0o644)
            # Per-PAIR mesh history for the flow-map ranges: each mesh link's directional rate, stored in a tiny
            # per-pair ring (reuses the node ring — rx slot = a→b, tx slot = b→a). Throttled per pair (≤1/min) so
            # both link ends dedup onto one write and it stays negligible. Panel-derived → no node change.
            now_i = int(time.time())
            mlast = Handler.deps.setdefault("_mesh_last", {})
            ov_ifaces = node.get("ifaces") or {}
            for ifn, blk in (snap.get("interfaces") or {}).items():
                meta = blk.get("meta") or {}; o = ov_ifaces.get(ifn) or {}
                peer = o.get("link_node") or meta.get("link_node") or o.get("egress_node") or meta.get("egress_node")   # a system mesh link's peer is link_node; egress_node is the user-iface forward target
                if not ((o.get("system") or meta.get("system")) and peer and peer in nodes):
                    continue
                a, b = sorted((nid, peer)); key = f"{a}|{b}"
                if now_i - mlast.get(key, 0) < MESH_THROTTLE_S:
                    continue                              # another end (or this one) wrote recently
                lrx = sum((p.get("rx_speed", 0) or 0) for p in (blk.get("peers") or []))
                ltx = sum((p.get("tx_speed", 0) or 0) for p in (blk.get("peers") or []))
                ab, ba = (ltx, lrx) if nid == a else (lrx, ltx)   # a→b, b→a from this node's perspective
                mM = [0] * HRRD_NM; mM[3] = ab; mM[4] = ba        # ab→rx slot, ba→tx slot (rest incl. inet = 0)
                with contextlib.suppress(Exception):
                    hrrd_update(mesh_rrd_path(stats_dir, a, b), now_i, mM)
                mlast[key] = now_i
            # DESTINATION STATS: the node reports the LATEST per-category rate directly (snap["cat_rate"] = {cat:
            # {up,dn}} B/s — it does the delta, like snap["inet"]). LIVE reads it straight through (nodes_view.cats);
            # ranges come from the per-(node,cat) RRD written here (lazily created + throttled ≤1/min like mesh).
            cat_rate = snap.get("cat_rate") or {}
            clast_w = Handler.deps.setdefault("_cat_last_w", {})   # (nid,cat) → last RRD write time
            for cat, v in cat_rate.items():
                rup = max(0, int(v.get("up") or 0)); rdn = max(0, int(v.get("dn") or 0))
                if (rup or rdn) and now_i - clast_w.get((nid, cat), 0) >= MESH_THROTTLE_S:   # lazy: only categories moving bytes get a ring
                    cM = [0] * HRRD_NM; cM[3] = rup; cM[4] = rdn                             # up→rx slot, dn→tx slot
                    with contextlib.suppress(Exception):
                        hrrd_update(cat_rrd_path(stats_dir, nid, cat), now_i, cM)
                    clast_w[(nid, cat)] = now_i
            # TURN-PROXY STATS (panel-derived, no node change): attribute each turn-routed peer to its proxy's FORK
            # (a peer whose wg endpoint is a proxy's connect IP; the proxy forwarding to that peer's iface listen
            # port claims it — mirrors reconcile.js). Aggregate rx/tx + online/total per fork → per-(node,fork) ring
            # (rx/tx slots = throughput, pon/ptot = peers), so the "by turn-proxy" doughnuts get ranged history.
            tps = snap.get("turn_proxies") or []
            if tps:
                conn_ips = set(); by_port = {}; sport_svc = {}
                for tp in tps:
                    ci = _ip_of(tp.get("connect"))
                    if ci: conn_ips.add(ci)
                    cp = _port_of(tp.get("connect"))
                    if cp: by_port.setdefault(cp, []).append(tp.get("service") or "turn")
                    for sp in (tp.get("wg_sports") or []):
                        sport_svc[str(sp)] = tp.get("service") or "turn"   # exact: endpoint source port → its proxy
                fagg = {}   # fork → [rx, tx, online, total]
                for ifn, blk in (snap.get("interfaces") or {}).items():
                    lp = str((blk.get("meta") or {}).get("listen_port") or "")
                    svcs = by_port.get(lp) or []
                    for p in (blk.get("peers") or []):
                        if _ip_of(p.get("endpoint")) not in conn_ips: continue
                        # exact proxy via the peer's endpoint source port (disambiguates several proxies on one iface);
                        # fall back to the iface's first proxy for old nodes that don't report wg_sports.
                        svc = sport_svc.get(str(_port_of(p.get("endpoint"))))
                        if not svc:
                            if not svcs: continue
                            svc = svcs[0]
                        fork = turn_fork(svc)
                        f = fagg.setdefault(fork, [0, 0, 0, 0])
                        f[0] += p.get("rx_speed", 0) or 0; f[1] += p.get("tx_speed", 0) or 0
                        f[3] += 1
                        if p.get("online"): f[2] += 1
                # every DEPLOYED fork gets a point EACH sync (0 when it has no clients) so the line stays continuous
                # — no gaps/broken segments when a proxy is briefly idle, exactly like the node/iface graphs. Cheap
                # (few forks/node); mesh stays throttled (N² pairs).
                deployed = {}
                for tp in (snap.get("turn_proxies") or []):
                    deployed.setdefault(turn_fork(tp.get("service") or ""), [0, 0, 0, 0])
                deployed.update(fagg)                            # override the idle 0s with real per-fork traffic
                for fork, (frx, ftx, fon, ftot) in deployed.items():
                    tM = [0] * HRRD_NM; tM[3] = int(frx); tM[4] = int(ftx); tM[11] = fon; tM[12] = ftot   # rx,tx + pon,ptot
                    with contextlib.suppress(Exception):
                        hrrd_update(turn_rrd_path(stats_dir, nid, fork), now_i, tM)
                # TURN source-IP collection: merge the unique client IPs the node ss-sampled per proxy (tp.src_ips) into
                # the panel's unique-IP store. No bytes / no time-series — just first/last-seen + which proxies saw it.
                # "active" is derived at read time from the live snapshot, not stored here.
                tips = Handler.deps.setdefault("turn_ips", {}).setdefault(nid, {})
                for tp in (snap.get("turn_proxies") or []):
                    svc = tp.get("service") or ""
                    for ip in (tp.get("src_ips") or []):
                        if not isinstance(ip, str) or not ip:
                            continue
                        rec = tips.get(ip)
                        if rec is None:
                            if len(tips) >= 1000:                # soft cap/node → evict the oldest-seen
                                tips.pop(min(tips, key=lambda k: tips[k].get("last", 0)), None)
                            rec = tips[ip] = {"first": now_i, "last": now_i, "by": []}
                        rec["last"] = now_i
                        if svc and svc not in rec["by"]:
                            rec["by"].append(svc)
                _tiw = Handler.deps.setdefault("_turn_ips_last_w", [0])
                if now_i - _tiw[0] >= 30:                         # persist throttled (small file; survives restart)
                    with contextlib.suppress(Exception):
                        atomic_write(_turn_ips_path(Handler.deps), json.dumps(Handler.deps.get("turn_ips") or {}))
                    _tiw[0] = now_i
            # PER-PEER throughput history (drives ranged Top talkers). CLIENT ifaces only (skip system/mesh). Sum a
            # peer's rx/tx across this node's ifaces, then lazily ring it — only peers moving ≥ PEER_MIN_BPS get a
            # file, throttled ≤1/min per (node,peer). Panel-derived: rx_speed/tx_speed are already in the snapshot.
            pagg = {}
            online_pks = set()                                  # presence: seen online this sync, traffic or not
            for ifn, blk in (snap.get("interfaces") or {}).items():
                meta = blk.get("meta") or {}; o = ov_ifaces.get(ifn) or {}
                if o.get("system") or meta.get("system"):
                    continue                                    # client ifaces only — mesh peers are never "online users"
                for p in (blk.get("peers") or []):
                    pk = p.get("public_key")
                    if not pk:
                        continue
                    a = pagg.setdefault(pk, [0, 0]); a[0] += p.get("rx_speed", 0) or 0; a[1] += p.get("tx_speed", 0) or 0
                    if p.get("online"):
                        online_pks.add(pk)
            # PRESENCE: union the online peers into this node's bitmap ring. Recorded from `online`, never from
            # traffic, so an idle-but-connected peer still counts — the per-peer traffic rings below cannot.
            if stats_dir:
                with contextlib.suppress(Exception):
                    idx = pres_bits_for(online_pks, stats_dir)
                    pres_feed(pres_path(stats_dir, nid), now_i,
                              [idx[pk] for pk in online_pks if pk in idx], pres_width(len(idx)))
            plast_w = Handler.deps.setdefault("_peer_last_w", {})   # (nid,pubkey) → last RRD write time
            for pk, (prx, ptx) in pagg.items():
                if (prx + ptx) >= PEER_MIN_BPS and now_i - plast_w.get((nid, pk), 0) >= MESH_THROTTLE_S:
                    pM = [0] * HRRD_NM; pM[3] = int(prx); pM[4] = int(ptx)
                    with contextlib.suppress(Exception):
                        hrrd_update(peer_rrd_path(stats_dir, nid, pk), now_i, pM)
                    plast_w[(nid, pk)] = now_i
            # PER-IFACE throughput history (drives the interface-detail graph). CLIENT ifaces only (skip system/mesh).
            # rx/tx = sum of the iface's peers' speeds — the exact value snap_aggregates + the doughnuts use — ringed
            # every sync (few ifaces per node → cheap, as smooth as the node graph). Panel-derived; no node change.
            for ifn, blk in (snap.get("interfaces") or {}).items():
                meta = blk.get("meta") or {}; o = ov_ifaces.get(ifn) or {}
                if o.get("system") or meta.get("system"):
                    continue
                irx = sum((p.get("rx_speed", 0) or 0) for p in (blk.get("peers") or []))
                itx = sum((p.get("tx_speed", 0) or 0) for p in (blk.get("peers") or []))
                iM = [0] * HRRD_NM; iM[3] = int(irx); iM[4] = int(itx)
                with contextlib.suppress(Exception):
                    hrrd_update(iface_rrd_path(stats_dir, nid, ifn), now_i, iM)
        # self-heal the full mesh BEFORE computing desired, so a node that entered the store outside
        # /api/nodes/create (auto-enrolled master/local node) or lost a link conf (convert/re-install)
        # gets its links (re)staged on its very next sync.
        if reconcile_mesh(nodes, Handler.deps.get("node_snaps") or {}, Handler.deps):
            with contextlib.suppress(Exception):
                nodes_save(Handler.deps["nodes_path"], nodes)
        roster = roster_load(Handler.deps["roster_path"])
        desired = desired_for_node(roster, nid)
        _clists = {cl["id"]: cl for cl in ((Handler.deps.get("panel_settings") or {}).get("custom_lists") or []) if cl.get("id")}
        cas_plans = cascade_plan(nodes, Handler.deps.get("node_snaps") or {}, _clists)   # Phase 2/3: whole-fleet forward + smart plan (resolves custom-list rules)
        my_plan = cas_plans.get(nid) or {"forward": [], "smart": [], "exit": [], "allowed": {}}
        _ps = Handler.deps.get("panel_settings") or {}   # Panel settings → mirrors / geo TTL / geo epoch for the node (used in the reply below)
        for _ifn, _mpeers in desired_mesh_for_node(nodes, nid, mesh_cfg(Handler.deps)["keepalive"],
                                                    my_plan.get("allowed"), Handler.deps.get("node_snaps")).items():
            desired.setdefault(_ifn, []).extend(_mpeers)   # node↔node mesh peers (endpoint + keepalive; cascade-aware AllowedIPs)
        # panel-managed interface config the node converges to — drift-aware: push an override until the
        # node confirms it (_synced); once confirmed, if the node diverges (a direct edit on the server)
        # PAUSE pushing + record the node's value in _drift so the panel can flag it (Adopt / Restore).
        snap_ifs = snap.get("interfaces") or {}
        ifaces_dirty = False
        desired_ifaces = {}
        for ifn, ov in (node.get("ifaces") or {}).items():
            rep = (snap_ifs.get(ifn) or {}).get("meta") or {}
            synced = ov.setdefault("_synced", {})
            drift = ov.setdefault("_drift", {})
            d = {}
            sysif = bool(ov.get("system"))   # mesh link — panel-managed: AUTO-ADOPT any node-side change, never drift
            def _clear_drift(k):
                if k in drift:
                    drift.pop(k, None); return True
                return False
            # listen port
            if ov.get("listen_port"):
                want = int(ov["listen_port"]); r = rep.get("listen_port")
                rp = int(r) if str(r).isdigit() else None
                if rp is None:
                    d["listen_port"] = want
                elif rp == want:
                    if synced.get("listen_port") != want:
                        synced["listen_port"] = want; ifaces_dirty = True
                    ifaces_dirty = _clear_drift("listen_port") or ifaces_dirty
                elif synced.get("listen_port") == want and not sysif:   # confirmed, then diverged → drift (user ifaces)
                    if drift.get("listen_port") != rp:
                        drift["listen_port"] = rp; ifaces_dirty = True
                else:                                                   # not yet confirmed → push to converge
                    ifaces_dirty = _clear_drift("listen_port") or ifaces_dirty
                    d["listen_port"] = want
            # AmneziaWG params
            if isinstance(ov.get("awg_params"), dict) and ov["awg_params"]:
                want = ov["awg_params"]; ra = rep.get("awg_params") or {}
                if not ra:
                    d["awg_params"] = want
                elif all(str(ra.get(k)) == str(want[k]) for k in want):
                    if synced.get("awg_params") != want:
                        synced["awg_params"] = dict(want); ifaces_dirty = True
                    ifaces_dirty = _clear_drift("awg_params") or ifaces_dirty
                elif synced.get("awg_params") == want and not sysif:    # confirmed, then diverged → drift (user ifaces)
                    nd = {k: ra.get(k) for k in want}
                    if drift.get("awg_params") != nd:
                        drift["awg_params"] = nd; ifaces_dirty = True
                else:                                                   # not yet confirmed (or a system link) → re-push the panel value
                    ifaces_dirty = _clear_drift("awg_params") or ifaces_dirty
                    d["awg_params"] = want
            # server keypair — the NODE owns the private key (the panel never holds it). Bless the first
            # public key we see; if it later changes (key rotated on the server) flag drift so the operator
            # can Restore (node reverts from its on-disk backup) or Adopt (accept new → every client breaks).
            # A SYSTEM (mesh) link auto-adopts a rotated key instead — a re-install regenerates the keypair,
            # and re-blessing lets the panel hand the new pubkey to the other end so the tunnel re-forms.
            rep_pub = rep.get("public_key")
            if rep_pub:
                blessed = ov.get("public_key")
                if not blessed:
                    ov["public_key"] = rep_pub; ifaces_dirty = True            # first sight → bless it
                elif rep_pub == blessed:
                    ifaces_dirty = _clear_drift("public_key") or ifaces_dirty
                elif sysif:                                                    # mesh link key rotated → auto-adopt (re-bless), no drift
                    ov["public_key"] = rep_pub; _clear_drift("public_key"); ifaces_dirty = True
                elif drift.get("public_key") != rep_pub:
                    drift["public_key"] = rep_pub; ifaces_dirty = True
            # egress IP + WAN NIC: the node doesn't report them back, so always push (no drift tracking).
            # FORWARD mode (cascade to another node) must NOT push a non-local egress_ip — that SNAT lands
            # on the wrong box. Phase 1 stores the forward config but the routing is Phase 2, so skip the push.
            if ov.get("egress_mode") != "forward":
                if "egress_ip" in ov:
                    d["egress_ip"] = ov.get("egress_ip") or ""
                if "wan_iface" in ov:
                    d["wan_iface"] = ov.get("wan_iface") or ""
            if not synced:
                ov.pop("_synced", None)
            if not drift:
                ov.pop("_drift", None)
            if d:
                desired_ifaces[ifn] = d
        if ifaces_dirty:
            with contextlib.suppress(Exception):
                nodes_save(Handler.deps["nodes_path"], nodes)
        # clear a pending self-update once the node reports a version different from when it was requested
        # (robust to the node landing past a lagging docker-panel image version). DON'T clear docker nodes
        # early any more: they DO self-update now via the host updater (swg-noded writes a trigger → the host
        # runs `compose pull && up`), so popping the flag on first sight meant swg-noded usually never received
        # it. A docker node with no host updater wired reports `update-failed` itself, so it won't hang silently.
        upd = node.get("update")
        rv = snap.get("noded_version")
        if upd and rv and rv != upd.get("from"):                       # version advanced → the update landed, clear the request
            node.pop("update", None)
            with contextlib.suppress(Exception):
                nodes_save(Handler.deps["nodes_path"], nodes)
            upd = None
        elif upd and (time.time() - (upd.get("at") or 0)) > PROC_GRACE:   # never landed within the window (hung / couldn't reach GitHub):
            node.pop("update", None)                                       # CLEAR the request so the operator can click Update again (not
            node["proc_status"] = {"state": "update-failed", "at": int(time.time()),   # stuck on "updating") and the node isn't asked to
                                   "err": "Update did not complete within %d min — the node never reported a new version "   # keep self-updating. A real, dismissible failure tag.
                                          "(e.g. it couldn't reach GitHub). Click Update to retry." % (PROC_GRACE // 60)}
            with contextlib.suppress(Exception):
                nodes_save(Handler.deps["nodes_path"], nodes)
            upd = None
        # close onboard/create requests for interfaces the node now reports (it added them on its side)
        for key in ("onboard", "create"):
            reqs = node.get(key) or {}
            if not reqs:
                continue
            present = set((snap.get("interfaces") or {}).keys())
            remaining = {k: v for k, v in reqs.items() if k not in present}
            if remaining != reqs:
                node[key] = remaining
                if not remaining:
                    node.pop(key, None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        # close DELETE requests once the iface is GONE from the snapshot (the node tore it down)
        dele = node.get("delete") or {}
        if dele:
            present = set((snap.get("interfaces") or {}).keys())
            remaining = {k: v for k, v in dele.items() if k in present}
            if remaining != dele:
                node["delete"] = remaining
                if not remaining:
                    node.pop("delete", None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        # clear RETIRE entries once the node stops reporting the pubkey (it removed it)
        retire = node.get("retire") or {}
        if retire:
            snap_ifs2 = snap.get("interfaces") or {}
            r_changed = False
            for ifn in list(retire.keys()):
                cur_pks = {pp.get("public_key") for pp in ((snap_ifs2.get(ifn) or {}).get("peers") or [])}
                kept = [pk for pk in retire[ifn] if pk in cur_pks]   # still on the iface → keep asking the node to drop it
                if kept != retire[ifn]:
                    r_changed = True
                    if kept:
                        retire[ifn] = kept
                    else:
                        retire.pop(ifn, None)
            if r_changed:
                if retire:
                    node["retire"] = retire
                else:
                    node.pop("retire", None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        # close RESTART requests after a grace — the node bounces the iface within a sync cycle
        rst = node.get("restart") or {}
        if rst:
            now_t = int(time.time())
            kept = {k: v for k, v in rst.items() if (now_t - (v or 0)) < 12}
            if kept != rst:
                if kept:
                    node["restart"] = kept
                else:
                    node.pop("restart", None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        # close STOP / START requests once the snapshot reflects the new state (down / up), else after a grace
        ifsnap = snap.get("interfaces") or {}
        now_t = int(time.time())
        for key, want_down in (("iface_stop", True), ("iface_start", False)):
            reqd = node.get(key) or {}
            if not reqd:
                continue
            kept = {}
            for ifc, at in reqd.items():
                e = ifsnap.get(ifc)
                # "up" = reported AND neither down nor stopped. A stopped iface has `stopped` (not `down`), so the
                # old `bool(e.get("down"))==want_down` cleared a start request instantly (down absent) before the
                # node applied it → the start never reached the node. Compare against real up/not-up instead.
                is_up = e is not None and not e.get("down") and not e.get("stopped")
                reflected = (not is_up) if want_down else is_up
                if not reflected and (now_t - (at or 0)) < 30:
                    kept[ifc] = at
            if kept != reqd:
                if kept:
                    node[key] = kept
                else:
                    node.pop(key, None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        # close IFACE_KEY requests after a grace — a rebaseline is a backup-file write (no snapshot effect)
        # and a restore re-keys + restarts within a sync cycle; the public_key drift clears on its own.
        ik = node.get("iface_key") or {}
        if ik:
            now_t = int(time.time())
            kept = {k: v for k, v in ik.items() if (now_t - ((v or {}).get("at") or 0)) < 20}
            if kept != ik:
                node["iface_key"] = kept
                if not kept:
                    node.pop("iface_key", None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        # close turn-proxy requests once the node reflects them (delete: service gone; onboard: it
        # appears; manage/rotate: the node applied + restarted — verified by listen match, else a grace)
        turn = node.get("turn") or {}; turn_onb = node.get("turn_onboard") or []
        if turn or turn_onb:
            now_ts = int(time.time())   # NB: the module 'now' lambda is local to the api handler — not in scope here
            tps = {tp.get("service"): tp for tp in (snap.get("turn_proxies") or []) if tp.get("service")}
            t_changed = False
            for svc, req in list(turn.items()):
                act, age = req.get("action"), now_ts - (req.get("at") or 0)
                tp = tps.get(svc)
                if act == "delete":
                    done = svc not in tps
                elif act == "install":              # clears once the new service shows up
                    done = svc in tps or age > 240   # generous: download can take a couple minutes
                elif act in ("manage", "restart"):
                    done = (tp and ("listen" not in req or tp.get("listen") == req["listen"])
                            and ("connect" not in req or tp.get("connect") == req["connect"]) and age > 5) or age > 60
                elif act == "title":                # clears once the node's record shows the new title
                    done = (tp is not None and tp.get("title", "") == req.get("title", "")) or age > 30
                elif act == "stop":                 # clears once the node reports it stopped (or it's gone)
                    done = (tp is not None and tp.get("stopped")) or (svc not in tps) or age > 30
                elif act == "start":                # clears once it's running again (not stopped)
                    done = (tp is not None and tp.get("running") and not tp.get("stopped")) or age > 60
                else:   # rotate — panel can't see the new key; give the node time to regen + restart
                    done = age > 12
                if done:
                    turn.pop(svc, None); t_changed = True
            def _svc(sp): b = sp.rsplit("/", 1)[-1]; return b[:-8] if b.endswith(".service") else b
            new_onb = [sp for sp in turn_onb if _svc(sp) not in tps]
            if new_onb != turn_onb:
                t_changed = True
            if t_changed:
                if turn: node["turn"] = turn
                else: node.pop("turn", None)
                if new_onb: node["turn_onboard"] = new_onb
                else: node.pop("turn_onboard", None)
                with contextlib.suppress(Exception):
                    nodes_save(Handler.deps["nodes_path"], nodes)
        interval = (Handler.deps.get("fleet") or {}).get("node_interval", 5)
        # ── Provider-list manifest ──────────────────────────────────────────────────────────────────────
        # For each PROVIDER-catalog category (<prov>:<id>) this node routes, ship the current resolved-list
        # version per tier so the node pulls a list from the panel ONLY when its version changed (and pulls a
        # newly-routed one immediately). Disabled-provider cats are omitted → the node GC drops their sets.
        # Built-ins (legacy) and custom cats are NOT here (they keep their existing inline/GitHub paths). The
        # panel re-resolves a routed list in the background when its cache is older than the schedule cadence.
        _node_mode = node.get("routing_mode") or "kernel"
        _enabled_prov = _ps.get("providers") or {}
        _gu = _ps.get("geo_update") or {}
        _cadence = max(1, int(_gu.get("every_days") or 1)) * 86400   # panel re-resolve cadence (0/continuous → daily fetch is fine)
        _cix = catalog_index()
        _list_manifest = {}
        for _c in {e["category"] for e in (my_plan.get("smart") or [])}:
            _curated = ":" not in _c and _c in SMART_CATEGORIES and _c != "all"   # built-in → panel-resolved + panel-pulled (Phase 2)
            if ":" not in _c and not _curated:                     # custom_<hash> / "all" → not panel-served (ship inline)
                continue
            if not _curated and not _enabled_prov.get(_c.split(":", 1)[0], False):   # provider not enabled → omit (node deletes the set)
                continue
            _caps = SMART_CAPS.get(_c, {}) if _curated else (_cix.get(_c) or {})
            _ent = {}
            for _tier in ("ip", "host"):
                if not _caps.get(_tier):
                    continue
                if _tier == "host" and _node_mode == "kernel":    # kernel matches by IP only → no host lists
                    continue
                _mt = list_meta(_c, _tier)
                _due = (not _mt) or (int(time.time()) - int((_mt or {}).get("at") or 0) > _cadence)
                _mt = list_ensure(_c, _tier, force=_due) or _mt    # background (re)resolve; ships current (old) version until the new one lands
                if _mt:
                    _ent[_tier] = _mt["v"]
            if _ent:
                _list_manifest[_c] = _ent
        return self._send(200, {"desired": desired, "desired_ifaces": desired_ifaces,
                                "remove": node.get("retire") or {},   # pubkeys to drop even on add-only ifaces (rotated/deleted)
                                "delete": list((node.get("delete") or {}).keys()),
                                "restart": list((node.get("restart") or {}).keys()),   # interfaces to bounce
                                "iface_stop": list((node.get("iface_stop") or {}).keys()),    # interfaces to stop (down + disable)
                                "iface_start": list((node.get("iface_start") or {}).keys()),  # interfaces to start (up + enable)
                                "onboard": node.get("onboard") or {}, "create": node.get("create") or None,
                                "turn": node.get("turn") or {}, "turn_onboard": node.get("turn_onboard") or [],
                                "iface_key": node.get("iface_key") or {},   # per-iface {restore|rebaseline} keypair requests
                                "cascade": {"forward": my_plan.get("forward") or [], "exit": my_plan.get("exit") or []},   # Phase 2: policy-route forwards + exit SNAT
                                "smart": {"entries": my_plan.get("smart") or [],   # Phase 3: per-destination category routing (entry marking)
                                          "mode": node.get("routing_mode") or "kernel",   # kernel | forcedns | sni — the node picks its fill mechanism from this
                                          "categories": sorted({e["category"] for e in (my_plan.get("smart") or [])}),
                                          # per-category caps {ip,host}: provider cats from the catalog index, built-ins from SMART_CAPS.
                                          # The node reads its <cat>.txt/.doms (pulled from the panel via list_manifest) using these — a
                                          # curated cat's host cap is what gets its pulled .doms loaded into dnsmasq (custom cats ship inline).
                                          "cat_caps": {**{c: SMART_CAPS[c] for c in {e["category"] for e in (my_plan.get("smart") or [])}
                                                          if c in SMART_CAPS},
                                                       **{c: catalog_index().get(c) for c in {e["category"] for e in (my_plan.get("smart") or [])}
                                                          if c in catalog_index() and c not in SMART_CATEGORIES}},
                                          # domain tier: active bundles + custom-rule domain lists → node fills these via dnsmasq. ONLY for a
                                          # DNS/SNI-mode node; a Kernel-only node (the default) gets no domains and matches purely by geoip.
                                          "domains": ({**{c: DOMAIN_BUNDLES.get(c, []) for c in {e["category"] for e in (my_plan.get("smart") or [])} if c in HOST_CATEGORIES},
                                                       **(my_plan.get("domains") or {})} if (node.get("routing_mode") or "kernel") != "kernel" else {}),
                                          "list_manifest": _list_manifest,   # provider-catalog cats → {tier: version}; node pulls each list from the panel on version change
                                          "cidrs": my_plan.get("cidrs") or {},   # custom-rule raw IPs/CIDRs → always loaded (DoH-proof) regardless of mode
                                          # Force-DNS guard: the node drops smart-subnet DoH/DoT so clients can't bypass its DNS-based
                                          # domain fill. Only in forcedns mode — kernel needs no DNS, and sni reads the TLS handshake so it
                                          # leaves the client's DNS (incl. DoH) untouched by design.
                                          "block_doh": (node.get("routing_mode") or "kernel") == "forcedns",
                                          "ip_learning": node.get("ip_learning", True),   # keep learned SNI IPs (True) vs stay fresh with a short TTL (False)
                                          "routing_reset": int(node.get("routing_reset") or 0),   # per-node 'Reset all routing' counter → node wipes+rebuilds+re-pulls when it changes
                                          "routing_reset_learned": int(node.get("routing_reset_learned") or 0)},   # 'Reset learned IPs' counter → node clears only its learned-IP sets
                                "node_egress": {"default_egress_ip": node.get("default_egress_ip") or "",   # node IP roles (Part 2)
                                                "panel_ip": node.get("panel_ip") or ""},
                                "panel": {"geo_mirror": (_ps.get("mirrors") or {}).get("geo") or "",   # Panel settings → node (Part 5)
                                          "turn_mirror": (_ps.get("mirrors") or {}).get("turn") or "",
                                          "geo_ttl_days": (_ps.get("advanced") or {}).get("geo_ttl_days") or 3,
                                          "geo_update": {"every_days": int((_gu.get("every_days") if _gu.get("every_days") is not None else 1)),
                                                         "at": _gu.get("at") or "04:00"},   # node applies a CHANGED provider list only in this quiet-hour window (new lists apply immediately)
                                          "geo_epoch": _ps.get("geo_epoch") or 0},
                                "update": upd or None, "interval": interval})

    def _node_goodbye(self):
        # The node's uninstaller signs off here (its bearer token). We ONLY complete a full removal (archive +
        # cascade-delete its peers) when the OPERATOR asked for it — i.e. they hit Nodes → remove, which set the
        # `removing` flag. An UNSOLICITED uninstall (someone ran the uninstaller on the box) must NOT delete the
        # node or its peers: peers whose only deployment is here would silently vanish — a destructive surprise.
        # In that case we keep everything; the node just goes stale/offline, and a re-install with the same token
        # re-syncs its peers. The operator can still Nodes → remove afterwards to purge it for good.
        nodes = nodes_load(Handler.deps["nodes_path"])
        hdr = self.headers.get("Authorization", "")
        token = hdr[7:].strip() if hdr.startswith("Bearer ") else ""
        nid, _ = find_node_by_token(nodes, token)
        if not nid:
            return self._send(401, {"error": "invalid node token"})
        with _api_lock:
            nodes = nodes_load(Handler.deps["nodes_path"])   # re-read under the lock
            if nid not in nodes:
                return self._send(200, {"ok": True, "kept": nid})
            if nodes[nid].get("removing"):
                nm = node_remove(Handler.deps, nid)
                return self._send(200, {"ok": True, "removed": nm or nid})
            # UNSOLICITED uninstall: keep the node + peers, but flag it 'uninstalled' so the UI shows a grey
            # "Uninstalled" tag (recoverable by re-installing with the same token). Drop the live snapshot/seen
            # so it reads offline at once. The flag clears the instant the node syncs again (see _node_sync).
            nodes[nid]["uninstalled"] = int(time.time())
            nodes[nid].pop("proc_status", None)   # the node is gone now — supersede any "uninstalling" tag
            nodes_save(Handler.deps["nodes_path"], nodes)
            (Handler.deps.get("node_snaps") or {}).pop(nid, None)
            (Handler.deps.get("node_seen") or {}).pop(nid, None)
            ev_append(Handler.deps["roster_path"], "node", nid, "Node uninstalled — kept for re-install",
                      nodes[nid].get("name", nid))
        return self._send(200, {"ok": True, "kept": nid})

    def _node_proc_status(self):
        # An installer/converter (its bearer token) flags that the node is about to go down for a
        # re-install or a method conversion, so the UI shows that instead of plain "offline". Cleared
        # when the node's next snapshot lands (it's back) — see _node_sync.
        nodes = nodes_load(Handler.deps["nodes_path"])
        hdr = self.headers.get("Authorization", "")
        token = hdr[7:].strip() if hdr.startswith("Bearer ") else ""
        nid, _ = find_node_by_token(nodes, token)
        if not nid:
            return self._send(401, {"error": "invalid node token"})
        length = self._body_len()
        if length is None:
            return
        try:
            body = json.loads(self.rfile.read(length) or b"{}") if length else {}
        except Exception:
            body = {}
        state = (body.get("state") or "").strip()
        err = (body.get("err") or "").strip()[:4000]   # failed-state log tail for the error popup
        with _api_lock:
            if _proc_inprogress(state) or _proc_terminal(state):
                ps = {"state": state, "at": int(time.time())}
                if err and (state.endswith("-failed") or state == "failed"):
                    ps["err"] = err
                nodes[nid]["proc_status"] = ps
                nodes[nid].pop("uninstalled", None)   # any active lifecycle (re-installing / updating / …) means the node is BACK → drop the grey "Uninstalled" tag so its real status (reinstalling → reinstalled-updated / failed) shows through
                if state == "reinstalling":   # a re-install adopts the node's CURRENT server keys → drop pinned/drift pubkeys
                    for ov in (nodes[nid].get("ifaces") or {}).values():
                        ov.pop("public_key", None)
                        if isinstance(ov.get("_drift"), dict):
                            ov["_drift"].pop("public_key", None)
                            if not ov["_drift"]:
                                ov.pop("_drift", None)
            else:
                nodes[nid].pop("proc_status", None)          # blank/unknown = clear it
            nodes_save(Handler.deps["nodes_path"], nodes)
        return self._send(200, {"ok": True, "data": {"id": nid, "state": state}})

    def _node_whoami(self):
        # Identify a node by its bearer token — for the installer's leftover-token salvage, so it can show
        # the operator the node's name / method / last-online instead of an opaque token. Read-only.
        nodes = nodes_load(Handler.deps["nodes_path"])
        hdr = self.headers.get("Authorization", "")
        token = hdr[7:].strip() if hdr.startswith("Bearer ") else ""
        nid, node = find_node_by_token(nodes, token)
        if not nid:
            return self._send(404, {"ok": False, "error": "unknown node token"})
        snap = (Handler.deps.get("node_snaps") or {}).get(nid) or {}
        return self._send(200, {"ok": True, "data": {
            "name": node.get("name", nid),
            "kind": node.get("kind") or snap.get("kind") or "",
            "created": node.get("created"),
            "last_seen": (Handler.deps.get("node_seen") or {}).get(nid)}})

    def _node_list(self, u):
        # Serve a resolved provider list (raw text: one CIDR/domain per line) for a routed category+tier.
        # Node-token auth; the node pulls this only for cats named in its own list_manifest, on version change.
        nodes = nodes_load(Handler.deps["nodes_path"])
        hdr = self.headers.get("Authorization", "")
        token = hdr[7:].strip() if hdr.startswith("Bearer ") else ""
        nid, _node = find_node_by_token(nodes, token)
        if not nid:
            return self._send(401, {"error": "invalid node token"})
        q = parse_qs(u.query)
        cat = (q.get("cat") or [""])[0].strip()
        tier = (q.get("tier") or [""])[0].strip()
        _curated = ":" not in cat and cat in SMART_CATEGORIES and cat != "all"   # built-in → panel-resolved, always served
        if tier not in ("ip", "host") or (":" not in cat and not _curated):
            return self._send(400, {"error": "bad cat/tier"})
        if not _curated and not ((Handler.deps.get("panel_settings") or {}).get("providers") or {}).get(cat.split(":", 1)[0], False):
            return self._send(403, {"error": "provider disabled"})   # never serve a not-enabled provider's list
        meta = list_meta(cat, tier)
        try:
            with open(_list_path(cat, tier), "rb") as f:
                data = f.read()
        except OSError:
            list_ensure(cat, tier)                                    # kick a resolve; node retries next sync
            return self._send(404, {"error": "not resolved yet"})
        self.send_response(200)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("X-List-Version", (meta or {}).get("v", ""))
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        with contextlib.suppress(BrokenPipeError):
            self.wfile.write(data)

    def _node_rename(self):
        # A node renames ITSELF (node-token auth) — so a re-install/convert can push a box-name change the
        # operator entered in the installer. name is a free display field (id-keyed store); no refs to migrate.
        nodes = nodes_load(Handler.deps["nodes_path"])
        hdr = self.headers.get("Authorization", "")
        token = hdr[7:].strip() if hdr.startswith("Bearer ") else ""
        nid, _ = find_node_by_token(nodes, token)
        if not nid:
            return self._send(401, {"error": "invalid node token"})
        length = self._body_len()
        if length is None:
            return
        try:
            body = json.loads(self.rfile.read(length) or b"{}") if length else {}
        except Exception:
            body = {}
        name = strip_ctrl((body.get("name") or "").strip())[:40]   # node names itself (node-token) — drop control chars
        if not name:
            return self._send(400, {"ok": False, "error": "empty name"})
        with _api_lock:
            old = nodes[nid].get("name", nid)
            nodes[nid]["name"] = name
            nodes_save(Handler.deps["nodes_path"], nodes)
        if name != old:
            ev_append(Handler.deps["roster_path"], "node", nid, "Renamed node", name)
        return self._send(200, {"ok": True, "data": {"id": nid, "name": name}})

    def do_GET(self):
        _REQ.listener_id = getattr(self.server, "listener_id", None)   # which listener → the Access-apply confirm gate
        u = urlparse(self.path)
        path = strip_base(u.path)
        if path is None:
            return self.send_error(404)
        if path in STATIC:                 # SPA assets are public so the login page can load
            return self._static(path)
        if path == "/api/node/whoami":     # node-token auth (not a session) — lets a re-installer identify a leftover token
            return self._node_whoami()
        if path == "/api/node/list":       # node-token auth — serve a resolved provider list (raw text) for a routed cat/tier
            return self._node_list(u)
        if path == "/healthz" or path == "/metrics" or path.startswith("/api/v1/"):
            return self._ext_api(path, u)  # external integration API — its OWN token/session auth (read-only)
        if not self._require_auth():       # everything else (data) needs a session
            return
        if path.startswith("/wgstats/"):
            return self._wgstats(path)
        if path.startswith("/api/"):
            if path == "/api/state":       # the hot poll path — served from the short-TTL memo
                return self._send_state()
            try:
                code, obj = api("GET", path, parse_qs(u.query), {}, self.deps)
            except Exception as e:
                code, obj = 500, {"ok": False, "error": str(e), "code": "internal"}
            return self._send(code, obj)
        self.send_error(404)

    def do_POST(self):
        _REQ.listener_id = getattr(self.server, "listener_id", None)   # which listener → the Access-apply confirm gate
        u = urlparse(self.path)
        path = strip_base(u.path)
        if path == "/api/node/sync":
            try:
                return self._node_sync()
            except Exception as e:        # never drop the connection (a proxy turns that into a 5xx/520) — a node skips a non-200 pass safely
                import traceback; traceback.print_exc()
                return self._send(500, {"ok": False, "error": str(e), "code": "internal"})
        if path == "/api/node/goodbye":
            return self._node_goodbye()
        if path == "/api/node/proc-status":
            return self._node_proc_status()
        if path == "/api/node/rename":     # node-token auth — installer pushes a box-name change
            return self._node_rename()
        if path == "/api/login":
            return self._login()
        if path == "/api/logout":
            return self._logout()
        if not self._require_auth():
            return
        if path is None or not path.startswith("/api/"):
            return self.send_error(404)
        length = self._body_len()
        if length is None:
            return
        raw = self.rfile.read(length) if length else b"{}"
        try:
            bodyobj = json.loads(raw or b"{}")
            if not isinstance(bodyobj, dict):
                raise ValueError
        except (json.JSONDecodeError, ValueError):
            return self._send(400, {"ok": False, "error": "invalid JSON body", "code": "bad_request"})
        try:
            with _api_lock:                       # mutations are read-modify-write; serialize them
                code, obj = api("POST", path, {}, bodyobj, self.deps)
        except Exception as e:
            code, obj = 500, {"ok": False, "error": str(e), "code": "internal"}
        if 200 <= code < 300:
            _invalidate_state_cache()             # a successful mutation → next poll rebuilds immediately
        self._send(code, obj)

    def log_message(self, *a):
        pass


def passwd_cmd(argv):
    """`swg-panel-server passwd` → the dedicated `swg-passwd` command, so this invocation resets the
    login instead of (the old footgun) falling through and starting a second server."""
    sp = shutil.which("swg-passwd") or "/usr/local/bin/swg-passwd"
    if os.path.exists(sp):
        os.execv(sp, [sp] + list(argv[2:]))
    raise SystemExit("reset the panel login with:  sudo swg-passwd")


# ───────────────────────── live listeners + Access & TLS apply ─────────────────────────
# The panel normally serves on ONE socket. Changing its OWN bind (IP/port) can't just restart onto the
# new address — a bad value would lock the operator out. So the apply flow binds a SECOND listener on the
# new address, keeps the OLD one serving, and drops the old only after the browser CONFIRMS the new one
# works (a redirect that lands and POSTs /api/access/confirm ON the new listener). No confirm in time →
# the new listener is dropped and the old never stopped. All in-process, so rollback needs no restart.
APPLY_TIMEOUT = 30                       # seconds the operator's browser has to confirm the new address

class _TLSServer(ThreadingHTTPServer):
    # TLS is wrapped PER CONNECTION in the worker thread (not on the listening socket): wrapping the
    # listener does the handshake inside accept(), so one stalled/half-open client (a scanner, a Cloudflare
    # probe, a dropped packet) wedges the accept loop and the whole panel stops answering. ssl_ctx=None →
    # plain HTTP (behind a reverse proxy, or the local dev panel).
    daemon_threads = True
    allow_reuse_address = True
    ssl_ctx = None
    listener_id = None
    def get_request(self):
        sock, addr = self.socket.accept(); sock.settimeout(60); return sock, addr
    def finish_request(self, request, client_address):
        if self.ssl_ctx is not None:
            request = self.ssl_ctx.wrap_socket(request, server_side=True)
        super().finish_request(request, client_address)
    def handle_error(self, request, client_address):
        pass                             # failed handshake / scanner / client vanished — routine noise


class _Listeners:
    """Registry of the panel's live listening sockets, each served in its own daemon thread. Add/remove
    at runtime so Access & TLS can dual-listen during an address change."""
    def __init__(self):
        self._lock = threading.Lock(); self._by_id = {}; self._seq = 0
    def add(self, host, port, cert, key, primary=False):
        srv = _TLSServer((host, port), Handler)        # binds here — raises OSError if the port is taken
        if cert and key:
            ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER); ctx.load_cert_chain(cert, key); srv.ssl_ctx = ctx
        with self._lock:
            self._seq += 1; lid = self._seq
            srv.listener_id = lid
            srv._swg = {"host": host, "port": port, "cert": cert, "key": key, "primary": primary}
            self._by_id[lid] = srv
        threading.Thread(target=srv.serve_forever, name="listener-%d" % lid, daemon=True).start()
        return lid
    def remove(self, lid):
        with self._lock:
            srv = self._by_id.pop(lid, None)
        if srv is None:
            return False
        with contextlib.suppress(Exception): srv.shutdown()
        with contextlib.suppress(Exception): srv.server_close()
        return True
    def get(self, lid):
        with self._lock:
            return self._by_id.get(lid)
    def primary(self):
        with self._lock:
            for lid, srv in self._by_id.items():
                if getattr(srv, "_swg", {}).get("primary"):
                    return lid, srv
        return None, None
    def reload_tls(self):                              # SIGHUP → every TLS listener re-reads its cert
        with self._lock:
            srvs = list(self._by_id.values())
        for srv in srvs:
            m = getattr(srv, "_swg", {})
            if srv.ssl_ctx is not None and m.get("cert") and m.get("key"):
                with contextlib.suppress(Exception):
                    srv.ssl_ctx.load_cert_chain(m["cert"], m["key"])


LISTENERS = _Listeners()
_REQ = threading.local()                 # per-request: which listener this request arrived on (set in do_GET/POST)
_APPLY = {"lock": threading.Lock(), "pending": None,
          "status": {"state": "idle", "message": "", "at": 0}}


def _apply_status(state, message="", **extra):
    s = {"state": state, "message": message, "at": int(time.time())}
    s.update(extra)                          # verifying carries nonce/redirect/host/port/expires for the UI
    _APPLY["status"] = s


def _cert_covers(cert_path, domain):
    """Does the cert at cert_path already cover `domain` (exact SAN/CN or a matching wildcard)? A domain
    change that the current cert doesn't cover is what triggers re-issuance before the new listener binds."""
    if not cert_path or not domain or not os.path.exists(cert_path):
        return False
    names = set()
    try:
        info = ssl._ssl._test_decode_cert(cert_path)            # stdlib cert parse (subject + SANs)
        for typ, val in info.get("subjectAltName", ()):
            if typ == "DNS":
                names.add(val.lower())
        for rdn in info.get("subject", ()):
            for k, v in rdn:
                if k == "commonName":
                    names.add(str(v).lower())
    except Exception:
        return False
    d = domain.lower()
    for n in names:
        if n == d or (n.startswith("*.") and d.split(".", 1)[-1:] == [n[2:]]):
            return True
    return False


def _netctl_wait(deps, rid, timeout=180):
    """Poll swg-netctl's status dir for the result of request `rid`. Returns (ok, message)."""
    if not rid:
        return False, "the root helper is not available"
    spath = os.path.join(os.path.dirname(deps.get("nodes_path") or ".") or ".",
                         "netctl", "status", rid + ".json")
    deadline = time.time() + timeout
    while time.time() < deadline:
        try:
            with open(spath) as f:
                doc = json.load(f)
            with contextlib.suppress(OSError):
                os.unlink(spath)
            return (doc.get("status") == "ok"), (doc.get("message") or "")
        except (OSError, ValueError):
            time.sleep(1)
    return False, "timed out waiting for the root helper"


def _netctl_enqueue(deps, verb, args):
    """Drop a validated request for the root helper (swg-netctl) into its queue. Best-effort: no queue dir
    (dev rig / not installed) → no-op, and the live in-process change still holds until the next restart."""
    qdir = os.path.join(os.path.dirname(deps.get("nodes_path") or ".") or ".", "netctl", "queue")
    if not os.path.isdir(qdir):
        return None
    rid = "acc-" + secrets.token_hex(6)
    with contextlib.suppress(Exception):
        tmp = os.path.join(qdir, rid + ".json.tmp")
        with open(tmp, "w") as f:
            json.dump({"id": rid, "verb": verb, "args": [str(a) for a in args], "nonce": rid}, f)
        os.replace(tmp, os.path.join(qdir, rid + ".json"))
        return rid
    return None


def _apply_timeout(nonce, deps):
    """Fires APPLY_TIMEOUT after an apply: if the new address never confirmed, drop it and keep the old."""
    with _APPLY["lock"]:
        pend = _APPLY["pending"]
        if not pend or pend.get("nonce") != nonce:
            return                       # already confirmed, or a newer apply superseded this one
        LISTENERS.remove(pend["new_lid"])
        _APPLY["pending"] = None
        _apply_status("reverted", "the new address didn't confirm in time — reverted to the previous one")


def _arm_pending(deps, new_lid, old_lid, host, port, url):
    """Register the freshly-bound listener as the pending change, publish nonce+redirect for the UI, and
    arm the revert timer. Caller holds _APPLY['lock']."""
    nonce = secrets.token_hex(12)
    deadline = int(time.time()) + APPLY_TIMEOUT
    sep = "&" if ("?" in url) else "?"
    redirect = (url + sep + "__apply=" + nonce) if url else None
    _APPLY["pending"] = {"nonce": nonce, "new_lid": new_lid, "old_lid": old_lid,
                         "host": host, "port": port, "deadline": deadline}
    _apply_status("verifying", "waiting for %s:%d to confirm" % (host, port),
                  nonce=nonce, redirect=redirect, host=host, port=port, expires=deadline)
    threading.Timer(APPLY_TIMEOUT + 1, _apply_timeout, args=(nonce, deps)).start()
    return nonce, redirect, deadline


def _apply_panel_cert_then_bind(deps, d_host, d_port, d_url, d_domain, old_lid):
    """Background worker for a panel address change that needs a NEW cert (domain changed): issue via the
    root helper, then dual-listen with the fresh cert. Failures clear the pending reservation."""
    try:
        _apply_status("issuing", "issuing a certificate for %s" % d_domain)
        rid = _netctl_enqueue(deps, "issue-cert", ["panel", d_domain])
        ok, msg = _netctl_wait(deps, rid, 180)
        if not ok:
            with _APPLY["lock"]:
                _APPLY["pending"] = None
            return _apply_status("failed", "certificate issuance failed: " + (msg or "unavailable"))
        try:
            new_lid = LISTENERS.add(d_host, d_port, TLS_CERT, TLS_KEY)   # the freshly-installed panel cert
        except OSError as e:
            with _APPLY["lock"]:
                _APPLY["pending"] = None
            return _apply_status("failed", "couldn't bind %s:%d — %s" % (d_host, d_port, e))
        with _APPLY["lock"]:
            _arm_pending(deps, new_lid, old_lid, d_host, d_port, d_url)
    except Exception as e:                   # never leave a stuck reservation
        with _APPLY["lock"]:
            _APPLY["pending"] = None
        _apply_status("failed", "internal error: %s" % (e,))


# swg-sub's apply is separate + simpler: it's a distinct process, and restarting it can't lock the admin
# out, so there's no dual-listen or confirm — just issue the cert (if the domain isn't covered), persist the
# bind, restart. Tracked in its OWN status so a panel apply and a sub apply can be in flight independently.
SUB_CERT_PATH = os.environ.get("SWG_SUB_TLS_CERT_PATH", "/etc/swg-sub/tls/fullchain.pem")
_SUBAPPLY = {"lock": threading.Lock(), "status": {"state": "idle", "message": "", "at": 0}}


def _subapply_status(state, message="", **extra):
    s = {"state": state, "message": message, "at": int(time.time())}
    s.update(extra)
    _SUBAPPLY["status"] = s


def _apply_sub_worker(deps, d_host, d_port, d_url, d_domain, mode):
    try:
        if d_domain and mode in ("cloudflare", "letsencrypt", "selfsigned", "cf15", "letsencrypt-ip") \
                and not _cert_covers(SUB_CERT_PATH, d_domain):
            _subapply_status("issuing", "issuing a certificate for %s" % d_domain)
            ok, msg = _netctl_wait(deps, _netctl_enqueue(deps, "issue-cert", ["sub", d_domain]), 180)
            if not ok:
                return _subapply_status("failed", "certificate issuance failed: " + (msg or "unavailable"))
        # persist the bind (drop-in), WAIT for it, THEN restart — the two requests must run in order and the
        # queue is drained by sorted filename, which is random for two ids, so we serialize them here.
        _subapply_status("applying", "applying %s:%d" % (d_host, d_port))
        ok, msg = _netctl_wait(deps, _netctl_enqueue(deps, "set-listen", ["sub", d_host, d_port]), 30)
        if not ok:
            return _subapply_status("failed", "couldn't set the address: " + (msg or "unavailable"))
        ok, msg = _netctl_wait(deps, _netctl_enqueue(deps, "restart", ["sub"]), 60)
        if not ok:
            return _subapply_status("failed", "restart failed: " + (msg or "unavailable"))
        _subapply_status("saved", "subscription server now on %s:%d" % (d_host, d_port))
    except Exception as e:
        _subapply_status("failed", "internal error: %s" % (e,))


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "passwd":   # host-side password reset, never starts the server
        return passwd_cmd(sys.argv)
    fleet = load_json(FLEET_PATH, None)
    if fleet is None:
        raise SystemExit(f"cannot read fleet config: {FLEET_PATH}")
    nodes_path = fleet.get("nodes_path", "/var/lib/swg-panel/nodes.json")
    # Single-instance-per-state-dir guard: two swg-panel-servers sharing one state dir keep INDEPENDENT in-memory
    # copies of nodes.json and clobber each other's writes → node-token desync → sync 401 → no config propagates.
    # (A stray no-auth :8091 test panel on the live state dir did exactly this.) A dryrun/test panel with its OWN
    # state dir (SWG_PANEL_FLEET → different nodes_path) takes a different lock, so it is unaffected. flock releases
    # automatically on exit/crash.
    _statedir = os.path.dirname(nodes_path) or "."
    globals()["CATALOG_PATH"] = os.path.join(_statedir, "catalog-index.json")   # catalog cache lives in the state dir
    globals()["PROV_STATUS_PATH"] = os.path.join(_statedir, "provider-status.json")   # per-provider update status
    globals()["LIST_DIR"] = os.path.join(_statedir, "lists")                    # resolved per-category lists served to nodes
    _prov_status_load()
    _lp = os.path.join(_statedir, ".panel.lock")
    try:
        _lockfd = os.open(_lp, os.O_WRONLY | os.O_CREAT, 0o600)
        fcntl.flock(_lockfd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        raise SystemExit(f"refusing to start: another swg-panel-server already holds {_lp} (state dir {_statedir}). "
                         f"Two panels on one state dir clobber nodes.json (desyncs node tokens → sync 401). "
                         f"Stop the other instance first, or point this one at a separate state dir.")
    os.ftruncate(_lockfd, 0); os.write(_lockfd, (str(os.getpid()) + "\n").encode())
    globals()["_STATE_LOCK_FD"] = _lockfd     # keep the fd open for the process lifetime → lock held until exit
    # After the state-dir lock (so two panels can't repair concurrently) and before serving: one-shot rebuild of
    # the coarse rings' headcounts, which older builds averaged into zeros. Marker file → runs once per install.
    with contextlib.suppress(Exception):
        hrrd_repair_all(fleet.get("stats_dir"))
    _rp = fleet.get("roster_path", "/var/lib/swg-panel/users.json")
    _sc = fleet.get("store_configs", True) is not False
    _cd = fleet.get("config_dir") or os.path.join(os.path.dirname(_rp) or ".", "configs")
    migrate_node_ids(nodes_path, _rp, _sc, _cd)        # legacy name-keyed -> stable id-keyed (one-time)
    _psp = fleet.get("panel_settings_path") or os.path.join(os.path.dirname(nodes_path) or ".", "panel-settings.json")
    migrate_ru_split(nodes_path, _psp)   # 'ru' -> 'ru_net' (ru_blocked split out; one-time)
    migrate_provider_defaults(nodes_path, _psp)   # providers default OFF, but keep already-routed ones enabled (one-time)
    normalize_stats_files(nodes_path, fleet.get("stats_dir", "/var/www/wgstats"))   # stats_file -> stats-<id>.json (id-keyed health files survive convert)
    _hpp = os.path.join(os.path.dirname(nodes_path) or ".", "host_proc")   # this host's re-install/convert flag
    with contextlib.suppress(Exception):
        # a fresh panel process means an in-flight RE-INSTALL is done → drop its tag. A CONVERT, though, writes its
        # terminal (converted/aborted/failed) AFTER the new panel is up, so KEEP a "converting-*" tag in place —
        # dropping it here blanks the header between "converting" and "converted" (the visible gap on switch-over).
        with open(_hpp) as _f:
            _hpfirst = (_f.readline() or "").strip()
        if not _hpfirst.startswith("converting"):
            os.remove(_hpp)
    _psp = fleet.get("panel_settings_path") or os.path.join(os.path.dirname(nodes_path) or ".", "panel-settings.json")
    Handler.deps = {"fleet": fleet, "host_proc_path": _hpp,
                    "roster_path": fleet.get("roster_path", "/var/lib/swg-panel/users.json"),
                    "stats_dir": fleet.get("stats_dir", "/var/www/wgstats"),
                    "panel_settings_path": _psp, "panel_settings": load_panel_settings(_psp),
                    "nodes_path": nodes_path, "nodes": nodes_load(nodes_path),
                    "node_snaps": {}, "node_seen": {}, "live_samples": {},
                    "auth": load_auth(),
                    "session_secret": load_session_secret(fleet.get("roster_path", "/var/lib/swg-panel/users.json")),
                    "twofa_path": os.path.join(os.path.dirname(fleet.get("roster_path", "/var/lib/swg-panel/users.json")) or ".", "2fa.json"),
                    "sub_dir": os.path.join(os.path.dirname(fleet.get("roster_path", "/var/lib/swg-panel/users.json")) or ".", "subs"),
                    "now": lambda: int(time.time())}
    Handler.deps["turn_ips"] = load_json(_turn_ips_path(Handler.deps), {}) or {}   # unique turn-proxy source-IP history (survives restart)
    write_sub_serve(Handler.deps)   # seed/refresh subs/serve.json so swg-sub has current enable/serve config from boot (even when subscriptions were never touched)
    normalize_sub_perms(Handler.deps)   # make swg-sub's readable subset group-readable (fixes 0600 files from older builds)
    # panel version-change → one "Panel updated" activity event (from→to). Tracked in an isolated
    # marker file so it never rides on the settings dict. First-ever boot just records the baseline.
    with contextlib.suppress(Exception):
        _cur_ver = _read_version()
        _vpath = os.path.join(os.path.dirname(nodes_path) or ".", "panel_version")
        _last = ""
        if os.path.exists(_vpath):
            with open(_vpath) as _vf:
                _last = (_vf.readline() or "").strip()
        if _cur_ver and _last and _last != _cur_ver:
            ev_append(Handler.deps["roster_path"], "panel", "update", "Panel updated", _last + " → " + _cur_ver)
        if _cur_ver and _last != _cur_ver:
            atomic_write(_vpath, _cur_ver + "\n")
    # warm-start: seed the in-memory snapshot cache from the mirrored stats files so a fresh panel process (a
    # restart, or the switch-over of a docker↔bare convert) shows each node's LAST-KNOWN state immediately, instead
    # of "awaiting enroll" + dashes until the next sync (~node_interval). Staleness still rides on each snapshot's
    # generated_at, so a node that was genuinely down reads as stale, not falsely online.
    for _nid, _c in Handler.deps["nodes"].items():
        _snap = load_json(os.path.join(Handler.deps["stats_dir"], _c.get("stats_file", f"stats-{_nid}.json")), None)
        if isinstance(_snap, dict) and _snap:
            Handler.deps["node_snaps"][_nid] = _snap
            Handler.deps["node_seen"][_nid] = int(_snap.get("generated_at") or 0) or int(time.time())
        # restore the LIVE 5s buffer so the LIVE chart survives a restart/update (mirrors live-<id>.json)
        _lb = load_json(os.path.join(Handler.deps["stats_dir"], f"live-{_nid}.json"), None)
        if isinstance(_lb, list) and _lb:
            Handler.deps["live_samples"][_nid] = [tuple(s) for s in _lb if isinstance(s, (list, tuple)) and len(s) >= 6][-LIVE_MAX:]
    # The primary listener goes into the live registry (so Access & TLS can add a second one on a new
    # address and drop this one only after the browser confirms). _TLSServer with ssl_ctx=None is plain HTTP.
    scheme = "https" if (TLS_CERT and TLS_KEY) else "http"
    if TLS_CERT and TLS_KEY:
        # SIGHUP reloads the cert into every live TLS listener (new connections pick it up) so automated
        # renewal — e.g. acme.sh --reloadcmd — has zero downtime.
        def _reload_tls(_sig, _frm):
            LISTENERS.reload_tls()
            print("reloaded TLS certificate (SIGHUP)", flush=True)
            _refresh_tls_status()                # a renewal just landed → refresh days-left immediately
        with contextlib.suppress(ValueError, OSError, AttributeError):
            signal.signal(signal.SIGHUP, _reload_tls)
        threading.Thread(target=_tls_watch_loop, daemon=True).start()   # watch cert expiry; warn before a stalled renewal goes dark
    threading.Thread(target=_remote_version_loop, daemon=True).start()   # poll the repo for newer releases
    threading.Thread(target=_turn_update_loop, daemon=True).start()       # scheduled turn-proxy auto-update (opt-in)
    threading.Thread(target=_node_watch_loop, args=(Handler.deps,), daemon=True).start()   # node online/offline → webhooks
    auth_note = "" if Handler.deps["auth"] else "  [no auth!]"
    LISTENERS.add(BIND_HOST, BIND_PORT, TLS_CERT if scheme == "https" else None,
                  TLS_KEY if scheme == "https" else None, primary=True)
    print(f"swg-panel-server on {scheme}://{BIND_HOST}:{BIND_PORT}{auth_note}")
    with contextlib.suppress(KeyboardInterrupt):
        threading.Event().wait()             # the listeners serve in their own threads; block here forever


if __name__ == "__main__":
    main()
