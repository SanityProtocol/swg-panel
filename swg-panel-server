# TLS expiry watch: the container's acme.sh --cron renewal silences its own failures, so a stalled renewal is
# invisible until the cert expires and the whole fleet's node-sync fails the TLS pin (goes dark). The panel
# instead watches its OWN cert from disk and surfaces days-left in state, warning loudly before expiry — works
# the same bare-metal or docker, independent of whatever issues/renews the cert.
TLS_STATUS = {}
def _refresh_tls_status():
    if not TLS_CERT:
        return
    try:
        info = ssl._ssl._test_decode_cert(TLS_CERT)   # stdlib decode of a cert FILE (no connection)
        exp = ssl.cert_time_to_seconds(info["notAfter"])
        selfsigned = dict(x[0] for x in info.get("issuer", ())) == dict(x[0] for x in info.get("subject", ()))
        days = int((exp - time.time()) // 86400)
        TLS_STATUS.clear()
        TLS_STATUS.update({"expires_at": int(exp), "days_left": days, "self_signed": bool(selfsigned)})
        if not selfsigned and days <= 14:
            print(f"WARNING: TLS certificate expires in {days} day(s) — check ACME/renewal", flush=True)
    except Exception as e:
        with contextlib.suppress(Exception):
            print(f"TLS status check failed: {e}", flush=True)
def _tls_watch_loop():
    while True:
        _refresh_tls_status()
        time.sleep(21600)   # every 6h
