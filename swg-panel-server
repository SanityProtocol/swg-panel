def _node_issues(c, snap):
    """Health-check roll-up for one node: settings edited on the server (drift), an egress IP / WAN
    NIC the node no longer has, and turn-proxies that aren't running. Empty list = healthy."""
    issues = []
    nips = snap.get("node_ips") or []; nifs = snap.get("node_ifaces") or []
    for ifn, ov in (c.get("ifaces") or {}).items():
        if ov.get("_drift"):
            issues.append(ifn + ": edited directly on the server")
        eg = ov.get("egress_ip")
        if eg and nips and eg not in nips:
            issues.append(ifn + ": egress IP " + eg + " is no longer on the node")
        wn = ov.get("wan_iface")
        if wn and nifs and wn not in nifs:
            issues.append(ifn + ": WAN interface " + wn + " is no longer on the node")
    for ifn, e in (snap.get("interfaces") or {}).items():
        if e.get("down"):                             # failed to come up
            issues.append(ifn + ": interface down on the node")
        elif e.get("stopped"):                        # stopped on the node — not serving, so it counts as an issue
            issues.append(ifn + ": interface stopped")
    for tp in (snap.get("turn_proxies") or []):
        if tp.get("running") is False:
            issues.append((tp.get("service") or "turn-proxy") + ": not running")
    return issues

# Node lifecycle status. A script (install / convert / update / uninstall) signals the panel where it is:
# an IN-PROGRESS state right after step 1, then a TERMINAL outcome (success / aborted / failed).
#   in-progress : reinstalling, converting-bare, converting-docker, updating, uninstalling
#   success     : reinstalled, converted-bare, converted-docker, updated   (green, ~5 s, then clears)
#   aborted     : <op>-aborted   (grey, persists until the node returns or the operator dismisses it)
#   failed      : <op>-failed  (+ err)  (red + error popup, persists likewise)
# `at` = unix time the state was set (node proc_status; host_proc file mtime).
PROC_GRACE = 300          # 5 min in-progress window; a stuck op (lost connection) then falls back to failed
PROC_SUCCESS_SHOW = 20    # success tag lifetime — long enough to ride through a master convert's node phase (so the
                          # host "converted" stays put instead of blanking between the panel-up stamp and the node
                          # stage), still short enough to clear shortly after the operator has seen it
PROC_INPROGRESS = ("reinstalling", "converting-bare", "converting-docker", "updating", "uninstalling")
PROC_SUCCESS = ("reinstalled", "reinstalled-updated", "converted-bare", "converted-docker", "updated", "uptodate")
_PROC_FAIL = {"reinstalling": "reinstall-failed", "converting-bare": "convert-failed",
              "converting-docker": "convert-failed", "updating": "update-failed", "uninstalling": "uninstall-failed"}
def _proc_inprogress(s): return s in PROC_INPROGRESS
def _proc_terminal(s):   return bool(s) and (s in PROC_SUCCESS or s.endswith("-aborted") or s.endswith("-failed") or s == "failed")
def _proc_view(state, at):
    if not state:
        return None
    age = time.time() - (at or 0)
    if state in PROC_SUCCESS:                     # green confirmation, then gone
        return state if age <= PROC_SUCCESS_SHOW else None
    if state in PROC_INPROGRESS:                  # running; a stuck one (no terminal ever arrived) → failed
        return state if age <= PROC_GRACE else _PROC_FAIL.get(state, "failed")
    return state                                  # explicit aborted/failed terminal → persists until dismissed

def node_describe(snapshot):
    """Server/interface info from a node's pushed snapshot (config-building + UI)."""
    interfaces = {}
    for iface, blk in (snapshot.get("interfaces") or {}).items():
        meta = blk.get("meta") or {}
        peers = blk.get("peers") or []
        used = sorted({(p.get("allowed_ips") or "").split("/")[0]
                       for p in peers if p.get("allowed_ips")})
        interfaces[iface] = {
            "public_key": meta.get("public_key"), "listen_port": meta.get("listen_port"),
            "endpoint": meta.get("endpoint"), "address": meta.get("address"),
            "subnet": meta.get("subnet"), "awg_params": meta.get("awg_params", {}),
            "dns": meta.get("dns", []), "used_ips": used, "peer_count": len(peers),
            "rx_speed": sum(p.get("rx_speed", 0) or 0 for p in peers),   # per-iface throughput (mesh link cards)
            "tx_speed": sum(p.get("tx_speed", 0) or 0 for p in peers),
            "rx_bytes": sum(p.get("rx_bytes", 0) or 0 for p in peers),   # cumulative totals (connection card)
            "tx_bytes": sum(p.get("tx_bytes", 0) or 0 for p in peers),
            "handshake_age": min((p.get("handshake_age") for p in peers if p.get("handshake_age") is not None), default=None),
            "peer_endpoint": (peers[0].get("endpoint") if len(peers) == 1 else None),   # the actual dialed peer endpoint (mesh link → connection card "Endpoint")
        }
    return {"ok": True, "op": "describe",
            "data": {"hostname": snapshot.get("hostname"), "interfaces": interfaces}}


AWG_PARAM_KEYS = ["Jc", "Jmin", "Jmax", "S1", "S2", "S3", "S4",
                  "H1", "H2", "H3", "H4", "I1", "I2", "I3", "I4", "I5"]


def apply_iface_meta(node_cfg, interfaces):
    """Overlay panel-side per-interface overrides onto node-reported metadata, in place:
    a public endpoint host/port (what clients dial — may differ from the node's listen port
    behind NAT), and a default DNS / MTU used when rendering configs & creating new peers.
    Does not change the node — only what the panel emits in client configs. Returns interfaces."""
    node_ep = (node_cfg or {}).get("endpoint_host")
    ifov = (node_cfg or {}).get("ifaces") or {}
    for ifn, ifc in interfaces.items():
        ov = ifov.get(ifn) or {}
        rep = ifc.get("endpoint") or ""
        rep_host = rep.rsplit(":", 1)[0] if ":" in rep else rep
        host = ov.get("endpoint_host") or node_ep or rep_host
        # listen_port is the desired UDP port — the node converges its ListenPort to it, and the
        # client Endpoint uses it (listen IP == connection IP for our purposes).
        want_port = ov.get("listen_port")
        port = want_port or ifc.get("listen_port")
        if host and port:
            ifc["endpoint"] = f"{host}:{port}"
        if want_port:
            ifc["desired_port"] = want_port   # != reported listen_port => "updating" in the UI
        if ov.get("dns") is not None:                # always serve dns as a list (the UI expects one)
            d = ov["dns"]
            ifc["dns"] = d if isinstance(d, list) else [s.strip() for s in str(d).split(",") if s.strip()]
        ifc["mtu"] = ov.get("mtu") or 1280
        ifc["egress_ip"] = ov.get("egress_ip") or ""   # per-interface source/egress IP (blank = auto/MASQUERADE)
        ifc["wan_iface"] = ov.get("wan_iface") or ""   # per-interface egress WAN NIC (blank = auto-detect)
        ifc["egress_mode"] = ov.get("egress_mode") or "direct"   # direct = SNAT a NIC | forward = whole-iface cascade (P2) | smart = per-dest rules (P3)
        ifc["egress_node"] = ov.get("egress_node") or ""         # forward target node id
        ifc["routing"] = ov.get("routing") or []                 # smart-routing rule list (P3): [{category,action,node}]
        ifc["system"] = bool(ov.get("system"))         # panel-managed mesh link interface (a node↔node connection)
        ifc["link_node"] = ov.get("link_node") or ""   # the peer node this link connects to (SPA resolves the name)
        _lr = ((node_cfg.get("links") or {}).get(ifc["link_node"]) or {}) if ifc["link_node"] else {}
        ifc["dial_src"] = _lr.get("dial_src") or ""             # source IP this node dials the peer FROM
        ifc["dial_endpoint"] = _lr.get("dial_endpoint") or ""   # which of the peer's IPs this node dials TO (override the peer's ingress)
        ifc["drift"] = dict(ov.get("_drift") or {})    # settings edited directly on the server (key → the node's value)
        # AmneziaWG obfuscation params: the override wins for what the panel renders into configs;
        # the node converges its interface to it. awg_pending flags desired != reported in the UI.
        ovawg = ov.get("awg_params")
        if isinstance(ovawg, dict) and ovawg:
            rep_awg = dict(ifc.get("awg_params") or {})
            ifc["awg_reported"] = rep_awg
            ifc["awg_params"] = {**rep_awg, **{k: ovawg[k] for k in ovawg if ovawg[k] not in (None, "")}}
            ifc["awg_pending"] = ifc["awg_params"] != rep_awg
    return interfaces


def panel_next_ip(snaps, roster, nodes, iface):
    """Lowest address free on every selected node's iface AND unclaimed in the roster."""
    used, subnet = set(), None
    for node in nodes:
        snap = snaps.get(node)
        if not snap:
            return err("next-ip", f"{node}: no snapshot yet (is the node online?)", "offline")
        blk = (snap.get("interfaces") or {}).get(iface)
        if not blk:
            return err("next-ip", f"{node} has no interface {iface!r}", "bad_request")
        meta = blk.get("meta") or {}
        for p in (blk.get("peers") or []):
            ip = (p.get("allowed_ips") or "").split("/")[0]
            if ip:
                used.add(ip)
        used.add((meta.get("address") or "").split("/")[0])
        if subnet is None:
            subnet = meta.get("subnet")
    for p in (roster.get("peers") or {}).values():
        if not isinstance(p, dict):
            continue
        for t in p.get("targets", []):
            if t.get("iface") == iface and t.get("ip"):   # IPs only collide within one iface's subnet
                used.add(t["ip"].split("/")[0])
    if not subnet:
        return err("next-ip", "no subnet info in snapshot")
    net = ipaddress.ip_network(subnet, strict=False)
    for host in net.hosts():
        if str(host) not in used:
            return {"ok": True, "op": "next-ip",
                    "data": {"iface": iface, "next_ip": str(host) + "/32", "subnet": subnet}}
    return err("next-ip", "no free addresses across selected nodes", "subnet_full")


# ───────────────────────── fleet mesh (node↔node tunnels) ─────────────────────────
# Every node pair gets a point-to-point AmneziaWG link interface (one per link, NOT one shared mesh
# iface) — because WireGuard can route 0.0.0.0/0 to only one peer per interface, so flexible per-user-
# interface exit (Phase 2 cascade) needs a dedicated tunnel per node-to-node link. Phase 1 just brings
# the tunnels up (handshake + keepalive); the cascade routing is Phase 2.

def mesh_cfg(deps):
    f = deps.get("fleet") or {}
    r = (deps.get("panel_settings") or {}).get("reserved") or {}   # Panel settings override the fleet/defaults
    return {"subnet": r.get("mesh_subnet") or f.get("mesh_subnet", "10.255.0.0/16"), "mtu": int(f.get("mesh_mtu", 1320)),
            "keepalive": int(f.get("mesh_keepalive", 25)),
            "port_base": int(r.get("mesh_port_base") or f.get("mesh_port_base", 9999)),
            "port_span": int(r.get("port_span") or 100),
            "iface_prefix": (r.get("iface_prefix") or f.get("mesh_iface_prefix") or "swg_")}


def node_mesh_cfg(deps, node):
    """Global mesh_cfg with this node's per-node overrides applied (Node settings → mesh subnet / port /
    prefix). New links involving the node use these; empty fields fall back to the global (panel) values."""
    mc = dict(mesh_cfg(deps)); n = node or {}
    if n.get("mesh_subnet"):
        mc["subnet"] = n["mesh_subnet"]
    if str(n.get("mesh_port") or "").strip().isdigit():
        mc["port_base"] = int(n["mesh_port"])
    if n.get("mesh_prefix"):
        mc["iface_prefix"] = n["mesh_prefix"]
    return mc


def is_system_iface(deps, nodes, node_id, iface):
    """True if (node_id, iface) is a panel-managed inter-node mesh link (swg_*) — never a valid
    user-peer target. Authoritative signal is the stored `.system` flag; fall back to the node's
    reserved mesh prefix so a link that predates the flag is still rejected."""
    if not iface:
        return False
    n = nodes.get(node_id) or {}
    ov = (n.get("ifaces") or {}).get(iface)
    if isinstance(ov, dict) and ov.get("system"):
        return True
    pfx = node_mesh_cfg(deps, n).get("iface_prefix") or "swg_"
    return str(iface).startswith(pfx) or str(iface).startswith("swg_")


def reserved_conflict(deps, nodes, node, subnet=None, port=None, name=None):
    """Reject user interfaces / turn-proxies that collide with the mesh's reserved ranges (subnet / port
    band / iface-name prefix) — evaluated against THIS node's EFFECTIVE mesh config (per-node overrides over
    the panel default). Also reserves the /16 around every in-use link subnet across the fleet, so an
    existing fleet on a different range stays protected. Returns an error string, or None if no conflict."""
    mc = node_mesh_cfg(deps, node)
    prefix = mc.get("iface_prefix") or "swg_"
    if name and str(name).startswith(prefix):
        return f"names starting with '{prefix}' are reserved for system mesh links"
    if subnet:
        try:
            net = ipaddress.ip_network(subnet, strict=False)
        except Exception:
            net = None
        if net is not None:
            reserved = []
            with contextlib.suppress(Exception):
                reserved.append(ipaddress.ip_network(mc["subnet"], strict=False))
            for n in (nodes or {}).values():
                for lr in (n.get("links") or {}).values():
                    with contextlib.suppress(Exception):
                        ln = ipaddress.ip_network(lr.get("subnet"), strict=False)
                        reserved.append(ln.supernet(new_prefix=16) if ln.version == 4 and ln.prefixlen > 16 else ln)
            for rn in reserved:
                if net.version == rn.version and net.overlaps(rn):
                    return f"subnet overlaps the reserved system mesh range ({rn})"
    if port is not None and str(port).strip().isdigit():
        base = mc["port_base"]; span = mc.get("port_span", 100)
        if base <= int(port) < base + span:
            return f"port {port} is in the reserved system mesh range ({base}–{base + span - 1})"
    return None


def gen_awg_params():
    """Panel-generated AmneziaWG obfuscation params (dict form). The panel owns each LINK's params and
    pushes the SAME dict to both ends, because AmneziaWG only handshakes when both peers share identical
    obfuscation — the node's own random per-iface params (swg-agent _awg_obfuscation) would differ."""
    s1 = 15 + random.randint(0, 135); s2 = 15 + random.randint(0, 135)
    while s2 == s1 or s2 == s1 + 56:
        s2 = 15 + random.randint(0, 135)
    s3 = 15 + random.randint(0, 85); s4 = 15 + random.randint(0, 85)
    b = [base + random.randint(0, 899999999) for base in (5, 1000000000, 2000000000, 3000000000)]
    w = 15
    return {"Jc": 4, "Jmin": 40, "Jmax": 70, "S1": s1, "S2": s2, "S3": s3, "S4": s4,
            "H1": f"{b[0]}-{b[0]+w}", "H2": f"{b[1]}-{b[1]+w}", "H3": f"{b[2]}-{b[2]+w}", "H4": f"{b[3]}-{b[3]+w}",
            "I1": "<b 0xc300000001><r 1200>"}


AWG_FIELDS = ("Jc", "Jmin", "Jmax", "S1", "S2", "S3", "S4", "H1", "H2", "H3", "H4", "I1")


def sanitize_awg_params(raw):
    """Keep only recognised AmneziaWG obfuscation fields with non-empty values, as strings. Empty → {}."""
    if not isinstance(raw, dict):
        return {}
    out = {}
    for k in AWG_FIELDS:
        v = raw.get(k)
        if v is None or str(v).strip() == "":
            continue
        out[k] = str(v).strip()
    return out


def link_awg_params(deps):
    """AWG params for a NEW mesh link: the panel-settings default if the operator set one, else a fresh set."""
    pa = sanitize_awg_params(((deps.get("panel_settings") or {}).get("mesh_awg")))
    return pa or gen_awg_params()


def _link_iface_name(node, link_id, prefix="swg_"):
    """`<prefix><8hex>` (≤ IFNAMSIZ 15), same on both ends of a link. On the rare 8-hex collision
    within one node, slide along the hash until a free window is found."""
    existing = {lr.get("iface") for lr in (node.get("links") or {}).values()}
    for i in range(0, len(link_id) - 8 + 1):
        nm = prefix + link_id[i:i + 8]
        if nm not in existing:
            return nm
    return prefix + link_id[:8]


def _used_ports(nodes, snaps, nid):
    used = set()
    snap = (snaps or {}).get(nid) or {}
    for blk in (snap.get("interfaces") or {}).values():
        p = ((blk.get("meta") or {}).get("listen_port"))
        if str(p).isdigit():
            used.add(int(p))
    for tp in (snap.get("turn_proxies") or []):
        m = re.search(r":(\d+)$", str(tp.get("listen") or ""))
        if m:
            used.add(int(m.group(1)))
    for lr in (nodes.get(nid, {}).get("links") or {}).values():
        if str(lr.get("listen_port")).isdigit():
            used.add(int(lr["listen_port"]))
    return used


def _alloc_port(used, base):
    p = base
    while p in used:
        p += 1
    return p


def _alloc_link_subnet(nodes, mesh_subnet):
    taken = {lr.get("subnet") for n in nodes.values() for lr in (n.get("links") or {}).values()}
    net = ipaddress.ip_network(mesh_subnet, strict=False)
    for sub in net.subnets(new_prefix=31):
        if str(sub) not in taken:
            return sub
    return None


def _link_id(nodes, a, b):
    """Deterministic link id (same from either end). Folds in each end's `mesh_gen` so bumping a node's
    generation (on a mesh-settings change) yields a NEW id → new iface names, so a re-provision is a clean
    delete-old + create-new rather than a same-name address swap."""
    lo, hi = sorted((a, b))
    glo = int((nodes.get(lo) or {}).get("mesh_gen") or 0)
    ghi = int((nodes.get(hi) or {}).get("mesh_gen") or 0)
    return hashlib.sha256(f"{lo}|{glo}|{hi}|{ghi}".encode()).hexdigest()


def mesh_reprovision_node(nodes, nid):
    """Re-provision node `nid`'s mesh links: bump its generation and tear down its current links on BOTH
    ends (stage iface deletes + drop the link records). reconcile_mesh (called next) then rebuilds every
    pair — `nid`'s links come back with NEW iface names + `nid`'s current per-node mesh config (subnet /
    port / prefix). `nid` is briefly off the mesh until peers pull the new config and reconnect."""
    me = nodes.get(nid) or {}
    me["mesh_gen"] = int(me.get("mesh_gen") or 0) + 1
    for peer, lr in list((me.get("links") or {}).items()):
        for who, link in ((nid, lr), (peer, ((nodes.get(peer) or {}).get("links") or {}).get(nid))):
            if link and link.get("iface"):
                (nodes[who].get("create") or {}).pop(link["iface"], None)   # cancel any pending create for the old iface
                nodes[who].setdefault("delete", {})[link["iface"]] = {"at": int(time.time())}
                (nodes[who].get("ifaces") or {}).pop(link["iface"], None)
        ((nodes.get(peer) or {}).get("links") or {}).pop(nid, None)
    me["links"] = {}


def _mesh_make_link(nodes, snaps, deps, a, b, mc):
    """Create the link between nodes a and b on BOTH ends (link records + create requests + matching
    awg_params/psk overrides). Caller ensures the pair isn't already linked."""
    link_id = _link_id(nodes, a, b)
    x_nid = min(a, b)                            # the smaller id is the .0 end (deterministic, both ends agree)
    sub = _alloc_link_subnet(nodes, node_mesh_cfg(deps, nodes[x_nid])["subnet"])   # link /31 from the x-end's mesh subnet
    if sub is None:
        return False
    hosts = list(sub)                            # /31 → [.0, .1]
    # the link's obfuscation = the X-end node's per-node mesh AWG if it set one, else the panel default / a fresh set.
    # both ends share it (the handshake requires matching params); editing a node's AWG re-provisions the links it anchors.
    psk = gen_psk(); awg = sanitize_awg_params(nodes[x_nid].get("mesh_awg")) or link_awg_params(deps)
    for nid, peer in ((a, b), (b, a)):
        n = nodes[nid]
        nmc = node_mesh_cfg(deps, n)             # per-node prefix / port base
        iface = _link_iface_name(n, link_id, nmc.get("iface_prefix") or "swg_")
        mine, theirs = (hosts[0], hosts[1]) if nid == x_nid else (hosts[1], hosts[0])
        port = _alloc_port(_used_ports(nodes, snaps, nid), nmc["port_base"])
        n.setdefault("links", {})[peer] = {
            "iface": iface, "link_id": link_id, "subnet": str(sub),
            "address": str(mine), "peer_address": str(theirs),
            "listen_port": port, "psk": psk, "role": "x" if nid == x_nid else "y"}
        n.setdefault("create", {})[iface] = {
            "cmd": ["awg"], "subnet": str(sub), "address": f"{mine}/31",
            "listen_port": port, "mtu": nmc["mtu"], "table": "off"}   # Table=off: cascade manages routing, no /0 hijack
        n.setdefault("ifaces", {})[iface] = {"awg_params": dict(awg), "system": True, "link_node": peer}
    ev_append(deps["roster_path"], "node", a, "Linked node", nodes[b].get("name", b))
    return True


def reconcile_mesh(nodes, snaps, deps):
    """Self-healing full mesh — run on every sync AND on node-add, so the mesh integrates with EVERY
    node lifecycle (panel add, auto-enrolled master/local node, convert, re-install, manual edits):
      1. ensure every node PAIR is linked (covers a node that entered nodes.json outside /api/nodes/create);
      2. re-stage a `create` for any link interface a node isn't currently reporting AND isn't already
         creating (covers a lost/replaced conf after convert/re-install).
    Returns True if it changed anything (so the caller persists)."""
    mc = mesh_cfg(deps)
    changed = False
    ids = list(nodes.keys())
    for i, a in enumerate(ids):                                  # 1) every pair linked
        for b in ids[i + 1:]:
            if b not in (nodes[a].get("links") or {}):
                changed = _mesh_make_link(nodes, snaps, deps, a, b, mc) or changed
    for nid, n in nodes.items():                                 # 2) re-stage any missing link iface
        snap_ifs = set((((snaps or {}).get(nid) or {}).get("interfaces") or {}))
        pending = set(n.get("create") or {})
        for peer, lr in (n.get("links") or {}).items():
            ifc = lr.get("iface")
            if ifc and ifc not in snap_ifs and ifc not in pending:
                n.setdefault("create", {})[ifc] = {"cmd": ["awg"], "subnet": lr["subnet"],
                    "address": lr["address"] + "/31", "listen_port": lr["listen_port"], "mtu": mc["mtu"], "table": "off"}
                ov = n.setdefault("ifaces", {}).setdefault(ifc, {})
                ov.setdefault("system", True); ov.setdefault("link_node", peer)
                changed = True
    return changed


def node_public_ip(snap):
    """A node's first public IPv4 from its reported node_ips — the address other nodes dial for the mesh
    (used when an operator hasn't set an explicit endpoint_host). Skips private/loopback/link-local."""
    for ip in (snap or {}).get("node_ips") or []:
        try:
            a = ipaddress.ip_address(ip)
        except ValueError:
            continue
        if a.version == 4 and not (a.is_private or a.is_loopback or a.is_link_local):
            return ip
    return ""


def mesh_endpoint_host(node, snap):
    """The host a peer dials for this node's mesh: the explicit endpoint_host, else its reported public IP."""
    return (node.get("endpoint_host") or "").strip() or node_public_ip(snap)


def desired_mesh_for_node(nodes, nid, keepalive, allowed_overrides=None, snaps=None):
    """The mesh peer set for `nid`, grouped by link iface — one remote peer per link, emitted only once
    the REMOTE end is ready (its pubkey blessed, its listen_port known, its dial endpoint resolvable).
    `allowed_overrides` (Phase 2 cascade) maps a local link iface → the AllowedIPs the mesh peer should
    carry (e.g. "0.0.0.0/0" on a forwarding entry, "<base>/32,<subnet>" on an exit); default = link /32."""
    ov_map = allowed_overrides or {}
    snaps = snaps or {}
    out = {}
    me = nodes.get(nid) or {}
    for peer_nid, lr in (me.get("links") or {}).items():
        peer = nodes.get(peer_nid)
        if not peer:
            continue
        iface = lr.get("iface")
        rov = (peer.get("ifaces") or {}).get((peer.get("links") or {}).get(nid, {}).get("iface")) or {}
        rlr = (peer.get("links") or {}).get(nid) or {}
        pub = rov.get("public_key"); rport = rlr.get("listen_port")
        rhost = (lr.get("dial_endpoint") or "").strip() or mesh_endpoint_host(peer, snaps.get(peer_nid))   # per-connection override → peer's ingress IP → reported public IP
        if not (pub and rport and rhost and iface):
            continue                                   # remote not ready → no peer yet (the iface still exists)
        out.setdefault(iface, []).append({
            "public_key": pub,
            "allowed_ips": ov_map.get(iface) or ((lr.get("peer_address") or "") + "/32"),   # cascade override, else link /32
            "preshared_key": lr.get("psk") or "none",
            "endpoint": f"{rhost}:{rport}",
            "persistent_keepalive": keepalive,
            "dial_src": lr.get("dial_src") or "",      # node IP role: local source IP to dial THIS peer (Part 3)
            "name": "mesh:" + (peer.get("name") or peer_nid)})
    return out


