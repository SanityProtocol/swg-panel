        cur = dict(deps.get("panel_settings") or {})
        a = dict(cur.get("api") or {})
        toks = list(a.get("tokens") or [])
        tid = gen_id()
        rec = {"id": tid, "label": label, "hash": _api_token_hash(raw), "created": now()}
        toks.append(rec)
        a["tokens"] = toks; a["enabled"] = True                       # minting a token turns the API on
        cur["api"] = a; _save_api(cur)
        ev_append(roster_path, "panel", "integrations", "Created API token", label)
        return 200, {"ok": True, "data": {"id": tid, "label": label, "created": rec["created"], "token": raw}}

