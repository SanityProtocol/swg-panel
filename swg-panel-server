def err(op, msg, code="internal"):
    return {"ok": False, "op": op, "error": msg, "code": code}


def verify_password(stored, password):
    # stored = "pbkdf2_sha256$<iterations>$<salt_b64>$<hash_b64>"
    try:
        algo, iters, salt_b64, hash_b64 = stored.split("$")
        if algo != "pbkdf2_sha256":
            return False
        actual = hashlib.pbkdf2_hmac("sha256", password.encode(),
                                     base64.b64decode(salt_b64), int(iters))
        return hmac.compare_digest(actual, base64.b64decode(hash_b64))
    except Exception:
        return False


def load_auth():
    if not AUTH_FILE:
        return None
    try:
        user, _, h = open(AUTH_FILE).read().strip().partition(":")
        if user and h:
            return (user, h)
    except OSError:
        pass
    return None


# ─────────────── browser sessions (signed cookie; no Basic-auth popup) ───────────────
# A small hmac-signed token in an HttpOnly cookie replaces the browser's Basic-auth prompt,
# giving a real login page + a working logout. Same pbkdf2 credentials; the node-sync path
# keeps its Bearer token, untouched. The signing secret is persisted next to the roster so
# sessions survive a panel restart.
SESSION_TTL = 7 * 24 * 3600
_B64PAD = lambda s: s + "=" * (-len(s) % 4)


def load_session_secret(roster_path):
    p = os.path.join(os.path.dirname(roster_path) or ".", "session.key")
    try:
        with open(p, "rb") as f:
            s = f.read().strip()
        if len(s) >= 32:
            return s
    except OSError:
        pass
    s = base64.b64encode(os.urandom(48))
    with contextlib.suppress(OSError):
        os.makedirs(os.path.dirname(p) or ".", exist_ok=True)
        fd = os.open(p, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "wb") as f:
            f.write(s)
    return s


def make_session(user, secret, ttl=SESSION_TTL):
    payload = (user + "|" + str(int(time.time()) + ttl)).encode()
    sig = hmac.new(secret, payload, hashlib.sha256).digest()
    return (base64.urlsafe_b64encode(payload).rstrip(b"=").decode() + "."
            + base64.urlsafe_b64encode(sig).rstrip(b"=").decode())


def verify_session(token, secret):
    try:
        p_s, sig_s = token.split(".", 1)
        payload = base64.urlsafe_b64decode(_B64PAD(p_s))
        sig = base64.urlsafe_b64decode(_B64PAD(sig_s))
        if not hmac.compare_digest(sig, hmac.new(secret, payload, hashlib.sha256).digest()):
            return None
        user, exp = payload.decode().rsplit("|", 1)
        return user if int(exp) >= int(time.time()) else None
    except Exception:
        return None


def cfg_hash(pubkey, node, iface=""):
    return hashlib.sha256((pubkey + "|" + node + "|" + iface).encode()).hexdigest() + ".conf"


def atomic_write(path, text, mode=0o600):
    os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
    tmp = path + ".tmp." + uuid.uuid4().hex[:8]
    try:
        fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, mode)
        with os.fdopen(fd, "w") as f:
            f.write(text); f.flush(); os.fsync(f.fileno())
        os.replace(tmp, path)
    except Exception:
        with contextlib.suppress(OSError):
            os.unlink(tmp)
        raise


def load_json(path, default):
    try:
        with open(path) as f:
            return json.load(f)
    except FileNotFoundError:
        return default
    except (json.JSONDecodeError, OSError):
        return default


# ───────────────────────── roster: users + peers ─────────────────────────
#
# users.json is a versioned envelope, NOT a flat dict:
#   { "version": 1,
#     "users": { "<user_id>": {id, name, tag, note, created_at, modified_at} },
#     "peers": { "<peer_id>": {id, user_id|None, pubkey, psk,
#                              targets:[{node, iface, ip, type}],
#                              created_at, modified_at} } }
# A User is identity only. A Peer is one credential (pubkey+psk) deployed to one
# or more targets; a target is one (node, iface, ip, type). user_id None means the
# peer is unassigned. desired_for_node() derives the node-facing peer set entirely
# from peers→targets and emits the SAME wire shape nodes have always consumed, so
# swg-noded / swg-agent need no changes.

ROSTER_VERSION = 1


def roster_load(path):
    r = load_json(path, {})
    if not isinstance(r, dict):
        r = {}
    r.setdefault("version", ROSTER_VERSION)
    if not isinstance(r.get("users"), dict):
        r["users"] = {}
    if not isinstance(r.get("peers"), dict):
        r["peers"] = {}
    return r


def roster_save(path, roster):
    d = os.path.dirname(path) or "."
    os.makedirs(d, exist_ok=True)
    tmp = path + ".tmp." + uuid.uuid4().hex[:8]
    with open(tmp, "w") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        json.dump(roster, f, indent=2); f.write("\n"); f.flush(); os.fsync(f.fileno())
    os.replace(tmp, path)


# ─────────────── audit / activity log (panel host only) ───────────────
# An append-only event log of operator actions, kept ONLY on the panel host next to the
# roster. Nothing here touches the nodes or the sync wire format — events are recorded
# in the panel's own API handlers when the admin mutates the roster. Stored as JSON-lines
# and capped, so it never grows unbounded. Read back newest-first by the Overview.

EVENTS_CAP = 1000          # keep at most this many events
EVENTS_TRIM_BYTES = 300_000

def events_path(roster_path):
    return os.path.join(os.path.dirname(roster_path) or ".", "events.jsonl")


def ev_append(roster_path, kind, ident, verb, name, detail=""):
    """Record one operator action. kind=user|peer, verb is the human action
    ("Created peer"), name is the display label, detail is optional context."""
    rec = {"ts": int(time.time()), "kind": kind, "id": ident or "",
           "verb": verb, "name": name or "", "detail": detail or ""}
    p = events_path(roster_path)
    try:
        os.makedirs(os.path.dirname(p) or ".", exist_ok=True)
        with open(p, "a") as f:
            fcntl.flock(f, fcntl.LOCK_EX)
            f.write(json.dumps(rec, separators=(",", ":")) + "\n")
        if os.path.getsize(p) > EVENTS_TRIM_BYTES:        # trim to the last EVENTS_CAP lines
            with open(p) as f:
                lines = f.readlines()
            if len(lines) > EVENTS_CAP:
                tmp = p + ".tmp." + uuid.uuid4().hex[:8]
                with open(tmp, "w") as f:
                    f.writelines(lines[-EVENTS_CAP:])
                os.replace(tmp, p)
    except OSError:
        pass          # the log is best-effort; never fail a mutation because it couldn't be recorded


def ev_read(roster_path, limit=12):
    """Return the newest `limit` events, newest first."""
    p = events_path(roster_path)
    out = []
    try:
        with open(p) as f:
            lines = f.readlines()
        for ln in lines[-limit:]:
            ln = ln.strip()
            if ln:
                with contextlib.suppress(Exception):
                    out.append(json.loads(ln))
    except OSError:
        pass
    out.reverse()
    return out


def gen_id():
    """Short opaque id for users and peers — decoupled from the pubkey so a peer's
    key can rotate in place without losing its identity or history."""
    return uuid.uuid4().hex[:12]


def gen_psk():
    """A WireGuard/AmneziaWG preshared key: 32 random bytes, base64 (stdlib only)."""
    return base64.b64encode(os.urandom(32)).decode()


def peer_label(roster, p):
    """Best display label for a peer in the activity log: title → owner name → unassigned."""
    if p.get("title"):
        return p["title"]
    uid = p.get("user_id")
    if uid and uid in (roster.get("users") or {}):
        return (roster["users"][uid] or {}).get("name", "") or "unassigned peer"
    return "unassigned peer"


def clean_target(t):
    """Normalise one deployment target: {node, iface, ip, type}."""
    return {
        "node": t.get("node", ""),
        "iface": t.get("iface", ""),
        "ip": (t.get("ip", "") or "").split("/")[0],
        "type": t.get("type", "") or "wg",
    }


def find_peer_by_pubkey(roster, pubkey):
    for p in roster.get("peers", {}).values():
        if isinstance(p, dict) and p.get("pubkey") == pubkey:
            return p
    return None


def valid_addr(s):
    """A bare IP (v4 or v6); a trailing /prefix is tolerated and ignored."""
    try:
        ipaddress.ip_address((s or "").split("/")[0].strip())
        return True
    except ValueError:
        return False


def bad_targets(targets):
    """First validation error across a target list, or None. Defence-in-depth behind the UI."""
    for t in targets:
        if not valid_addr(t.get("ip", "")):
            return f"invalid address {t.get('ip')!r} for {t.get('node')}/{t.get('iface')}"
    return None


def iface_type(snaps, node, iface):
    """wg vs awg, read from the node's pushed snapshot (awg interfaces carry awg_params)."""
    blk = ((snaps.get(node) or {}).get("interfaces") or {}).get(iface) or {}
    return "awg" if (blk.get("meta") or {}).get("awg_params") else "wg"


def save_config(store_configs, config_dir, pubkey, node, iface, conf):
    if store_configs and config_dir and isinstance(conf, str) and conf:
        with contextlib.suppress(OSError):
            atomic_write(os.path.join(config_dir, cfg_hash(pubkey, node, iface)), conf, mode=0o600)


def del_config(store_configs, config_dir, pubkey, node, iface):
    if store_configs and config_dir:
        with contextlib.suppress(OSError):
            os.unlink(os.path.join(config_dir, cfg_hash(pubkey, node, iface)))


def user_set(roster, uid, fields, now):
    u = roster["users"].get(uid) or {}
    roster["users"][uid] = {
        "id": uid,
        "name": fields.get("name", u.get("name", "")),
        "tag": fields.get("tag", u.get("tag", "")),
        "note": fields.get("note", u.get("note", "")),
        "created_at": u.get("created_at", now),
        "modified_at": now,
    }
    return roster["users"][uid]


def peer_set(roster, pid, fields, now):
    p = roster["peers"].get(pid) or {}
    targets = fields.get("targets", p.get("targets", []))
    roster["peers"][pid] = {
        "id": pid,
        "user_id": fields.get("user_id", p.get("user_id")),   # None => unassigned
        "title": (fields.get("title", p.get("title", "")) or "")[:64],   # operator label to tell devices apart
        "pubkey": fields.get("pubkey", p.get("pubkey", "")),
        "psk": fields.get("psk", p.get("psk", "")),
        "targets": [clean_target(t) for t in targets],
        "created_at": p.get("created_at", now),
        "modified_at": now,
    }
    return roster["peers"][pid]


def unassign_peer(p, store_configs, config_dir, now):
    """Detach a peer from its user AND revoke the old holder's access.

    The PSK is panel-owned and mixed into every WireGuard handshake, so rotating it
    here makes the config already on the previous owner's device fail on the node's
    next sync — instant revocation with no client in the loop. The keypair is left
    intact (re-keying needs the browser, where the private key lives); the peer is
    parked, present on its nodes but unusable until it's re-issued to someone.
    """
    p["user_id"] = None
    p["psk"] = gen_psk()
    p["modified_at"] = now
    for t in p.get("targets", []):
        del_config(store_configs, config_dir, p.get("pubkey", ""), t["node"], t["iface"])


