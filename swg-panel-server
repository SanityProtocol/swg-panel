def strip_base(path):
    """Remove the configured subpath prefix from a request path.

    Returns the root-relative path ("/...", with "/" for the base itself) or None
    when the request falls outside the mount point. With no PANEL_BASE this is a no-op.
    """
    if not PANEL_BASE:
        return path
    if path == PANEL_BASE:
        return "/"
    if path.startswith(PANEL_BASE + "/"):
        return path[len(PANEL_BASE):]
    return None


