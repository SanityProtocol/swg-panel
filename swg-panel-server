        acc = (deps.get("panel_settings") or {}).get("access") or {}
        s = acc.get("sub") or {}
        d_host = (str(s.get("host") or "0.0.0.0")).strip() or "0.0.0.0"
        try:
            d_port = max(1, min(65535, int(s.get("port") or 8444)))
        except (TypeError, ValueError):
            d_port = 8444
        d_url = (str(s.get("url") or "")).strip()
        d_domain = _url_host(d_url)
        mode = (acc.get("tls") or {}).get("mode") or ""
        with _SUBAPPLY["lock"]:
            if _SUBAPPLY["status"].get("state") in ("issuing", "applying"):
                return 409, {"ok": False, "error": "a subscription change is already in progress", "code": "busy"}
            _subapply_status("applying", "starting")
        threading.Thread(target=_apply_sub_worker, name="access-apply-sub",
                         args=(deps, d_host, d_port, d_url, d_domain, mode), daemon=True).start()
        return 200, {"ok": True, "started": True}

    # ── external integration API: token + webhook management (session-authed, mutations) ──
    def _save_api(cur):
        deps["panel_settings"] = cur
        with contextlib.suppress(Exception):
