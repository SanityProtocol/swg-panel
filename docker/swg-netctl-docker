#!/usr/bin/env python3
"""swg-netctl-docker — the Docker root helper.

The bare-metal panel delegates privileged host jobs (rebind a listener, restart a
service) to swg-netctl over a queue dir. Docker has no swg-netctl — the panel
container runs as root but can't reach the HOST to restart a sibling container or
change a published port. This is the Docker equivalent: it drains the SAME request
queue the panel already writes (drop-in compatible — the panel needs no change) and
maps each verb to a `docker compose` action on the host.

Polled by swg-netctl-docker.timer, NOT a .path unit: a host inotify watch never
sees the container's write to a bind-mounted queue file, so we poll the dir.

Request  (queue/<id>.json):  {"id","verb","args":[...],"nonce"}   — written by the panel
Result   (status/<id>.json): {"status":"ok"|"error","message":...} — read by the panel's _netctl_wait

Verbs handled (others are a no-op "ok" — e.g. cert issuance is done by acme.sh INSIDE
the container, not on the host):
  restart <sub|panel>              -> docker compose restart swg-<svc>
  set-listen <sub|panel> <h> <p>   -> set the published port/bind in .env, recreate swg-<svc>
  reload <sub|panel>               -> docker compose kill -s HUP swg-<svc>  (re-read config, no restart)
  set-base <panel> <base>          -> persist SWG_PANEL_BASE (PANEL_BASE in .env) for the next recreate
"""
import contextlib
import json
import os
import re
import subprocess

DIR = os.environ.get("SWG_DOCKER_DIR", "/opt/swg-panel-docker")
QUEUE = os.path.join(DIR, "data", "lib", "netctl", "queue")
STATUS = os.path.join(DIR, "data", "lib", "netctl", "status")
ENV = os.path.join(DIR, ".env")
COMPOSE = ["docker", "compose", "-f", os.path.join(DIR, "docker-compose.yml")]
SVC = {"sub": "swg-sub", "panel": "swg-panel"}


def _compose(*args):
    r = subprocess.run(COMPOSE + list(args), capture_output=True, text=True, timeout=180)
    return r.returncode == 0, (r.stderr or r.stdout or "").strip()[:200]


def _set_env(keys):
    """Set KEY=value lines in .env (add if absent), atomically."""
    try:
        lines = open(ENV).read().splitlines() if os.path.exists(ENV) else []
    except OSError:
        lines = []
    for k, v in keys.items():
        pat = re.compile(r"^%s=" % re.escape(k))
        for i, ln in enumerate(lines):
            if pat.match(ln):
                lines[i] = "%s=%s" % (k, v)
                break
        else:
            lines.append("%s=%s" % (k, v))
    tmp = ENV + ".tmp"
    with open(tmp, "w") as f:
        f.write("\n".join(lines) + "\n")
    os.replace(tmp, ENV)


def _handle(verb, args):
    if verb == "restart":
        svc = SVC.get(args[0] if args else "")
        if not svc:
            return False, "unknown service %r" % (args[0] if args else "")
        ok, msg = _compose("restart", svc)
        return ok, ("restarted %s" % svc) if ok else ("restart %s failed: %s" % (svc, msg))
    if verb == "set-listen":
        # args: <sub|panel> <host> <port> — set the container's published port/bind, then recreate it
        who, host, port = (args + ["", "", ""])[:3]
        svc = SVC.get(who)
        if not svc:
            return False, "unknown service %r" % who
        _set_env({"SUB_PORT" if who == "sub" else "PANEL_PORT": port,
                  "SUB_BIND" if who == "sub" else "PANEL_BIND": host})
        # --no-deps: recreate ONLY this service. Without it, `up` follows depends_on and would recreate the panel
        # container too, killing the very apply request that's in flight (the panel loses its _netctl_wait).
        ok, msg = _compose("up", "-d", "--no-deps", svc)
        return ok, ("%s on %s:%s" % (svc, host, port)) if ok else ("recreate %s failed: %s" % (svc, msg))
    if verb == "reload":
        # SIGHUP the container's main process to re-read its config with NO restart. Both swg-panel-server and
        # swg-sub are exec'd as PID 1 (the sub's entrypoint IS /opt/swg-panel/swg-sub), so the signal reaches them;
        # each handles SIGHUP (re-read serve.json / swap cert) and keeps running. Mirrors `systemctl kill -s HUP`.
        svc = SVC.get(args[0] if args else "")
        if not svc:
            return False, "unknown service %r" % (args[0] if args else "")
        ok, msg = _compose("kill", "-s", "HUP", svc)
        return ok, ("reloaded (SIGHUP) %s" % svc) if ok else ("reload %s failed: %s" % (svc, msg))
    if verb == "set-base":
        # args: <panel> <base> — persist the panel's reverse-proxy mount base (compose maps SWG_PANEL_BASE ←
        # PANEL_BASE). The LIVE panel already switched base in-memory at confirm; this just makes it durable for the
        # next recreate. No recreate here — that would needlessly bounce the panel (a base change is zero-downtime).
        who, base = (args + ["", ""])[:2]
        if who != "panel":
            return False, "set-base only applies to the panel"
        _set_env({"PANEL_BASE": base.strip("/")})
        return True, "persisted panel mount base = %s (takes effect on next recreate)" % (base or "/")
    if verb == "set-cert-env":
        # Bare-metal flips the panel HTTP↔HTTPS with a systemd cert-env drop-in. In Docker the panel's scheme is
        # driven by the TLS= var in .env (the entrypoint issues the cert / clears it on boot), so a reverse-proxy↔
        # direct-TLS flip is a TLS= change + `compose up` recreate — heavier than a live drop-in. Persist the intent
        # so the next recreate honors it (the TLS *mode* itself is set separately in .env for the 'on' side).
        who = args[0] if args else ""
        state = (args[1].lower() if len(args) > 1 else "")
        if who != "panel":
            return True, "set-cert-env only applies to the panel (no-op)"
        if state == "off":
            _set_env({"TLS": "none"})
            return True, "persisted TLS=none (direct-TLS off) — recreate swg-panel to apply"
        return True, "direct-TLS on — set TLS=<mode> in .env, then recreate swg-panel"
    if verb == "set-local-port":
        # the panel's internal loopback-HTTP port for co-located nodes (direct-TLS). The container can't live-rebind
        # (the port is read at startup), so persist to .env AND recreate now — like set-listen. Without the recreate
        # the change wouldn't take effect until the next unrelated recreate, and a plain docker restart / reboot
        # (restart:unless-stopped) would re-init the OLD port from the container's stale env (co-located nodes then
        # dial a dead loopback port). --no-deps recreates ONLY the panel (the request's own _netctl_wait is lost, as
        # for set-listen — best-effort, the recreate still completes).
        who = args[0] if args else ""
        port = (args[1] if len(args) > 1 else "")
        if who != "panel":
            return True, "set-local-port only applies to the panel (no-op)"
        _set_env({"PANEL_LOCAL_PORT": port})
        ok, msg = _compose("up", "-d", "--no-deps", "swg-panel")
        return (ok, "panel internal loopback port = %s (recreated)" % port) if ok \
            else (False, "PANEL_LOCAL_PORT=%s persisted but recreate failed: %s" % (port, msg))
    if verb == "flip":
        # docker reverse-proxy↔direct-TLS SCHEME FLIP. The container can't live-rebind (fixed port map; in
        # reverse-proxy mode there's no cert on disk to bind HTTPS with — the entrypoint issues/clears the cert from
        # TLS= on boot), so a flip is ONE atomic .env write of the whole target scheme+bind, then ONE recreate.
        # Doing it as one verb (not separate set-cert-env/set-listen) avoids the queue's filename-sort ordering
        # racing the recreate ahead of the TLS= change. args: <panel> <tls> <host> <port> [localport]
        # (tls = a direct-TLS mode name, or "none" for reverse-proxy).
        who, tls, host, port = (args + ["", "", "", ""])[:4]
        localport = args[4] if len(args) > 4 else ""
        if who != "panel":
            return False, "flip only applies to the panel"
        env = {"TLS": tls or "none", "PANEL_PORT": port, "PANEL_BIND": host}
        if localport:
            env["PANEL_LOCAL_PORT"] = localport
        _set_env(env)
        ok, msg = _compose("up", "-d", "--no-deps", "swg-panel")
        return (ok, "flipped panel → TLS=%s bind %s:%s (recreated)" % (tls or "none", host, port)) if ok \
            else (False, "flip .env persisted but recreate failed: %s" % msg)
    if verb == "persist-url":
        # Keep .env's PANEL_DOMAIN in step with a CONFIRMED address-migration. The flip verbs already keep
        # PANEL_PORT/BIND/BASE/LOCAL_PORT/TLS current, but nothing else persists the DOMAIN — so without this a
        # docker→bare-metal convert (or an in-container cert reissue) would resurrect the pre-migration domain.
        # args: <domain> <base> <port> <serve> <tls> (base/port/tls already carried by their own verbs).
        domain = (args[0] if args else "").strip()
        if not domain:
            return True, "persist-url: no domain (no-op)"
        _set_env({"PANEL_DOMAIN": domain})
        return True, "persisted PANEL_DOMAIN=%s in .env" % domain
    return True, "no-op (%s handled in-container)" % verb   # cert verbs etc.


def main():
    if not os.path.isdir(QUEUE):
        return
    os.makedirs(STATUS, exist_ok=True)
    for name in sorted(os.listdir(QUEUE)):
        if not name.endswith(".json"):
            continue
        path = os.path.join(QUEUE, name)
        try:
            req = json.load(open(path))
        except (OSError, ValueError):
            with contextlib.suppress(OSError):
                os.remove(path)
            continue
        rid = str(req.get("id") or name[:-5])
        try:
            ok, msg = _handle(str(req.get("verb") or ""), [str(a) for a in (req.get("args") or [])])
        except Exception as e:
            ok, msg = False, "internal error: %s" % e
        with open(os.path.join(STATUS, rid + ".json"), "w") as f:
            json.dump({"status": "ok" if ok else "error", "message": msg}, f)
        with contextlib.suppress(OSError):
            os.remove(path)


if __name__ == "__main__":
    main()
