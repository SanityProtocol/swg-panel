#!/usr/bin/env python3
"""swg-netctl-docker — the Docker root helper.

The bare-metal panel delegates privileged host jobs (rebind a listener, restart a
service) to swg-netctl over a queue dir. Docker has no swg-netctl — the panel
container runs as root but can't reach the HOST to restart a sibling container or
change a published port. This is the Docker equivalent: it drains the SAME request
queue the panel already writes (drop-in compatible — the panel needs no change) and
maps each verb to a `docker compose` action on the host.

Polled by swg-netctl-docker.timer, NOT a .path unit: a host inotify watch never
sees the container's write to a bind-mounted queue file, so we poll the dir.

Request  (queue/<id>.json):  {"id","verb","args":[...],"nonce"}   — written by the panel
Result   (status/<id>.json): {"status":"ok"|"error","message":...} — read by the panel's _netctl_wait

Verbs handled (others are a no-op "ok" — e.g. cert issuance is done by acme.sh INSIDE
the container, not on the host):
  restart <sub|panel>              -> docker compose restart swg-<svc>
  set-listen <sub|panel> <h> <p>   -> set the published port/bind in .env, recreate swg-<svc>
  reload <sub|panel>               -> docker compose kill -s HUP swg-<svc>  (re-read config, no restart)
  set-base <panel> <base>          -> persist SWG_PANEL_BASE (PANEL_BASE in .env) for the next recreate
"""
import contextlib
import json
import os
import re
import shutil
import subprocess
import time
from urllib.parse import urlparse

DIR = os.environ.get("SWG_DOCKER_DIR", "/opt/swg-panel-docker")
QUEUE = os.path.join(DIR, "data", "lib", "netctl", "queue")
STATUS = os.path.join(DIR, "data", "lib", "netctl", "status")
ENV = os.path.join(DIR, ".env")
COMPOSE = ["docker", "compose", "-f", os.path.join(DIR, "docker-compose.yml")]
SVC = {"sub": "swg-sub", "panel": "swg-panel"}


def _compose(*args):
    r = subprocess.run(COMPOSE + list(args), capture_output=True, text=True, timeout=180)
    return r.returncode == 0, (r.stderr or r.stdout or "").strip()[:200]


def _cert_covers_host(cert_path, host):
    """Does the cert at cert_path name `host` — an exact SAN/CN, or a single-label *.wildcard (so *.example.com
    covers sub.example.com but not a.b.example.com)? Mirrors the entrypoint's cert_covers_host, host-side."""
    try:
        out = subprocess.run(["openssl", "x509", "-in", cert_path, "-noout", "-text"],
                             capture_output=True, text=True, timeout=10).stdout
    except (OSError, subprocess.SubprocessError):
        return False
    for dns in re.findall(r"DNS:([^,\s]+)", out):
        if dns == host:
            return True
        if dns.startswith("*."):
            base = dns[2:]
            if host.endswith("." + base):
                pre = host[:-(len(base) + 1)]
                if pre and "." not in pre:
                    return True
    return False


def _set_env(keys):
    """Set KEY=value lines in .env (add if absent), atomically."""
    try:
        lines = open(ENV).read().splitlines() if os.path.exists(ENV) else []
    except OSError:
        lines = []
    for k, v in keys.items():
        pat = re.compile(r"^%s=" % re.escape(k))
        for i, ln in enumerate(lines):
            if pat.match(ln):
                lines[i] = "%s=%s" % (k, v)
                break
        else:
            lines.append("%s=%s" % (k, v))
    tmp = ENV + ".tmp"
    with open(tmp, "w") as f:
        f.write("\n".join(lines) + "\n")
    os.replace(tmp, ENV)


def _read_env(keys):
    """Current values of KEYs in .env (missing keys omitted) — a snapshot to roll back to."""
    out = {}
    with contextlib.suppress(OSError):
        for ln in open(ENV).read().splitlines():
            for k in keys:
                if ln.startswith(k + "="):
                    out[k] = ln[len(k) + 1:]
    return out


def _tls_creds(mode):
    """The cert credential a direct-TLS CA mode needs, read from the panel's OWN settings on the host and mapped to
    the env vars docker-compose passes into the container. The netctl protocol carries NO secrets — the helper
    fetches them itself (as bare-metal swg-netctl reads install.conf), so a queued request never exposes the token."""
    creds = {}
    with contextlib.suppress(Exception):
        t = ((json.load(open(os.path.join(DIR, "data", "lib", "panel-settings.json"))).get("access") or {})
             .get("tls") or {})
        if t.get("email"):
            creds["ACME_EMAIL"] = str(t["email"])
        if t.get("cf_token"):
            creds["CF_TOKEN"] = str(t["cf_token"])
        if t.get("cf_origin_token"):
            creds["CF_ORIGIN_TOKEN"] = str(t["cf_origin_token"])
    return creds


def _served_cert_real(port, domain="", host="", tries=60):
    """After a flip to a CA mode, is the panel serving a REAL CA cert THAT COVERS <domain> on <host>:<port>?
    Polls while the container boots + ISSUES (DNS-01 through Cloudflare can take 40-90s for record propagation +
    validation, so the window is generous — a too-short one falsely rolls back a slow-but-successful issuance).
    Returns True (issuer != subject AND the cert names <domain>), False (self-signed fallback, wrong-domain cert,
    or the port never served TLS), or None (openssl unavailable → can't judge, caller proceeds w/o rollback).
    NOTE: the entrypoint issues the cert BEFORE it starts the panel, so during issuance the port is simply not
    listening yet (connection refused) — that's the 'keep waiting' case, distinct from a served cert.
    <host> is the panel's PUBLISHED bind — connect to THAT, not a hardcoded 127.0.0.1: a bind to a specific public
    IP (PANEL_BIND=<ip>, not 0.0.0.0) doesn't answer on loopback, so probing 127.0.0.1 there falsely 'never served a
    cert' → a false rollback that then strands nodes that already followed the candidate. 0.0.0.0/::/blank → loopback."""
    if subprocess.run(["sh", "-c", "command -v openssl"], capture_output=True).returncode != 0:
        return None
    ch = host.strip() if (host or "").strip() and host.strip() not in ("0.0.0.0", "::", "*") else "127.0.0.1"
    cmd = ("echo | openssl s_client -connect %s:%s 2>/dev/null | "
           "openssl x509 -noout -issuer -subject -ext subjectAltName 2>/dev/null" % (ch, port))
    for _ in range(tries):                     # tries*3s ≈ 3 min ceiling — covers a slow Cloudflare DNS-01
        r = subprocess.run(["sh", "-c", cmd], capture_output=True, text=True, timeout=15)
        out = r.stdout or ""
        iss = sub = None
        for ln in out.splitlines():
            if ln.startswith("issuer="):
                iss = ln.split("=", 1)[1].strip()
            elif ln.startswith("subject="):
                sub = ln.split("=", 1)[1].strip()
        if iss is not None and sub is not None:   # got a cert → decide now
            real = iss != sub                     # a real CA cert (not the self-signed fallback)
            covers = (not domain) or (domain in out)   # the cert's subject/SAN actually names this domain
            return real and covers
        time.sleep(3)                          # not serving TLS yet — container still booting/issuing
    return False                               # never served a cert within the window → treat as failed


BLESS = os.path.join(DIR, "data", "lib", "panel-confirmed.json")   # the blessed dial address nodes are told
REVERT = os.path.join(DIR, "data", "lib", "panel-flip-revert.json")   # host-side .env+bless snapshot for an auto-revert


def _bless_snapshot():
    """Raw current blessed file, or None if absent — an exact value to restore on a rollback."""
    with contextlib.suppress(OSError):
        return open(BLESS).read()
    return None


def _bless_write(url, mode):
    """Adopt <url> as the blessed dial address (atomically). The flip verb writes this OPTIMISTICALLY before the
    recreate so a verified flip is a single recreate that comes up already advertising the new url; a failed CA flip
    calls _bless_restore below to undo it. Mirrors the panel's own _write_bless payload ({url, mode})."""
    tmp = BLESS + ".tmp"
    with open(tmp, "w") as f:
        json.dump({"url": url, "mode": mode}, f, indent=2)
    os.replace(tmp, BLESS)


def _bless_restore(snap):
    if snap is None:
        with contextlib.suppress(OSError):
            os.remove(BLESS)
        return
    tmp = BLESS + ".tmp"
    with open(tmp, "w") as f:
        f.write(snap)
    os.replace(tmp, BLESS)


def _revert_snapshot_write(old_env, old_bless):
    """Persist the pre-flip .env values + blessed file so a LATER auto-revert (driven by the panel's reachability
    timer, in a different process) can restore the EXACT previous address. This is what the panel can't do itself: in
    docker the host-published PANEL_PORT (what the proxy targets) is a .env fact, distinct from the port the panel binds
    INSIDE the container — so reconstructing the revert target from the panel's own listener would use the wrong port."""
    tmp = REVERT + ".tmp"
    with open(tmp, "w") as f:
        json.dump({"env": old_env, "bless": old_bless}, f)
    os.replace(tmp, REVERT)


def _handle(verb, args):
    if verb == "restart":
        svc = SVC.get(args[0] if args else "")
        if not svc:
            return False, "unknown service %r" % (args[0] if args else "")
        ok, msg = _compose("restart", svc)
        return ok, ("restarted %s" % svc) if ok else ("restart %s failed: %s" % (svc, msg))
    if verb == "set-listen":
        # args: <sub|panel> <host> <port> — set the container's published port/bind, then recreate it
        who, host, port = (args + ["", "", ""])[:3]
        svc = SVC.get(who)
        if not svc:
            return False, "unknown service %r" % who
        _set_env({"SUB_PORT" if who == "sub" else "PANEL_PORT": port,
                  "SUB_BIND" if who == "sub" else "PANEL_BIND": host})
        # --no-deps: recreate ONLY this service. Without it, `up` follows depends_on and would recreate the panel
        # container too, killing the very apply request that's in flight (the panel loses its _netctl_wait).
        ok, msg = _compose("up", "-d", "--no-deps", svc)
        return ok, ("%s on %s:%s" % (svc, host, port)) if ok else ("recreate %s failed: %s" % (svc, msg))
    if verb == "reload":
        # SIGHUP the container's main process to re-read its config with NO restart. Both swg-panel-server and
        # swg-sub are exec'd as PID 1 (the sub's entrypoint IS /opt/swg-panel/swg-sub), so the signal reaches them;
        # each handles SIGHUP (re-read serve.json / swap cert) and keeps running. Mirrors `systemctl kill -s HUP`.
        svc = SVC.get(args[0] if args else "")
        if not svc:
            return False, "unknown service %r" % (args[0] if args else "")
        ok, msg = _compose("kill", "-s", "HUP", svc)
        return ok, ("reloaded (SIGHUP) %s" % svc) if ok else ("reload %s failed: %s" % (svc, msg))
    if verb == "set-base":
        # args: <panel> <base> — persist the panel's reverse-proxy mount base (compose maps SWG_PANEL_BASE ←
        # PANEL_BASE). The LIVE panel already switched base in-memory at confirm; this just makes it durable for the
        # next recreate. No recreate here — that would needlessly bounce the panel (a base change is zero-downtime).
        who, base = (args + ["", ""])[:2]
        if who != "panel":
            return False, "set-base only applies to the panel"
        _set_env({"PANEL_BASE": base.strip("/")})
        return True, "persisted panel mount base = %s (takes effect on next recreate)" % (base or "/")
    if verb == "set-cert-env":
        # Bare-metal flips the panel HTTP↔HTTPS with a systemd cert-env drop-in. In Docker the panel's scheme is
        # driven by the TLS= var in .env (the entrypoint issues the cert / clears it on boot), so a reverse-proxy↔
        # direct-TLS flip is a TLS= change + `compose up` recreate — heavier than a live drop-in. Persist the intent
        # so the next recreate honors it (the TLS *mode* itself is set separately in .env for the 'on' side).
        who = args[0] if args else ""
        state = (args[1].lower() if len(args) > 1 else "")
        if who != "panel":
            return True, "set-cert-env only applies to the panel (no-op)"
        if state == "off":
            _set_env({"TLS": "none"})
            return True, "persisted TLS=none (direct-TLS off) — recreate swg-panel to apply"
        return True, "direct-TLS on — set TLS=<mode> in .env, then recreate swg-panel"
    if verb == "set-local-port":
        # the panel's internal loopback-HTTP port for co-located nodes (direct-TLS). The container can't live-rebind
        # (the port is read at startup), so persist to .env AND recreate now — like set-listen. Without the recreate
        # the change wouldn't take effect until the next unrelated recreate, and a plain docker restart / reboot
        # (restart:unless-stopped) would re-init the OLD port from the container's stale env (co-located nodes then
        # dial a dead loopback port). --no-deps recreates ONLY the panel (the request's own _netctl_wait is lost, as
        # for set-listen — best-effort, the recreate still completes).
        who = args[0] if args else ""
        port = (args[1] if len(args) > 1 else "")
        if who != "panel":
            return True, "set-local-port only applies to the panel (no-op)"
        _set_env({"PANEL_LOCAL_PORT": port})
        ok, msg = _compose("up", "-d", "--no-deps", "swg-panel")
        return (ok, "panel internal loopback port = %s (recreated)" % port) if ok \
            else (False, "PANEL_LOCAL_PORT=%s persisted but recreate failed: %s" % (port, msg))
    if verb == "dryrun":
        # Prove a scheme/port/domain change is safe BEFORE recreating the live container. args: <tls> <domain>
        # <port> <base>. Two checks, neither touches the running panel:
        #   (1) the target host port must be free (a recreate can't publish a port another service already holds);
        #   (2) a THROWAWAY container (`compose run --rm`, DRY_RUN=1, NO ports published → no conflict/state writes)
        #       runs the entrypoint, which issues+validates the cert into the shared volume, then exits 0/non-0.
        tls, domain, port = (args + ["", "", "", ""])[:3]
        ca = tls in ("cloudflare", "cf15", "letsencrypt", "letsencrypt-ip")
        if port:
            busy = subprocess.run(["sh", "-c", "ss -lntH 'sport = :%s' 2>/dev/null | grep -q ." % port],
                                  capture_output=True).returncode == 0
            if busy and str(port) != str(_read_env(["PANEL_PORT"]).get("PANEL_PORT", "")):
                return False, "port %s is already in use on this host — choose a free port" % port
        env = ["-e", "DRY_RUN=1", "-e", "TLS=%s" % (tls or "none")]
        if domain:
            env += ["-e", "PANEL_DOMAIN=%s" % domain]
        if ca:
            for k, v in _tls_creds(tls).items():
                env += ["-e", "%s=%s" % (k, v)]
        r = subprocess.run(COMPOSE + ["run", "--rm", "--no-deps", "-T"] + env + ["swg-panel"],
                           capture_output=True, text=True, timeout=180)
        if r.returncode == 0:
            return True, "dry-run passed — the new address has a valid certificate; safe to switch"
        clean = re.sub(r"\x1b\[[0-9;]*m", "", (r.stdout or r.stderr or ""))   # strip the entrypoint log's ANSI colours
        clean = clean.replace("[entrypoint]", "").strip()
        tail = " ".join(clean.splitlines()[-3:])[:280]
        return False, "dry-run failed — the new address wouldn't get a valid certificate. %s" % tail
    if verb == "flip":
        # docker reverse-proxy↔direct-TLS SCHEME FLIP. The container can't live-rebind (fixed port map; in
        # reverse-proxy mode there's no cert on disk to bind HTTPS with — the entrypoint issues/clears the cert from
        # TLS= on boot), so a flip is ONE atomic .env write of the whole target scheme+bind, then ONE recreate.
        # Doing it as one verb (not separate set-cert-env/set-listen) avoids the queue's filename-sort ordering
        # racing the recreate ahead of the TLS= change. args: <panel> <tls> <host> <port> [localport]
        # (tls = a direct-TLS mode name, or "none" for reverse-proxy).
        # args: <panel> <tls> <host> <port> [localport] [target_url]
        who, tls, host, port = (args + ["", "", "", ""])[:4]
        localport = args[4] if len(args) > 4 else ""
        target_url = args[5] if len(args) > 5 else ""
        if who != "panel":
            return False, "flip only applies to the panel"
        ca = tls in ("cloudflare", "cf15", "letsencrypt", "letsencrypt-ip")
        target_mode = "" if tls in ("", "none") else tls
        # The target url carries the DOMAIN and the mount PATH too — a flip can change them alongside the scheme, and
        # they must reach .env or the entrypoint issues the cert for the OLD domain (wrong-domain cert → proxy 526)
        # and serves the wrong base. (persist-url/set-base cover these on the reverse-proxy path; the flip bypasses
        # both, so we do it here.)
        _u = urlparse(target_url if "://" in target_url else "https://" + target_url) if target_url else None
        dom = (_u.hostname or "") if _u else ""
        base = ((_u.path or "").strip("/")) if _u else ""
        # Snapshot the current scheme + DOMAIN/BASE + the blessed dial address, so a failed CA flip restores them all.
        old_env = _read_env(["TLS", "PANEL_PORT", "PANEL_BIND", "PANEL_LOCAL_PORT", "PANEL_DOMAIN", "PANEL_BASE"])
        old_bless = _bless_snapshot()
        _revert_snapshot_write(old_env, old_bless)   # the panel's reachability timer can undo THIS flip via `revert-flip`
        # OPTIMISTIC adopt: advance blessed to the target BEFORE the recreate, so a verified flip is a SINGLE recreate
        # and the panel comes up already advertising the new url (no racy boot-time "did the scheme match" guess — the
        # authority is HERE, host-side). A CA failure below restores env + blessed together.
        if target_url:
            _bless_write(target_url, target_mode)
        env = {"TLS": tls or "none", "PANEL_PORT": port, "PANEL_BIND": host}
        if localport:
            env["PANEL_LOCAL_PORT"] = localport
        if dom:
            env["PANEL_DOMAIN"] = dom          # so the entrypoint issues the cert for the RIGHT domain
            env["PANEL_BASE"] = base           # keep the mount path in step (blank = root)
        if ca:
            env.update(_tls_creds(tls))       # carry the cert credential so the entrypoint can issue a REAL cert
        _set_env(env)
        ok, msg = _compose("up", "-d", "--no-deps", "swg-panel")
        if not ok:                            # the recreate itself failed → restore the previous scheme + address
            _set_env(old_env); _bless_restore(old_bless); _compose("up", "-d", "--no-deps", "swg-panel")
            return False, "flip recreate failed (%s) — rolled back to the previous address" % msg
        if ca and _served_cert_real(port, dom, host) is False:
            # The cert must be a REAL CA cert that COVERS this domain. A self-signed fallback (missing/blocked token,
            # unreachable :80, rate limit) OR a stale cert for a DIFFERENT domain would be rejected by a validating
            # proxy (Cloudflare 526) and strand nodes. Roll BOTH the scheme and the blessed address back, so the panel
            # comes up on the still-working old address and never advertises the broken one.
            _set_env(old_env); _bless_restore(old_bless); _compose("up", "-d", "--no-deps", "swg-panel")
            return False, ("the %s certificate could not be issued for %s (served a self-signed or wrong-domain cert)"
                           " — rolled back to the previous address. Check the TLS credential / DNS, then try again."
                           % (tls, dom or "the panel"))
        return True, "flipped panel → TLS=%s bind %s:%s (recreated%s)" % (
            tls or "none", host, port, ", cert verified" if ca else "")
    if verb == "revert-flip":
        # Undo the most recent flip, back to the address it came from — the panel's reachability timer enqueues this when
        # a recreated-onto address is never confirmed reachable. Restores the .env + blessed snapshot the forward flip
        # saved (the host-side truth, incl. the right published PANEL_PORT) and recreates. No args: the snapshot IS the
        # target, so this can't use a wrong reconstructed port (the bug where the panel's internal 8443 leaked in).
        if not os.path.exists(REVERT):
            return True, "no revert snapshot on file — nothing to undo"
        try:
            snap = json.load(open(REVERT))
        except (OSError, ValueError) as e:
            return False, "revert snapshot unreadable: %s" % e
        _set_env(snap.get("env") or {})
        _bless_restore(snap.get("bless"))
        ok, msg = _compose("up", "-d", "--no-deps", "swg-panel")
        if not ok:
            return False, "revert recreate failed: %s" % msg
        with contextlib.suppress(OSError):
            os.remove(REVERT)
        env = snap.get("env") or {}
        return True, "reverted the panel to the previous address (TLS=%s PANEL_PORT=%s)" % (env.get("TLS", "?"), env.get("PANEL_PORT", "?"))
    if verb == "persist-url":
        # Keep .env's PANEL_DOMAIN in step with a CONFIRMED address-migration. The flip verbs already keep
        # PANEL_PORT/BIND/BASE/LOCAL_PORT/TLS current, but nothing else persists the DOMAIN — so without this a
        # docker→bare-metal convert (or an in-container cert reissue) would resurrect the pre-migration domain.
        # args: <domain> <base> <port> <serve> <tls> (base/port/tls already carried by their own verbs).
        domain = (args[0] if args else "").strip()
        if not domain:
            return True, "persist-url: no domain (no-op)"
        _set_env({"PANEL_DOMAIN": domain})
        return True, "persisted PANEL_DOMAIN=%s in .env" % domain
    if verb == "issue-cert":
        # RUNTIME, panel-managed sub-cert issuance. Bare-metal swg-netctl issues via acme directly; docker used to
        # no-op this ("handled in-container" at boot only), so a sub address set/changed in the UI never got a
        # matching cert → 525. Now: apply the operator's rule host-side — if the panel's OWN cert already covers the
        # sub host, copy it (no issuance, no container touch); otherwise issue a SEPARATE cert inside the panel
        # container (which holds acme + the CF credentials), writing into the shared ./data/sub-tls volume.
        svc = args[0] if args else ""
        domain = (args[1] if len(args) > 1 else "").strip()
        if svc != "sub" or not domain:
            return True, "issue-cert: nothing to do (panel cert is issued by the boot flow / flip verb)"
        panel_cert = os.path.join(DIR, "data", "etc", "tls", "fullchain.pem")
        panel_key = os.path.join(DIR, "data", "etc", "tls", "key.pem")
        sub_dir = os.path.join(DIR, "data", "sub-tls")
        with contextlib.suppress(OSError):
            os.makedirs(sub_dir, exist_ok=True)
        sc, sk = os.path.join(sub_dir, "fullchain.pem"), os.path.join(sub_dir, "key.pem")
        if os.path.exists(panel_cert) and os.path.exists(panel_key) and _cert_covers_host(panel_cert, domain):
            try:
                shutil.copyfile(panel_cert, sc); shutil.copyfile(panel_key, sk); os.chmod(sk, 0o600)
            except OSError as e:
                return False, "could not copy the panel certificate for the subscription page: %s" % e
            return True, "reused the panel certificate for %s" % domain
        # Not covered → a distinct sub hostname needs its own cert: run the panel container's issuance for it.
        ok, msg = _compose("exec", "-T", "swg-panel", "/entrypoint.sh", "sub-cert", domain)
        return ok, (msg or ("issued a separate certificate for %s" % domain))
    return True, "no-op (%s handled in-container)" % verb   # cert verbs etc.


def main():
    if not os.path.isdir(QUEUE):
        return
    os.makedirs(STATUS, exist_ok=True)
    for name in sorted(os.listdir(QUEUE)):
        if not name.endswith(".json"):
            continue
        path = os.path.join(QUEUE, name)
        try:
            req = json.load(open(path))
        except (OSError, ValueError):
            with contextlib.suppress(OSError):
                os.remove(path)
            continue
        rid = str(req.get("id") or name[:-5])
        try:
            ok, msg = _handle(str(req.get("verb") or ""), [str(a) for a in (req.get("args") or [])])
        except Exception as e:
            ok, msg = False, "internal error: %s" % e
        with open(os.path.join(STATUS, rid + ".json"), "w") as f:
            json.dump({"status": "ok" if ok else "error", "message": msg}, f)
        with contextlib.suppress(OSError):
            os.remove(path)


if __name__ == "__main__":
    main()
